diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..b944986
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,46 @@
+/**
+ * Pure validation functions for order operations.
+ *
+ * These validators contain no side effects and no database calls.
+ * They validate data shape and business rules that don't require external state.
+ */
+
+import type { OrderItem, OrderStatus, CreateOrderInput } from '../models/order.js';
+
+/**
+ * Valid status transitions for orders.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate that an order has at least one item.
+ */
+export function validateOrderItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Validate the input for creating an order.
+ * Does NOT check whether the user exists (that requires a database call).
+ */
+export function validateCreateOrderInput(input: CreateOrderInput): void {
+  validateOrderItems(input.items);
+}
diff --git a/src/validators/preferences.validator.ts b/src/validators/preferences.validator.ts
new file mode 100644
index 0000000..192a07e
--- /dev/null
+++ b/src/validators/preferences.validator.ts
@@ -0,0 +1,32 @@
+/**
+ * Pure validation functions for user preferences operations.
+ *
+ * These validators contain no side effects and no database calls.
+ * They validate data shape and business rules that don't require external state.
+ */
+
+import type { CreatePreferencesInput, UpdatePreferencesInput } from '../models/user-preferences.js';
+
+const VALID_FREQUENCIES = ['immediate', 'daily-digest', 'weekly-digest'] as const;
+
+/**
+ * Validate the input for creating preferences.
+ * Does NOT check user existence or duplicate preferences (those require database calls).
+ */
+export function validateCreatePreferencesInput(input: CreatePreferencesInput): void {
+  if (!input.userId || input.userId.trim().length === 0) {
+    throw new Error('userId is required');
+  }
+  if (input.emailFrequency !== undefined && !VALID_FREQUENCIES.includes(input.emailFrequency)) {
+    throw new Error(`Invalid email frequency: ${input.emailFrequency}`);
+  }
+}
+
+/**
+ * Validate the input for updating preferences.
+ */
+export function validateUpdatePreferencesInput(input: UpdatePreferencesInput): void {
+  if (input.emailFrequency !== undefined && !VALID_FREQUENCIES.includes(input.emailFrequency)) {
+    throw new Error(`Invalid email frequency: ${input.emailFrequency}`);
+  }
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..5f7ed82
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,43 @@
+/**
+ * Pure validation functions for user operations.
+ *
+ * These validators contain no side effects and no database calls.
+ * They validate data shape and business rules that don't require external state.
+ */
+
+import type { CreateUserInput, UpdateUserInput } from '../models/user.js';
+
+const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
+
+/**
+ * Validate that an email address has a valid format.
+ */
+export function validateEmail(email: string): void {
+  if (!EMAIL_REGEX.test(email)) {
+    throw new Error(`Invalid email format: ${email}`);
+  }
+}
+
+/**
+ * Validate the input for creating a user.
+ * Does NOT check email uniqueness (that requires a database call).
+ */
+export function validateCreateUserInput(input: CreateUserInput): void {
+  if (!input.name || input.name.trim().length === 0) {
+    throw new Error('User name is required');
+  }
+  validateEmail(input.email);
+}
+
+/**
+ * Validate the input for updating a user.
+ * Does NOT check email uniqueness (that requires a database call).
+ */
+export function validateUpdateUserInput(input: UpdateUserInput): void {
+  if (input.name !== undefined && input.name.trim().length === 0) {
+    throw new Error('User name cannot be empty');
+  }
+  if (input.email !== undefined) {
+    validateEmail(input.email);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..004ee71
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,87 @@
+import { describe, it, expect } from 'vitest';
+import {
+  isValidStatusTransition,
+  validateOrderItems,
+  validateCreateOrderInput,
+} from '../../src/validators/order.validator.js';
+
+describe('Order Validators', () => {
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject pending -> shipped', () => {
+      expect(isValidStatusTransition('pending', 'shipped')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(isValidStatusTransition('delivered', 'pending')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'cancelled')).toBe(false);
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(isValidStatusTransition('cancelled', 'pending')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'confirmed')).toBe(false);
+    });
+
+    it('should reject shipped -> cancelled', () => {
+      expect(isValidStatusTransition('shipped', 'cancelled')).toBe(false);
+    });
+  });
+
+  describe('validateOrderItems', () => {
+    it('should accept non-empty items array', () => {
+      expect(() =>
+        validateOrderItems([
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+        ]),
+      ).not.toThrow();
+    });
+
+    it('should throw for empty items array', () => {
+      expect(() => validateOrderItems([])).toThrow(
+        'Order must have at least one item',
+      );
+    });
+  });
+
+  describe('validateCreateOrderInput', () => {
+    it('should accept valid input', () => {
+      expect(() =>
+        validateCreateOrderInput({
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+          ],
+        }),
+      ).not.toThrow();
+    });
+
+    it('should throw for empty items', () => {
+      expect(() =>
+        validateCreateOrderInput({ userId: 'user-1', items: [] }),
+      ).toThrow('Order must have at least one item');
+    });
+  });
+});
diff --git a/tests/validators/preferences.validator.test.ts b/tests/validators/preferences.validator.test.ts
