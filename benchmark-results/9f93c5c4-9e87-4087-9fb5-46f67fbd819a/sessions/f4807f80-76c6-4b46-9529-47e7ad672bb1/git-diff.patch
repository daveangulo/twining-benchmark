@@ -0,0 +1,186 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { WebhookAdapter } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order-confirmation',
+    channel: 'webhook',
+    recipient: 'https://hooks.example.com/notify',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    createdAt: new Date('2026-01-01'),
+    ...overrides,
+  };
+}
+
+describe('WebhookAdapter', () => {
+  let adapter: WebhookAdapter;
+
+  beforeEach(() => {
+    adapter = new WebhookAdapter();
+  });
+
+  describe('constructor and config', () => {
+    it('should use default config', () => {
+      const config = adapter.getConfig();
+      expect(config.maxRetries).toBe(2);
+      expect(config.headers).toEqual({});
+    });
+
+    it('should accept custom config', () => {
+      const custom = new WebhookAdapter({
+        maxRetries: 5,
+        headers: { 'X-Api-Key': 'secret123' },
+      });
+      const config = custom.getConfig();
+      expect(config.maxRetries).toBe(5);
+      expect(config.headers).toEqual({ 'X-Api-Key': 'secret123' });
+    });
+
+    it('should report webhook channel', () => {
+      expect(adapter.channel).toBe('webhook');
+    });
+  });
+
+  describe('recipient validation', () => {
+    it('should accept valid HTTP URLs', () => {
+      expect(adapter.validateRecipient('https://hooks.example.com/notify')).toBeUndefined();
+      expect(adapter.validateRecipient('http://localhost:3000/webhook')).toBeUndefined();
+      expect(adapter.validateRecipient('https://api.service.io/v2/hooks/abc')).toBeUndefined();
+    });
+
+    it('should reject empty recipient', () => {
+      expect(adapter.validateRecipient('')).toBe('Webhook URL is empty');
+      expect(adapter.validateRecipient('   ')).toBe('Webhook URL is empty');
+    });
+
+    it('should reject invalid URL format', () => {
+      expect(adapter.validateRecipient('not-a-url')).toContain('Invalid webhook URL');
+      expect(adapter.validateRecipient('ftp://files.example.com')).toContain('Invalid webhook URL');
+      expect(adapter.validateRecipient('just-text')).toContain('Invalid webhook URL');
+    });
+
+    it('should return failure result for invalid recipient on send', async () => {
+      const payload = makePayload({ recipient: 'bad-url' });
+      const result = await adapter.send(payload);
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid webhook URL');
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+  });
+
+  describe('payload formatting', () => {
+    it('should format notification payload as JSON body', () => {
+      const payload = makePayload();
+      const body = adapter.formatPayload(payload);
+      expect(body.notificationId).toBe('notif-0001');
+      expect(body.type).toBe('order-confirmation');
+      expect(body.subject).toBe('Order Confirmation: order-1');
+      expect(body.body).toContain('Widget x2');
+      expect(body.recipient).toBe('https://hooks.example.com/notify');
+      expect(body.createdAt).toBe('2026-01-01T00:00:00.000Z');
+    });
+
+    it('should include metadata when present', () => {
+      const payload = makePayload({ metadata: { orderId: 'order-1', total: 20 } });
+      const body = adapter.formatPayload(payload);
+      expect(body.metadata).toEqual({ orderId: 'order-1', total: 20 });
+    });
+
+    it('should omit metadata when not present', () => {
+      const payload = makePayload({ metadata: undefined });
+      const body = adapter.formatPayload(payload);
+      expect(body.metadata).toBeUndefined();
+    });
+  });
+
+  describe('send', () => {
+    it('should send webhook and record delivery', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('webhook');
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]!.url).toBe('https://hooks.example.com/notify');
+      expect(deliveries[0]!.method).toBe('POST');
+      expect(deliveries[0]!.headers['Content-Type']).toBe('application/json');
+      expect(deliveries[0]!.body.notificationId).toBe('notif-0001');
+    });
+
+    it('should include custom headers in delivery', async () => {
+      const custom = new WebhookAdapter({ headers: { 'X-Api-Key': 'key123' } });
+      await custom.send(makePayload());
+      const deliveries = custom.getDeliveries();
+      expect(deliveries[0]!.headers['X-Api-Key']).toBe('key123');
+      expect(deliveries[0]!.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should clear deliveries', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getDeliveries()).toHaveLength(1);
+      adapter.clearDeliveries();
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+  });
+
+  describe('retry behavior', () => {
+    it('should retry on transport failure and succeed', async () => {
+      let attempts = 0;
+      adapter.setTransport(async () => {
+        attempts++;
+        if (attempts < 2) throw new Error('Transient failure');
+      });
+
+      const result = await adapter.send(makePayload());
+      expect(result.success).toBe(true);
+      expect(attempts).toBe(2);
+    });
+
+    it('should fail after exhausting retries', async () => {
+      adapter.setTransport(async () => {
+        throw new Error('Permanent failure');
+      });
+
+      const result = await adapter.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Delivery failed after 3 attempts');
+      expect(result.error).toContain('Permanent failure');
+    });
+
+    it('should respect maxRetries config', async () => {
+      const noRetry = new WebhookAdapter({ maxRetries: 0 });
+      let attempts = 0;
+      noRetry.setTransport(async () => {
+        attempts++;
+        throw new Error('fail');
+      });
+
+      const result = await noRetry.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(attempts).toBe(1);
+      expect(result.error).toContain('Delivery failed after 1 attempts');
+    });
+  });
+
+  describe('custom transport', () => {
+    it('should use custom transport when set', async () => {
+      const captured: Array<{ url: string; body: unknown }> = [];
+      adapter.setTransport(async (delivery) => {
+        captured.push({ url: delivery.url, body: delivery.body });
+      });
+
+      await adapter.send(makePayload());
+      expect(captured).toHaveLength(1);
+      expect(captured[0]!.url).toBe('https://hooks.example.com/notify');
+      // Default in-memory store should NOT have the delivery since we replaced transport
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+  });
+});
