@@ -0,0 +1,181 @@
+/**
+ * Webhook notification adapter — delivers notifications via HTTP POST to a configured URL.
+ *
+ * Features:
+ * - JSON payload formatting: maps NotificationPayload to a webhook-friendly JSON body
+ * - URL validation: validates webhook URLs before sending
+ * - Configurable retry behavior and custom headers
+ * - Pluggable transport for testing (swap with real HTTP client)
+ */
+
+import type { NotificationAdapter } from './notification.adapter.js';
+import type {
+  NotificationPayload,
+  NotificationResult,
+} from '../models/notification.js';
+import { Logger } from '../utils/logger.js';
+
+/** Configuration for the webhook adapter. */
+export interface WebhookConfig {
+  /** Maximum retries on transient failure */
+  maxRetries: number;
+  /** Custom headers to include in the webhook request */
+  headers: Record<string, string>;
+}
+
+/** The JSON body sent to the webhook endpoint. */
+export interface WebhookDelivery {
+  url: string;
+  method: 'POST';
+  headers: Record<string, string>;
+  body: WebhookBody;
+  sentAt: Date;
+  notificationId: string;
+}
+
+/** The structured JSON body of a webhook POST. */
+export interface WebhookBody {
+  notificationId: string;
+  type: string;
+  subject: string;
+  body: string;
+  recipient: string;
+  createdAt: string;
+  metadata?: Record<string, unknown>;
+}
+
+const URL_REGEX = /^https?:\/\/\S+/;
+
+const DEFAULT_CONFIG: WebhookConfig = {
+  maxRetries: 2,
+  headers: {},
+};
+
+export class WebhookAdapter implements NotificationAdapter {
+  readonly channel = 'webhook' as const;
+  private logger = new Logger('WebhookAdapter');
+  private deliveries: WebhookDelivery[] = [];
+  private config: WebhookConfig;
+  /** Pluggable transport — override for testing or real HTTP clients. */
+  private transport: (delivery: WebhookDelivery) => Promise<void>;
+
+  constructor(config?: Partial<WebhookConfig>) {
+    this.config = { ...DEFAULT_CONFIG, ...config, headers: { ...DEFAULT_CONFIG.headers, ...config?.headers } };
+    // Default transport: in-memory store (replace with fetch/axios/etc.)
+    this.transport = async (delivery: WebhookDelivery) => {
+      this.deliveries.push(delivery);
+    };
+  }
+
+  /**
+   * Replace the default in-memory transport with a custom one.
+   * Use this to plug in a real HTTP client (fetch, axios, etc.).
+   */
+  setTransport(transport: (delivery: WebhookDelivery) => Promise<void>): void {
+    this.transport = transport;
+  }
+
+  async send(payload: NotificationPayload): Promise<NotificationResult> {
+    const validationError = this.validateRecipient(payload.recipient);
+    if (validationError) {
+      this.logger.warn(`Invalid webhook URL "${payload.recipient}": ${validationError}`);
+      return {
+        success: false,
+        notificationId: payload.id,
+        channel: this.channel,
+        deliveredAt: new Date(),
+        error: validationError,
+      };
+    }
+
+    const webhookBody = this.formatPayload(payload);
+
+    const delivery: WebhookDelivery = {
+      url: payload.recipient,
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        ...this.config.headers,
+      },
+      body: webhookBody,
+      sentAt: new Date(),
+      notificationId: payload.id,
+    };
+
+    let lastError: string | undefined;
+    for (let attempt = 0; attempt <= this.config.maxRetries; attempt++) {
+      try {
+        await this.transport(delivery);
+        this.logger.info(
+          `Webhook delivered to ${delivery.url} (attempt ${attempt + 1})`,
+        );
+        return {
+          success: true,
+          notificationId: payload.id,
+          channel: this.channel,
+          deliveredAt: delivery.sentAt,
+        };
+      } catch (err) {
+        lastError = err instanceof Error ? err.message : String(err);
+        this.logger.warn(
+          `Webhook attempt ${attempt + 1} failed for ${delivery.url}: ${lastError}`,
+        );
+      }
+    }
+
+    this.logger.error(
+      `Webhook delivery failed after ${this.config.maxRetries + 1} attempts for ${delivery.url}`,
+    );
+    return {
+      success: false,
+      notificationId: payload.id,
+      channel: this.channel,
+      deliveredAt: new Date(),
+      error: `Delivery failed after ${this.config.maxRetries + 1} attempts: ${lastError}`,
+    };
+  }
+
+  /**
+   * Validate that the recipient is a well-formed HTTP(S) URL.
+   * Returns an error message if invalid, or undefined if valid.
+   */
+  validateRecipient(recipient: string): string | undefined {
+    if (!recipient || recipient.trim().length === 0) {
+      return 'Webhook URL is empty';
+    }
+    if (!URL_REGEX.test(recipient)) {
+      return `Invalid webhook URL: ${recipient}`;
+    }
+    return undefined;
+  }
+
+  /**
+   * Format a NotificationPayload into the JSON body sent to the webhook endpoint.
+   */
+  formatPayload(payload: NotificationPayload): WebhookBody {
+    return {
+      notificationId: payload.id,
+      type: payload.type,
+      subject: payload.subject,
+      body: payload.body,
+      recipient: payload.recipient,
+      createdAt: payload.createdAt.toISOString(),
+      ...(payload.metadata ? { metadata: payload.metadata } : {}),
+    };
+  }
+
+  /** Get all deliveries (for testing). */
+  getDeliveries(): WebhookDelivery[] {
+    return [...this.deliveries];
+  }
+
+  /** Clear deliveries (for testing). */
+  clearDeliveries(): void {
+    this.deliveries = [];
+  }
+
+  /** Get the current configuration. */
+  getConfig(): WebhookConfig {
+    return { ...this.config, headers: { ...this.config.headers } };
+  }
+}
