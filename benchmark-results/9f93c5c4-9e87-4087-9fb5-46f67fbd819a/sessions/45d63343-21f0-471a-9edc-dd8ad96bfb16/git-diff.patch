+  describe('notification ordering', () => {
+    it('should deliver notifications in order even when events are emitted concurrently', async () => {
+      // Create a slow adapter that introduces variable delay per notification
+      const deliveryOrder: string[] = [];
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          // First notification (order-confirmation) takes longer than the second
+          const delay = payload.type === 'order-confirmation' ? 50 : 10;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.type);
+          return {
+            success: true,
+            notificationId: payload.id,
+            channel: 'email',
+            timestamp: new Date(),
+          };
+        },
+      };
+      service.registerAdapter(slowAdapter);
+
+      const orderCreatedEvent: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      const statusChangedEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      // Emit both events concurrently — without the queue, the faster
+      // status-changed notification would arrive before order-confirmation
+      const [result1, result2] = await Promise.all([
+        eventBus.emit(orderCreatedEvent),
+        eventBus.emit(statusChangedEvent),
+      ]);
+
+      // Verify order-confirmation was delivered before order-status-update
+      expect(deliveryOrder).toEqual(['order-confirmation', 'order-status-update']);
+
+      // Also verify the stored notifications maintain order
+      const notifications = service.getNotifications();
+      expect(notifications).toHaveLength(2);
+      expect(notifications[0]?.type).toBe('order-confirmation');
+      expect(notifications[1]?.type).toBe('order-status-update');
+    });
+
