@@ -157,6 +158,26 @@ export class NotificationService {
     body: string;
     metadata?: Record<string, unknown>;
     userId?: string;
+  }): Promise<void> {
+    // Queue notifications per-user to guarantee delivery order.
+    // Without this, concurrent event emissions (e.g., order:created and
+    // order:status-changed fired without awaiting) can cause adapter.send()
+    // calls to race, delivering notifications out of order.
+    const queueKey = params.userId ?? params.recipient;
+    const previous = this.sendQueues.get(queueKey) ?? Promise.resolve();
+    const current = previous.then(() => this.processSend(params));
+    this.sendQueues.set(queueKey, current);
+    return current;
+  }
+
+  private async processSend(params: {
+    type: NotificationType;
+    channel: NotificationChannel;
+    recipient: string;
+    subject: string;
+    body: string;
+    metadata?: Record<string, unknown>;
+    userId?: string;
   }): Promise<void> {
     // Check user preferences before sending (all channels, not just email)
     if (this.preferencesService && params.userId) {
@@ -255,5 +276,6 @@ export class NotificationService {
