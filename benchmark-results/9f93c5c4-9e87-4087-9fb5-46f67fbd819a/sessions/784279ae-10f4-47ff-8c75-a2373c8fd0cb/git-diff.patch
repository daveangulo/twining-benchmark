+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import {
+  EmailAdapter,
+  InMemoryTransport,
+  renderTemplate,
+  resolveRecipient,
+} from '../../src/adapters/email.adapter.js';
+import type {
+  EmailTransport,
+  RenderedEmail,
+} from '../../src/adapters/email.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: 'alice@example.com',
+    subject: 'Test Subject',
+    body: 'Test body content',
+    channel: 'email',
+    priority: 'normal',
+    ...overrides,
+  };
+}
+
+describe('resolveRecipient', () => {
+  it('should return valid email addresses as-is', () => {
+    expect(resolveRecipient('alice@example.com')).toBe('alice@example.com');
+    expect(resolveRecipient('user+tag@sub.domain.org')).toBe('user+tag@sub.domain.org');
+  });
+
+  it('should return null for non-email strings', () => {
+    expect(resolveRecipient('user-123')).toBeNull();
+    expect(resolveRecipient('')).toBeNull();
+    expect(resolveRecipient('not an email')).toBeNull();
+  });
+});
+
+describe('renderTemplate', () => {
+  it('should render default template when no notificationType metadata', () => {
+    const payload = makePayload();
+    const { html, text } = renderTemplate(payload, 'TaskFlow Pro');
+
+    expect(html).toContain('Test Subject');
+    expect(html).toContain('Test body content');
+    expect(html).toContain('TaskFlow Pro');
+    expect(text).toContain('Test Subject');
+    expect(text).toContain('Test body content');
+  });
+
+  it('should render order-confirmation template', () => {
+    const payload = makePayload({
+      subject: 'Order Confirmation: order-1',
+      body: 'Items: Widget x2. Total: $20.00',
+      metadata: { notificationType: 'order-confirmation', orderId: 'order-1' },
+    });
+    const { html } = renderTemplate(payload, 'TaskFlow Pro');
+
+    expect(html).toContain('Order Confirmed');
+    expect(html).toContain('order-1');
+    expect(html).toContain('Widget x2');
+  });
+
+  it('should render order-status-update template', () => {
+    const payload = makePayload({
+      subject: 'Order Update: order-1',
+      body: 'Your order status has changed from pending to confirmed.',
+      metadata: { notificationType: 'order-status-update', orderId: 'order-1', newStatus: 'confirmed' },
+    });
+    const { html } = renderTemplate(payload, 'TaskFlow Pro');
+
+    expect(html).toContain('Order Status Update');
+    expect(html).toContain('confirmed');
+  });
+
+  it('should render user-welcome template', () => {
+    const payload = makePayload({
+      subject: 'Welcome to TaskFlow Pro',
+      body: 'Hi Alice, welcome to TaskFlow Pro!',
+      metadata: { notificationType: 'user-welcome' },
+    });
+    const { html } = renderTemplate(payload, 'TaskFlow Pro');
+
+    expect(html).toContain('Welcome!');
+    expect(html).toContain('glad to have you');
+  });
+
+  it('should escape HTML in payload content', () => {
+    const payload = makePayload({
+      subject: '<script>alert("xss")</script>',
+      body: '<img onerror="hack">',
+    });
+    const { html } = renderTemplate(payload, 'TestApp');
+
+    expect(html).not.toContain('<script>');
+    expect(html).not.toContain('<img onerror');
+    expect(html).toContain('&lt;script&gt;');
+  });
+});
+
+describe('InMemoryTransport', () => {
+  let transport: InMemoryTransport;
+
+  beforeEach(() => {
+    transport = new InMemoryTransport();
+  });
+
+  it('should store sent emails in inbox', async () => {
+    const email: RenderedEmail = {
+      to: 'alice@example.com',
+      from: 'noreply@taskflow.com',
+      subject: 'Test',
+      html: '<p>Hello</p>',
+      text: 'Hello',
+    };
+
+    const result = await transport.sendMail(email);
+
+    expect(result.messageId).toBeTruthy();
+    expect(transport.getInbox()).toHaveLength(1);
+    expect(transport.getInbox()[0]?.to).toBe('alice@example.com');
+  });
+
+  it('should clear inbox', async () => {
+    await transport.sendMail({ to: 'a@b.com', from: 'x@y.com', subject: '', html: '', text: '' });
+    transport.clear();
+    expect(transport.getInbox()).toHaveLength(0);
+  });
+});
+
+describe('EmailAdapter', () => {
+  let transport: InMemoryTransport;
+  let adapter: EmailAdapter;
+
+  beforeEach(() => {
+    transport = new InMemoryTransport();
+    adapter = new EmailAdapter(
+      { from: 'noreply@taskflow.com', replyTo: 'support@taskflow.com', appName: 'TaskFlow Pro' },
+      transport,
+    );
+  });
+
+  it('should have channel set to email', () => {
+    expect(adapter.channel).toBe('email');
+  });
+
+  it('should send an email successfully', async () => {
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(true);
+    expect(result.channel).toBe('email');
+    expect(result.notificationId).toBeTruthy();
+
+    const inbox = transport.getInbox();
+    expect(inbox).toHaveLength(1);
+    expect(inbox[0]?.to).toBe('alice@example.com');
+    expect(inbox[0]?.from).toBe('noreply@taskflow.com');
+    expect(inbox[0]?.replyTo).toBe('support@taskflow.com');
+    expect(inbox[0]?.subject).toBe('Test Subject');
+    expect(inbox[0]?.html).toContain('Test body content');
+    expect(inbox[0]?.text).toContain('Test body content');
+  });
+
+  it('should fail for invalid recipient email', async () => {
+    const payload = makePayload({ recipient: 'not-an-email' });
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('Invalid recipient email');
+    expect(transport.getInbox()).toHaveLength(0);
+  });
+
+  it('should retry on transport failure and eventually fail', async () => {
+    const failingTransport: EmailTransport = {
+      sendMail: vi.fn().mockRejectedValue(new Error('SMTP connection refused')),
+    };
+    const retryAdapter = new EmailAdapter(
+      { from: 'noreply@taskflow.com', maxRetries: 2 },
+      failingTransport,
+    );
+
+    const result = await retryAdapter.send(makePayload());
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('Delivery failed after 3 attempts');
+    expect(result.error).toContain('SMTP connection refused');
+    expect(failingTransport.sendMail).toHaveBeenCalledTimes(3);
+  });
+
+  it('should succeed on retry after initial failure', async () => {
+    let callCount = 0;
+    const flakyTransport: EmailTransport = {
+      sendMail: vi.fn().mockImplementation(async () => {
+        callCount++;
+        if (callCount === 1) {
+          throw new Error('Temporary failure');
+        }
+        return { messageId: 'msg-retry-success' };
+      }),
+    };
+    const retryAdapter = new EmailAdapter(
+      { from: 'noreply@taskflow.com', maxRetries: 2 },
+      flakyTransport,
+    );
+
+    const result = await retryAdapter.send(makePayload());
+
+    expect(result.success).toBe(true);
+    expect(result.notificationId).toBe('msg-retry-success');
+    expect(flakyTransport.sendMail).toHaveBeenCalledTimes(2);
+  });
+
+  it('should use InMemoryTransport by default', () => {
+    const defaultAdapter = new EmailAdapter({ from: 'test@test.com' });
+    expect(defaultAdapter.getTransport()).toBeInstanceOf(InMemoryTransport);
+  });
+
+  it('should render HTML template in sent email', async () => {
+    const payload = makePayload({
+      subject: 'Order Confirmation: order-42',
+      body: 'Items: Gadget x1. Total: $25.00',
+      metadata: { notificationType: 'order-confirmation', orderId: 'order-42' },
+    });
+
+    await adapter.send(payload);
+
+    const inbox = transport.getInbox();
+    expect(inbox[0]?.html).toContain('Order Confirmed');
+    expect(inbox[0]?.html).toContain('order-42');
+    expect(inbox[0]?.html).toContain('TaskFlow Pro');
+  });
+});
+
+describe('EmailAdapter integration with NotificationService', () => {
+  it('should receive notifications routed through the service', async () => {
+    const { EventBus } = await import('../../src/events/event-bus.js');
+    const { NotificationService, resetNotificationIdCounter } = await import(
+      '../../src/services/notification.service.js'
+    );
+
+    const eventBus = new EventBus();
+    const service = new NotificationService(eventBus);
+    resetNotificationIdCounter();
+
+    const transport = new InMemoryTransport();
+    const emailAdapter = new EmailAdapter(
+      { from: 'noreply@taskflow.com' },
+      transport,
+    );
+    service.registerAdapter(emailAdapter);
+
+    await eventBus.emit({
+      type: 'order:created',
+      order: {
+        id: 'order-99',
+        userId: 'user-1',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 3, unitPrice: 15 }],
+        total: 45,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: {
+        id: 'user-1',
+        name: 'Bob',
+        email: 'bob@example.com',
+        role: 'member',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      timestamp: new Date(),
+    });
+
+    const inbox = transport.getInbox();
+    expect(inbox).toHaveLength(1);
+    expect(inbox[0]?.to).toBe('bob@example.com');
+    expect(inbox[0]?.subject).toContain('Order Confirmation');
+    expect(inbox[0]?.html).toContain('Widget x3');
+
+    const notifications = service.getNotifications();
+    expect(notifications).toHaveLength(1);
+    expect(notifications[0]?.status).toBe('sent');
+  });
+});
