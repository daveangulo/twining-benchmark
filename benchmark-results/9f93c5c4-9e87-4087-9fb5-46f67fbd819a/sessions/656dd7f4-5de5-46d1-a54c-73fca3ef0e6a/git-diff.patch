@@ -0,0 +1,46 @@
+/**
+ * User validators — pure validation functions for user operations.
+ *
+ * All functions are pure: no side effects, no database calls.
+ * Services fetch data and pass it in; validators make the decision.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that a user exists.
+ */
+export function validateUserExists(
+  user: User | undefined,
+  userId: string,
+): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${userId}`);
+  }
+}
+
+/**
+ * Validate that an email is not already taken.
+ * Used during user creation.
+ */
+export function validateEmailNotTaken(
+  email: string,
+  existingUser: User | undefined,
+): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not in use by another user.
+ * Used during user update (allows keeping the same email).
+ */
+export function validateEmailNotInUse(
+  email: string,
+  existingUser: User | undefined,
+): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..c4d2d4c
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,130 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateOrderExists,
+  validateOrderUser,
+  validateOrderItems,
+  isValidStatusTransition,
+  validateStatusTransition,
+} from '../../src/validators/order.validator.js';
+import type { Order, OrderStatus } from '../../src/models/order.js';
+import type { User } from '../../src/models/user.js';
+
+describe('Order Validators', () => {
+  const mockOrder: Order = {
+    id: 'order-0001',
+    userId: 'user-1',
+    items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+    total: 10,
+    status: 'pending',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  };
+
+  const mockUser: User = {
+    id: 'user-1',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  };
+
+  describe('validateOrderExists', () => {
+    it('should not throw when order exists', () => {
+      expect(() => validateOrderExists(mockOrder, 'order-0001')).not.toThrow();
+    });
+
+    it('should throw when order is undefined', () => {
+      expect(() => validateOrderExists(undefined, 'order-9999')).toThrow(
+        'Order not found: order-9999',
+      );
+    });
+  });
+
+  describe('validateOrderUser', () => {
+    it('should not throw when user exists', () => {
+      expect(() => validateOrderUser(mockUser, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateOrderUser(undefined, 'user-9999')).toThrow(
+        'User not found: user-9999',
+      );
+    });
+  });
+
+  describe('validateOrderItems', () => {
+    it('should not throw when items are present', () => {
+      expect(() =>
+        validateOrderItems({
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        }),
+      ).not.toThrow();
+    });
+
+    it('should throw when items array is empty', () => {
+      expect(() =>
+        validateOrderItems({ userId: 'user-1', items: [] }),
+      ).toThrow('Order must have at least one item');
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      const targets: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'cancelled'];
+      for (const target of targets) {
+        expect(isValidStatusTransition('delivered', target)).toBe(false);
+      }
+    });
+
+    it('should reject cancelled -> any', () => {
+      const targets: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'delivered'];
+      for (const target of targets) {
+        expect(isValidStatusTransition('cancelled', target)).toBe(false);
+      }
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+
+    it('should throw for transitions from terminal states', () => {
+      expect(() => validateStatusTransition('cancelled', 'confirmed')).toThrow(
+        'Invalid status transition: cancelled -> confirmed',
+      );
+    });
+  });
+});
