+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(`${payload.recipient}:${payload.subject}`);
+          return { success: true, notificationId: `test-${callCount}`, channel: 'email' };
+        },
+      };
+
+      service.registerAdapter(trackingAdapter);
+
+      const aliceEvent: OrderCreatedEvent = {
