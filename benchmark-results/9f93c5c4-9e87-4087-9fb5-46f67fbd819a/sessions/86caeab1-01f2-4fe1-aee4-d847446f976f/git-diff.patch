+  describe('notification delivery ordering', () => {
+    it('should deliver notifications to the same recipient in order even when adapter has variable latency', async () => {
+      // Track the order in which the adapter actually delivers notifications
+      const deliveryOrder: string[] = [];
+
+      // Create an adapter with variable latency — first call is slow, second is fast.
+      // Without queuing, the second notification would be delivered first.
+      let callCount = 0;
+      const slowThenFastAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          callCount++;
+          const delay = callCount === 1 ? 50 : 5;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.subject);
+          return { success: true, notificationId: `test-${callCount}`, channel: 'email' };
+        },
+      };
+
+      service.registerAdapter(slowThenFastAdapter);
+
+      const orderCreatedEvent: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      const statusChangedEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'alice@example.com',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      // Fire both events concurrently — without ordering fix,
+      // the second (fast) notification would arrive before the first (slow) one
+      const p1 = eventBus.emit(orderCreatedEvent);
+      const p2 = eventBus.emit(statusChangedEvent);
+      await Promise.all([p1, p2]);
+
+      // The "Order Confirmation" notification must be delivered before the "Order Update"
+      expect(deliveryOrder).toHaveLength(2);
+      expect(deliveryOrder[0]).toContain('Order Confirmation');
+      expect(deliveryOrder[1]).toContain('Order Update');
+
+      // Verify the notifications array also reflects correct ordering
+      const notifications = service.getNotifications();
+      expect(notifications).toHaveLength(2);
+      expect(notifications[0]?.type).toBe('order-confirmation');
+      expect(notifications[1]?.type).toBe('order-status-update');
+    });
+
+    it('should not block notifications for different recipients', async () => {
+      const deliveryOrder: string[] = [];
