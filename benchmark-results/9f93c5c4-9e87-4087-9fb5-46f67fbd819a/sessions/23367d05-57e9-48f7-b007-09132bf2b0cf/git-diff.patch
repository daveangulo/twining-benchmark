+        id: 'notif-0002',
+        recipient: 'b@example.com',
+        subject: 'S',
+        body: 'B',
+        channel: 'email',
+        type: 'system-alert',
+        priority: 'normal',
+        status: 'sent',
+        sentAt: new Date(),
+      });
+
+      expect(log1.id).toBe('log-0001');
+      expect(log2.id).toBe('log-0002');
+    });
+
+    it('should persist logs in the repository', () => {
+      historyService.logNotification({
+        id: 'notif-0001',
+        recipient: 'a@example.com',
+        subject: 'S',
+        body: 'B',
+        channel: 'email',
+        type: 'system-alert',
+        priority: 'normal',
+        status: 'sent',
+        sentAt: new Date(),
+      });
+
+      expect(historyService.getCount()).toBe(1);
+      expect(historyService.getById('log-0001')).toBeDefined();
+    });
+  });
+
+  describe('query', () => {
+    beforeEach(() => {
+      // Seed with varied notification logs
+      historyService.logNotification({
+        id: 'notif-0001',
+        recipient: 'alice@example.com',
+        subject: 'Order Confirmation',
+        body: 'Your order.',
+        channel: 'email',
+        type: 'order-confirmation',
+        priority: 'normal',
+        status: 'sent',
+        sentAt: new Date('2026-01-10T10:00:00Z'),
+      });
+      historyService.logNotification({
+        id: 'notif-0002',
+        recipient: 'alice@example.com',
