+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { EventBus } from '../../src/events/event-bus.js';
+import { NotificationLogRepository } from '../../src/repositories/notification-log.repository.js';
+import {
+  NotificationHistoryService,
+  resetLogIdCounter,
+} from '../../src/services/notification-history.service.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+describe('NotificationHistoryService', () => {
+  let db: Database;
+  let repository: NotificationLogRepository;
+  let historyService: NotificationHistoryService;
+
+  beforeEach(() => {
+    db = new Database();
+    repository = new NotificationLogRepository(db);
+    historyService = new NotificationHistoryService(repository);
+    resetLogIdCounter();
+    resetNotificationIdCounter();
+  });
+
+  describe('logNotification', () => {
+    it('should log a sent notification', () => {
+      const log = historyService.logNotification({
+        id: 'notif-0001',
+        recipient: 'alice@example.com',
+        subject: 'Order Confirmation',
+        body: 'Your order has been placed.',
+        channel: 'email',
+        type: 'order-confirmation',
+        priority: 'normal',
+        status: 'sent',
+        sentAt: new Date('2026-01-15T10:00:00Z'),
+      });
+
+      expect(log.id).toBe('log-0001');
+      expect(log.notificationId).toBe('notif-0001');
+      expect(log.recipient).toBe('alice@example.com');
+      expect(log.channel).toBe('email');
+      expect(log.type).toBe('order-confirmation');
+      expect(log.priority).toBe('normal');
+      expect(log.subject).toBe('Order Confirmation');
+      expect(log.status).toBe('sent');
+      expect(log.sentAt).toEqual(new Date('2026-01-15T10:00:00Z'));
+    });
+
+    it('should log a failed notification', () => {
+      const log = historyService.logNotification({
+        id: 'notif-0001',
+        recipient: 'bob@example.com',
+        subject: 'Alert',
+        body: 'Something happened.',
+        channel: 'sms',
+        type: 'system-alert',
+        priority: 'high',
+        status: 'failed',
+        sentAt: new Date('2026-01-15T10:00:00Z'),
+      });
+
+      expect(log.status).toBe('failed');
+      expect(log.channel).toBe('sms');
+    });
+
+    it('should log a suppressed notification', () => {
+      const log = historyService.logNotification({
+        id: 'notif-0001',
+        recipient: 'carol@example.com',
+        subject: 'Update',
+        body: 'Profile updated.',
+        channel: 'email',
+        type: 'user-profile-update',
+        priority: 'low',
+        status: 'suppressed',
+        metadata: { suppressedByPreferences: true },
+        sentAt: new Date('2026-01-15T10:00:00Z'),
+      });
+
+      expect(log.status).toBe('suppressed');
+      expect(log.metadata).toEqual({ suppressedByPreferences: true });
+    });
+
+    it('should generate sequential log IDs', () => {
+      const log1 = historyService.logNotification({
+        id: 'notif-0001',
+        recipient: 'a@example.com',
+        subject: 'S',
+        body: 'B',
+        channel: 'email',
+        type: 'system-alert',
+        priority: 'normal',
+        status: 'sent',
