+/**
+ * SMS notification adapter — delivers notifications via SMS.
+ *
+ * Features:
+ * - Phone number validation: validates E.164-like phone numbers before sending
+ * - Message formatting: maps NotificationPayload to concise SMS text
+ * - Configurable sender number and retry behavior
+ * - Pluggable transport for testing (swap with real SMS provider)
+ *
+ * NOTE: User preferences currently only support email channel opt-in/opt-out.
+ * The preferences model (src/models/user-preferences.ts) and PreferencesService
+ * need to be updated to support per-channel preferences before SMS preference
+ * checks can be enforced in NotificationService. See decision records and
+ * warnings for details.
+ */
+
+import type { NotificationAdapter } from './notification.adapter.js';
+import type {
+  NotificationPayload,
+  NotificationResult,
+} from '../models/notification.js';
+import { Logger } from '../utils/logger.js';
+
+/** Configuration for the SMS adapter. */
+export interface SmsConfig {
+  /** Sender phone number or short code shown as the "From" number */
+  fromNumber: string;
+  /** Maximum retries on transient failure */
+  maxRetries: number;
+  /** Maximum SMS body length (standard SMS limit) */
+  maxMessageLength: number;
+}
+
+/** A formatted SMS message ready for delivery. */
+export interface SmsMessage {
+  to: string;
+  from: string;
+  body: string;
+  sentAt: Date;
+  notificationId: string;
+}
+
+/**
+ * Basic phone number validation: must start with + followed by digits,
+ * with a minimum length of 8 characters (e.g., +1234567).
+ */
+const PHONE_REGEX = /^\+[1-9]\d{6,14}$/;
+
+const DEFAULT_CONFIG: SmsConfig = {
+  fromNumber: '+10000000000',
+  maxRetries: 2,
+  maxMessageLength: 160,
+};
+
+export class SmsAdapter implements NotificationAdapter {
+  readonly channel = 'sms' as const;
+  private logger = new Logger('SmsAdapter');
+  private sentMessages: SmsMessage[] = [];
+  private config: SmsConfig;
+  /** Pluggable transport — override for testing or real providers. */
+  private transport: (message: SmsMessage) => Promise<void>;
+
+  constructor(config?: Partial<SmsConfig>) {
+    this.config = { ...DEFAULT_CONFIG, ...config };
+    // Default transport: in-memory store (replace with Twilio/SNS/etc.)
+    this.transport = async (message: SmsMessage) => {
+      this.sentMessages.push(message);
+    };
+  }
+
+  /**
+   * Replace the default in-memory transport with a custom one.
+   * Use this to plug in a real SMS provider (Twilio, AWS SNS, etc.).
+   */
+  setTransport(transport: (message: SmsMessage) => Promise<void>): void {
+    this.transport = transport;
+  }
+
+  async send(payload: NotificationPayload): Promise<NotificationResult> {
+    const validationError = this.validateRecipient(payload.recipient);
+    if (validationError) {
+      this.logger.warn(`Invalid phone number "${payload.recipient}": ${validationError}`);
+      return {
+        success: false,
+        notificationId: payload.id,
+        channel: this.channel,
+        deliveredAt: new Date(),
+        error: validationError,
+      };
+    }
+
+    const body = this.formatMessage(payload);
+
+    const message: SmsMessage = {
+      to: payload.recipient,
+      from: this.config.fromNumber,
+      body,
+      sentAt: new Date(),
+      notificationId: payload.id,
+    };
+
+    let lastError: string | undefined;
+    for (let attempt = 0; attempt <= this.config.maxRetries; attempt++) {
+      try {
+        await this.transport(message);
+        this.logger.info(
+          `SMS sent to ${message.to}: "${message.body.slice(0, 30)}..." (attempt ${attempt + 1})`,
+        );
+        return {
+          success: true,
+          notificationId: payload.id,
+          channel: this.channel,
+          deliveredAt: message.sentAt,
+        };
+      } catch (err) {
+        lastError = err instanceof Error ? err.message : String(err);
+        this.logger.warn(
+          `SMS send attempt ${attempt + 1} failed for ${message.to}: ${lastError}`,
+        );
+      }
+    }
+
+    this.logger.error(
+      `SMS delivery failed after ${this.config.maxRetries + 1} attempts for ${message.to}`,
+    );
+    return {
+      success: false,
+      notificationId: payload.id,
+      channel: this.channel,
+      deliveredAt: new Date(),
+      error: `Delivery failed after ${this.config.maxRetries + 1} attempts: ${lastError}`,
+    };
+  }
+
+  /**
+   * Validate that the recipient is a valid phone number (E.164 format).
+   * Returns an error message if invalid, or undefined if valid.
+   */
+  validateRecipient(recipient: string): string | undefined {
+    if (!recipient || recipient.trim().length === 0) {
+      return 'Phone number is empty';
+    }
+    if (!PHONE_REGEX.test(recipient)) {
+      return `Invalid phone number format: ${recipient}`;
+    }
+    return undefined;
+  }
+
+  /**
+   * Format a NotificationPayload into a concise SMS message body.
+   * Truncates to maxMessageLength if necessary.
+   */
+  formatMessage(payload: NotificationPayload): string {
+    const text = `${payload.subject}: ${payload.body}`;
+    if (text.length <= this.config.maxMessageLength) {
+      return text;
+    }
+    return text.slice(0, this.config.maxMessageLength - 3) + '...';
+  }
+
+  /** Get all sent messages (for testing). */
+  getSentMessages(): SmsMessage[] {
+    return [...this.sentMessages];
+  }
+
+  /** Clear sent messages (for testing). */
+  clearSentMessages(): void {
+    this.sentMessages = [];
+  }
+
+  /** Get the current configuration. */
+  getConfig(): SmsConfig {
+    return { ...this.config };
+  }
+}
