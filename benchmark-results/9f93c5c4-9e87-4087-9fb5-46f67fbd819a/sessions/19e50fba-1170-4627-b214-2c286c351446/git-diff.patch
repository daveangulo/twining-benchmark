@@ -0,0 +1,182 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { SmsAdapter } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order-confirmation',
+    channel: 'sms',
+    recipient: '+15551234567',
+    subject: 'Order Confirmed',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    createdAt: new Date('2026-01-01'),
+    ...overrides,
+  };
+}
+
+describe('SmsAdapter', () => {
+  let adapter: SmsAdapter;
+
+  beforeEach(() => {
+    adapter = new SmsAdapter();
+  });
+
+  describe('constructor and config', () => {
+    it('should use default config', () => {
+      const config = adapter.getConfig();
+      expect(config.maxRetries).toBe(2);
+      expect(config.fromNumber).toBe('+10000000000');
+      expect(config.maxMessageLength).toBe(160);
+    });
+
+    it('should accept custom config', () => {
+      const custom = new SmsAdapter({
+        maxRetries: 5,
+        fromNumber: '+18005551234',
+        maxMessageLength: 320,
+      });
+      const config = custom.getConfig();
+      expect(config.maxRetries).toBe(5);
+      expect(config.fromNumber).toBe('+18005551234');
+      expect(config.maxMessageLength).toBe(320);
+    });
+
+    it('should report sms channel', () => {
+      expect(adapter.channel).toBe('sms');
+    });
+  });
+
+  describe('recipient validation', () => {
+    it('should accept valid E.164 phone numbers', () => {
+      expect(adapter.validateRecipient('+15551234567')).toBeUndefined();
+      expect(adapter.validateRecipient('+442071234567')).toBeUndefined();
+      expect(adapter.validateRecipient('+861381234567')).toBeUndefined();
+    });
+
+    it('should reject empty recipient', () => {
+      expect(adapter.validateRecipient('')).toBe('Phone number is empty');
+      expect(adapter.validateRecipient('   ')).toBe('Phone number is empty');
+    });
+
+    it('should reject invalid phone number format', () => {
+      expect(adapter.validateRecipient('5551234567')).toContain('Invalid phone number format');
+      expect(adapter.validateRecipient('not-a-number')).toContain('Invalid phone number format');
+      expect(adapter.validateRecipient('+0123')).toContain('Invalid phone number format');
+      expect(adapter.validateRecipient('+abc')).toContain('Invalid phone number format');
+    });
+
+    it('should return failure result for invalid recipient on send', async () => {
+      const payload = makePayload({ recipient: 'bad-number' });
+      const result = await adapter.send(payload);
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid phone number format');
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+
+  describe('message formatting', () => {
+    it('should format subject and body into SMS text', () => {
+      const payload = makePayload({
+        subject: 'Order Update',
+        body: 'Status changed to shipped',
+      });
+      const text = adapter.formatMessage(payload);
+      expect(text).toBe('Order Update: Status changed to shipped');
+    });
+
+    it('should truncate messages exceeding maxMessageLength', () => {
+      const longBody = 'A'.repeat(200);
+      const payload = makePayload({ body: longBody });
+      const text = adapter.formatMessage(payload);
+      expect(text.length).toBe(160);
+      expect(text.endsWith('...')).toBe(true);
+    });
+
+    it('should not truncate messages within limit', () => {
+      const payload = makePayload({ subject: 'Hi', body: 'Short' });
+      const text = adapter.formatMessage(payload);
+      expect(text).toBe('Hi: Short');
+      expect(text.length).toBeLessThanOrEqual(160);
+    });
+  });
+
+  describe('send', () => {
+    it('should send SMS and record message', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('sms');
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+
+      const messages = adapter.getSentMessages();
+      expect(messages).toHaveLength(1);
+      expect(messages[0]!.to).toBe('+15551234567');
+      expect(messages[0]!.from).toBe('+10000000000');
+      expect(messages[0]!.body).toContain('Order Confirmed');
+    });
+
+    it('should clear sent messages', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentMessages()).toHaveLength(1);
+      adapter.clearSentMessages();
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+
+  describe('retry behavior', () => {
+    it('should retry on transport failure and succeed', async () => {
+      let attempts = 0;
+      adapter.setTransport(async () => {
+        attempts++;
+        if (attempts < 2) throw new Error('Transient failure');
+      });
+
+      const result = await adapter.send(makePayload());
+      expect(result.success).toBe(true);
+      expect(attempts).toBe(2);
+    });
+
+    it('should fail after exhausting retries', async () => {
+      adapter.setTransport(async () => {
+        throw new Error('Permanent failure');
+      });
+
+      const result = await adapter.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Delivery failed after 3 attempts');
+      expect(result.error).toContain('Permanent failure');
+    });
+
+    it('should respect maxRetries config', async () => {
+      const noRetry = new SmsAdapter({ maxRetries: 0 });
+      let attempts = 0;
+      noRetry.setTransport(async () => {
+        attempts++;
+        throw new Error('fail');
+      });
+
+      const result = await noRetry.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(attempts).toBe(1);
+      expect(result.error).toContain('Delivery failed after 1 attempts');
+    });
+  });
+
+  describe('custom transport', () => {
+    it('should use custom transport when set', async () => {
+      const captured: Array<{ to: string; body: string }> = [];
+      adapter.setTransport(async (message) => {
+        captured.push({ to: message.to, body: message.body });
+      });
+
+      await adapter.send(makePayload());
+      expect(captured).toHaveLength(1);
+      expect(captured[0]!.to).toBe('+15551234567');
+      // Default in-memory store should NOT have the message since we replaced transport
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+});
