+/**
+ * Notification history service — logs and queries sent notifications.
+ *
+ * Integrates with NotificationService via setter injection.
+ * Every notification (delivered, failed, or suppressed) is logged.
+ */
+
+import type { NotificationLogRepository } from '../repositories/notification-log.repository.js';
+import type {
+  NotificationLog,
+  NotificationHistoryQuery,
+  DeliveryStatus,
+} from '../models/notification-log.js';
+import type { NotificationChannel, NotificationType } from '../models/notification.js';
+import { Logger } from '../utils/logger.js';
+
+let nextLogId = 1;
+
+function generateLogId(): string {
+  return `log-${String(nextLogId++).padStart(4, '0')}`;
+}
+
+/** Reset the log ID counter. Useful for testing. */
+export function resetLogIdCounter(): void {
+  nextLogId = 1;
+}
+
+export class NotificationHistoryService {
+  private logger = new Logger('NotificationHistoryService');
+
+  constructor(private repository: NotificationLogRepository) {}
+
+  /**
+   * Record a notification in the history log.
+   */
+  log(params: {
+    notificationId: string;
+    recipient: string;
+    userId?: string;
+    channel: NotificationChannel;
+    type: NotificationType;
+    subject: string;
+    status: DeliveryStatus;
+    error?: string;
+    timestamp?: Date;
+  }): NotificationLog {
+    const entry: NotificationLog = {
+      id: generateLogId(),
+      notificationId: params.notificationId,
+      recipient: params.recipient,
+      userId: params.userId,
+      channel: params.channel,
+      type: params.type,
+      subject: params.subject,
+      status: params.status,
+      error: params.error,
+      timestamp: params.timestamp ?? new Date(),
+    };
+
+    this.repository.save(entry);
+    this.logger.info(
+      `Logged notification ${params.notificationId} [${params.type}] ${params.status}`,
+    );
+    return entry;
+  }
+
+  /**
+   * Query notification history with flexible filters.
+   */
+  query(filters: NotificationHistoryQuery): NotificationLog[] {
+    return this.repository.findAll((log) => {
+      if (filters.userId && log.userId !== filters.userId) return false;
+      if (filters.recipient && log.recipient !== filters.recipient) return false;
+      if (filters.type && log.type !== filters.type) return false;
+      if (filters.channel && log.channel !== filters.channel) return false;
+      if (filters.status && log.status !== filters.status) return false;
+      if (filters.from && log.timestamp < filters.from) return false;
+      if (filters.to && log.timestamp > filters.to) return false;
+      return true;
+    });
+  }
+
+  /**
+   * Get all log entries for a specific user.
+   */
+  getByUserId(userId: string): NotificationLog[] {
+    return this.repository.findByUserId(userId);
+  }
+
+  /**
+   * Get all log entries for a specific recipient.
+   */
+  getByRecipient(recipient: string): NotificationLog[] {
+    return this.repository.findByRecipient(recipient);
+  }
+
+  /**
+   * Get all log entries for a specific notification type.
+   */
+  getByType(type: NotificationType): NotificationLog[] {
+    return this.repository.findByType(type);
+  }
+
+  /**
+   * Get all log entries within a date range.
+   */
+  getByDateRange(from: Date, to: Date): NotificationLog[] {
+    return this.repository.findByDateRange(from, to);
+  }
+
+  /**
+   * Get the total count of logged notifications.
+   */
+  count(): number {
+    return this.repository.count();
+  }
+}
