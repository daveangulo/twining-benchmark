+import { describe, it, expect } from 'vitest';
+import { PriorityRouter, resolveChannel } from '../../src/services/priority-router.js';
+
+describe('PriorityRouter', () => {
+  const router = new PriorityRouter();
+
+  it('should route urgent to sms', () => {
+    expect(router.route('urgent')).toBe('sms');
+  });
+
+  it('should route normal to email', () => {
+    expect(router.route('normal')).toBe('email');
+  });
+
+  it('should route low to webhook', () => {
+    expect(router.route('low')).toBe('webhook');
+  });
+});
+
+describe('resolveChannel', () => {
+  it('should resolve urgent to sms', () => {
+    expect(resolveChannel('urgent')).toBe('sms');
+  });
+
+  it('should resolve normal to email', () => {
+    expect(resolveChannel('normal')).toBe('email');
+  });
+
+  it('should resolve low to webhook', () => {
+    expect(resolveChannel('low')).toBe('webhook');
+  });
+
+  it('should throw for unknown priority', () => {
+    expect(() => resolveChannel('critical' as any)).toThrow('Unknown notification priority');
+  });
+});
