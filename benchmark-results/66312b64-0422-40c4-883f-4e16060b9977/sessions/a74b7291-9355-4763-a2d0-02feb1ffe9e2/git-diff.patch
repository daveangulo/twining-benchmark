diff --git a/src/services/priority-router.ts b/src/services/priority-router.ts
new file mode 100644
index 0000000..f10ad27
--- /dev/null
+++ b/src/services/priority-router.ts
@@ -0,0 +1,92 @@
+/**
+ * Priority-based notification router.
+ *
+ * Routes notifications to channel handlers based on priority level:
+ * - urgent → SMS channel
+ * - normal → email channel (NotificationService)
+ * - low    → webhook channel
+ *
+ * This replaces the previous broadcast pattern where all channels
+ * independently subscribed to EventBus events. Now the router is
+ * the single subscriber that decides which channel handles each
+ * notification.
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent, AppEvent } from '../events/event-types.js';
+import type { NotificationService } from './notification.service.js';
+import type { SmsChannelService } from './sms-channel.service.js';
+import type { WebhookChannelService } from './webhook-channel.service.js';
+import { Logger } from '../utils/logger.js';
+
+export type NotificationPriority = 'urgent' | 'normal' | 'low';
+
+export interface PriorityNotification {
+  priority: NotificationPriority;
+  recipient: string;
+  subject: string;
+  body: string;
+  event: AppEvent;
+}
+
+export class PriorityRouter {
+  private logger = new Logger('PriorityRouter');
+  private routingLog: Array<{ priority: NotificationPriority; channel: string; notification: PriorityNotification }> = [];
+
+  constructor(
+    private smsChannel: SmsChannelService,
+    private emailChannel: NotificationService,
+    private webhookChannel: WebhookChannelService,
+  ) {}
+
+  /**
+   * Route a notification to the appropriate channel based on priority.
+   */
+  route(notification: PriorityNotification): void {
+    this.logger.info(`Routing ${notification.priority} notification to ${this.channelName(notification.priority)}`);
+
+    switch (notification.priority) {
+      case 'urgent':
+        this.smsChannel.send({
+          to: notification.recipient,
+          body: `[URGENT] ${notification.subject}: ${notification.body}`,
+        });
+        this.routingLog.push({ priority: 'urgent', channel: 'sms', notification });
+        break;
+
+      case 'normal':
+        this.emailChannel.send({
+          recipient: notification.recipient,
+          subject: notification.subject,
+          body: notification.body,
+        });
+        this.routingLog.push({ priority: 'normal', channel: 'email', notification });
+        break;
+
+      case 'low':
+        this.webhookChannel.deliver(notification.event);
+        this.routingLog.push({ priority: 'low', channel: 'webhook', notification });
+        break;
+    }
+  }
+
+  private channelName(priority: NotificationPriority): string {
+    switch (priority) {
+      case 'urgent': return 'sms';
+      case 'normal': return 'email';
+      case 'low': return 'webhook';
+    }
+  }
+
+  getRoutingLog(): Array<{ priority: NotificationPriority; channel: string; notification: PriorityNotification }> {
+    return [...this.routingLog];
+  }
+
+  getRoutingCountByChannel(channel: string): number {
+    return this.routingLog.filter((entry) => entry.channel === channel).length;
+  }
+
+  clearRoutingLog(): void {
+    this.routingLog = [];
+  }
+}
