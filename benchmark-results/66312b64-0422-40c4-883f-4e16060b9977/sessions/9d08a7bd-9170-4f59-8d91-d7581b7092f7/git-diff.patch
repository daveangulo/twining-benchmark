+/**
+ * Channel handler interface — implement this to add new notification channels.
+ */
+export interface ChannelHandler {
+  readonly channel: string;
+  handle(event: NotificationRequestedEvent): void;
+}
+
+/**
+ * Email channel handler — listens for notification:requested events
+ * and delivers notifications via email (in-memory for this demo).
+ *
+ * Follows the EventBus pub/sub pattern: subscribes to notification:requested
+ * events and processes those targeted at the 'email' channel.
+ */
+export class EmailChannelHandler implements ChannelHandler {
+  readonly channel = 'email';
+  private logger = new Logger('EmailChannelHandler');
+  private deliveredEmails: DeliveredNotification[] = [];
+
+  constructor(private eventBus: EventBus) {
+    this.eventBus.on<NotificationRequestedEvent>('notification:requested', (event) => {
+      if (event.channel === this.channel) {
+        this.handle(event);
+      }
+    });
+  }
+
+  handle(event: NotificationRequestedEvent): void {
+    const delivered: DeliveredNotification = {
+      id: generateNotificationId(),
+      channel: this.channel,
+      recipient: event.recipient,
+      subject: event.subject,
+      body: event.body,
+      sentAt: new Date(),
+    };
+    this.deliveredEmails.push(delivered);
+    this.logger.info(`Email sent: ${delivered.id} to ${event.recipient}`);
+  }
+
+  getDeliveredEmails(): DeliveredNotification[] {
+    return [...this.deliveredEmails];
+  }
+
+  getDeliveredCount(): number {
+    return this.deliveredEmails.length;
+  }
+
+  clearDelivered(): void {
+    this.deliveredEmails = [];
+  }
+}
