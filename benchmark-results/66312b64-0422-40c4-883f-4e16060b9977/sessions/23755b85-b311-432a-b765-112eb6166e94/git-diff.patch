diff --git a/tests/services/priority-router.test.ts b/tests/services/priority-router.test.ts
new file mode 100644
index 0000000..c68569e
--- /dev/null
+++ b/tests/services/priority-router.test.ts
@@ -0,0 +1,142 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { NotificationService, resetNotificationIdCounter } from '../../src/services/notification.service.js';
+import { SmsChannelService, resetSmsIdCounter } from '../../src/services/sms-channel.service.js';
+import { WebhookChannelService, resetWebhookIdCounter } from '../../src/services/webhook-channel.service.js';
+import { PriorityRouter } from '../../src/services/priority-router.js';
+import type { PriorityNotification } from '../../src/services/priority-router.js';
+import { statusChangeCallbacks } from '../../src/utils/callback-registry.js';
+
+describe('PriorityRouter', () => {
+  let eventBus: EventBus;
+  let emailChannel: NotificationService;
+  let smsChannel: SmsChannelService;
+  let webhookChannel: WebhookChannelService;
+  let router: PriorityRouter;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    statusChangeCallbacks.clear();
+    emailChannel = new NotificationService(eventBus);
+    smsChannel = new SmsChannelService(eventBus);
+    webhookChannel = new WebhookChannelService(eventBus);
+    router = new PriorityRouter(smsChannel, emailChannel, webhookChannel);
+    resetNotificationIdCounter();
+    resetSmsIdCounter();
+    resetWebhookIdCounter();
+  });
+
+  describe('urgent priority', () => {
+    it('should route urgent notifications to SMS channel', () => {
+      const notification: PriorityNotification = {
+        priority: 'urgent',
+        recipient: '+1234567890',
+        subject: 'Server Down',
+        body: 'Production server is unreachable',
+      };
+
+      router.route(notification);
+
+      expect(smsChannel.getMessageCount()).toBe(1);
+      expect(emailChannel.getNotificationCount()).toBe(0);
+      expect(webhookChannel.getDeliveryCount()).toBe(0);
+
+      const messages = smsChannel.getMessages();
+      expect(messages[0]?.phoneNumber).toBe('+1234567890');
+      expect(messages[0]?.message).toContain('Server Down');
+      expect(messages[0]?.message).toContain('Production server is unreachable');
+    });
+  });
+
+  describe('normal priority', () => {
+    it('should route normal notifications to email channel', () => {
+      const notification: PriorityNotification = {
+        priority: 'normal',
+        recipient: 'user@example.com',
+        subject: 'Order Shipped',
+        body: 'Your order has been shipped',
+      };
+
+      router.route(notification);
+
+      expect(emailChannel.getNotificationCount()).toBe(1);
+      expect(smsChannel.getMessageCount()).toBe(0);
+      expect(webhookChannel.getDeliveryCount()).toBe(0);
+
+      const notifications = emailChannel.getNotifications();
+      expect(notifications[0]?.recipient).toBe('user@example.com');
+      expect(notifications[0]?.subject).toBe('Order Shipped');
+      expect(notifications[0]?.body).toBe('Your order has been shipped');
+    });
+  });
+
+  describe('low priority', () => {
+    it('should route low-priority notifications to webhook channel', () => {
+      const notification: PriorityNotification = {
+        priority: 'low',
+        recipient: 'system-monitor',
+        subject: 'Daily Report',
+        body: 'All systems nominal',
+        webhookUrl: 'https://hooks.example.com/reports',
+      };
+
+      router.route(notification);
+
+      expect(webhookChannel.getDeliveryCount()).toBe(1);
+      expect(smsChannel.getMessageCount()).toBe(0);
+      expect(emailChannel.getNotificationCount()).toBe(0);
+
+      const deliveries = webhookChannel.getDeliveries();
+      expect(deliveries[0]?.url).toBe('https://hooks.example.com/reports');
+      expect(deliveries[0]?.eventType).toBe('notification');
+      expect(deliveries[0]?.payload).toEqual({
+        recipient: 'system-monitor',
+        subject: 'Daily Report',
+        body: 'All systems nominal',
+        priority: 'low',
+      });
+    });
+
+    it('should use default webhook URL when none provided', () => {
+      const notification: PriorityNotification = {
+        priority: 'low',
+        recipient: 'system-monitor',
+        subject: 'Info',
+        body: 'Minor update',
+      };
+
+      router.route(notification);
+
+      const deliveries = webhookChannel.getDeliveries();
+      expect(deliveries[0]?.url).toBe('https://hooks.default/notifications');
+    });
+  });
+
+  describe('routing isolation', () => {
+    it('should route multiple notifications to correct channels', () => {
+      router.route({
+        priority: 'urgent',
+        recipient: '+1111111111',
+        subject: 'Alert',
+        body: 'Urgent alert',
+      });
+      router.route({
+        priority: 'normal',
+        recipient: 'user@example.com',
+        subject: 'Update',
+        body: 'Normal update',
+      });
+      router.route({
+        priority: 'low',
+        recipient: 'logger',
+        subject: 'Log',
+        body: 'Low priority log',
+        webhookUrl: 'https://hooks.example.com/log',
+      });
+
+      expect(smsChannel.getMessageCount()).toBe(1);
+      expect(emailChannel.getNotificationCount()).toBe(1);
+      expect(webhookChannel.getDeliveryCount()).toBe(1);
+    });
+  });
+});
