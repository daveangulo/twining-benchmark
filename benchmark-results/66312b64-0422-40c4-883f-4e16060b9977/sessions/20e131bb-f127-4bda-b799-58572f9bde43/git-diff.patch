+
+  it('should handle multiple notifications', async () => {
+    await eventBus.emit({
+      type: 'notification:requested',
+      recipient: 'alert-1',
+      subject: 'First',
+      body: 'First webhook',
+      channel: 'webhook',
+      timestamp: new Date(),
+    });
+    await eventBus.emit({
+      type: 'notification:requested',
+      recipient: 'alert-2',
+      subject: 'Second',
+      body: 'Second webhook',
+      channel: 'webhook',
+      timestamp: new Date(),
+    });
+
+    const delivered = webhookHandler.getDeliveredNotifications();
+    expect(delivered).toHaveLength(2);
+    const payloads = webhookHandler.getDeliveredPayloads();
+    expect(payloads).toHaveLength(2);
+  });
+
+  it('should generate sequential IDs for delivered notifications', async () => {
+    await eventBus.emit({
+      type: 'notification:requested',
+      recipient: 'alert-1',
+      subject: 'First',
+      body: 'First',
+      channel: 'webhook',
+      timestamp: new Date(),
+    });
+    await eventBus.emit({
+      type: 'notification:requested',
+      recipient: 'alert-2',
+      subject: 'Second',
+      body: 'Second',
+      channel: 'webhook',
+      timestamp: new Date(),
+    });
+
+    const delivered = webhookHandler.getDeliveredNotifications();
+    expect(delivered[0]?.id).toBe('notif-0001');
+    expect(delivered[1]?.id).toBe('notif-0002');
+  });
+
+  it('should clear both notifications and payloads', async () => {
+    await eventBus.emit({
+      type: 'notification:requested',
+      recipient: 'alert-1',
+      subject: 'Test',
+      body: 'Test',
+      channel: 'webhook',
+      timestamp: new Date(),
