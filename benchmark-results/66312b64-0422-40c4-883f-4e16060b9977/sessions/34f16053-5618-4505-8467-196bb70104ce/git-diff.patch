+import { describe, it, expect, beforeEach } from 'vitest';
+import { NotificationPreferencesService } from '../../src/services/notification-preferences.service.js';
+
+describe('NotificationPreferencesService', () => {
+  let prefs: NotificationPreferencesService;
+
+  beforeEach(() => {
+    prefs = new NotificationPreferencesService();
+  });
+
+  it('should return null for users with no preference', () => {
+    expect(prefs.getPreference('user-1')).toBeNull();
+  });
+
+  it('should set and get a preference', () => {
+    prefs.setPreference('user-1', 'sms');
+    expect(prefs.getPreference('user-1')).toBe('sms');
+  });
+
+  it('should overwrite an existing preference', () => {
+    prefs.setPreference('user-1', 'sms');
+    prefs.setPreference('user-1', 'email');
+    expect(prefs.getPreference('user-1')).toBe('email');
+  });
+
+  it('should remove a preference', () => {
+    prefs.setPreference('user-1', 'webhook');
+    expect(prefs.removePreference('user-1')).toBe(true);
+    expect(prefs.getPreference('user-1')).toBeNull();
+  });
+
+  it('should return false when removing non-existent preference', () => {
+    expect(prefs.removePreference('user-1')).toBe(false);
+  });
+
+  it('should check if a preference exists', () => {
+    expect(prefs.hasPreference('user-1')).toBe(false);
+    prefs.setPreference('user-1', 'email');
+    expect(prefs.hasPreference('user-1')).toBe(true);
+  });
+
+  it('should return all preferences', () => {
+    prefs.setPreference('user-1', 'sms');
+    prefs.setPreference('user-2', 'email');
+
+    const all = prefs.getAllPreferences();
+    expect(all).toHaveLength(2);
+    expect(all).toContainEqual({ userId: 'user-1', preferredChannel: 'sms' });
+    expect(all).toContainEqual({ userId: 'user-2', preferredChannel: 'email' });
+  });
+
+  it('should clear all preferences', () => {
+    prefs.setPreference('user-1', 'sms');
+    prefs.setPreference('user-2', 'email');
+    prefs.clear();
+    expect(prefs.getAllPreferences()).toHaveLength(0);
+  });
+});
