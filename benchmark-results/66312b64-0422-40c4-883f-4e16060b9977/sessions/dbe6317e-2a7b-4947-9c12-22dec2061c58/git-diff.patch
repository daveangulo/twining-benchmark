+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  SmsChannelService,
+  resetSmsIdCounter,
+} from '../../src/services/sms-channel.service.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('SmsChannelService', () => {
+  let eventBus: EventBus;
+  let service: SmsChannelService;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    service = new SmsChannelService(eventBus);
+    resetSmsIdCounter();
+  });
+
+  describe('order:created handler', () => {
+    it('should send SMS on order created', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const messages = service.getMessages();
+      expect(messages).toHaveLength(1);
+      expect(messages[0]?.to).toBe('user-1');
+      expect(messages[0]?.body).toContain('order-1');
+      expect(messages[0]?.body).toContain('2 item(s)');
+      expect(messages[0]?.body).toContain('$20.00');
+    });
+
+    it('should count total items across all line items', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 3, unitPrice: 5 },
+          ],
+          total: 35,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const messages = service.getMessages();
+      expect(messages[0]?.body).toContain('5 item(s)');
+    });
+  });
+
+  describe('order:status-changed handler', () => {
+    it('should send SMS on status change', async () => {
+      const event: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const messages = service.getMessages();
+      expect(messages).toHaveLength(1);
+      expect(messages[0]?.to).toBe('user-1');
+      expect(messages[0]?.body).toContain('confirmed');
+    });
+  });
+
+  describe('message management', () => {
+    it('should count messages', async () => {
+      expect(service.getMessageCount()).toBe(0);
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(service.getMessageCount()).toBe(1);
+    });
+
+    it('should filter by recipient', async () => {
+      await eventBus.emit({
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+          ],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      expect(service.getMessagesForRecipient('user-1')).toHaveLength(1);
+      expect(service.getMessagesForRecipient('user-2')).toHaveLength(0);
+    });
+
+    it('should clear messages', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      service.clearMessages();
+      expect(service.getMessageCount()).toBe(0);
+    });
+
+    it('should generate sequential SMS IDs', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-2',
+          userId: 'user-1',
+          items: [],
+          total: 30,
+          status: 'shipped',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      });
+
+      const messages = service.getMessages();
+      expect(messages[0]?.id).toBe('sms-0001');
+      expect(messages[1]?.id).toBe('sms-0002');
+    });
+  });
+});
