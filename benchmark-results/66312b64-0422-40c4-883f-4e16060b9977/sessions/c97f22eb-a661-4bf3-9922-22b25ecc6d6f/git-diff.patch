+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const notifications = notificationService.getNotifications();
+      expect(notifications).toHaveLength(1);
+      expect(notifications[0]!.channel).toBe('email');
+      expect(notifications[0]!.priority).toBe('normal');
+    });
+  });
+
+  describe('user preference overrides', () => {
+    it('should override priority routing when user has a preference', async () => {
+      // Alice prefers SMS for normal-priority notifications
+      preferencesService.setPreference('alice@example.com', 'normal', 'sms');
+
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
