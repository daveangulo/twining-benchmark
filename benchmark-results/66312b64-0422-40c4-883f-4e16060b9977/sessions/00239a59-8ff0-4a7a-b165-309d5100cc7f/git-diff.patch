+describe('SmsNotificationHandler', () => {
+  let eventBus: EventBus;
+  let smsHandler: SmsNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    statusChangeCallbacks.clear();
+    resetNotificationIdCounter();
+    smsHandler = new SmsNotificationHandler(eventBus);
+  });
+
+  it('should deliver SMS when notification:send events are published', async () => {
+    await eventBus.emit({
+      type: 'notification:send',
+      recipient: '+15551234567',
+      subject: 'Order Update',
+      body: 'Your order has shipped',
+      timestamp: new Date(),
+    });
+
+    const messages = smsHandler.getDeliveredMessages();
+    expect(messages).toHaveLength(1);
+    expect(messages[0]?.phoneNumber).toBe('+15551234567');
+    expect(messages[0]?.message).toBe('Order Update: Your order has shipped');
+  });
+
+  it('should receive notifications dispatched by NotificationService', async () => {
+    const service = new NotificationService(eventBus);
+
+    const event: OrderCreatedEvent = {
+      type: 'order:created',
+      order: {
+        id: 'order-1',
+        userId: 'user-1',
+        items: [
+          { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+        ],
+        total: 20,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: {
+        id: 'user-1',
+        name: 'Alice',
+        email: 'alice@example.com',
+        role: 'member',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+
+    const messages = smsHandler.getDeliveredMessages();
+    expect(messages).toHaveLength(1);
+    expect(messages[0]?.phoneNumber).toBe('alice@example.com');
+    expect(messages[0]?.message).toContain('Order Confirmation');
+    expect(messages[0]?.message).toContain('Widget x2');
+  });
+
+  it('should handle multiple notification events', async () => {
+    await eventBus.emit({
+      type: 'notification:send',
+      recipient: '+15551111111',
+      subject: 'First',
+      body: 'First SMS',
+      timestamp: new Date(),
+    });
+    await eventBus.emit({
+      type: 'notification:send',
+      recipient: '+15552222222',
+      subject: 'Second',
+      body: 'Second SMS',
+      timestamp: new Date(),
+    });
+
+    const messages = smsHandler.getDeliveredMessages();
+    expect(messages).toHaveLength(2);
+    expect(messages[0]?.phoneNumber).toBe('+15551111111');
+    expect(messages[1]?.phoneNumber).toBe('+15552222222');
+  });
+
+  it('should clear delivered messages', async () => {
+    await eventBus.emit({
+      type: 'notification:send',
+      recipient: '+15551234567',
+      subject: 'Test',
+      body: 'Test',
+      timestamp: new Date(),
+    });
+
+    smsHandler.clearDeliveredMessages();
+    expect(smsHandler.getDeliveredMessages()).toHaveLength(0);
+  });
+});
