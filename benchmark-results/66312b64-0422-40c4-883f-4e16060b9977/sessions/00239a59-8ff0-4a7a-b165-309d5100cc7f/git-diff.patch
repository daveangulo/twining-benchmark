+export interface SmsDelivery {
+  id: string;
+  phoneNumber: string;
+  message: string;
+  sentAt: Date;
+}
+
+export class SmsNotificationHandler implements NotificationChannelHandler {
+  private logger = new Logger('SmsNotificationHandler');
+  private deliveredMessages: SmsDelivery[] = [];
+
+  constructor(private eventBus: EventBus) {
+    this.eventBus.on<NotificationSendEvent>('notification:send', (event) => {
+      this.handle(event);
+    });
+  }
+
+  handle(event: NotificationSendEvent): void {
+    const delivery: SmsDelivery = {
+      id: generateNotificationId(),
+      phoneNumber: event.recipient,
+      message: `${event.subject}: ${event.body}`,
+      sentAt: new Date(),
+    };
+    this.deliveredMessages.push(delivery);
+    this.logger.info(`SMS sent: ${delivery.id} to ${event.recipient}`);
+  }
+
+  getDeliveredMessages(): SmsDelivery[] {
+    return [...this.deliveredMessages];
+  }
+
+  clearDeliveredMessages(): void {
+    this.deliveredMessages = [];
+  }
+}
+
+export interface WebhookDelivery {
+  id: string;
+  payload: {
+    recipient: string;
+    subject: string;
+    body: string;
+    timestamp: Date;
+  };
+  deliveredAt: Date;
+}
+
+export class WebhookNotificationHandler implements NotificationChannelHandler {
+  private logger = new Logger('WebhookNotificationHandler');
+  private deliveredWebhooks: WebhookDelivery[] = [];
+
+  constructor(private eventBus: EventBus) {
+    this.eventBus.on<NotificationSendEvent>('notification:send', (event) => {
+      this.handle(event);
+    });
+  }
+
+  handle(event: NotificationSendEvent): void {
+    const delivery: WebhookDelivery = {
+      id: generateNotificationId(),
+      payload: {
+        recipient: event.recipient,
+        subject: event.subject,
+        body: event.body,
+        timestamp: event.timestamp,
+      },
+      deliveredAt: new Date(),
+    };
+    this.deliveredWebhooks.push(delivery);
+    this.logger.info(`Webhook delivered: ${delivery.id} for ${event.recipient}`);
+  }
+
+  getDeliveredWebhooks(): WebhookDelivery[] {
+    return [...this.deliveredWebhooks];
+  }
+
+  clearDeliveredWebhooks(): void {
+    this.deliveredWebhooks = [];
+  }
+}
