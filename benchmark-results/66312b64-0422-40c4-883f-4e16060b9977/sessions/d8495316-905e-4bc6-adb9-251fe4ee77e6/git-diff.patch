     return this.deliveries.length;
   }
 
+  /**
+   * Public method for delivering a webhook directly (used by PriorityRouter).
+   */
+  send(params: {
+    url: string;
+    eventType: string;
+    payload: Record<string, unknown>;
+  }): WebhookDelivery {
+    const delivery: WebhookDelivery = {
+      id: generateWebhookDeliveryId(),
+      url: params.url,
+      eventType: params.eventType,
+      payload: params.payload,
+      deliveredAt: new Date(),
+    };
+    this.deliveries.push(delivery);
+    this.logger.info(`Webhook delivered: ${delivery.id} to ${params.url} for ${params.eventType}`);
+    return delivery;
+  }
+
   clearDeliveries(): void {
     this.deliveries = [];
   }
