+  }
+
+  private handleWebhook(event: NotificationEvent): void {
+    const notification: Notification = {
+      id: generateNotificationId(),
+      type: 'webhook',
+      recipient: event.recipient,
+      subject: event.subject,
+      body: event.body,
+      sentAt: new Date(),
+    };
+    this.sent.push(notification);
+    this.logger.info(`Webhook sent: ${notification.id} to ${event.recipient}`);
+  }
+
+  getSentWebhooks(): Notification[] {
+    return [...this.sent];
+  }
+
+  getSentCount(): number {
+    return this.sent.length;
+  }
+
+  clearSent(): void {
+    this.sent = [];
+  }
+}
