diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..5f5121b
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,45 @@
+/**
+ * Pure validation functions for order operations.
+ */
+
+import type { OrderItem, OrderStatus } from '../models/order.js';
+
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Validate that an order has at least one item.
+ * Throws if the items array is empty.
+ */
+export function validateOrderHasItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate a status transition, throwing if it is not allowed.
+ */
+export function validateStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(`Invalid status transition: ${from} -> ${to}`);
+  }
+}
diff --git a/src/validators/preferences.validator.ts b/src/validators/preferences.validator.ts
new file mode 100644
index 0000000..6e3ad8c
--- /dev/null
+++ b/src/validators/preferences.validator.ts
@@ -0,0 +1,34 @@
+/**
+ * Pure validation functions for notification preferences.
+ */
+
+import type { UserPreferences } from '../models/user-preferences.js';
+import type { NotificationType } from '../models/notification.js';
+
+/**
+ * Determine whether an email notification of the given type should be
+ * sent based on the user's preferences.
+ *
+ * Returns true if:
+ *  - No preferences exist (default: send all)
+ *  - Email is enabled AND the category is subscribed AND frequency is not 'none'
+ */
+export function shouldSendNotification(
+  preferences: UserPreferences | undefined,
+  notificationType: NotificationType,
+): boolean {
+  // No preferences stored — default to sending
+  if (!preferences) {
+    return true;
+  }
+
+  if (!preferences.email.enabled) {
+    return false;
+  }
+
+  if (preferences.email.frequency === 'none') {
+    return false;
+  }
+
+  return preferences.email.subscribedCategories.includes(notificationType);
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..d46504a
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,47 @@
+/**
+ * Pure validation functions for user operations.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that an email is not already taken.
+ * Takes the result of a findByEmail lookup as input.
+ * Throws if a user with that email already exists.
+ */
+export function validateEmailNotTaken(
+  email: string,
+  existingUser: User | undefined,
+): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not already in use by another user.
+ * Used during updates where the current user's own email should be allowed.
+ * Throws if a different user holds the email.
+ */
+export function validateEmailNotInUse(
+  email: string,
+  existingUser: User | undefined,
+): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
+
+/**
+ * Validate that a user exists.
+ * Takes the result of a findById lookup as input.
+ * Throws if the user is not found.
+ */
+export function validateUserExists(
+  id: string,
+  user: User | undefined,
+): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${id}`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..f473534
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,72 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateOrderHasItems,
+  isValidStatusTransition,
+  validateStatusTransition,
+} from '../../src/validators/order.validator.js';
+
+describe('order validators', () => {
+  describe('validateOrderHasItems', () => {
+    it('should throw for empty items', () => {
+      expect(() => validateOrderHasItems([])).toThrow(
+        'Order must have at least one item',
+      );
+    });
+
+    it('should not throw for non-empty items', () => {
+      expect(() =>
+        validateOrderHasItems([
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+        ]),
+      ).not.toThrow();
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(isValidStatusTransition('delivered', 'pending')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'cancelled')).toBe(false);
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(isValidStatusTransition('cancelled', 'pending')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'confirmed')).toBe(false);
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+  });
+});
diff --git a/tests/validators/preferences.validator.test.ts b/tests/validators/preferences.validator.test.ts
new file mode 100644
index 0000000..1190764
--- /dev/null
+++ b/tests/validators/preferences.validator.test.ts
@@ -0,0 +1,59 @@
+import { describe, it, expect } from 'vitest';
+import { shouldSendNotification } from '../../src/validators/preferences.validator.js';
+import type { UserPreferences } from '../../src/models/user-preferences.js';
+
+const makePrefs = (
+  overrides: Partial<UserPreferences['email']> = {},
+): UserPreferences => ({
+  id: 'pref-0001',
+  userId: 'user-0001',
+  email: {
+    enabled: true,
+    frequency: 'immediate',
+    subscribedCategories: ['order:confirmation', 'order:status-update'],
+    ...overrides,
+  },
+  createdAt: new Date(),
+  updatedAt: new Date(),
+});
+
+describe('preferences validators', () => {
+  describe('shouldSendNotification', () => {
+    it('should return true when no preferences exist', () => {
+      expect(shouldSendNotification(undefined, 'order:confirmation')).toBe(true);
+    });
+
+    it('should return true when email is enabled and category is subscribed', () => {
+      expect(
+        shouldSendNotification(makePrefs(), 'order:confirmation'),
+      ).toBe(true);
+    });
+
+    it('should return false when email is disabled', () => {
+      expect(
+        shouldSendNotification(makePrefs({ enabled: false }), 'order:confirmation'),
+      ).toBe(false);
+    });
+
+    it('should return false when frequency is none', () => {
+      expect(
+        shouldSendNotification(makePrefs({ frequency: 'none' }), 'order:confirmation'),
+      ).toBe(false);
+    });
+
+    it('should return false when category is not subscribed', () => {
+      expect(
+        shouldSendNotification(makePrefs(), 'user:welcome'),
+      ).toBe(false);
+    });
+
+    it('should return true for subscribed category with daily frequency', () => {
+      expect(
+        shouldSendNotification(
+          makePrefs({ frequency: 'daily' }),
+          'order:confirmation',
+        ),
+      ).toBe(true);
+    });
+  });
+});
diff --git a/tests/validators/user.validator.test.ts b/tests/validators/user.validator.test.ts
