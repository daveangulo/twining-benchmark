@@ -0,0 +1,228 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  SmsAdapter,
+  InMemorySmsTransport,
+  formatSmsBody,
+  validatePhoneNumber,
+} from '../../src/adapters/sms.adapter.js';
+import type { SmsTransport } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+describe('SmsAdapter', () => {
+  let eventBus: EventBus;
+  let transport: InMemorySmsTransport;
+  let adapter: SmsAdapter;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    transport = new InMemorySmsTransport();
+    adapter = new SmsAdapter(eventBus, transport);
+  });
+
+  // -------------------------------------------------------------------------
+  // validatePhoneNumber
+  // -------------------------------------------------------------------------
+
+  describe('validatePhoneNumber', () => {
+    it('should accept a valid E.164 phone number', () => {
+      expect(validatePhoneNumber('+14155551234')).toBe('+14155551234');
+    });
+
+    it('should accept an international number', () => {
+      expect(validatePhoneNumber('+442071234567')).toBe('+442071234567');
+    });
+
+    it('should strip spaces and dashes', () => {
+      expect(validatePhoneNumber('+1 415-555-1234')).toBe('+14155551234');
+    });
+
+    it('should strip parentheses', () => {
+      expect(validatePhoneNumber('+1 (415) 555-1234')).toBe('+14155551234');
+    });
+
+    it('should reject an empty string', () => {
+      expect(validatePhoneNumber('')).toBeNull();
+    });
+
+    it('should reject a number without country code', () => {
+      expect(validatePhoneNumber('4155551234')).toBeNull();
+    });
+
+    it('should reject a number starting with +0', () => {
+      expect(validatePhoneNumber('+04155551234')).toBeNull();
+    });
+
+    it('should reject a plain string', () => {
+      expect(validatePhoneNumber('not-a-phone')).toBeNull();
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // formatSmsBody
+  // -------------------------------------------------------------------------
+
+  describe('formatSmsBody', () => {
+    const basePayload: NotificationPayload = {
+      recipient: '+14155551234',
+      subject: 'Order Confirmation',
+      body: 'Your order has been placed.',
+      notificationType: 'order_confirmation',
+      channel: 'sms',
+      priority: 'normal',
+    };
+
+    it('should format subject and body', () => {
+      const text = formatSmsBody(basePayload);
+      expect(text).toBe('Order Confirmation: Your order has been placed.');
+    });
+
+    it('should truncate messages longer than 160 characters', () => {
+      const longBody = 'A'.repeat(200);
+      const text = formatSmsBody({ ...basePayload, body: longBody });
+      expect(text.length).toBe(160);
+      expect(text.endsWith('...')).toBe(true);
+    });
+
+    it('should not truncate messages at exactly 160 characters', () => {
+      // "Order Confirmation: " is 20 chars, so body needs to be 140 chars for total 160
+      const exactBody = 'B'.repeat(140);
+      const text = formatSmsBody({ ...basePayload, body: exactBody });
+      expect(text.length).toBe(160);
+      expect(text.endsWith('...')).toBe(false);
+    });
+
+    it('should not truncate short messages', () => {
+      const text = formatSmsBody({ ...basePayload, body: 'Short.' });
+      expect(text).toBe('Order Confirmation: Short.');
+      expect(text.length).toBeLessThan(160);
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // send()
+  // -------------------------------------------------------------------------
+
+  describe('send', () => {
+    const payload: NotificationPayload = {
+      recipient: '+14155551234',
+      subject: 'Order Confirmation: order-1',
+      body: 'Your order has been placed.',
+      notificationType: 'order_confirmation',
+      channel: 'sms',
+      priority: 'normal',
+    };
+
+    it('should send an SMS via the transport', async () => {
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const messages = transport.getSentMessages();
+      expect(messages).toHaveLength(1);
+      expect(messages[0]?.to).toBe('+14155551234');
+      expect(messages[0]?.body).toContain('Order Confirmation');
+    });
+
+    it('should record the payload in sent list', async () => {
+      await adapter.send(payload);
+
+      const sent = adapter.getSentSms();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.recipient).toBe('+14155551234');
+    });
+
+    it('should return failure for invalid phone number', async () => {
+      const result = await adapter.send({ ...payload, recipient: 'not-a-phone' });
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid phone number');
+      expect(transport.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should return failure when transport throws', async () => {
+      const failingTransport: SmsTransport = {
+        sendSms: async () => {
+          throw new Error('SMS gateway unavailable');
+        },
+      };
+      const failAdapter = new SmsAdapter(eventBus, failingTransport);
+
+      const result = await failAdapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('SMS gateway unavailable');
+    });
+
+    it('should handle high priority payload', async () => {
+      const result = await adapter.send({ ...payload, priority: 'high' });
+
+      expect(result.success).toBe(true);
+      expect(adapter.getSentSms()).toHaveLength(1);
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // EventBus integration
+  // -------------------------------------------------------------------------
+
+  describe('event bus integration', () => {
+    it('should handle notification:send events for sms channel', async () => {
+      await eventBus.emit({
+        type: 'notification:send',
+        payload: {
+          recipient: '+14155551234',
+          subject: 'Test',
+          body: 'Test body',
+          notificationType: 'order_confirmation' as const,
+          channel: 'sms' as const,
+          priority: 'normal' as const,
+        },
+        timestamp: new Date(),
+      });
+
+      expect(adapter.getSentSms()).toHaveLength(1);
+      expect(transport.getSentMessages()).toHaveLength(1);
+    });
+
+    it('should ignore notification:send events for other channels', async () => {
+      await eventBus.emit({
+        type: 'notification:send',
+        payload: {
+          recipient: 'alice@example.com',
+          subject: 'Test',
+          body: 'Test body',
+          notificationType: 'order_confirmation' as const,
+          channel: 'email' as const,
+          priority: 'normal' as const,
+        },
+        timestamp: new Date(),
+      });
+
+      expect(adapter.getSentSms()).toHaveLength(0);
+      expect(transport.getSentMessages()).toHaveLength(0);
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // Utility methods
+  // -------------------------------------------------------------------------
+
+  describe('utility methods', () => {
+    it('should clear sent SMS', async () => {
+      await adapter.send({
+        recipient: '+14155551234',
+        subject: 'Test',
+        body: 'Test',
+        notificationType: 'order_confirmation',
+        channel: 'sms',
+      });
+
+      adapter.clearSentSms();
+      expect(adapter.getSentSms()).toHaveLength(0);
+    });
+
+    it('should expose the transport', () => {
+      expect(adapter.getTransport()).toBe(transport);
+    });
+  });
+});
