+          deliveredSubjects.push(payload.subject);
+          return {
+            success: true,
+            notificationId: payload.id,
+            channel: 'email' as const,
+            deliveredAt: new Date(),
+          };
+        },
+      };
+      service.registerAdapter(trackingAdapter);
+
+      // Emit 3 events in rapid succession for same user
+      const event1: OrderCreatedEvent = {
+        type: 'order:created',
+        order: sampleOrder,
+        user: alice,
+        timestamp: new Date(),
+      };
+
+      const event2: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: { ...sampleOrder, status: 'confirmed' },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      const event3: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: { ...sampleOrder, status: 'shipped' },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      };
+
+      await Promise.all([
+        eventBus.emit(event1),
+        eventBus.emit(event2),
+        eventBus.emit(event3),
+      ]);
+
+      // All 3 must have been delivered in order
+      expect(deliveredSubjects).toHaveLength(3);
+      expect(deliveredSubjects[0]).toContain('Order Confirmation');
+      expect(deliveredSubjects[1]).toContain('Order Update');
