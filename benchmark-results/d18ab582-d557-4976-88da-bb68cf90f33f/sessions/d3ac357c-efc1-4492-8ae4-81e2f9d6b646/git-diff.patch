+        type: 'order:status-changed',
+        order: { ...sampleOrder, status: 'confirmed' },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      } as OrderStatusChangedEvent);
+
+      // 4. Order ships → status update email
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: { ...sampleOrder, status: 'shipped' },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
