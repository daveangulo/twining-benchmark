+
+      // Email goes through
+      await eventBus.emit({
+        type: 'order:created',
+        order: sampleOrder,
+        user: alice,
+        timestamp: new Date(),
+      } as OrderCreatedEvent);
+
+      // SMS is suppressed
+      await service['sendNotification']({
+        type: 'order-confirmation',
+        channel: 'sms',
+        recipient: alice.id,
+        userId: alice.id,
+        subject: 'Order Confirmation',
+        body: 'Your order has been placed.',
