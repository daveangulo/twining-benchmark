+
+      const variableLatencyAdapter = {
+        channel: 'email' as const,
+        async send(payload: { id: string; recipient: string; [key: string]: unknown }) {
+          const idx = callIndex++;
+          // Alice's notification takes longer
+          const delay = idx === 0 ? 40 : 5;
+          await new Promise((r) => setTimeout(r, delay));
+          deliveryOrder.push(payload.recipient);
+          return {
+            success: true,
+            notificationId: payload.id,
+            channel: 'email' as const,
+            deliveredAt: new Date(),
