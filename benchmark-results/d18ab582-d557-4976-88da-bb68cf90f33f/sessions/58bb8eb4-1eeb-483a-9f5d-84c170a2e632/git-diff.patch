+/**
+ * Notification log model — tracks the history of all sent notifications.
+ *
+ * Each log entry captures the recipient, channel, type, timestamp,
+ * and delivery status of a notification for auditing and querying.
+ */
+
+import type { NotificationChannel, NotificationType, NotificationStatus } from './notification.js';
+
+export interface NotificationLog {
+  id: string;
+  notificationId: string;
+  recipient: string;
+  channel: NotificationChannel;
+  type: NotificationType;
+  status: NotificationStatus;
+  error: string | null;
+  timestamp: Date;
+  createdAt: Date;
+}
+
+export interface NotificationLogQuery {
+  recipient?: string;
+  channel?: NotificationChannel;
+  type?: NotificationType;
+  status?: NotificationStatus;
+  startDate?: Date;
+  endDate?: Date;
+}
