+        timestamp: new Date(),
+      } as OrderStatusChangedEvent);
+
+      // 4. Order shipped
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: { ...sampleOrder, status: 'shipped' },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      } as OrderStatusChangedEvent);
+
+      // 5. User updates profile
