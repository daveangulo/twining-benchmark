+
+      const trackingAdapter: NotificationAdapter = {
+        channel: 'email' as NotificationChannel,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          sendCount++;
+          const currentSend = sendCount;
+          // First send (alice) is slow, second (bob) is fast
+          if (currentSend === 1) {
+            await new Promise((resolve) => setTimeout(resolve, 50));
+          }
+          deliveryOrder.push(payload.recipient);
+          return { success: true, notificationId: `test-${currentSend}`, channel: 'email' };
+        },
+      };
+
+      const testBus = new EventBus();
+      const testService = new NotificationService(testBus);
+      testService.registerAdapter(trackingAdapter);
+
+      // Send to two different recipients concurrently
+      const p1 = testService.sendNotification({
+        type: 'welcome',
+        recipient: 'alice@example.com',
+        subject: 'Welcome Alice',
+        body: 'Hello Alice',
+        channel: 'email',
+      });
+      const p2 = testService.sendNotification({
+        type: 'welcome',
+        recipient: 'bob@example.com',
+        subject: 'Welcome Bob',
+        body: 'Hello Bob',
+        channel: 'email',
+      });
+      await Promise.all([p1, p2]);
+
+      // Bob should arrive before Alice since they are different recipients (no queuing)
+      expect(deliveryOrder).toEqual(['bob@example.com', 'alice@example.com']);
+    });
+  });
