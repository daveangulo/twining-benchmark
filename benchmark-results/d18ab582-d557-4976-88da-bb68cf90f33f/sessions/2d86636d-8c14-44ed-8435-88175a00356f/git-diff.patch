+  describe('notification ordering', () => {
+    it('should deliver notifications in order when events fire concurrently for the same recipient', async () => {
+      // Create a slow adapter that delays the first send to simulate a race condition.
+      // Without per-recipient queuing, the second notification would arrive before the first.
+      let sendCount = 0;
+      const deliveryOrder: string[] = [];
+
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as NotificationChannel,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          sendCount++;
+          const currentSend = sendCount;
+          // First send is slow, second is fast — without queuing this would reorder
+          if (currentSend === 1) {
+            await new Promise((resolve) => setTimeout(resolve, 50));
+          }
+          deliveryOrder.push(payload.type);
+          return { success: true, notificationId: `test-${currentSend}`, channel: 'email' };
+        },
+      };
+
+      // Create a fresh service with the slow adapter
+      const testBus = new EventBus();
+      const testService = new NotificationService(testBus);
+      testService.registerAdapter(slowAdapter);
+
+      const orderCreatedEvent: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      const statusChangedEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'alice@example.com',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      // Fire both events concurrently — don't await the first before emitting the second
+      const p1 = testBus.emit(orderCreatedEvent);
+      const p2 = testBus.emit(statusChangedEvent);
+      await Promise.all([p1, p2]);
+
+      // Notifications must arrive in the order they were dispatched
+      const notifications = testService.getNotifications();
+      expect(notifications).toHaveLength(2);
+      expect(notifications[0]?.type).toBe('order_confirmation');
+      expect(notifications[1]?.type).toBe('order_status_update');
+
+      // Adapter delivery order must also be preserved
+      expect(deliveryOrder).toEqual(['order_confirmation', 'order_status_update']);
+    });
+
+    it('should not queue notifications for different recipients', async () => {
+      let sendCount = 0;
