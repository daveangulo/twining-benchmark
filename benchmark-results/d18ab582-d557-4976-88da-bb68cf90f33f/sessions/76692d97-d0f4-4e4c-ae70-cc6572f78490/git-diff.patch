+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,195 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { WebhookAdapter } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+import type { WebhookRequestOptions, WebhookResponse } from '../../src/adapters/webhook.adapter.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: 'user-123',
+    subject: 'Order Confirmed',
+    body: 'Your order has been placed.',
+    channel: 'webhook',
+    type: 'order_confirmation',
+    priority: 'normal',
+    metadata: { orderId: 'order-456' },
+    ...overrides,
+  };
+}
+
+function makeTransport(response?: Partial<WebhookResponse>) {
+  return vi.fn<[string, WebhookRequestOptions], Promise<WebhookResponse>>().mockResolvedValue({
+    ok: true,
+    status: 200,
+    ...response,
+  });
+}
+
+describe('WebhookAdapter', () => {
+  let adapter: WebhookAdapter;
+  let transport: ReturnType<typeof makeTransport>;
+
+  beforeEach(() => {
+    transport = makeTransport();
+    adapter = new WebhookAdapter({
+      url: 'https://hooks.example.com/notify',
+      transport,
+    });
+  });
+
+  describe('send', () => {
+    it('should POST notification payload as JSON to the configured URL', async () => {
+      const result = await adapter.send(makePayload());
+      expect(result.success).toBe(true);
+
+      expect(transport).toHaveBeenCalledOnce();
+      const [url, options] = transport.mock.calls[0]!;
+      expect(url).toBe('https://hooks.example.com/notify');
+      expect(options.method).toBe('POST');
+      expect(options.headers['Content-Type']).toBe('application/json');
+
+      const body = JSON.parse(options.body);
+      expect(body.event).toBe('order_confirmation');
+      expect(body.recipient).toBe('user-123');
+      expect(body.subject).toBe('Order Confirmed');
+      expect(body.body).toBe('Your order has been placed.');
+      expect(body.priority).toBe('normal');
+      expect(body.metadata).toEqual({ orderId: 'order-456' });
+      expect(body.timestamp).toBeDefined();
+    });
+
+    it('should record delivery on success', async () => {
+      await adapter.send(makePayload());
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.url).toBe('https://hooks.example.com/notify');
+      expect(deliveries[0]?.statusCode).toBe(200);
+      expect(deliveries[0]?.payload.event).toBe('order_confirmation');
+    });
+
+    it('should fail for invalid webhook URL', async () => {
+      const badAdapter = new WebhookAdapter({
+        url: 'not-a-url',
+        transport,
+      });
+      const result = await badAdapter.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid webhook URL');
+    });
+
+    it('should fail for non-HTTP URL', async () => {
+      const badAdapter = new WebhookAdapter({
+        url: 'ftp://files.example.com/hook',
+        transport,
+      });
+      const result = await badAdapter.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid webhook URL');
+    });
+
+    it('should fail when transport returns non-ok response', async () => {
+      const failTransport = makeTransport({ ok: false, status: 500 });
+      const failAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+        transport: failTransport,
+      });
+
+      const result = await failAdapter.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('status 500');
+
+      // Should still record the failed delivery
+      expect(failAdapter.getDeliveries()).toHaveLength(1);
+      expect(failAdapter.getDeliveries()[0]?.statusCode).toBe(500);
+    });
+
+    it('should handle transport errors gracefully', async () => {
+      const errorTransport = vi.fn().mockRejectedValue(new Error('Connection refused'));
+      const errorAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+        transport: errorTransport,
+      });
+
+      const result = await errorAdapter.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Connection refused');
+    });
+
+    it('should include custom headers in the request', async () => {
+      const customAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+        headers: {
+          'Authorization': 'Bearer secret-token',
+          'X-Custom-Header': 'custom-value',
+        },
+        transport,
+      });
+
+      await customAdapter.send(makePayload());
+
+      const options = transport.mock.calls[0]?.[1];
+      expect(options?.headers['Authorization']).toBe('Bearer secret-token');
+      expect(options?.headers['X-Custom-Header']).toBe('custom-value');
+      expect(options?.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should work without transport (no-op delivery)', async () => {
+      const noTransportAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+      });
+
+      const result = await noTransportAdapter.send(makePayload());
+      expect(result.success).toBe(true);
+      expect(noTransportAdapter.getDeliveries()).toHaveLength(1);
+    });
+  });
+
+  describe('formatPayload', () => {
+    it('should format notification payload into webhook body', () => {
+      const formatted = adapter.formatPayload(makePayload());
+      expect(formatted.event).toBe('order_confirmation');
+      expect(formatted.recipient).toBe('user-123');
+      expect(formatted.subject).toBe('Order Confirmed');
+      expect(formatted.body).toBe('Your order has been placed.');
+      expect(formatted.priority).toBe('normal');
+      expect(formatted.metadata).toEqual({ orderId: 'order-456' });
+      expect(formatted.timestamp).toBeDefined();
+    });
+
+    it('should handle payload without metadata', () => {
+      const formatted = adapter.formatPayload(makePayload({ metadata: undefined }));
+      expect(formatted.metadata).toBeUndefined();
+    });
+  });
+
+  describe('URL validation', () => {
+    it('should accept valid HTTP URLs', () => {
+      expect(WebhookAdapter.validateUrl('http://example.com/hook')).toBe(true);
+      expect(WebhookAdapter.validateUrl('https://hooks.example.com/notify')).toBe(true);
+      expect(WebhookAdapter.validateUrl('https://example.com:8080/webhook')).toBe(true);
+    });
+
+    it('should reject invalid URLs', () => {
+      expect(WebhookAdapter.validateUrl('not-a-url')).toBe(false);
+      expect(WebhookAdapter.validateUrl('')).toBe(false);
+      expect(WebhookAdapter.validateUrl('ftp://files.example.com')).toBe(false);
+    });
+  });
+
+  describe('getDeliveries / clearDeliveries', () => {
+    it('should track and clear deliveries', async () => {
+      await adapter.send(makePayload());
+      await adapter.send(makePayload({ type: 'system_alert' }));
+
+      expect(adapter.getDeliveries()).toHaveLength(2);
+      adapter.clearDeliveries();
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+
+    it('should return a copy of deliveries', async () => {
+      await adapter.send(makePayload());
+      const deliveries = adapter.getDeliveries();
+      deliveries.pop();
+      expect(adapter.getDeliveries()).toHaveLength(1);
+    });
+  });
+});
