+/**
+ * Email notification adapter.
+ *
+ * Implements the NotificationAdapter interface for the 'email' channel.
+ * Currently a stub that logs sends in-memory. Replace the send() body
+ * with a real email provider (SMTP, SendGrid, SES, etc.) for production use.
+ */
+
+import type { NotificationAdapter } from './notification.adapter.js';
+import type { NotificationPayload, NotificationResult } from '../models/notification.js';
+import { Logger } from '../utils/logger.js';
+
+export interface EmailConfig {
+  /** Default sender address for outgoing emails. */
+  from: string;
+  /** Provider name — for logging and diagnostics. */
+  provider: string;
+}
+
+const defaultEmailConfig: EmailConfig = {
+  from: 'noreply@taskflowpro.com',
+  provider: 'stub',
+};
+
+export class EmailAdapter implements NotificationAdapter {
+  readonly channel = 'email' as const;
+  private logger = new Logger('EmailAdapter');
+  private sentEmails: Array<{ payload: NotificationPayload; sentAt: Date }> = [];
+
+  constructor(private config: EmailConfig = defaultEmailConfig) {}
+
+  async send(payload: NotificationPayload): Promise<NotificationResult> {
+    this.logger.info(
+      `Sending email from ${this.config.from} to ${payload.recipient}: ${payload.subject}`,
+    );
+
+    // Stub implementation — stores the email in memory.
+    // Replace this with a real email provider call in production.
+    this.sentEmails.push({ payload, sentAt: new Date() });
+
+    return {
+      success: true,
+      notificationId: '', // Filled in by NotificationService
+      channel: 'email',
+    };
+  }
+
+  /**
+   * Get all sent emails (useful for testing).
+   */
+  getSentEmails(): Array<{ payload: NotificationPayload; sentAt: Date }> {
+    return [...this.sentEmails];
+  }
+
+  /**
+   * Clear sent emails (useful for testing).
+   */
+  clearSentEmails(): void {
+    this.sentEmails = [];
+  }
+}
