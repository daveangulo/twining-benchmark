+/**
+ * Notification model and related types.
+ *
+ * Defines the core notification types, channels, and payloads used
+ * throughout the notification system. All notification adapters and
+ * services operate on these types.
+ */
+
+/**
+ * Supported notification channels.
+ * Each channel corresponds to a NotificationAdapter implementation.
+ */
+export type NotificationChannel = 'email' | 'webhook' | 'in-app';
+
+/**
+ * Categories of notifications — used for routing and user preferences.
+ */
+export type NotificationType =
+  | 'order:confirmation'
+  | 'order:status-update'
+  | 'user:welcome'
+  | 'user:profile-update';
+
+/**
+ * The payload passed to notification adapters for delivery.
+ */
+export interface NotificationPayload {
+  recipient: string;
+  subject: string;
+  body: string;
+  type: NotificationType;
+  channel: NotificationChannel;
+  metadata?: Record<string, unknown>;
+}
+
+/**
+ * A sent notification record, stored for audit and retrieval.
+ */
+export interface Notification {
+  id: string;
+  recipient: string;
+  subject: string;
+  body: string;
+  type: NotificationType;
+  channel: NotificationChannel;
+  sentAt: Date;
+  metadata?: Record<string, unknown>;
+}
+
+/**
+ * Result returned by a NotificationAdapter after attempting delivery.
+ */
+export interface NotificationResult {
+  success: boolean;
+  notificationId: string;
+  channel: NotificationChannel;
+  error?: string;
+}
