diff --git a/tests/services/notification-history.service.test.ts b/tests/services/notification-history.service.test.ts
new file mode 100644
index 0000000..b6c33b5
--- /dev/null
+++ b/tests/services/notification-history.service.test.ts
@@ -0,0 +1,321 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import {
+  NotificationHistoryService,
+  resetLogIdCounter,
+} from '../../src/services/notification-history.service.js';
+import { EmailAdapter, resetEmailIdCounter } from '../../src/adapters/email.adapter.js';
+import type {
+  OrderCreatedEvent,
+  OrderStatusChangedEvent,
+  UserCreatedEvent,
+} from '../../src/events/event-types.js';
+
+describe('NotificationHistoryService', () => {
+  let eventBus: EventBus;
+  let notificationService: NotificationService;
+  let historyService: NotificationHistoryService;
+  let emailAdapter: EmailAdapter;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    notificationService = new NotificationService(eventBus);
+    historyService = new NotificationHistoryService();
+    emailAdapter = new EmailAdapter();
+    notificationService.registerAdapter(emailAdapter);
+    notificationService.setHistoryService(historyService);
+    resetNotificationIdCounter();
+    resetEmailIdCounter();
+    resetLogIdCounter();
+  });
+
+  function createOrderEvent(overrides: Partial<OrderCreatedEvent> = {}): OrderCreatedEvent {
+    return {
+      type: 'order:created',
+      order: {
+        id: 'order-1',
+        userId: 'user-1',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        total: 10,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: {
+        id: 'user-1',
+        name: 'Alice',
+        email: 'alice@example.com',
+        role: 'member',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      timestamp: new Date(),
+      ...overrides,
+    };
+  }
+
+  describe('logging', () => {
+    it('should log a notification when one is sent', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const entries = historyService.getAll();
+      expect(entries).toHaveLength(1);
+      expect(entries[0]?.id).toBe('log-0001');
+      expect(entries[0]?.notificationId).toBe('notif-0001');
+      expect(entries[0]?.recipient).toBe('alice@example.com');
+      expect(entries[0]?.channel).toBe('email');
+      expect(entries[0]?.type).toBe('order_confirmation');
+      expect(entries[0]?.status).toBe('sent');
+      expect(entries[0]?.timestamp).toBeInstanceOf(Date);
+    });
+
+    it('should log multiple notifications with sequential IDs', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const statusEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+      await eventBus.emit(statusEvent);
+
+      const entries = historyService.getAll();
+      expect(entries).toHaveLength(2);
+      expect(entries[0]?.id).toBe('log-0001');
+      expect(entries[1]?.id).toBe('log-0002');
+    });
+
+    it('should capture subject and body', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const entries = historyService.getAll();
+      expect(entries[0]?.subject).toContain('Order Confirmation');
+      expect(entries[0]?.body).toContain('Widget x1');
+    });
+
+    it('should capture metadata', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const entries = historyService.getAll();
+      expect(entries[0]?.metadata).toEqual({ userId: 'user-1' });
+    });
+
+    it('should log failed notifications', async () => {
+      // Create a service without an adapter for the channel
+      const bareService = new NotificationService(new EventBus());
+      const bareHistory = new NotificationHistoryService();
+      bareService.setHistoryService(bareHistory);
+
+      await bareService.sendNotification({
+        type: 'welcome',
+        recipient: 'test@example.com',
+        subject: 'Test',
+        body: 'Test body',
+        channel: 'sms',
+      });
+
+      const entries = bareHistory.getAll();
+      expect(entries).toHaveLength(1);
+      // No adapter for sms, but it still gets stored as 'sent' (no adapter = in-memory only)
+      expect(entries[0]?.channel).toBe('sms');
+    });
+  });
+
+  describe('query by recipient', () => {
+    it('should return entries for a specific recipient', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      await eventBus.emit(
+        createOrderEvent({
+          user: {
+            id: 'user-2',
+            name: 'Bob',
+            email: 'bob@example.com',
+            role: 'member',
+            createdAt: new Date(),
+            updatedAt: new Date(),
+          },
+        }),
+      );
+
+      const aliceEntries = historyService.getByRecipient('alice@example.com');
+      expect(aliceEntries).toHaveLength(1);
+      expect(aliceEntries[0]?.recipient).toBe('alice@example.com');
+
+      const bobEntries = historyService.getByRecipient('bob@example.com');
+      expect(bobEntries).toHaveLength(1);
+      expect(bobEntries[0]?.recipient).toBe('bob@example.com');
+    });
+
+    it('should return empty array for unknown recipient', () => {
+      const entries = historyService.getByRecipient('nobody@example.com');
+      expect(entries).toHaveLength(0);
+    });
+  });
+
+  describe('query by type', () => {
+    it('should return entries for a specific notification type', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const welcomeEvent: UserCreatedEvent = {
+        type: 'user:created',
+        user: {
+          id: 'user-2',
+          name: 'Bob',
+          email: 'bob@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+      await eventBus.emit(welcomeEvent);
+
+      const orderEntries = historyService.getByType('order_confirmation');
+      expect(orderEntries).toHaveLength(1);
+
+      const welcomeEntries = historyService.getByType('welcome');
+      expect(welcomeEntries).toHaveLength(1);
+    });
+  });
+
+  describe('query by date range', () => {
+    it('should return entries within a date range', async () => {
+      const now = new Date();
+      await eventBus.emit(createOrderEvent());
+
+      const past = new Date(now.getTime() - 60000);
+      const future = new Date(now.getTime() + 60000);
+
+      const entries = historyService.getByDateRange(past, future);
+      expect(entries).toHaveLength(1);
+    });
+
+    it('should exclude entries outside the date range', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const farPast = new Date('2020-01-01');
+      const pastEnd = new Date('2020-12-31');
+
+      const entries = historyService.getByDateRange(farPast, pastEnd);
+      expect(entries).toHaveLength(0);
+    });
+  });
+
+  describe('combined query filters', () => {
+    it('should filter by multiple criteria', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const welcomeEvent: UserCreatedEvent = {
+        type: 'user:created',
+        user: {
+          id: 'user-2',
+          name: 'Bob',
+          email: 'bob@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+      await eventBus.emit(welcomeEvent);
+
+      const results = historyService.query({
+        recipient: 'alice@example.com',
+        type: 'order_confirmation',
+      });
+      expect(results).toHaveLength(1);
+      expect(results[0]?.recipient).toBe('alice@example.com');
+      expect(results[0]?.type).toBe('order_confirmation');
+    });
+
+    it('should return empty when no match for combined filters', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const results = historyService.query({
+        recipient: 'alice@example.com',
+        type: 'welcome',
+      });
+      expect(results).toHaveLength(0);
+    });
+
+    it('should filter by channel', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      expect(historyService.query({ channel: 'email' })).toHaveLength(1);
+      expect(historyService.query({ channel: 'webhook' })).toHaveLength(0);
+    });
+  });
+
+  describe('pagination', () => {
+    it('should return paginated results', async () => {
+      // Send 3 notifications
+      await eventBus.emit(createOrderEvent());
+      await eventBus.emit(createOrderEvent());
+      await eventBus.emit(createOrderEvent());
+
+      const page1 = historyService.queryPaginated({}, 1, 2);
+      expect(page1.items).toHaveLength(2);
+      expect(page1.totalItems).toBe(3);
+      expect(page1.totalPages).toBe(2);
+      expect(page1.hasNext).toBe(true);
+      expect(page1.hasPrevious).toBe(false);
+
+      const page2 = historyService.queryPaginated({}, 2, 2);
+      expect(page2.items).toHaveLength(1);
+      expect(page2.hasNext).toBe(false);
+      expect(page2.hasPrevious).toBe(true);
+    });
+
+    it('should apply filters before pagination', async () => {
+      await eventBus.emit(createOrderEvent());
+
+      const welcomeEvent: UserCreatedEvent = {
+        type: 'user:created',
+        user: {
+          id: 'user-2',
+          name: 'Bob',
+          email: 'bob@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+      await eventBus.emit(welcomeEvent);
+
+      const result = historyService.queryPaginated({ type: 'welcome' }, 1, 10);
+      expect(result.totalItems).toBe(1);
+      expect(result.items[0]?.type).toBe('welcome');
+    });
+  });
+
+  describe('management', () => {
+    it('should return count', async () => {
+      expect(historyService.getCount()).toBe(0);
+      await eventBus.emit(createOrderEvent());
+      expect(historyService.getCount()).toBe(1);
+    });
+
+    it('should clear all entries', async () => {
+      await eventBus.emit(createOrderEvent());
+      expect(historyService.getCount()).toBe(1);
+      historyService.clear();
+      expect(historyService.getCount()).toBe(0);
+    });
+  });
+});
