diff --git a/tests/adapters/sms.adapter.test.ts b/tests/adapters/sms.adapter.test.ts
new file mode 100644
index 0000000..05fd841
--- /dev/null
+++ b/tests/adapters/sms.adapter.test.ts
@@ -0,0 +1,232 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { SmsAdapter } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides: Partial<NotificationPayload> = {}): NotificationPayload {
+  return {
+    recipient: '+15551234567',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    type: 'order:confirmation',
+    channel: 'sms',
+    ...overrides,
+  };
+}
+
+describe('SmsAdapter', () => {
+  let adapter: SmsAdapter;
+
+  beforeEach(() => {
+    adapter = new SmsAdapter();
+  });
+
+  describe('channel', () => {
+    it('should report sms as its channel', () => {
+      expect(adapter.channel).toBe('sms');
+    });
+  });
+
+  describe('send', () => {
+    it('should send an SMS successfully', async () => {
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('sms');
+      expect(result.error).toBeUndefined();
+    });
+
+    it('should store sent messages for retrieval', async () => {
+      await adapter.send(makePayload());
+
+      const sent = adapter.getSentMessages();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]!.message.to).toBe('+15551234567');
+      expect(sent[0]!.message.from).toBe('+10000000000');
+      expect(sent[0]!.message.body).toContain('Order Confirmation');
+      expect(sent[0]!.sentAt).toBeInstanceOf(Date);
+      expect(sent[0]!.attempts).toBe(1);
+    });
+
+    it('should reject invalid phone numbers', async () => {
+      const result = await adapter.send(makePayload({ recipient: 'not-a-phone' }));
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid recipient phone number');
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should reject empty recipient', async () => {
+      const result = await adapter.send(makePayload({ recipient: '' }));
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid recipient phone number');
+    });
+
+    it('should reject phone numbers without + prefix', async () => {
+      const result = await adapter.send(makePayload({ recipient: '15551234567' }));
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid recipient phone number');
+    });
+
+    it('should use custom config when provided', async () => {
+      const customAdapter = new SmsAdapter({
+        fromNumber: '+18005551234',
+        provider: 'twilio',
+      });
+
+      await customAdapter.send(makePayload());
+
+      const sent = customAdapter.getSentMessages();
+      expect(sent[0]!.message.from).toBe('+18005551234');
+      expect(customAdapter.getConfig().provider).toBe('twilio');
+    });
+  });
+
+  describe('message formatting', () => {
+    it('should format order:confirmation messages', async () => {
+      await adapter.send(makePayload({ type: 'order:confirmation' }));
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.message.body).toContain('TaskFlow Pro');
+      expect(sent[0]!.message.body).toContain('Order Confirmation');
+    });
+
+    it('should format order:status-update messages', async () => {
+      await adapter.send(
+        makePayload({
+          type: 'order:status-update',
+          subject: 'Order Update: order-1',
+          body: 'Your order status has changed from pending to confirmed.',
+        }),
+      );
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.message.body).toContain('TaskFlow Pro');
+      expect(sent[0]!.message.body).toContain('Order Update');
+    });
+
+    it('should format user:welcome messages', async () => {
+      await adapter.send(
+        makePayload({
+          type: 'user:welcome',
+          subject: 'Welcome!',
+          body: 'Welcome to TaskFlow Pro!',
+        }),
+      );
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.message.body).toContain('Welcome to TaskFlow Pro');
+    });
+
+    it('should format user:profile-update messages', async () => {
+      await adapter.send(
+        makePayload({
+          type: 'user:profile-update',
+          subject: 'Profile Updated',
+          body: 'Your profile has been updated.',
+        }),
+      );
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.message.body).toContain('TaskFlow Pro');
+      expect(sent[0]!.message.body).toContain('Profile Updated');
+    });
+
+    it('should truncate messages exceeding max length', async () => {
+      const longBody = 'A'.repeat(200);
+      await adapter.send(makePayload({ body: longBody }));
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.message.body.length).toBeLessThanOrEqual(160);
+      expect(sent[0]!.message.body).toMatch(/\.\.\.$/);
+    });
+
+    it('should respect custom max length', async () => {
+      const shortAdapter = new SmsAdapter({ maxLength: 50 });
+      const longBody = 'A'.repeat(200);
+      await shortAdapter.send(makePayload({ body: longBody }));
+
+      const sent = shortAdapter.getSentMessages();
+      expect(sent[0]!.message.body.length).toBeLessThanOrEqual(50);
+      expect(sent[0]!.message.body).toMatch(/\.\.\.$/);
+    });
+  });
+
+  describe('formatMessage', () => {
+    it('should produce an SmsMessage from a payload', () => {
+      const message = adapter.formatMessage(makePayload());
+
+      expect(message.from).toBe('+10000000000');
+      expect(message.to).toBe('+15551234567');
+      expect(message.body).toContain('Order Confirmation');
+      expect(message.type).toBe('order:confirmation');
+    });
+
+    it('should include metadata when present', () => {
+      const message = adapter.formatMessage(
+        makePayload({ metadata: { orderId: 'order-1' } }),
+      );
+
+      expect(message.metadata).toEqual({ orderId: 'order-1' });
+    });
+  });
+
+  describe('retry behavior', () => {
+    it('should retry on transport failure and succeed', async () => {
+      let callCount = 0;
+      class FailOnceAdapter extends SmsAdapter {
+        protected async transport(): Promise<void> {
+          callCount++;
+          if (callCount === 1) {
+            throw new Error('Transient SMS gateway error');
+          }
+        }
+      }
+
+      const retryAdapter = new FailOnceAdapter({ maxRetries: 3 });
+      const result = await retryAdapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(callCount).toBe(2);
+      expect(retryAdapter.getSentMessages()[0]!.attempts).toBe(2);
+    });
+
+    it('should fail after exhausting retries', async () => {
+      class AlwaysFailAdapter extends SmsAdapter {
+        protected async transport(): Promise<void> {
+          throw new Error('SMS gateway down');
+        }
+      }
+
+      const failAdapter = new AlwaysFailAdapter({ maxRetries: 2 });
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Delivery failed after 2 attempts');
+      expect(result.error).toContain('SMS gateway down');
+      expect(failAdapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+
+  describe('clearSentMessages', () => {
+    it('should clear all sent messages', async () => {
+      await adapter.send(makePayload());
+      await adapter.send(makePayload({ recipient: '+15559876543' }));
+      expect(adapter.getSentMessages()).toHaveLength(2);
+
+      adapter.clearSentMessages();
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+
+  describe('getConfig', () => {
+    it('should return a copy of the config', () => {
+      const config = adapter.getConfig();
+      expect(config.fromNumber).toBe('+10000000000');
+      expect(config.provider).toBe('in-memory');
+      expect(config.maxRetries).toBe(3);
+      expect(config.maxLength).toBe(160);
+    });
+  });
+});
