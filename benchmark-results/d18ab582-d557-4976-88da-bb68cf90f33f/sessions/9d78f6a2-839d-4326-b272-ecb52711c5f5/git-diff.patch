+
+  describe('notification delivery ordering', () => {
+    it('should deliver notifications in order even when emitted concurrently', async () => {
+      // Use a slow transport for the first notification to simulate a race condition.
+      // Without the delivery queue, the second (fast) notification would complete
+      // before the first (slow) one, causing out-of-order delivery.
+      const deliveryLog: string[] = [];
+      let callCount = 0;
+
+      const slowTransport: EmailTransport = {
+        async sendMail(message: EmailMessage) {
+          callCount++;
+          const delay = callCount === 1 ? 50 : 5;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryLog.push(message.subject);
+          return { success: true };
+        },
+      };
+
+      const freshBus = new EventBus();
+      const freshService = new NotificationService(freshBus);
+      const slowEmailAdapter = new EmailAdapter({ transport: slowTransport });
+      freshService.registerAdapter(slowEmailAdapter);
+
+      const orderCreatedEvent: NotificationSendEvent = {
+        type: 'notification:send',
+        payload: {
+          type: 'order:confirmation',
+          recipient: 'alice@example.com',
+          subject: 'Order Placed',
+          body: 'Your order has been placed.',
+          metadata: { orderId: 'order-1' },
+        },
+        channels: ['email'],
+        timestamp: new Date(),
+      };
+
+      const paymentConfirmedEvent: NotificationSendEvent = {
+        type: 'notification:send',
+        payload: {
+          type: 'order:status-update',
+          recipient: 'alice@example.com',
+          subject: 'Payment Confirmed',
+          body: 'Your payment has been confirmed.',
+          metadata: { orderId: 'order-1', newStatus: 'confirmed' },
+        },
+        channels: ['email'],
+        timestamp: new Date(),
+      };
+
+      // Emit both without awaiting — simulates concurrent requests
+      const p1 = freshBus.emit(orderCreatedEvent);
+      const p2 = freshBus.emit(paymentConfirmedEvent);
+      await Promise.all([p1, p2]);
+
+      // Notifications must arrive in the order they were emitted
+      expect(deliveryLog).toEqual(['Order Placed', 'Payment Confirmed']);
+
+      const notifications = freshService.getNotifications();
+      expect(notifications).toHaveLength(2);
+      expect(notifications[0]?.subject).toBe('Order Placed');
+      expect(notifications[1]?.subject).toBe('Payment Confirmed');
+    });
+  });
 });
