+/**
+ * Notification log model — tracks sent notification history.
+ *
+ * Each log entry captures the outcome of a notification dispatch,
+ * including recipient, channel, type, delivery status, and timestamps.
+ */
+
+import type { NotificationType, NotificationChannel } from './notification.js';
+
+/**
+ * Delivery status of a logged notification.
+ */
+export type DeliveryStatus = 'sent' | 'failed';
+
+/**
+ * A persisted record of a notification that was dispatched.
+ */
+export interface NotificationLog {
+  id: string;
+  notificationId: string;
+  recipient: string;
+  channel: NotificationChannel;
+  type: NotificationType;
+  subject: string;
+  status: DeliveryStatus;
+  error?: string;
+  metadata: Record<string, unknown>;
+  createdAt: Date;
+  deliveredAt?: Date;
+}
+
+/**
+ * Query filters for searching notification history.
+ */
+export interface NotificationHistoryQuery {
+  recipient?: string;
+  type?: NotificationType;
+  channel?: NotificationChannel;
+  status?: DeliveryStatus;
+  startDate?: Date;
+  endDate?: Date;
+}
diff --git a/src/repositories/notification-log.repository.ts b/src/repositories/notification-log.repository.ts
