diff --git a/tests/adapters/webhook.adapter.test.ts b/tests/adapters/webhook.adapter.test.ts
new file mode 100644
index 0000000..a7a38e7
--- /dev/null
+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,221 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import {
+  WebhookAdapter,
+  InMemoryWebhookTransport,
+  resetWebhookIdCounter,
+} from '../../src/adapters/webhook.adapter.js';
+import type {
+  WebhookTransport,
+  WebhookPayload,
+} from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+const WEBHOOK_URL = 'https://hooks.example.com/notify';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    type: 'order_confirmation',
+    recipient: 'alice@example.com',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    channel: 'webhook',
+    ...overrides,
+  };
+}
+
+describe('WebhookAdapter', () => {
+  let adapter: WebhookAdapter;
+
+  beforeEach(() => {
+    adapter = new WebhookAdapter({ url: WEBHOOK_URL });
+    resetWebhookIdCounter();
+  });
+
+  describe('send', () => {
+    it('should send a webhook and return success', async () => {
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('webhook');
+      expect(result.notificationId).toBe('webhook-0001');
+    });
+
+    it('should store delivered webhooks for inspection', async () => {
+      await adapter.send(makePayload());
+
+      const delivered = adapter.getDeliveredWebhooks();
+      expect(delivered).toHaveLength(1);
+      expect(delivered[0]?.url).toBe(WEBHOOK_URL);
+      expect(delivered[0]?.payload.event).toBe('order_confirmation');
+      expect(delivered[0]?.payload.recipient).toBe('alice@example.com');
+      expect(delivered[0]?.payload.subject).toBe('Order Confirmation: order-1');
+      expect(delivered[0]?.statusCode).toBe(200);
+    });
+
+    it('should generate sequential webhook IDs', async () => {
+      const r1 = await adapter.send(makePayload());
+      const r2 = await adapter.send(makePayload({ recipient: 'bob@example.com' }));
+
+      expect(r1.notificationId).toBe('webhook-0001');
+      expect(r2.notificationId).toBe('webhook-0002');
+    });
+
+    it('should clear delivered webhooks', async () => {
+      await adapter.send(makePayload());
+      adapter.clearDeliveredWebhooks();
+      expect(adapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+
+    it('should include metadata in webhook payload', async () => {
+      await adapter.send(makePayload({ metadata: { orderId: 'order-42', userId: 'user-1' } }));
+
+      const delivered = adapter.getDeliveredWebhooks();
+      expect(delivered[0]?.payload.metadata).toEqual({ orderId: 'order-42', userId: 'user-1' });
+    });
+
+    it('should include a timestamp in webhook payload', async () => {
+      await adapter.send(makePayload());
+
+      const delivered = adapter.getDeliveredWebhooks();
+      expect(delivered[0]?.payload.timestamp).toBeTruthy();
+      expect(() => new Date(delivered[0]!.payload.timestamp)).not.toThrow();
+    });
+  });
+
+  describe('error handling', () => {
+    it('should fail when webhook returns non-2xx status', async () => {
+      const transport: WebhookTransport = {
+        post: vi.fn().mockResolvedValue({ statusCode: 500 }),
+      };
+
+      const errorAdapter = new WebhookAdapter({ url: WEBHOOK_URL, transport });
+      resetWebhookIdCounter();
+
+      const result = await errorAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('status 500');
+      expect(errorAdapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+
+    it('should fail on 404 status', async () => {
+      const transport: WebhookTransport = {
+        post: vi.fn().mockResolvedValue({ statusCode: 404 }),
+      };
+
+      const errorAdapter = new WebhookAdapter({ url: WEBHOOK_URL, transport });
+
+      const result = await errorAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('status 404');
+    });
+
+    it('should handle transport errors gracefully', async () => {
+      const transport: WebhookTransport = {
+        post: vi.fn().mockRejectedValue(new Error('Connection refused')),
+      };
+
+      const errorAdapter = new WebhookAdapter({ url: WEBHOOK_URL, transport });
+
+      const result = await errorAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Connection refused');
+      expect(errorAdapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+
+    it('should handle non-Error transport throws', async () => {
+      const transport: WebhookTransport = {
+        post: vi.fn().mockRejectedValue('string error'),
+      };
+
+      const errorAdapter = new WebhookAdapter({ url: WEBHOOK_URL, transport });
+      const result = await errorAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('string error');
+    });
+  });
+
+  describe('transport', () => {
+    it('should use a custom transport', async () => {
+      const post = vi.fn().mockResolvedValue({ statusCode: 201 });
+      const transport: WebhookTransport = { post };
+
+      const customAdapter = new WebhookAdapter({ url: WEBHOOK_URL, transport });
+      resetWebhookIdCounter();
+
+      await customAdapter.send(makePayload());
+
+      expect(post).toHaveBeenCalledOnce();
+      expect(post).toHaveBeenCalledWith(
+        WEBHOOK_URL,
+        expect.objectContaining({
+          event: 'order_confirmation',
+          recipient: 'alice@example.com',
+          subject: 'Order Confirmation: order-1',
+        }),
+      );
+    });
+
+    it('should pass the configured URL to the transport', async () => {
+      const post = vi.fn().mockResolvedValue({ statusCode: 200 });
+      const customUrl = 'https://other.example.com/webhook';
+
+      const customAdapter = new WebhookAdapter({ url: customUrl, transport: { post } });
+      await customAdapter.send(makePayload());
+
+      expect(post).toHaveBeenCalledWith(customUrl, expect.any(Object));
+    });
+  });
+});
+
+describe('InMemoryWebhookTransport', () => {
+  it('should store deliveries', async () => {
+    const transport = new InMemoryWebhookTransport();
+    const body: WebhookPayload = {
+      event: 'test',
+      recipient: 'a@b.com',
+      subject: 's',
+      body: 'b',
+      timestamp: new Date().toISOString(),
+    };
+
+    await transport.post('https://example.com', body);
+
+    const deliveries = transport.getDeliveries();
+    expect(deliveries).toHaveLength(1);
+    expect(deliveries[0]?.url).toBe('https://example.com');
+    expect(deliveries[0]?.body.event).toBe('test');
+  });
+
+  it('should return 200 status code', async () => {
+    const transport = new InMemoryWebhookTransport();
+    const body: WebhookPayload = {
+      event: 'test',
+      recipient: 'a@b.com',
+      subject: 's',
+      body: 'b',
+      timestamp: new Date().toISOString(),
+    };
+
+    const result = await transport.post('https://example.com', body);
+    expect(result.statusCode).toBe(200);
+  });
+
+  it('should clear deliveries', async () => {
+    const transport = new InMemoryWebhookTransport();
+    const body: WebhookPayload = {
+      event: 'test',
+      recipient: 'a@b.com',
+      subject: 's',
+      body: 'b',
+      timestamp: new Date().toISOString(),
+    };
+
+    await transport.post('https://example.com', body);
+    transport.clearDeliveries();
+    expect(transport.getDeliveries()).toHaveLength(0);
+  });
+});
