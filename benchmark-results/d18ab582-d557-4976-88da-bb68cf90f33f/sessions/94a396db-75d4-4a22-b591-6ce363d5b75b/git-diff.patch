diff --git a/src/validators/email.validator.ts b/src/validators/email.validator.ts
new file mode 100644
index 0000000..557b471
--- /dev/null
+++ b/src/validators/email.validator.ts
@@ -0,0 +1,27 @@
+/**
+ * Pure validation functions for email addresses.
+ *
+ * These validators contain no side effects and no database calls.
+ * Shared across services and adapters that need email validation.
+ */
+
+const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
+
+/**
+ * Check whether a string is a valid email address.
+ */
+export function isValidEmail(email: string): boolean {
+  return EMAIL_REGEX.test(email.trim().toLowerCase());
+}
+
+/**
+ * Validate and normalize an email address.
+ * Returns the trimmed, lowercased address if valid, or null if invalid.
+ */
+export function normalizeEmail(email: string): string | null {
+  const trimmed = email.trim().toLowerCase();
+  if (!EMAIL_REGEX.test(trimmed)) {
+    return null;
+  }
+  return trimmed;
+}
diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..56cfb3f
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,53 @@
+/**
+ * Pure validation functions for order operations.
+ *
+ * These validators contain no side effects and no database calls.
+ * They can be reused across services that need order validation logic.
+ */
+
+import type { CreateOrderInput, OrderStatus } from '../models/order.js';
+
+/**
+ * Valid status transitions for the order lifecycle.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Validate that a create-order input has at least one item.
+ * Throws if validation fails.
+ */
+export function validateCreateOrderInput(input: CreateOrderInput): void {
+  if (input.items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Check whether a status transition is allowed in the order lifecycle.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate a status transition, throwing if it is not allowed.
+ */
+export function validateStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(
+      `Invalid status transition: ${from} -> ${to}`,
+    );
+  }
+}
diff --git a/tests/validators/email.validator.test.ts b/tests/validators/email.validator.test.ts
new file mode 100644
index 0000000..c75237e
--- /dev/null
+++ b/tests/validators/email.validator.test.ts
@@ -0,0 +1,43 @@
+import { describe, it, expect } from 'vitest';
+import { isValidEmail, normalizeEmail } from '../../src/validators/email.validator.js';
+
+describe('email.validator', () => {
+  describe('isValidEmail', () => {
+    it('should accept valid email addresses', () => {
+      expect(isValidEmail('alice@example.com')).toBe(true);
+      expect(isValidEmail('bob.smith@company.co.uk')).toBe(true);
+      expect(isValidEmail('user+tag@domain.org')).toBe(true);
+    });
+
+    it('should reject invalid email addresses', () => {
+      expect(isValidEmail('')).toBe(false);
+      expect(isValidEmail('not-an-email')).toBe(false);
+      expect(isValidEmail('@missing-local.com')).toBe(false);
+      expect(isValidEmail('missing-domain@')).toBe(false);
+      expect(isValidEmail('spaces in@email.com')).toBe(false);
+    });
+
+    it('should handle whitespace by trimming', () => {
+      expect(isValidEmail('  alice@example.com  ')).toBe(true);
+    });
+
+    it('should handle case-insensitively', () => {
+      expect(isValidEmail('Alice@Example.COM')).toBe(true);
+    });
+  });
+
+  describe('normalizeEmail', () => {
+    it('should return lowercase trimmed email for valid address', () => {
+      expect(normalizeEmail('  Alice@Example.COM  ')).toBe('alice@example.com');
+    });
+
+    it('should return null for invalid address', () => {
+      expect(normalizeEmail('not-an-email')).toBeNull();
+      expect(normalizeEmail('')).toBeNull();
+    });
+
+    it('should normalize a standard email', () => {
+      expect(normalizeEmail('user@domain.com')).toBe('user@domain.com');
+    });
+  });
+});
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..bee00c7
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,87 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateCreateOrderInput,
+  isValidStatusTransition,
+  validateStatusTransition,
+} from '../../src/validators/order.validator.js';
+
+describe('order.validator', () => {
+  describe('validateCreateOrderInput', () => {
+    it('should pass for valid input with items', () => {
+      expect(() =>
+        validateCreateOrderInput({
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        }),
+      ).not.toThrow();
+    });
+
+    it('should throw for empty items', () => {
+      expect(() =>
+        validateCreateOrderInput({ userId: 'user-1', items: [] }),
+      ).toThrow('Order must have at least one item');
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject pending -> shipped', () => {
+      expect(isValidStatusTransition('pending', 'shipped')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(isValidStatusTransition('delivered', 'pending')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'confirmed')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'shipped')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'cancelled')).toBe(false);
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(isValidStatusTransition('cancelled', 'pending')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'confirmed')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'shipped')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'delivered')).toBe(false);
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transition', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transition', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+
+    it('should throw for transition from terminal state', () => {
+      expect(() => validateStatusTransition('cancelled', 'confirmed')).toThrow(
+        'Invalid status transition: cancelled -> confirmed',
+      );
+    });
+  });
+});
