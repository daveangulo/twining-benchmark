+import { describe, it, expect } from 'vitest';
+import {
+  validateEmailUniqueness,
+  validateEmailNotTaken,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const makeUser = (overrides: Partial<User> = {}): User => ({
+  id: 'user-0001',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+  ...overrides,
+});
+
+describe('User Validators', () => {
+  describe('validateEmailUniqueness', () => {
+    it('should pass when no existing user has the email', () => {
+      expect(() => validateEmailUniqueness('new@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when a user already has the email', () => {
+      const existing = makeUser({ email: 'alice@example.com' });
+      expect(() => validateEmailUniqueness('alice@example.com', existing)).toThrow(
+        'User with email alice@example.com already exists',
+      );
+    });
+  });
+
+  describe('validateEmailNotTaken', () => {
+    it('should pass when no existing user has the email', () => {
+      expect(() => validateEmailNotTaken('new@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when the email is already in use', () => {
+      const existing = makeUser({ email: 'taken@example.com' });
+      expect(() => validateEmailNotTaken('taken@example.com', existing)).toThrow(
+        'Email taken@example.com is already in use',
+      );
+    });
+  });
+});
