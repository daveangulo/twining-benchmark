diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..35fc64c
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,62 @@
+/**
+ * Order validation — pure functions for validating order-related inputs.
+ *
+ * These validators have no side effects and no database calls.
+ * Services call these after performing any necessary lookups.
+ */
+
+import type { Order, OrderItem, OrderStatus } from '../models/order.js';
+
+/**
+ * Valid status transitions for the order lifecycle.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Validate that an order exists. Throws if the order is undefined.
+ */
+export function validateOrderExists(
+  order: Order | undefined,
+  orderId: string,
+): asserts order is Order {
+  if (!order) {
+    throw new Error(`Order not found: ${orderId}`);
+  }
+}
+
+/**
+ * Validate that an order has at least one item.
+ */
+export function validateOrderHasItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate that a status transition is allowed. Throws if not.
+ */
+export function validateStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(`Invalid status transition: ${from} -> ${to}`);
+  }
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..4e8deb1
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,46 @@
+/**
+ * User validation — pure functions for validating user-related inputs.
+ *
+ * These validators have no side effects and no database calls.
+ * Services call these after performing any necessary lookups.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that a user exists. Throws if the user is undefined.
+ */
+export function validateUserExists(
+  user: User | undefined,
+  userId: string,
+): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${userId}`);
+  }
+}
+
+/**
+ * Validate that an email is not already taken by another user.
+ * Pass the result of a findByEmail lookup as `existingUser`.
+ */
+export function validateEmailNotTaken(
+  existingUser: User | undefined,
+  email: string,
+): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not in use by another user during an update.
+ * Pass the result of a findByEmail lookup as `existingUser`.
+ */
+export function validateEmailNotInUse(
+  existingUser: User | undefined,
+  email: string,
+): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..1f56af8
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,103 @@
+import { describe, it, expect } from 'vitest';
+import type { Order, OrderStatus } from '../../src/models/order.js';
+import {
+  validateOrderExists,
+  validateOrderHasItems,
+  isValidStatusTransition,
+  validateStatusTransition,
+} from '../../src/validators/order.validator.js';
+
+const mockOrder: Order = {
+  id: 'order-0001',
+  userId: 'user-0001',
+  items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+  total: 20,
+  status: 'pending',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+};
+
+describe('order.validator', () => {
+  describe('validateOrderExists', () => {
+    it('should not throw when order exists', () => {
+      expect(() => validateOrderExists(mockOrder, 'order-0001')).not.toThrow();
+    });
+
+    it('should throw when order is undefined', () => {
+      expect(() => validateOrderExists(undefined, 'order-9999')).toThrow(
+        'Order not found: order-9999',
+      );
+    });
+  });
+
+  describe('validateOrderHasItems', () => {
+    it('should not throw when items are present', () => {
+      expect(() =>
+        validateOrderHasItems([
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+        ]),
+      ).not.toThrow();
+    });
+
+    it('should throw when items array is empty', () => {
+      expect(() => validateOrderHasItems([])).toThrow(
+        'Order must have at least one item',
+      );
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    const validTransitions: [OrderStatus, OrderStatus][] = [
+      ['pending', 'confirmed'],
+      ['pending', 'cancelled'],
+      ['confirmed', 'shipped'],
+      ['confirmed', 'cancelled'],
+      ['shipped', 'delivered'],
+    ];
+
+    const invalidTransitions: [OrderStatus, OrderStatus][] = [
+      ['pending', 'shipped'],
+      ['pending', 'delivered'],
+      ['confirmed', 'pending'],
+      ['confirmed', 'delivered'],
+      ['shipped', 'pending'],
+      ['shipped', 'cancelled'],
+      ['delivered', 'pending'],
+      ['delivered', 'cancelled'],
+      ['cancelled', 'pending'],
+      ['cancelled', 'confirmed'],
+    ];
+
+    it.each(validTransitions)(
+      'should return true for %s -> %s',
+      (from, to) => {
+        expect(isValidStatusTransition(from, to)).toBe(true);
+      },
+    );
+
+    it.each(invalidTransitions)(
+      'should return false for %s -> %s',
+      (from, to) => {
+        expect(isValidStatusTransition(from, to)).toBe(false);
+      },
+    );
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transition', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transition', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+
+    it('should throw for transition from terminal state', () => {
+      expect(() => validateStatusTransition('cancelled', 'confirmed')).toThrow(
+        'Invalid status transition: cancelled -> confirmed',
+      );
+    });
+  });
+});
