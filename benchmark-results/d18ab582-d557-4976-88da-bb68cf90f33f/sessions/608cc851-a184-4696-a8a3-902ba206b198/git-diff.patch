+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  EmailAdapter,
+  InMemoryTransport,
+} from '../../src/adapters/email.adapter.js';
+import type {
+  EmailTransport,
+  EmailMessage,
+} from '../../src/adapters/email.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+describe('EmailAdapter', () => {
+  let adapter: EmailAdapter;
+  let transport: InMemoryTransport;
+
+  beforeEach(() => {
+    transport = new InMemoryTransport();
+    adapter = new EmailAdapter({ transport });
+  });
+
+  describe('send', () => {
+    it('should send an order confirmation email with rendered template', async () => {
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'alice@example.com',
+        subject: 'Order Confirmation: order-1',
+        body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+        metadata: { orderId: 'order-1', userId: 'user-1' },
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('email');
+
+      const messages = transport.getMessages();
+      expect(messages).toHaveLength(1);
+      expect(messages[0]?.to).toBe('alice@example.com');
+      expect(messages[0]?.from).toBe('noreply@taskflowpro.com');
+      expect(messages[0]?.html).toContain('<h1>Order Confirmation</h1>');
+      expect(messages[0]?.html).toContain('order-1');
+      expect(messages[0]?.text).toContain('Order Confirmation');
+    });
+
+    it('should send an order status update email', async () => {
+      const payload: NotificationPayload = {
+        type: 'order:status-update',
+        recipient: 'alice@example.com',
+        subject: 'Order Update: order-1',
+        body: 'Your order status has changed from pending to confirmed.',
+        metadata: { orderId: 'order-1', previousStatus: 'pending', newStatus: 'confirmed' },
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const messages = transport.getMessages();
+      expect(messages[0]?.html).toContain('<h1>Order Update</h1>');
+      expect(messages[0]?.html).toContain('confirmed');
+      expect(messages[0]?.text).toContain('Order Update');
+    });
+
+    it('should send a welcome email', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'bob@example.com',
+        subject: 'Welcome!',
+        body: 'Welcome to TaskFlow Pro.',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const messages = transport.getMessages();
+      expect(messages[0]?.html).toContain('Welcome to TaskFlow Pro!');
+      expect(messages[0]?.text).toContain('Get started by creating your first order.');
+    });
+
+    it('should send a profile updated email', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:profile-updated',
+        recipient: 'carol@example.com',
+        subject: 'Profile Updated',
+        body: 'Your profile has been updated.',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const messages = transport.getMessages();
+      expect(messages[0]?.html).toContain('<h1>Profile Updated</h1>');
+    });
+
+    it('should track sent emails via getSentEmails()', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'alice@example.com',
+        subject: 'Welcome!',
+        body: 'Welcome to TaskFlow Pro.',
+      };
+
+      await adapter.send(payload);
+
+      const sent = adapter.getSentEmails();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.to).toBe('alice@example.com');
+      expect(sent[0]?.subject).toBe('Welcome!');
+    });
+  });
+
+  describe('recipient resolution', () => {
+    it('should reject empty recipient', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: '',
+        subject: 'Welcome!',
+        body: 'Welcome to TaskFlow Pro.',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('empty');
+      expect(transport.getMessages()).toHaveLength(0);
+    });
+
+    it('should reject invalid email format', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'not-an-email',
+        subject: 'Welcome!',
+        body: 'Welcome to TaskFlow Pro.',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid email address');
+      expect(transport.getMessages()).toHaveLength(0);
+    });
+
+    it('should trim whitespace from recipient', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: '  alice@example.com  ',
+        subject: 'Welcome!',
+        body: 'Welcome to TaskFlow Pro.',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(transport.getMessages()[0]?.to).toBe('alice@example.com');
+    });
+  });
+
+  describe('transport error handling', () => {
+    it('should return failed result when transport fails', async () => {
+      const failingTransport: EmailTransport = {
+        async sendMail(): Promise<{ success: boolean; error?: string }> {
+          return { success: false, error: 'SMTP connection refused' };
+        },
+      };
+
+      const failAdapter = new EmailAdapter({ transport: failingTransport });
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'alice@example.com',
+        subject: 'Welcome!',
+        body: 'Welcome to TaskFlow Pro.',
+      };
+
+      const result = await failAdapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('SMTP connection refused');
+      expect(failAdapter.getSentEmails()).toHaveLength(0);
+    });
+
+    it('should catch transport exceptions and return failed result', async () => {
+      const throwingTransport: EmailTransport = {
+        async sendMail(): Promise<{ success: boolean; error?: string }> {
+          throw new Error('Network timeout');
+        },
+      };
+
+      const throwAdapter = new EmailAdapter({ transport: throwingTransport });
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'alice@example.com',
+        subject: 'Welcome!',
+        body: 'Welcome to TaskFlow Pro.',
+      };
+
+      const result = await throwAdapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Network timeout');
+    });
+  });
+
+  describe('configuration', () => {
+    it('should use custom from address', async () => {
+      const customAdapter = new EmailAdapter({
+        defaultFrom: 'support@taskflowpro.com',
+        transport,
+      });
+
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'alice@example.com',
+        subject: 'Welcome!',
+        body: 'Welcome.',
+      };
+
+      await customAdapter.send(payload);
+
+      expect(transport.getMessages()[0]?.from).toBe('support@taskflowpro.com');
+    });
+
+    it('should use InMemoryTransport by default', () => {
+      const defaultAdapter = new EmailAdapter();
+      expect(defaultAdapter.getTransport()).toBeInstanceOf(InMemoryTransport);
+    });
+  });
+
+  describe('clearSentEmails', () => {
+    it('should clear sent email history', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'alice@example.com',
+        subject: 'Welcome!',
+        body: 'Welcome.',
+      };
+
+      await adapter.send(payload);
+      expect(adapter.getSentEmails()).toHaveLength(1);
+
+      adapter.clearSentEmails();
+      expect(adapter.getSentEmails()).toHaveLength(0);
+    });
+  });
+
+  describe('InMemoryTransport', () => {
+    it('should store and return messages', async () => {
+      const msg: EmailMessage = {
+        from: 'a@b.com',
+        to: 'c@d.com',
+        subject: 'Test',
+        html: '<p>Test</p>',
+        text: 'Test',
+        sentAt: new Date(),
+      };
+
+      const result = await transport.sendMail(msg);
+
+      expect(result.success).toBe(true);
+      expect(transport.getMessages()).toHaveLength(1);
+      expect(transport.getMessages()[0]?.to).toBe('c@d.com');
+    });
+
+    it('should clear messages', async () => {
+      const msg: EmailMessage = {
+        from: 'a@b.com',
+        to: 'c@d.com',
+        subject: 'Test',
+        html: '<p>Test</p>',
+        text: 'Test',
+        sentAt: new Date(),
+      };
+
+      await transport.sendMail(msg);
+      transport.clear();
+      expect(transport.getMessages()).toHaveLength(0);
+    });
+  });
+});
