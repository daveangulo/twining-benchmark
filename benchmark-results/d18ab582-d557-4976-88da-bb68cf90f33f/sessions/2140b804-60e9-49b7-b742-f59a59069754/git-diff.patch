+  describe('notification ordering', () => {
+    it('should deliver notifications in order even when adapter has variable latency', async () => {
+      // Simulate an adapter where the first call is slow and the second is fast.
+      // Without ordering guarantees, the second notification would arrive first.
+      let callCount = 0;
+      const deliveryOrder: string[] = [];
+
+      const slowThenFastAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          callCount++;
+          const delay = callCount === 1 ? 50 : 5;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.type);
+          return {
+            success: true,
+            notificationId: payload.id,
+            channel: payload.channel,
+            deliveredAt: new Date(),
+          };
+        },
+      };
+
+      service.registerAdapter(slowThenFastAdapter);
+
+      const orderCreatedEvent: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      const statusChangedEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      // Emit both events concurrently (no await between them)
+      const [, statusResult] = await Promise.all([
+        eventBus.emit(orderCreatedEvent),
+        eventBus.emit(statusChangedEvent),
+      ]);
+
+      // Wait for both to complete
+      await statusResult;
+
+      // Notifications must be delivered in emission order, not completion order
+      expect(deliveryOrder).toEqual(['order-confirmation', 'order-status-update']);
+
+      const notifications = service.getNotifications();
+      expect(notifications).toHaveLength(2);
+      expect(notifications[0]?.type).toBe('order-confirmation');
+      expect(notifications[1]?.type).toBe('order-status-update');
+    });
+  });
 });
