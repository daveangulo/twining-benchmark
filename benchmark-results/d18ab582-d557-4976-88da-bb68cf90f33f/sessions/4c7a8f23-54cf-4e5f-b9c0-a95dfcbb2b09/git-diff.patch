+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  WebhookAdapter,
+  InMemoryWebhookTransport,
+  formatWebhookPayload,
+  validateWebhookUrl,
+} from '../../src/adapters/webhook.adapter.js';
+import type { WebhookTransport } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+describe('WebhookAdapter', () => {
+  let eventBus: EventBus;
+  let transport: InMemoryWebhookTransport;
+  let adapter: WebhookAdapter;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    transport = new InMemoryWebhookTransport();
+    adapter = new WebhookAdapter(eventBus, transport);
+  });
+
+  // -------------------------------------------------------------------------
+  // validateWebhookUrl
+  // -------------------------------------------------------------------------
+
+  describe('validateWebhookUrl', () => {
+    it('should accept a valid http URL', () => {
+      expect(validateWebhookUrl('http://hooks.example.com/webhook')).toBe('http://hooks.example.com/webhook');
+    });
+
+    it('should accept a valid https URL', () => {
+      expect(validateWebhookUrl('https://hooks.example.com/webhook')).toBe('https://hooks.example.com/webhook');
+    });
+
+    it('should trim whitespace', () => {
+      expect(validateWebhookUrl('  https://hooks.example.com/webhook  ')).toBe('https://hooks.example.com/webhook');
+    });
+
+    it('should reject an empty string', () => {
+      expect(validateWebhookUrl('')).toBeNull();
+    });
+
+    it('should reject a string without http/https', () => {
+      expect(validateWebhookUrl('ftp://example.com')).toBeNull();
+    });
+
+    it('should reject a plain string', () => {
+      expect(validateWebhookUrl('not-a-url')).toBeNull();
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // formatWebhookPayload
+  // -------------------------------------------------------------------------
+
+  describe('formatWebhookPayload', () => {
+    const basePayload: NotificationPayload = {
+      recipient: 'https://hooks.example.com/webhook',
+      subject: 'Order Confirmation: order-1',
+      body: 'Your order has been placed.',
+      notificationType: 'order_confirmation',
+      channel: 'webhook',
+      priority: 'normal',
+    };
+
+    it('should format the payload with correct fields', () => {
+      const body = formatWebhookPayload(basePayload);
+      expect(body.event).toBe('order_confirmation');
+      expect(body.recipient).toBe('https://hooks.example.com/webhook');
+      expect(body.subject).toBe('Order Confirmation: order-1');
+      expect(body.body).toBe('Your order has been placed.');
+      expect(body.priority).toBe('normal');
+      expect(body.timestamp).toBeDefined();
+    });
+
+    it('should include metadata when provided', () => {
+      const body = formatWebhookPayload({ ...basePayload, metadata: { orderId: '123' } });
+      expect(body.metadata).toEqual({ orderId: '123' });
+    });
+
+    it('should default priority to normal when omitted', () => {
+      const body = formatWebhookPayload({ ...basePayload, priority: undefined });
+      expect(body.priority).toBe('normal');
+    });
+
+    it('should include a valid ISO timestamp', () => {
+      const body = formatWebhookPayload(basePayload);
+      expect(() => new Date(body.timestamp)).not.toThrow();
+      expect(new Date(body.timestamp).toISOString()).toBe(body.timestamp);
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // send()
+  // -------------------------------------------------------------------------
+
+  describe('send', () => {
+    const payload: NotificationPayload = {
+      recipient: 'https://hooks.example.com/webhook',
+      subject: 'Order Confirmation: order-1',
+      body: 'Your order has been placed.',
+      notificationType: 'order_confirmation',
+      channel: 'webhook',
+      priority: 'normal',
+    };
+
+    it('should send a webhook via the transport', async () => {
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const webhooks = transport.getSentWebhooks();
+      expect(webhooks).toHaveLength(1);
+      expect(webhooks[0]?.url).toBe('https://hooks.example.com/webhook');
+      expect(webhooks[0]?.body.event).toBe('order_confirmation');
+      expect(webhooks[0]?.body.subject).toBe('Order Confirmation: order-1');
+    });
+
+    it('should record the payload in sent list', async () => {
+      await adapter.send(payload);
+
+      const sent = adapter.getSentWebhooks();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.recipient).toBe('https://hooks.example.com/webhook');
+    });
+
+    it('should return failure for invalid URL', async () => {
+      const result = await adapter.send({ ...payload, recipient: 'not-a-url' });
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid webhook URL');
+      expect(transport.getSentWebhooks()).toHaveLength(0);
+    });
+
+    it('should return failure when transport throws', async () => {
+      const failingTransport: WebhookTransport = {
+        post: async () => {
+          throw new Error('Connection refused');
+        },
+      };
+      const failAdapter = new WebhookAdapter(eventBus, failingTransport);
+
+      const result = await failAdapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Connection refused');
+    });
+
+    it('should handle high priority', async () => {
+      await adapter.send({ ...payload, priority: 'high' });
+
+      const webhooks = transport.getSentWebhooks();
+      expect(webhooks[0]?.body.priority).toBe('high');
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // EventBus integration
+  // -------------------------------------------------------------------------
+
+  describe('event bus integration', () => {
+    it('should handle notification:send events for webhook channel', async () => {
+      await eventBus.emit({
+        type: 'notification:send',
+        payload: {
+          recipient: 'https://hooks.example.com/webhook',
+          subject: 'Test',
+          body: 'Test body',
+          notificationType: 'order_confirmation' as const,
+          channel: 'webhook' as const,
+          priority: 'normal' as const,
+        },
+        timestamp: new Date(),
+      });
+
+      expect(adapter.getSentWebhooks()).toHaveLength(1);
+      expect(transport.getSentWebhooks()).toHaveLength(1);
+    });
+
+    it('should ignore notification:send events for other channels', async () => {
+      await eventBus.emit({
+        type: 'notification:send',
+        payload: {
+          recipient: 'alice@example.com',
+          subject: 'Test',
+          body: 'Test body',
+          notificationType: 'order_confirmation' as const,
+          channel: 'email' as const,
+          priority: 'normal' as const,
+        },
+        timestamp: new Date(),
+      });
+
+      expect(adapter.getSentWebhooks()).toHaveLength(0);
+      expect(transport.getSentWebhooks()).toHaveLength(0);
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // Utility methods
+  // -------------------------------------------------------------------------
+
+  describe('utility methods', () => {
+    it('should clear sent webhooks', async () => {
+      await adapter.send({
+        recipient: 'https://hooks.example.com/webhook',
+        subject: 'Test',
+        body: 'Test',
+        notificationType: 'order_confirmation',
+        channel: 'webhook',
+      });
+
+      adapter.clearSentWebhooks();
+      expect(adapter.getSentWebhooks()).toHaveLength(0);
+    });
+
+    it('should expose the transport', () => {
+      expect(adapter.getTransport()).toBe(transport);
+    });
+  });
+});
