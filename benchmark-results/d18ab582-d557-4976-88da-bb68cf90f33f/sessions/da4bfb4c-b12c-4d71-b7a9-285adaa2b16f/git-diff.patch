+import { describe, it, expect } from 'vitest';
+import {
+  validateUserExists,
+  validateEmailNotTaken,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const testUser: User = {
+  id: 'user-1',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+};
+
+describe('User Validators', () => {
+  describe('validateUserExists', () => {
+    it('should not throw when user exists', () => {
+      expect(() => validateUserExists(testUser, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists(undefined, 'user-99')).toThrow(
+        'User not found: user-99',
+      );
+    });
+  });
+
+  describe('validateEmailNotTaken', () => {
+    it('should not throw when no existing user', () => {
+      expect(() => validateEmailNotTaken(undefined, 'new@example.com')).not.toThrow();
+    });
+
+    it('should throw when email is taken', () => {
+      expect(() => validateEmailNotTaken(testUser, 'alice@example.com')).toThrow(
+        'Email alice@example.com is already in use',
+      );
+    });
+
+    it('should use custom message when provided', () => {
+      expect(() =>
+        validateEmailNotTaken(testUser, 'alice@example.com', 'Custom error'),
+      ).toThrow('Custom error');
+    });
+  });
+});
