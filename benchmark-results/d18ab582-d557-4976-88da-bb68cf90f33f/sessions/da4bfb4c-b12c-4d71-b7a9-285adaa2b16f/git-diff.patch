+import { describe, it, expect } from 'vitest';
+import {
+  validatePreferencesNotExist,
+  validatePreferencesExist,
+} from '../../src/validators/preferences.validator.js';
+import type { UserPreferences } from '../../src/models/user-preferences.js';
+
+const testPrefs: UserPreferences = {
+  userId: 'user-1',
+  emailEnabled: true,
+  emailFrequency: 'immediate',
+  subscribedCategories: ['order_confirmation'],
+  createdAt: new Date(),
+  updatedAt: new Date(),
+};
+
+describe('Preferences Validators', () => {
+  describe('validatePreferencesNotExist', () => {
+    it('should not throw when preferences do not exist', () => {
+      expect(() => validatePreferencesNotExist(undefined, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when preferences already exist', () => {
+      expect(() => validatePreferencesNotExist(testPrefs, 'user-1')).toThrow(
+        'Preferences already exist for user: user-1',
+      );
+    });
+  });
+
+  describe('validatePreferencesExist', () => {
+    it('should not throw when preferences exist', () => {
+      expect(() => validatePreferencesExist(testPrefs, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when preferences do not exist', () => {
+      expect(() => validatePreferencesExist(undefined, 'user-1')).toThrow(
+        'No preferences found for user: user-1',
+      );
+    });
+  });
+});
