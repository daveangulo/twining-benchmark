+
+  describe('notification ordering', () => {
+    it('should deliver notifications in the order they were emitted', async () => {
+      const deliveryOrder: string[] = [];
+      service.registerAdapter({
+        channel: 'email',
+        async send(payload) {
+          // Simulate variable adapter latency — earlier notifications take longer
+          const delay = payload.subject.includes('Confirmation') ? 50 : 10;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.subject);
+          return { success: true, channel: 'email' };
+        },
+      });
+
+      // Emit order:created first, then order:status-changed
+      await eventBus.emit({
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      } satisfies OrderCreatedEvent);
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      } satisfies OrderStatusChangedEvent);
+
+      // Despite the confirmation adapter call taking 5x longer,
+      // it must complete before the status update is sent
+      expect(deliveryOrder).toHaveLength(2);
+      expect(deliveryOrder[0]).toContain('Order Confirmation');
+      expect(deliveryOrder[1]).toContain('Order Update');
+    });
+  });
