+      total: 10,
+      status: 'pending',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    user: {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    timestamp: new Date(),
+  };
+
+  it('should send to email only by default (SMS and webhook disabled)', async () => {
+    await eventBus.emit(orderCreatedEvent);
+
+    const notifications = notificationService.getNotifications();
