+import { describe, it, expect } from 'vitest';
+import {
+  validateEmailNotTaken,
+  validateUserExists,
+  validateEmailNotInUse,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+describe('User Validators', () => {
+  const testUser: User = {
+    id: 'user-1',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  };
+
+  describe('validateEmailNotTaken', () => {
+    it('should pass when no existing user has the email', () => {
+      expect(() => validateEmailNotTaken('new@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when email is already taken', () => {
+      expect(() =>
+        validateEmailNotTaken('alice@example.com', testUser),
+      ).toThrow('User with email alice@example.com already exists');
+    });
+  });
+
+  describe('validateUserExists', () => {
+    it('should pass when user exists', () => {
+      expect(() => validateUserExists(testUser, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists(undefined, 'user-99')).toThrow(
+        'User not found: user-99',
+      );
+    });
+  });
+
+  describe('validateEmailNotInUse', () => {
+    it('should pass when email is not in use', () => {
+      expect(() => validateEmailNotInUse('new@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when email is in use', () => {
+      expect(() =>
+        validateEmailNotInUse('alice@example.com', testUser),
+      ).toThrow('Email alice@example.com is already in use');
+    });
+  });
+});
