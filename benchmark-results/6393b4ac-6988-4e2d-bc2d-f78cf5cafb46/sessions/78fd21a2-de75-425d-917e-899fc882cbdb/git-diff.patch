diff --git a/tests/adapters/webhook.adapter.test.ts b/tests/adapters/webhook.adapter.test.ts
new file mode 100644
index 0000000..05775c3
--- /dev/null
+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,208 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookAdapter,
+  InMemoryWebhookTransport,
+  FailingWebhookTransport,
+} from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    type: 'order:confirmation',
+    recipient: 'user-123',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    channel: 'webhook',
+    priority: 'normal',
+    metadata: { orderId: 'order-1', notificationId: 'notif-0001' },
+    ...overrides,
+  };
+}
+
+describe('WebhookAdapter', () => {
+  let transport: InMemoryWebhookTransport;
+  let adapter: WebhookAdapter;
+
+  beforeEach(() => {
+    transport = new InMemoryWebhookTransport();
+    adapter = new WebhookAdapter({
+      url: 'https://hooks.example.com/notify',
+      secret: 'test-secret',
+      transport,
+    });
+  });
+
+  it('has channel set to webhook', () => {
+    expect(adapter.channel).toBe('webhook');
+  });
+
+  describe('buildRequest', () => {
+    it('formats payload as JSON with correct URL', () => {
+      const request = adapter.buildRequest(makePayload());
+
+      expect(request.url).toBe('https://hooks.example.com/notify');
+      expect(request.headers['Content-Type']).toBe('application/json');
+
+      const body = JSON.parse(request.body);
+      expect(body.event).toBe('order:confirmation');
+      expect(body.recipient).toBe('user-123');
+      expect(body.subject).toBe('Order Confirmation: order-1');
+      expect(body.body).toBe('Your order has been placed. Items: Widget x2. Total: $20.00');
+      expect(body.channel).toBe('webhook');
+      expect(body.priority).toBe('normal');
+      expect(body.metadata.orderId).toBe('order-1');
+      expect(body.timestamp).toBeDefined();
+    });
+
+    it('includes secret header when configured', () => {
+      const request = adapter.buildRequest(makePayload());
+      expect(request.headers['X-Webhook-Secret']).toBe('test-secret');
+    });
+
+    it('omits secret header when not configured', () => {
+      const noSecretAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+        transport,
+      });
+      const request = noSecretAdapter.buildRequest(makePayload());
+      expect(request.headers['X-Webhook-Secret']).toBeUndefined();
+    });
+
+    it('includes empty metadata when none provided', () => {
+      const payload = makePayload({ metadata: undefined });
+      const request = adapter.buildRequest(payload);
+      const body = JSON.parse(request.body);
+      expect(body.metadata).toEqual({});
+    });
+
+    it('formats all notification types', () => {
+      const types = [
+        'order:confirmation',
+        'order:status-update',
+        'user:welcome',
+        'user:profile-updated',
+      ] as const;
+
+      for (const type of types) {
+        const request = adapter.buildRequest(makePayload({ type }));
+        const body = JSON.parse(request.body);
+        expect(body.event).toBe(type);
+      }
+    });
+  });
+
+  describe('send', () => {
+    it('sends webhook and returns success', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('webhook');
+      expect(result.error).toBeUndefined();
+
+      expect(transport.sent).toHaveLength(1);
+      expect(transport.sent[0]?.url).toBe('https://hooks.example.com/notify');
+    });
+
+    it('returns failure when transport throws', async () => {
+      const failAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+        transport: new FailingWebhookTransport('Connection refused'),
+      });
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Connection refused');
+      expect(result.channel).toBe('webhook');
+    });
+
+    it('uses notificationId from metadata', async () => {
+      const payload = makePayload({
+        metadata: { notificationId: 'custom-id' },
+      });
+      const result = await adapter.send(payload);
+      expect(result.notificationId).toBe('custom-id');
+    });
+
+    it('falls back to unknown when no notificationId in metadata', async () => {
+      const payload = makePayload({ metadata: undefined });
+      const result = await adapter.send(payload);
+      expect(result.notificationId).toBe('unknown');
+    });
+
+    it('sends multiple webhooks independently', async () => {
+      await adapter.send(makePayload({ recipient: 'user-1' }));
+      await adapter.send(makePayload({ recipient: 'user-2' }));
+
+      expect(transport.sent).toHaveLength(2);
+      const body1 = JSON.parse(transport.sent[0]!.body);
+      const body2 = JSON.parse(transport.sent[1]!.body);
+      expect(body1.recipient).toBe('user-1');
+      expect(body2.recipient).toBe('user-2');
+    });
+
+    it('preserves all payload fields in request body', async () => {
+      const payload = makePayload({
+        type: 'order:status-update',
+        subject: 'Status Changed',
+        body: 'Order updated',
+        priority: 'high',
+        metadata: { orderId: 'order-2', newStatus: 'shipped', notificationId: 'notif-0005' },
+      });
+      await adapter.send(payload);
+
+      const body = JSON.parse(transport.sent[0]!.body);
+      expect(body.event).toBe('order:status-update');
+      expect(body.subject).toBe('Status Changed');
+      expect(body.body).toBe('Order updated');
+      expect(body.priority).toBe('high');
+      expect(body.metadata.orderId).toBe('order-2');
+      expect(body.metadata.newStatus).toBe('shipped');
+    });
+  });
+
+  describe('InMemoryWebhookTransport', () => {
+    it('records sent requests', async () => {
+      const t = new InMemoryWebhookTransport();
+      const request = adapter.buildRequest(makePayload());
+
+      const r1 = await t.post(request);
+      const r2 = await t.post(request);
+
+      expect(r1.statusCode).toBe(200);
+      expect(r1.accepted).toBe(true);
+      expect(r2.statusCode).toBe(200);
+      expect(t.sent).toHaveLength(2);
+    });
+
+    it('clears sent requests', async () => {
+      const t = new InMemoryWebhookTransport();
+      await t.post(adapter.buildRequest(makePayload()));
+      t.clear();
+      expect(t.sent).toHaveLength(0);
+    });
+  });
+
+  describe('FailingWebhookTransport', () => {
+    it('throws with configured error message', async () => {
+      const t = new FailingWebhookTransport('Custom error');
+      const request = adapter.buildRequest(makePayload());
+      await expect(t.post(request)).rejects.toThrow('Custom error');
+    });
+
+    it('uses default error message when none provided', async () => {
+      const t = new FailingWebhookTransport();
+      const request = adapter.buildRequest(makePayload());
+      await expect(t.post(request)).rejects.toThrow('Connection refused');
+    });
+  });
+
+  describe('integration with NotificationService pattern', () => {
+    it('conforms to NotificationAdapter interface', () => {
+      expect(typeof adapter.channel).toBe('string');
+      expect(typeof adapter.send).toBe('function');
+    });
+  });
+});
