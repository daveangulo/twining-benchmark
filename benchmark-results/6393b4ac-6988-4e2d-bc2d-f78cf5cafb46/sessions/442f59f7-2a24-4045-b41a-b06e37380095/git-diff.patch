+  describe('notification ordering', () => {
+    it('should deliver notifications to the same recipient in order even when dispatched concurrently', async () => {
+      const deliveryOrder: string[] = [];
+
+      // Adapter where the first notification takes longer than the second
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as NotificationChannel,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          const delay = payload.subject?.includes('first') ? 50 : 5;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.subject ?? '');
+          return {
+            notificationId: payload.id,
+            channel: payload.channel,
+            success: true,
+            deliveredAt: new Date(),
+          };
+        },
+        async isAvailable() {
+          return true;
+        },
+      };
+
+      const bus = new EventBus();
+      const svc = new NotificationService(bus);
+      svc.registerAdapter(slowAdapter);
+
+      // Dispatch two notifications concurrently to the same recipient.
+      // Without ordering, the faster second one would arrive first.
+      const p1 = svc.dispatchNotification({
+        type: 'order-confirmation',
+        channel: 'email',
+        recipient: 'user@example.com',
+        subject: 'first: order placed',
+        body: '',
+      });
+      const p2 = svc.dispatchNotification({
+        type: 'order-status-update',
+        channel: 'email',
+        recipient: 'user@example.com',
+        subject: 'second: payment confirmed',
+        body: '',
+      });
+
+      await Promise.all([p1, p2]);
+
+      expect(deliveryOrder).toEqual([
+        'first: order placed',
+        'second: payment confirmed',
+      ]);
+    });
+
+    it('should allow concurrent delivery to different recipients', async () => {
+      const deliveryOrder: string[] = [];
+
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as NotificationChannel,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          const delay = payload.recipient === 'slow@example.com' ? 50 : 5;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.recipient);
+          return {
+            notificationId: payload.id,
+            channel: payload.channel,
+            success: true,
+            deliveredAt: new Date(),
+          };
+        },
+        async isAvailable() {
+          return true;
+        },
+      };
+
+      const bus = new EventBus();
+      const svc = new NotificationService(bus);
+      svc.registerAdapter(slowAdapter);
+
+      // Different recipients should NOT block each other
+      const p1 = svc.dispatchNotification({
+        type: 'order-confirmation',
+        channel: 'email',
+        recipient: 'slow@example.com',
+        subject: 'Test',
+        body: '',
+      });
+      const p2 = svc.dispatchNotification({
+        type: 'order-confirmation',
+        channel: 'email',
+        recipient: 'fast@example.com',
+        subject: 'Test',
+        body: '',
+      });
+
+      await Promise.all([p1, p2]);
+
+      // fast@example.com should arrive before slow@example.com
+      expect(deliveryOrder).toEqual([
+        'fast@example.com',
+        'slow@example.com',
