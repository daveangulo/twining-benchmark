@@ -0,0 +1,217 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  SmsAdapter,
+  DefaultSmsTransport,
+  isValidPhoneNumber,
+  resolvePhoneNumber,
+  formatSmsBody,
+  defaultSmsConfig,
+} from '../../src/adapters/sms.adapter.js';
+import type { SmsTransport, SmsMessage } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: '+14155551234',
+    type: 'system-alert',
+    channel: 'sms',
+    subject: 'Test Subject',
+    body: 'Test body content.',
+    ...overrides,
+  };
+}
+
+class MockSmsTransport implements SmsTransport {
+  public calls: SmsMessage[] = [];
+  public nextResult: { accepted: boolean; error?: string } = { accepted: true };
+  public shouldThrow: Error | null = null;
+
+  async sendSms(message: SmsMessage): Promise<{ accepted: boolean; error?: string }> {
+    this.calls.push(message);
+    if (this.shouldThrow) throw this.shouldThrow;
+    return this.nextResult;
+  }
+}
+
+describe('isValidPhoneNumber', () => {
+  it('should accept valid E.164 phone numbers', () => {
+    expect(isValidPhoneNumber('+14155551234')).toBe(true);
+    expect(isValidPhoneNumber('+442071234567')).toBe(true);
+    expect(isValidPhoneNumber('+8613800138000')).toBe(true);
+  });
+
+  it('should reject invalid phone numbers', () => {
+    expect(isValidPhoneNumber('14155551234')).toBe(false);
+    expect(isValidPhoneNumber('+0123456')).toBe(false);
+    expect(isValidPhoneNumber('')).toBe(false);
+    expect(isValidPhoneNumber('not-a-number')).toBe(false);
+    expect(isValidPhoneNumber('+1')).toBe(false);
+    expect(isValidPhoneNumber('user@example.com')).toBe(false);
+  });
+});
+
+describe('resolvePhoneNumber', () => {
+  it('should use recipient when it is a valid phone number', () => {
+    const payload = makePayload({ recipient: '+14155551234' });
+    expect(resolvePhoneNumber(payload)).toBe('+14155551234');
+  });
+
+  it('should prefer metadata.recipientPhone over recipient', () => {
+    const payload = makePayload({
+      recipient: 'user-123',
+      metadata: { recipientPhone: '+442071234567' },
+    });
+    expect(resolvePhoneNumber(payload)).toBe('+442071234567');
+  });
+
+  it('should fall back to recipient if metadata.recipientPhone is invalid', () => {
+    const payload = makePayload({
+      recipient: '+14155551234',
+      metadata: { recipientPhone: 'not-valid' },
+    });
+    expect(resolvePhoneNumber(payload)).toBe('+14155551234');
+  });
+
+  it('should return null when neither recipient nor metadata has a valid phone number', () => {
+    const payload = makePayload({ recipient: 'user-123' });
+    expect(resolvePhoneNumber(payload)).toBeNull();
+  });
+});
+
+describe('formatSmsBody', () => {
+  it('should format subject and body together', () => {
+    const payload = makePayload({ subject: 'Alert', body: 'Something happened' });
+    expect(formatSmsBody(payload, 160)).toBe('Alert: Something happened');
+  });
+
+  it('should truncate long messages with ellipsis', () => {
+    const payload = makePayload({ subject: 'Alert', body: 'A'.repeat(200) });
+    const result = formatSmsBody(payload, 160);
+    expect(result.length).toBe(160);
+    expect(result.endsWith('...')).toBe(true);
+  });
+
+  it('should not truncate messages at exactly maxLength', () => {
+    const payload = makePayload({ subject: 'Hi', body: 'X'.repeat(156) });
+    // "Hi: " + 156 X's = 160
+    const result = formatSmsBody(payload, 160);
+    expect(result.length).toBe(160);
+    expect(result.endsWith('...')).toBe(false);
+  });
+});
+
+describe('defaultSmsConfig', () => {
+  it('should have sensible defaults', () => {
+    expect(defaultSmsConfig.fromNumber).toBe('+10000000000');
+    expect(defaultSmsConfig.maxLength).toBe(160);
+  });
+});
+
+describe('DefaultSmsTransport', () => {
+  it('should track sent messages', async () => {
+    const transport = new DefaultSmsTransport();
+    const message: SmsMessage = { to: '+14155551234', from: '+10000000000', body: 'Hi' };
+    const result = await transport.sendSms(message);
+
+    expect(result.accepted).toBe(true);
+    expect(transport.getSentMessages()).toHaveLength(1);
+    expect(transport.getSentMessages()[0]).toEqual(message);
+  });
+});
+
+describe('SmsAdapter', () => {
+  let transport: MockSmsTransport;
+  let adapter: SmsAdapter;
+
+  beforeEach(() => {
+    transport = new MockSmsTransport();
+    adapter = new SmsAdapter(undefined, transport);
+  });
+
+  it('should have channel set to sms', () => {
+    expect(adapter.channel).toBe('sms');
+  });
+
+  it('should send successfully and return success result', async () => {
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(true);
+    expect(transport.calls).toHaveLength(1);
+    expect(transport.calls[0].to).toBe('+14155551234');
+  });
+
+  it('should return failure for invalid phone number', async () => {
+    const payload = makePayload({ recipient: 'not-a-phone' });
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('Invalid phone number');
+    expect(transport.calls).toHaveLength(0);
+  });
+
+  it('should return failure when transport rejects', async () => {
+    transport.nextResult = { accepted: false, error: 'Number unreachable' };
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('Number unreachable');
+  });
+
+  it('should return failure with default message when transport rejects without error', async () => {
+    transport.nextResult = { accepted: false };
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('SMS rejected by transport');
+  });
+
+  it('should return failure when transport throws', async () => {
+    transport.shouldThrow = new Error('Network error');
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('Network error');
+  });
+
+  it('should use custom config', async () => {
+    const customAdapter = new SmsAdapter(
+      { fromNumber: '+15551234567', maxLength: 100 },
+      transport,
+    );
+    const payload = makePayload({ subject: 'S', body: 'B' });
+    await customAdapter.send(payload);
+
+    expect(transport.calls[0].from).toBe('+15551234567');
+  });
+
+  it('should truncate body based on maxLength config', async () => {
+    const customAdapter = new SmsAdapter({ maxLength: 20 }, transport);
+    const payload = makePayload({ subject: 'Alert', body: 'This is a long message body' });
+    await customAdapter.send(payload);
+
+    expect(transport.calls[0].body.length).toBe(20);
+    expect(transport.calls[0].body.endsWith('...')).toBe(true);
+  });
+
+  it('should resolve phone from metadata.recipientPhone', async () => {
+    const payload = makePayload({
+      recipient: 'user-123',
+      metadata: { recipientPhone: '+442071234567' },
+    });
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(true);
+    expect(transport.calls[0].to).toBe('+442071234567');
+  });
+
+  it('should format the message with subject and body', async () => {
+    const payload = makePayload({ subject: 'Order Update', body: 'Your order shipped.' });
+    await adapter.send(payload);
+
+    expect(transport.calls[0].body).toBe('Order Update: Your order shipped.');
+  });
+});
