+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.unsubscribeFromCategory('user-1', 'order-confirmation');
+      expect(updated.emailCategories).not.toContain('order-confirmation');
+    });
+
+    it('should leave other categories intact', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.unsubscribeFromCategory('user-1', 'order-confirmation');
