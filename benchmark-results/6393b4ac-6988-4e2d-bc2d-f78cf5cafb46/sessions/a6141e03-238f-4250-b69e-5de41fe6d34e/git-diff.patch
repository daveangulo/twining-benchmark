+    });
+
+    it('should create preferences if none exist then reset', () => {
+      const reset = service.resetToDefaults('user-1');
+      expect(reset.emailEnabled).toBe(true);
+      expect(reset.emailCategories).toEqual(ALL_NOTIFICATION_CATEGORIES);
+    });
+  });
