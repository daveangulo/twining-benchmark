diff --git a/src/validators/email.validator.ts b/src/validators/email.validator.ts
new file mode 100644
index 0000000..0f743ca
--- /dev/null
+++ b/src/validators/email.validator.ts
@@ -0,0 +1,19 @@
+/**
+ * Pure email validation and normalization functions.
+ *
+ * No side effects — can be reused across services and adapters.
+ */
+
+/**
+ * Validate that a string looks like a valid email address.
+ */
+export function isValidEmail(email: string): boolean {
+  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
+}
+
+/**
+ * Normalize an email address: trim whitespace and lowercase.
+ */
+export function normalizeEmail(email: string): string {
+  return email.trim().toLowerCase();
+}
diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..9125966
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,39 @@
+/**
+ * Pure validation functions for order operations.
+ *
+ * No side effects, no database calls — can be reused across services.
+ */
+
+import type { OrderItem, OrderStatus } from '../models/order.js';
+
+/**
+ * Valid status transitions for orders.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate that an order has at least one item.
+ * Returns an error message if invalid, or null if valid.
+ */
+export function validateOrderItems(items: OrderItem[]): string | null {
+  if (items.length === 0) {
+    return 'Order must have at least one item';
+  }
+  return null;
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..219f126
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,53 @@
+/**
+ * Pure validation functions for user operations.
+ *
+ * No side effects, no database calls — can be reused across services.
+ */
+
+import type { CreateUserInput, UpdateUserInput } from '../models/user.js';
+import { isValidEmail } from './email.validator.js';
+
+/**
+ * Validate input for creating a user.
+ * Returns an error message if invalid, or null if valid.
+ */
+export function validateCreateUserInput(input: CreateUserInput): string | null {
+  if (!input.name || input.name.trim().length === 0) {
+    return 'User name is required';
+  }
+  if (!input.email || input.email.trim().length === 0) {
+    return 'User email is required';
+  }
+  if (!isValidEmail(input.email)) {
+    return `Invalid email format: ${input.email}`;
+  }
+  return null;
+}
+
+/**
+ * Validate input for updating a user.
+ * Returns an error message if invalid, or null if valid.
+ */
+export function validateUpdateUserInput(input: UpdateUserInput): string | null {
+  if (input.email !== undefined && !isValidEmail(input.email)) {
+    return `Invalid email format: ${input.email}`;
+  }
+  if (input.name !== undefined && input.name.trim().length === 0) {
+    return 'User name cannot be empty';
+  }
+  return null;
+}
+
+/**
+ * Determine which fields changed between existing and update input.
+ */
+export function detectUserChanges(
+  existing: { name: string; email: string; role: string },
+  input: UpdateUserInput,
+): string[] {
+  const changes: string[] = [];
+  if (input.name && input.name !== existing.name) changes.push('name');
+  if (input.email && input.email !== existing.email) changes.push('email');
+  if (input.role && input.role !== existing.role) changes.push('role');
+  return changes;
+}
diff --git a/tests/validators/email.validator.test.ts b/tests/validators/email.validator.test.ts
new file mode 100644
index 0000000..74890de
--- /dev/null
+++ b/tests/validators/email.validator.test.ts
@@ -0,0 +1,48 @@
+import { describe, it, expect } from 'vitest';
+import { isValidEmail, normalizeEmail } from '../../src/validators/email.validator.js';
+
+describe('Email Validators', () => {
+  describe('isValidEmail', () => {
+    it('should accept valid email', () => {
+      expect(isValidEmail('user@example.com')).toBe(true);
+    });
+
+    it('should accept email with subdomain', () => {
+      expect(isValidEmail('user@mail.example.com')).toBe(true);
+    });
+
+    it('should reject missing @', () => {
+      expect(isValidEmail('userexample.com')).toBe(false);
+    });
+
+    it('should reject missing domain', () => {
+      expect(isValidEmail('user@')).toBe(false);
+    });
+
+    it('should reject missing local part', () => {
+      expect(isValidEmail('@example.com')).toBe(false);
+    });
+
+    it('should reject spaces', () => {
+      expect(isValidEmail('user @example.com')).toBe(false);
+    });
+
+    it('should reject empty string', () => {
+      expect(isValidEmail('')).toBe(false);
+    });
+  });
+
+  describe('normalizeEmail', () => {
+    it('should lowercase email', () => {
+      expect(normalizeEmail('User@Example.COM')).toBe('user@example.com');
+    });
+
+    it('should trim whitespace', () => {
+      expect(normalizeEmail('  user@example.com  ')).toBe('user@example.com');
+    });
+
+    it('should handle already normalized email', () => {
+      expect(normalizeEmail('user@example.com')).toBe('user@example.com');
+    });
+  });
+});
