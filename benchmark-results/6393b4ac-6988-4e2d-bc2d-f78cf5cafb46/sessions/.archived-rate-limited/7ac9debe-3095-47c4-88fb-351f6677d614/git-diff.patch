diff --git a/tests/adapters/email.adapter.test.ts b/tests/adapters/email.adapter.test.ts
new file mode 100644
index 0000000..e69ed42
--- /dev/null
+++ b/tests/adapters/email.adapter.test.ts
@@ -0,0 +1,47 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { NotificationPayload } from '../../src/adapters/notification.adapter.js';
+
+describe('EmailAdapter', () => {
+  let adapter: EmailAdapter;
+
+  const samplePayload: NotificationPayload = {
+    id: 'notif-0001',
+    recipient: 'alice@example.com',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed.',
+    sentAt: new Date('2026-01-15T10:00:00Z'),
+  };
+
+  beforeEach(() => {
+    adapter = new EmailAdapter();
+  });
+
+  it('should have name "email"', () => {
+    expect(adapter.name).toBe('email');
+  });
+
+  it('should store sent email', async () => {
+    await adapter.send(samplePayload);
+
+    const emails = adapter.getSentEmails();
+    expect(emails).toHaveLength(1);
+    expect(emails[0]?.to).toBe('alice@example.com');
+    expect(emails[0]?.subject).toBe('Order Confirmation: order-1');
+    expect(emails[0]?.body).toBe('Your order has been placed.');
+  });
+
+  it('should track multiple emails', async () => {
+    await adapter.send(samplePayload);
+    await adapter.send({ ...samplePayload, recipient: 'bob@example.com' });
+
+    expect(adapter.getSentEmails()).toHaveLength(2);
+  });
+
+  it('should clear sent emails', async () => {
+    await adapter.send(samplePayload);
+    adapter.clearSentEmails();
+
+    expect(adapter.getSentEmails()).toHaveLength(0);
+  });
+});
diff --git a/tests/adapters/webhook.adapter.test.ts b/tests/adapters/webhook.adapter.test.ts
new file mode 100644
index 0000000..05e6444
--- /dev/null
+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,98 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { WebhookAdapter } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/adapters/notification.adapter.js';
+import type { HttpPostFn } from '../../src/adapters/webhook.adapter.js';
+
+describe('WebhookAdapter', () => {
+  const webhookUrl = 'https://hooks.example.com/notify';
+  let mockPost: HttpPostFn;
+  let adapter: WebhookAdapter;
+
+  const samplePayload: NotificationPayload = {
+    id: 'notif-0001',
+    recipient: 'alice@example.com',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed.',
+    sentAt: new Date('2026-01-15T10:00:00Z'),
+  };
+
+  beforeEach(() => {
+    mockPost = vi.fn().mockResolvedValue({ ok: true, status: 200 });
+    adapter = new WebhookAdapter(webhookUrl, mockPost);
+  });
+
+  it('should have name "webhook"', () => {
+    expect(adapter.name).toBe('webhook');
+  });
+
+  it('should return the configured URL', () => {
+    expect(adapter.getUrl()).toBe(webhookUrl);
+  });
+
+  it('should POST JSON payload to the configured URL', async () => {
+    await adapter.send(samplePayload);
+
+    expect(mockPost).toHaveBeenCalledOnce();
+    expect(mockPost).toHaveBeenCalledWith(webhookUrl, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({
+        notificationId: 'notif-0001',
+        recipient: 'alice@example.com',
+        subject: 'Order Confirmation: order-1',
+        body: 'Your order has been placed.',
+        sentAt: '2026-01-15T10:00:00.000Z',
+      }),
+    });
+  });
+
+  it('should record successful delivery', async () => {
+    await adapter.send(samplePayload);
+
+    const deliveries = adapter.getDeliveries();
+    expect(deliveries).toHaveLength(1);
+    expect(deliveries[0]?.url).toBe(webhookUrl);
+    expect(deliveries[0]?.success).toBe(true);
+    expect(deliveries[0]?.statusCode).toBe(200);
+    expect(deliveries[0]?.payload.notificationId).toBe('notif-0001');
+    expect(deliveries[0]?.payload.sentAt).toBe('2026-01-15T10:00:00.000Z');
+  });
+
+  it('should record failed delivery on non-ok response', async () => {
+    mockPost = vi.fn().mockResolvedValue({ ok: false, status: 500 });
+    adapter = new WebhookAdapter(webhookUrl, mockPost);
+
+    await adapter.send(samplePayload);
+
+    const deliveries = adapter.getDeliveries();
+    expect(deliveries).toHaveLength(1);
+    expect(deliveries[0]?.success).toBe(false);
+    expect(deliveries[0]?.statusCode).toBe(500);
+  });
+
+  it('should record failed delivery on network error', async () => {
+    mockPost = vi.fn().mockRejectedValue(new Error('Network error'));
+    adapter = new WebhookAdapter(webhookUrl, mockPost);
+
+    await adapter.send(samplePayload);
+
+    const deliveries = adapter.getDeliveries();
+    expect(deliveries).toHaveLength(1);
+    expect(deliveries[0]?.success).toBe(false);
+    expect(deliveries[0]?.statusCode).toBeUndefined();
+  });
+
+  it('should track multiple deliveries', async () => {
+    await adapter.send(samplePayload);
+    await adapter.send({ ...samplePayload, id: 'notif-0002' });
+
+    expect(adapter.getDeliveries()).toHaveLength(2);
+  });
+
+  it('should clear deliveries', async () => {
+    await adapter.send(samplePayload);
+    adapter.clearDeliveries();
+
+    expect(adapter.getDeliveries()).toHaveLength(0);
+  });
+});
