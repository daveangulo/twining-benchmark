+/**
+ * Notification history service — logs every sent notification and
+ * provides query capabilities for audit and analysis.
+ *
+ * Depends on:
+ * - NotificationLogRepository for persistence
+ */
+
+import type { NotificationLogRepository } from '../repositories/notification-log.repository.js';
+import type {
+  NotificationLog,
+  NotificationChannel,
+  NotificationType,
+  DeliveryStatus,
+} from '../models/notification-log.js';
+import { Logger } from '../utils/logger.js';
+
+export interface LogNotificationParams {
+  notificationId: string;
+  recipient: string;
+  channel: NotificationChannel;
+  type: NotificationType;
+  subject: string;
+  body: string;
+  status: DeliveryStatus;
+  sentAt: Date;
+}
+
+export interface NotificationHistoryQuery {
+  recipient?: string;
+  type?: NotificationType;
+  channel?: NotificationChannel;
+  status?: DeliveryStatus;
+  startDate?: Date;
+  endDate?: Date;
+}
+
+let nextLogId = 1;
+
+function generateLogId(): string {
+  return `nlog-${String(nextLogId++).padStart(4, '0')}`;
+}
+
+export function resetLogIdCounter(): void {
+  nextLogId = 1;
+}
+
+export class NotificationHistoryService {
+  private logger = new Logger('NotificationHistoryService');
+
+  constructor(private repository: NotificationLogRepository) {}
+
+  /**
+   * Log a sent notification.
+   */
+  log(params: LogNotificationParams): NotificationLog {
+    const entry: NotificationLog = {
+      id: generateLogId(),
+      notificationId: params.notificationId,
+      recipient: params.recipient,
+      channel: params.channel,
+      type: params.type,
+      subject: params.subject,
+      body: params.body,
+      status: params.status,
+      sentAt: params.sentAt,
+      createdAt: new Date(),
+    };
+
+    this.repository.save(entry);
+    this.logger.info(
+      `Logged notification ${params.notificationId} [${params.channel}/${params.status}] to ${params.recipient}`,
+    );
+
+    return entry;
+  }
+
+  /**
+   * Query notification history by recipient.
+   */
+  getByRecipient(recipient: string): NotificationLog[] {
+    return this.repository.findByRecipient(recipient);
+  }
+
+  /**
+   * Query notification history by type.
+   */
+  getByType(type: NotificationType): NotificationLog[] {
+    return this.repository.findByType(type);
+  }
+
+  /**
+   * Query notification history by date range.
+   */
+  getByDateRange(start: Date, end: Date): NotificationLog[] {
+    return this.repository.findByDateRange(start, end);
+  }
+
+  /**
+   * Query notification history with multiple filters.
+   */
+  query(filters: NotificationHistoryQuery): NotificationLog[] {
+    let results = this.repository.findAll();
+
+    if (filters.recipient) {
+      results = results.filter((log) => log.recipient === filters.recipient);
+    }
+    if (filters.type) {
+      results = results.filter((log) => log.type === filters.type);
+    }
+    if (filters.channel) {
+      results = results.filter((log) => log.channel === filters.channel);
+    }
+    if (filters.status) {
+      results = results.filter((log) => log.status === filters.status);
+    }
+    if (filters.startDate) {
+      results = results.filter((log) => log.sentAt >= filters.startDate!);
+    }
+    if (filters.endDate) {
+      results = results.filter((log) => log.sentAt <= filters.endDate!);
+    }
+
+    return results;
+  }
+
+  /**
+   * Get a single log entry by ID.
+   */
+  getById(id: string): NotificationLog | undefined {
+    return this.repository.findById(id);
+  }
+
+  /**
+   * Get all log entries.
+   */
+  getAll(): NotificationLog[] {
+    return this.repository.findAll();
+  }
+
+  /**
+   * Get the count of log entries.
+   */
+  getCount(): number {
+    return this.repository.count();
+  }
+}
