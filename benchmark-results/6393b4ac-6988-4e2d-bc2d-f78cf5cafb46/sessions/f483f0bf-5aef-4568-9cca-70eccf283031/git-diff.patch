@@ -0,0 +1,230 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookAdapter,
+  isValidWebhookUrl,
+  resolveWebhookUrl,
+  formatWebhookBody,
+  defaultWebhookConfig,
+} from '../../src/adapters/webhook.adapter.js';
+import type { WebhookTransport, WebhookPayloadBody } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: 'https://hooks.example.com/notify',
+    type: 'system-alert',
+    channel: 'webhook',
+    subject: 'Test Subject',
+    body: 'Test body content.',
+    ...overrides,
+  };
+}
+
+class MockWebhookTransport implements WebhookTransport {
+  public calls: Array<{
+    url: string;
+    body: WebhookPayloadBody;
+    headers: Record<string, string>;
+    timeoutMs: number;
+  }> = [];
+  public nextResult: { ok: boolean; status: number; error?: string } = {
+    ok: true,
+    status: 200,
+  };
+  public shouldThrow: Error | null = null;
+
+  async post(
+    url: string,
+    body: WebhookPayloadBody,
+    headers: Record<string, string>,
+    timeoutMs: number,
+  ): Promise<{ ok: boolean; status: number; error?: string }> {
+    this.calls.push({ url, body, headers, timeoutMs });
+    if (this.shouldThrow) throw this.shouldThrow;
+    return this.nextResult;
+  }
+}
+
+describe('isValidWebhookUrl', () => {
+  it('should accept http URLs', () => {
+    expect(isValidWebhookUrl('http://example.com/hook')).toBe(true);
+  });
+
+  it('should accept https URLs', () => {
+    expect(isValidWebhookUrl('https://hooks.slack.com/services/T00/B00/xxx')).toBe(true);
+  });
+
+  it('should reject non-URL strings', () => {
+    expect(isValidWebhookUrl('not-a-url')).toBe(false);
+    expect(isValidWebhookUrl('ftp://files.example.com')).toBe(false);
+    expect(isValidWebhookUrl('')).toBe(false);
+    expect(isValidWebhookUrl('user@example.com')).toBe(false);
+  });
+});
+
+describe('resolveWebhookUrl', () => {
+  it('should use recipient when it is a valid URL', () => {
+    const payload = makePayload({ recipient: 'https://hooks.example.com/notify' });
+    expect(resolveWebhookUrl(payload)).toBe('https://hooks.example.com/notify');
+  });
+
+  it('should prefer metadata.webhookUrl over recipient', () => {
+    const payload = makePayload({
+      recipient: 'user-123',
+      metadata: { webhookUrl: 'https://custom.example.com/hook' },
+    });
+    expect(resolveWebhookUrl(payload)).toBe('https://custom.example.com/hook');
+  });
+
+  it('should fall back to recipient if metadata.webhookUrl is invalid', () => {
+    const payload = makePayload({
+      recipient: 'https://hooks.example.com/notify',
+      metadata: { webhookUrl: 'not-a-url' },
+    });
+    expect(resolveWebhookUrl(payload)).toBe('https://hooks.example.com/notify');
+  });
+
+  it('should return null when neither recipient nor metadata has a valid URL', () => {
+    const payload = makePayload({ recipient: 'user-123' });
+    expect(resolveWebhookUrl(payload)).toBeNull();
+  });
+});
+
+describe('formatWebhookBody', () => {
+  it('should format payload into webhook JSON body', () => {
+    const payload = makePayload({ metadata: { orderId: 'ord-1' } });
+    const body = formatWebhookBody(payload);
+
+    expect(body.type).toBe('system-alert');
+    expect(body.recipient).toBe('https://hooks.example.com/notify');
+    expect(body.subject).toBe('Test Subject');
+    expect(body.body).toBe('Test body content.');
+    expect(body.metadata).toEqual({ orderId: 'ord-1' });
+    expect(body.timestamp).toBeDefined();
+  });
+
+  it('should include undefined metadata when not provided', () => {
+    const payload = makePayload();
+    delete payload.metadata;
+    const body = formatWebhookBody(payload);
+    expect(body.metadata).toBeUndefined();
+  });
+});
+
+describe('defaultWebhookConfig', () => {
+  it('should have sensible defaults', () => {
+    expect(defaultWebhookConfig.timeoutMs).toBe(5000);
+    expect(defaultWebhookConfig.headers).toEqual({});
+  });
+});
+
+describe('WebhookAdapter', () => {
+  let transport: MockWebhookTransport;
+  let adapter: WebhookAdapter;
+
+  beforeEach(() => {
+    transport = new MockWebhookTransport();
+    adapter = new WebhookAdapter(undefined, transport);
+  });
+
+  it('should have channel set to webhook', () => {
+    expect(adapter.channel).toBe('webhook');
+  });
+
+  it('should send successfully and return success result', async () => {
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(true);
+    expect(transport.calls).toHaveLength(1);
+    expect(transport.calls[0].url).toBe('https://hooks.example.com/notify');
+  });
+
+  it('should include Content-Type header in request', async () => {
+    const payload = makePayload();
+    await adapter.send(payload);
+
+    expect(transport.calls[0].headers['Content-Type']).toBe('application/json');
+  });
+
+  it('should return failure for invalid webhook URL', async () => {
+    const payload = makePayload({ recipient: 'not-a-url' });
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('Invalid webhook URL');
+    expect(transport.calls).toHaveLength(0);
+  });
+
+  it('should return failure when transport returns non-ok status', async () => {
+    transport.nextResult = { ok: false, status: 500, error: 'Internal Server Error' };
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('Internal Server Error');
+  });
+
+  it('should return failure with status code when no error message', async () => {
+    transport.nextResult = { ok: false, status: 404 };
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('Webhook returned status 404');
+  });
+
+  it('should return failure when transport throws', async () => {
+    transport.shouldThrow = new Error('Network error');
+    const payload = makePayload();
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('Network error');
+  });
+
+  it('should use custom config headers', async () => {
+    const customAdapter = new WebhookAdapter(
+      { headers: { Authorization: 'Bearer token123' } },
+      transport,
+    );
+    const payload = makePayload();
+    await customAdapter.send(payload);
+
+    expect(transport.calls[0].headers['Authorization']).toBe('Bearer token123');
+  });
+
+  it('should use custom timeout', async () => {
+    const customAdapter = new WebhookAdapter({ timeoutMs: 10000 }, transport);
+    const payload = makePayload();
+    await customAdapter.send(payload);
+
+    expect(transport.calls[0].timeoutMs).toBe(10000);
+  });
+
+  it('should format the body as a WebhookPayloadBody', async () => {
+    const payload = makePayload({
+      type: 'order-confirmation',
+      metadata: { orderId: 'ord-42' },
+    });
+    await adapter.send(payload);
+
+    const sentBody = transport.calls[0].body;
+    expect(sentBody.type).toBe('order-confirmation');
+    expect(sentBody.subject).toBe('Test Subject');
+    expect(sentBody.body).toBe('Test body content.');
+    expect(sentBody.metadata).toEqual({ orderId: 'ord-42' });
+    expect(sentBody.timestamp).toBeDefined();
+  });
+
+  it('should resolve URL from metadata.webhookUrl', async () => {
+    const payload = makePayload({
+      recipient: 'user-123',
+      metadata: { webhookUrl: 'https://custom.example.com/hook' },
+    });
+    const result = await adapter.send(payload);
+
+    expect(result.success).toBe(true);
+    expect(transport.calls[0].url).toBe('https://custom.example.com/hook');
+  });
+});
