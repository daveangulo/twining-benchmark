 const VALID_FREQUENCIES = ['immediate', 'daily-digest', 'weekly-digest'] as const;
+const VALID_CHANNELS = ['email', 'sms', 'webhook', 'in-app'] as const;
+
+function validateChannelsInput(channels: CreatePreferencesInput['channels']): void {
+  if (!channels) return;
+  for (const [ch, chInput] of Object.entries(channels)) {
+    if (!VALID_CHANNELS.includes(ch as (typeof VALID_CHANNELS)[number])) {
+      throw new Error(`Invalid channel: ${ch}`);
+    }
+    if (!chInput) continue;
+    if (ch === 'email' && 'frequency' in chInput && chInput.frequency !== undefined) {
+      if (!VALID_FREQUENCIES.includes(chInput.frequency)) {
+        throw new Error(`Invalid email frequency in channel preferences: ${chInput.frequency}`);
+      }
+    }
+  }
+}
 
