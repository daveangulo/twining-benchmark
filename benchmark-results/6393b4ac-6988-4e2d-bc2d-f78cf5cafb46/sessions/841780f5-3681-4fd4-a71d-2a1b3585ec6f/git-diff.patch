+import { describe, it, expect } from 'vitest';
+import {
+  validateUserExists,
+  validateEmailUnique,
+  validateEmailNotInUse,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const makeUser = (overrides: Partial<User> = {}): User => ({
+  id: 'user-1',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+  ...overrides,
+});
+
+describe('user.validator', () => {
+  describe('validateUserExists', () => {
+    it('should not throw when user exists', () => {
+      expect(() => validateUserExists(makeUser(), 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists(undefined, 'user-42')).toThrow(
+        'User not found: user-42',
+      );
+    });
+  });
+
+  describe('validateEmailUnique', () => {
+    it('should not throw when no existing user', () => {
+      expect(() => validateEmailUnique(undefined, 'new@example.com')).not.toThrow();
+    });
+
+    it('should throw when email is already taken', () => {
+      expect(() => validateEmailUnique(makeUser(), 'alice@example.com')).toThrow(
+        'User with email alice@example.com already exists',
+      );
+    });
+  });
+
+  describe('validateEmailNotInUse', () => {
+    it('should not throw when no existing user', () => {
+      expect(() => validateEmailNotInUse(undefined, 'new@example.com')).not.toThrow();
+    });
+
+    it('should throw when email is in use', () => {
+      expect(() => validateEmailNotInUse(makeUser(), 'alice@example.com')).toThrow(
+        'Email alice@example.com is already in use',
+      );
+    });
+  });
+});
