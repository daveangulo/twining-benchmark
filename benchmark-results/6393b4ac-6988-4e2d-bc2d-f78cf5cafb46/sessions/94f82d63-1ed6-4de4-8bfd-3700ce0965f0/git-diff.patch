index 0000000..ec1cc6f
--- /dev/null
+++ b/src/validators/preferences.validator.ts
@@ -0,0 +1,15 @@
+/**
+ * Pure validation functions for user preferences.
+ */
+
+import type { NotificationType } from '../models/notification.js';
+import { ALL_NOTIFICATION_CATEGORIES } from '../models/user-preferences.js';
+
+/**
+ * Validate that the given categories are all valid notification types.
+ */
+export function validateCategories(categories: string[]): categories is NotificationType[] {
+  return categories.every((cat) =>
+    (ALL_NOTIFICATION_CATEGORIES as string[]).includes(cat),
+  );
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..99c414b
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,62 @@
+import { describe, it, expect } from 'vitest';
+import { validateOrderHasItems, isValidStatusTransition } from '../../src/validators/order.validator.js';
+import type { OrderItem } from '../../src/models/order.js';
+
+describe('order.validator', () => {
+  describe('validateOrderHasItems', () => {
+    it('should pass when items are present', () => {
+      const items: OrderItem[] = [
+        { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+      ];
+      expect(() => validateOrderHasItems(items)).not.toThrow();
+    });
+
+    it('should throw when items array is empty', () => {
+      expect(() => validateOrderHasItems([])).toThrow('Order must have at least one item');
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject pending -> shipped', () => {
+      expect(isValidStatusTransition('pending', 'shipped')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(isValidStatusTransition('delivered', 'pending')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'confirmed')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'shipped')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'cancelled')).toBe(false);
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(isValidStatusTransition('cancelled', 'pending')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'confirmed')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'shipped')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'delivered')).toBe(false);
+    });
+  });
+});
diff --git a/tests/validators/preferences.validator.test.ts b/tests/validators/preferences.validator.test.ts
new file mode 100644
index 0000000..3ecde40
--- /dev/null
+++ b/tests/validators/preferences.validator.test.ts
@@ -0,0 +1,33 @@
+import { describe, it, expect } from 'vitest';
+import { validateCategories } from '../../src/validators/preferences.validator.js';
+
+describe('preferences.validator', () => {
+  describe('validateCategories', () => {
+    it('should accept valid categories', () => {
+      expect(validateCategories(['order_confirmation', 'user_welcome'])).toBe(true);
+    });
+
+    it('should accept all valid categories', () => {
+      expect(
+        validateCategories([
+          'order_confirmation',
+          'order_status_update',
+          'user_welcome',
+          'user_updated',
+        ]),
+      ).toBe(true);
+    });
+
+    it('should reject invalid categories', () => {
+      expect(validateCategories(['order_confirmation', 'invalid_type'])).toBe(false);
+    });
+
+    it('should reject completely invalid categories', () => {
+      expect(validateCategories(['not_a_category'])).toBe(false);
+    });
+
+    it('should accept empty array', () => {
+      expect(validateCategories([])).toBe(true);
+    });
+  });
+});
