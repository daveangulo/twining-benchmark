diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..ff7310f
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,125 @@
+/**
+ * Preferences service — business logic for managing user notification preferences.
+ *
+ * Depends on:
+ * - PreferencesRepository (data layer) for persistence
+ *
+ * Provides methods to get, create, and update user preferences. When no
+ * preferences exist for a user, returns sensible defaults (all notifications
+ * enabled at immediate frequency).
+ *
+ * Used by NotificationService to check whether a notification should be
+ * delivered to a given user.
+ */
+
+import type { UserPreferences, UpdateEmailPreferencesInput } from '../models/user-preferences.js';
+import { DEFAULT_EMAIL_PREFERENCES } from '../models/user-preferences.js';
+import type { NotificationType } from '../models/notification.js';
+import type { PreferencesRepository } from '../repositories/preferences.repository.js';
+import { Logger } from '../utils/logger.js';
+
+let nextId = 1;
+
+function generateId(): string {
+  return `pref-${String(nextId++).padStart(4, '0')}`;
+}
+
+export function resetPreferencesIdCounter(): void {
+  nextId = 1;
+}
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(private preferencesRepository: PreferencesRepository) {}
+
+  /**
+   * Get preferences for a user. Returns stored preferences if they exist,
+   * otherwise returns defaults without persisting them.
+   */
+  getPreferences(userId: string): UserPreferences {
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (existing) {
+      return existing;
+    }
+
+    this.logger.info(`No preferences found for user ${userId}, returning defaults`);
+    const now = new Date();
+    return {
+      id: '',
+      userId,
+      email: { ...DEFAULT_EMAIL_PREFERENCES, subscribedCategories: [...DEFAULT_EMAIL_PREFERENCES.subscribedCategories] },
+      createdAt: now,
+      updatedAt: now,
+    };
+  }
+
+  /**
+   * Create or update email preferences for a user. If no preferences record
+   * exists, one is created. Otherwise the existing record is updated.
+   */
+  updateEmailPreferences(userId: string, input: UpdateEmailPreferencesInput): UserPreferences {
+    this.logger.info(`Updating email preferences for user ${userId}`);
+
+    const existing = this.preferencesRepository.findByUserId(userId);
+
+    if (existing) {
+      const updatedEmail = {
+        enabled: input.enabled ?? existing.email.enabled,
+        frequency: input.frequency ?? existing.email.frequency,
+        subscribedCategories: input.subscribedCategories ?? [...existing.email.subscribedCategories],
+      };
+
+      return this.preferencesRepository.update(existing.id, {
+        email: updatedEmail,
+        updatedAt: new Date(),
+      });
+    }
+
+    // Create new preferences record
+    const now = new Date();
+    const prefs: UserPreferences = {
+      id: generateId(),
+      userId,
+      email: {
+        enabled: input.enabled ?? DEFAULT_EMAIL_PREFERENCES.enabled,
+        frequency: input.frequency ?? DEFAULT_EMAIL_PREFERENCES.frequency,
+        subscribedCategories: input.subscribedCategories ?? [...DEFAULT_EMAIL_PREFERENCES.subscribedCategories],
+      },
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    this.preferencesRepository.save(prefs);
+    this.logger.info(`Created preferences ${prefs.id} for user ${userId}`);
+    return prefs;
+  }
+
+  /**
+   * Check whether a notification should be sent to a user via email.
+   * Returns true if:
+   * - Email is enabled
+   * - Frequency is not 'never'
+   * - The notification type is in the user's subscribed categories
+   */
+  shouldSendEmail(userId: string, notificationType: NotificationType): boolean {
+    const prefs = this.getPreferences(userId);
+
+    if (!prefs.email.enabled) {
+      this.logger.info(`Email disabled for user ${userId}, skipping ${notificationType}`);
+      return false;
+    }
+
+    if (prefs.email.frequency === 'never') {
+      this.logger.info(`Email frequency is 'never' for user ${userId}, skipping ${notificationType}`);
+      return false;
+    }
+
+    if (!prefs.email.subscribedCategories.includes(notificationType)) {
+      this.logger.info(`User ${userId} not subscribed to ${notificationType}, skipping`);
+      return false;
+    }
+
+    return true;
+  }
+}
diff --git a/tests/services/preferences.service.test.ts b/tests/services/preferences.service.test.ts
new file mode 100644
index 0000000..07a7cef
--- /dev/null
+++ b/tests/services/preferences.service.test.ts
@@ -0,0 +1,248 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { OrderCreatedEvent } from '../../src/events/event-types.js';
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let preferencesRepo: PreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    preferencesRepo = new PreferencesRepository(db);
+    service = new PreferencesService(preferencesRepo);
+    resetPreferencesIdCounter();
+  });
+
+  describe('getPreferences', () => {
+    it('should return defaults when no preferences exist', () => {
+      const prefs = service.getPreferences('user-1');
+
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.subscribedCategories).toEqual([
+        'order_confirmation',
+        'order_status_update',
+        'user_welcome',
+        'user_updated',
+      ]);
+    });
+
+    it('should return stored preferences when they exist', () => {
+      service.updateEmailPreferences('user-1', { frequency: 'daily_digest' });
+
+      const prefs = service.getPreferences('user-1');
+      expect(prefs.email.frequency).toBe('daily_digest');
+      expect(prefs.id).toBe('pref-0001');
+    });
+  });
+
+  describe('updateEmailPreferences', () => {
+    it('should create preferences on first update', () => {
+      const prefs = service.updateEmailPreferences('user-1', {
+        enabled: false,
+      });
+
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(false);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.subscribedCategories).toHaveLength(4);
+    });
+
+    it('should update existing preferences', () => {
+      service.updateEmailPreferences('user-1', { frequency: 'daily_digest' });
+      const updated = service.updateEmailPreferences('user-1', {
+        frequency: 'weekly_digest',
+      });
+
+      expect(updated.id).toBe('pref-0001');
+      expect(updated.email.frequency).toBe('weekly_digest');
+      expect(updated.email.enabled).toBe(true);
+    });
+
+    it('should update subscribed categories', () => {
+      const prefs = service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['order_confirmation'],
+      });
+
+      expect(prefs.email.subscribedCategories).toEqual(['order_confirmation']);
+    });
+
+    it('should preserve unchanged fields on update', () => {
+      service.updateEmailPreferences('user-1', {
+        enabled: true,
+        frequency: 'daily_digest',
+        subscribedCategories: ['order_confirmation', 'order_status_update'],
+      });
+
+      const updated = service.updateEmailPreferences('user-1', {
+        frequency: 'weekly_digest',
+      });
+
+      expect(updated.email.enabled).toBe(true);
+      expect(updated.email.frequency).toBe('weekly_digest');
+      expect(updated.email.subscribedCategories).toEqual([
+        'order_confirmation',
+        'order_status_update',
+      ]);
+    });
+
+    it('should generate sequential IDs for different users', () => {
+      const prefs1 = service.updateEmailPreferences('user-1', {});
+      const prefs2 = service.updateEmailPreferences('user-2', {});
+
+      expect(prefs1.id).toBe('pref-0001');
+      expect(prefs2.id).toBe('pref-0002');
+    });
+  });
+
+  describe('shouldSendEmail', () => {
+    it('should return true with default preferences', () => {
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(true);
+    });
+
+    it('should return false when email is disabled', () => {
+      service.updateEmailPreferences('user-1', { enabled: false });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false when frequency is never', () => {
+      service.updateEmailPreferences('user-1', { frequency: 'never' });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false when category is not subscribed', () => {
+      service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['order_status_update'],
+      });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+      expect(service.shouldSendEmail('user-1', 'order_status_update')).toBe(true);
+    });
+
+    it('should return true for subscribed categories with non-immediate frequency', () => {
+      service.updateEmailPreferences('user-1', { frequency: 'daily_digest' });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(true);
+    });
+  });
+});
+
+describe('NotificationService with preferences', () => {
+  let eventBus: EventBus;
+  let db: Database;
+  let preferencesRepo: PreferencesRepository;
+  let preferencesService: PreferencesService;
+  let notificationService: NotificationService;
+  let emailAdapter: EmailAdapter;
+
+  function makeOrderCreatedEvent(userId: string, email: string): OrderCreatedEvent {
+    return {
+      type: 'order:created',
+      order: {
+        id: 'order-1',
+        userId,
+        items: [
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+        ],
+        total: 10,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: {
+        id: userId,
+        name: 'Test User',
+        email,
+        role: 'member',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      timestamp: new Date(),
+    };
+  }
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    db = new Database();
+    preferencesRepo = new PreferencesRepository(db);
+    preferencesService = new PreferencesService(preferencesRepo);
+    notificationService = new NotificationService(eventBus, preferencesService);
+    emailAdapter = new EmailAdapter();
+    notificationService.registerAdapter(emailAdapter);
+    resetNotificationIdCounter();
+    resetPreferencesIdCounter();
+  });
+
+  it('should send notification when user has default preferences', async () => {
+    await eventBus.emit(makeOrderCreatedEvent('user-1', 'alice@example.com'));
+
+    expect(notificationService.getNotifications()).toHaveLength(1);
+    expect(emailAdapter.getSentEmails()).toHaveLength(1);
+  });
+
+  it('should suppress notification when email is disabled', async () => {
+    preferencesService.updateEmailPreferences('user-1', { enabled: false });
+
+    await eventBus.emit(makeOrderCreatedEvent('user-1', 'alice@example.com'));
+
+    expect(notificationService.getNotifications()).toHaveLength(0);
+    expect(emailAdapter.getSentEmails()).toHaveLength(0);
+  });
+
+  it('should suppress notification when category is unsubscribed', async () => {
+    preferencesService.updateEmailPreferences('user-1', {
+      subscribedCategories: ['order_status_update'],
+    });
+
+    await eventBus.emit(makeOrderCreatedEvent('user-1', 'alice@example.com'));
+
+    expect(notificationService.getNotifications()).toHaveLength(0);
+    expect(emailAdapter.getSentEmails()).toHaveLength(0);
+  });
+
+  it('should suppress notification when frequency is never', async () => {
+    preferencesService.updateEmailPreferences('user-1', { frequency: 'never' });
+
+    await eventBus.emit(makeOrderCreatedEvent('user-1', 'alice@example.com'));
+
+    expect(notificationService.getNotifications()).toHaveLength(0);
+  });
+
+  it('should send notification when category is subscribed', async () => {
+    preferencesService.updateEmailPreferences('user-1', {
+      subscribedCategories: ['order_confirmation'],
+    });
+
+    await eventBus.emit(makeOrderCreatedEvent('user-1', 'alice@example.com'));
+
+    expect(notificationService.getNotifications()).toHaveLength(1);
+  });
+
+  it('should handle different preferences for different users', async () => {
+    preferencesService.updateEmailPreferences('user-1', { enabled: false });
+    // user-2 keeps defaults (all enabled)
+
+    await eventBus.emit(makeOrderCreatedEvent('user-1', 'alice@example.com'));
+    await eventBus.emit(makeOrderCreatedEvent('user-2', 'bob@example.com'));
+
+    expect(notificationService.getNotifications()).toHaveLength(1);
+    expect(notificationService.getNotificationsForRecipient('bob@example.com')).toHaveLength(1);
+    expect(notificationService.getNotificationsForRecipient('alice@example.com')).toHaveLength(0);
+  });
+});
