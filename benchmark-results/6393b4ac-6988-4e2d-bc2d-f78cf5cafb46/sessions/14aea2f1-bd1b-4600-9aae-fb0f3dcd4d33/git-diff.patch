diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..d056bee
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,131 @@
+/**
+ * Preferences service — manages user notification preferences.
+ *
+ * Provides CRUD operations for notification preferences and exposes
+ * a method for the notification service to check whether a given
+ * notification should be delivered to a user.
+ *
+ * Depends on:
+ * - PreferencesRepository for data access
+ */
+
+import type { PreferencesRepository } from '../repositories/preferences.repository.js';
+import type {
+  UserNotificationPreferences,
+  UpdateEmailPreferencesInput,
+} from '../models/user-preferences.js';
+import type { NotificationType } from '../models/notification.js';
+import { getDefaultEmailPreferences } from '../models/user-preferences.js';
+import { Logger } from '../utils/logger.js';
+
+let nextId = 1;
+
+function generatePreferencesId(): string {
+  return `pref-${String(nextId++).padStart(4, '0')}`;
+}
+
+export function resetPreferencesIdCounter(): void {
+  nextId = 1;
+}
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(private preferencesRepository: PreferencesRepository) {}
+
+  /**
+   * Get preferences for a user. Returns defaults if none are persisted.
+   */
+  getPreferences(userId: string): UserNotificationPreferences {
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (existing) {
+      return existing;
+    }
+
+    return {
+      id: '',
+      userId,
+      email: getDefaultEmailPreferences(),
+      updatedAt: new Date(),
+    };
+  }
+
+  /**
+   * Update email preferences for a user. Creates preferences if they
+   * don't exist yet.
+   */
+  updateEmailPreferences(
+    userId: string,
+    input: UpdateEmailPreferencesInput,
+  ): UserNotificationPreferences {
+    const existing = this.preferencesRepository.findByUserId(userId);
+
+    if (existing) {
+      const updated: UserNotificationPreferences = {
+        ...existing,
+        email: {
+          enabled: input.enabled ?? existing.email.enabled,
+          frequency: input.frequency ?? existing.email.frequency,
+          subscribedCategories:
+            input.subscribedCategories ?? existing.email.subscribedCategories,
+        },
+        updatedAt: new Date(),
+      };
+      this.preferencesRepository.update(existing.id, updated);
+      this.logger.info(`Updated email preferences for user ${userId}`);
+      return updated;
+    }
+
+    const defaults = getDefaultEmailPreferences();
+    const prefs: UserNotificationPreferences = {
+      id: generatePreferencesId(),
+      userId,
+      email: {
+        enabled: input.enabled ?? defaults.enabled,
+        frequency: input.frequency ?? defaults.frequency,
+        subscribedCategories:
+          input.subscribedCategories ?? defaults.subscribedCategories,
+      },
+      updatedAt: new Date(),
+    };
+    this.preferencesRepository.save(prefs);
+    this.logger.info(`Created email preferences for user ${userId}`);
+    return prefs;
+  }
+
+  /**
+   * Check whether an email notification of the given type should be
+   * sent to the specified user based on their preferences.
+   *
+   * Returns true if:
+   * - The user has no persisted preferences (defaults allow all)
+   * - Email is enabled AND the category is subscribed AND frequency is not 'none'
+   */
+  shouldSendEmail(userId: string, notificationType: NotificationType): boolean {
+    const prefs = this.preferencesRepository.findByUserId(userId);
+
+    // No preferences stored — use defaults (everything enabled)
+    if (!prefs) {
+      return true;
+    }
+
+    if (!prefs.email.enabled) {
+      this.logger.info(`Email disabled for user ${userId}, skipping ${notificationType}`);
+      return false;
+    }
+
+    if (prefs.email.frequency === 'none') {
+      this.logger.info(`Email frequency is none for user ${userId}, skipping ${notificationType}`);
+      return false;
+    }
+
+    if (!prefs.email.subscribedCategories.includes(notificationType)) {
+      this.logger.info(
+        `User ${userId} not subscribed to ${notificationType}, skipping`,
+      );
+      return false;
+    }
+
+    return true;
+  }
+}
diff --git a/tests/services/preferences.service.test.ts b/tests/services/preferences.service.test.ts
new file mode 100644
index 0000000..6ab51a7
--- /dev/null
+++ b/tests/services/preferences.service.test.ts
@@ -0,0 +1,159 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import { ALL_NOTIFICATION_CATEGORIES } from '../../src/models/user-preferences.js';
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let repo: PreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    repo = new PreferencesRepository(db);
+    service = new PreferencesService(repo);
+    resetPreferencesIdCounter();
+  });
+
+  describe('getPreferences', () => {
+    it('should return defaults when no preferences exist', () => {
+      const prefs = service.getPreferences('user-1');
+
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.subscribedCategories).toEqual(ALL_NOTIFICATION_CATEGORIES);
+    });
+
+    it('should return stored preferences when they exist', () => {
+      service.updateEmailPreferences('user-1', { frequency: 'daily-digest' });
+      const prefs = service.getPreferences('user-1');
+
+      expect(prefs.email.frequency).toBe('daily-digest');
+      expect(prefs.email.enabled).toBe(true);
+    });
+  });
+
+  describe('updateEmailPreferences', () => {
+    it('should create preferences on first update', () => {
+      const prefs = service.updateEmailPreferences('user-1', {
+        enabled: false,
+      });
+
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(false);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.subscribedCategories).toEqual(ALL_NOTIFICATION_CATEGORIES);
+    });
+
+    it('should update existing preferences', () => {
+      service.updateEmailPreferences('user-1', { enabled: true });
+      const updated = service.updateEmailPreferences('user-1', {
+        frequency: 'weekly-digest',
+      });
+
+      expect(updated.email.enabled).toBe(true);
+      expect(updated.email.frequency).toBe('weekly-digest');
+    });
+
+    it('should update subscribed categories', () => {
+      const prefs = service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['order:confirmation'],
+      });
+
+      expect(prefs.email.subscribedCategories).toEqual(['order:confirmation']);
+    });
+
+    it('should preserve unspecified fields when updating', () => {
+      service.updateEmailPreferences('user-1', {
+        enabled: true,
+        frequency: 'daily-digest',
+        subscribedCategories: ['order:confirmation', 'order:status-update'],
+      });
+
+      const updated = service.updateEmailPreferences('user-1', {
+        frequency: 'weekly-digest',
+      });
+
+      expect(updated.email.enabled).toBe(true);
+      expect(updated.email.frequency).toBe('weekly-digest');
+      expect(updated.email.subscribedCategories).toEqual([
+        'order:confirmation',
+        'order:status-update',
+      ]);
+    });
+
+    it('should generate sequential IDs for new preferences', () => {
+      const prefs1 = service.updateEmailPreferences('user-1', {});
+      const prefs2 = service.updateEmailPreferences('user-2', {});
+
+      expect(prefs1.id).toBe('pref-0001');
+      expect(prefs2.id).toBe('pref-0002');
+    });
+  });
+
+  describe('shouldSendEmail', () => {
+    it('should return true when no preferences are stored (defaults)', () => {
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(true);
+    });
+
+    it('should return true when email is enabled and category is subscribed', () => {
+      service.updateEmailPreferences('user-1', {
+        enabled: true,
+        frequency: 'immediate',
+        subscribedCategories: ['order:confirmation'],
+      });
+
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(true);
+    });
+
+    it('should return false when email is disabled', () => {
+      service.updateEmailPreferences('user-1', { enabled: false });
+
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(false);
+      expect(service.shouldSendEmail('user-1', 'order:status-update')).toBe(false);
+    });
+
+    it('should return false when frequency is none', () => {
+      service.updateEmailPreferences('user-1', { frequency: 'none' });
+
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(false);
+    });
+
+    it('should return false when category is not subscribed', () => {
+      service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['order:confirmation'],
+      });
+
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(true);
+      expect(service.shouldSendEmail('user-1', 'order:status-update')).toBe(false);
+    });
+
+    it('should return false when subscribed categories is empty', () => {
+      service.updateEmailPreferences('user-1', {
+        subscribedCategories: [],
+      });
+
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(false);
+    });
+
+    it('should allow daily-digest frequency', () => {
+      service.updateEmailPreferences('user-1', { frequency: 'daily-digest' });
+
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(true);
+    });
+
+    it('should handle preferences for different users independently', () => {
+      service.updateEmailPreferences('user-1', { enabled: false });
+      service.updateEmailPreferences('user-2', { enabled: true });
+
+      expect(service.shouldSendEmail('user-1', 'order:confirmation')).toBe(false);
+      expect(service.shouldSendEmail('user-2', 'order:confirmation')).toBe(true);
+    });
+  });
+});
