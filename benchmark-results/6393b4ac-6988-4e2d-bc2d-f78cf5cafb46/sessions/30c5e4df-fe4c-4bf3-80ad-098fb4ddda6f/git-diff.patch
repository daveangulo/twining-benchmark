+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,316 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookNotificationAdapter,
+  isValidWebhookUrl,
+  formatWebhookPayload,
+} from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+describe('WebhookNotificationAdapter', () => {
+  let adapter: WebhookNotificationAdapter;
+
+  beforeEach(() => {
+    adapter = new WebhookNotificationAdapter();
+  });
+
+  describe('send', () => {
+    it('should send webhook for a valid URL and payload', async () => {
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Order Confirmation: order-1',
+        body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(true);
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.url).toBe('http://localhost:8080/webhooks');
+      expect(deliveries[0]?.payload.type).toBe('order:confirmation');
+      expect(deliveries[0]?.payload.recipient).toBe('user-123');
+      expect(deliveries[0]?.payload.subject).toBe('Order Confirmation: order-1');
+      expect(deliveries[0]?.payload.body).toContain('Widget x2');
+      expect(deliveries[0]?.statusCode).toBe(200);
+    });
+
+    it('should reject invalid webhook URL', async () => {
+      adapter = new WebhookNotificationAdapter({ url: 'not-a-url' });
+
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Test',
+        body: 'Test body',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(false);
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+
+    it('should include metadata in webhook payload', async () => {
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Order Confirmation: order-1',
+        body: 'Your order has been placed.',
+        metadata: { orderId: 'order-1', total: 20.0 },
+      };
+
+      await adapter.send(payload);
+
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries[0]?.payload.metadata).toEqual({ orderId: 'order-1', total: 20.0 });
+    });
+
+    it('should include timestamp in webhook payload', async () => {
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Test',
+        body: 'Test',
+      };
+
+      await adapter.send(payload);
+
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries[0]?.payload.timestamp).toBeDefined();
+      // Timestamp should be a valid ISO string
+      expect(new Date(deliveries[0]!.payload.timestamp).toISOString()).toBe(
+        deliveries[0]!.payload.timestamp,
+      );
+    });
+
+    it('should send webhook for order status update', async () => {
+      const payload: NotificationPayload = {
+        type: 'order:status-update',
+        recipient: 'user-123',
+        subject: 'Order Update: order-1',
+        body: 'Status changed from pending to confirmed.',
+        metadata: { newStatus: 'confirmed' },
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(true);
+      expect(adapter.getDeliveries()[0]?.payload.type).toBe('order:status-update');
+    });
+
+    it('should send webhook for user welcome', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:welcome',
+        recipient: 'user-456',
+        subject: 'Welcome to TaskFlow!',
+        body: 'Welcome, New User!',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(true);
+      expect(adapter.getDeliveries()[0]?.payload.type).toBe('user:welcome');
+    });
+
+    it('should send webhook for profile update', async () => {
+      const payload: NotificationPayload = {
+        type: 'user:profile-updated',
+        recipient: 'user-123',
+        subject: 'Profile Updated',
+        body: 'Your profile has been updated.',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(true);
+      expect(adapter.getDeliveries()[0]?.payload.type).toBe('user:profile-updated');
+    });
+  });
+
+  describe('retry behavior', () => {
+    it('should retry on transient HTTP failure and succeed', async () => {
+      adapter = new WebhookNotificationAdapter({ maxRetries: 2, retryDelayMs: 1 });
+
+      let attempts = 0;
+      adapter.setHttpPostFn(async () => {
+        attempts++;
+        if (attempts < 2) {
+          throw new Error('Connection refused');
+        }
+        return 200;
+      });
+
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Test',
+        body: 'Test',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(true);
+      expect(attempts).toBe(2);
+      expect(adapter.getDeliveries()).toHaveLength(1);
+    });
+
+    it('should fail after exhausting all retries', async () => {
+      adapter = new WebhookNotificationAdapter({ maxRetries: 1, retryDelayMs: 1 });
+
+      adapter.setHttpPostFn(async () => {
+        throw new Error('Server unreachable');
+      });
+
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Test',
+        body: 'Test',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(false);
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+
+    it('should retry when server returns non-2xx status', async () => {
+      adapter = new WebhookNotificationAdapter({ maxRetries: 2, retryDelayMs: 1 });
+
+      let attempts = 0;
+      adapter.setHttpPostFn(async () => {
+        attempts++;
+        return attempts >= 3 ? 200 : 500;
+      });
+
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Test',
+        body: 'Test',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(true);
+      expect(attempts).toBe(3);
+    });
+
+    it('should fail when server consistently returns non-2xx', async () => {
+      adapter = new WebhookNotificationAdapter({ maxRetries: 1, retryDelayMs: 1 });
+
+      adapter.setHttpPostFn(async () => 503);
+
+      const payload: NotificationPayload = {
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Test',
+        body: 'Test',
+      };
+
+      const result = await adapter.send(payload);
+
+      expect(result).toBe(false);
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+  });
+
+  describe('configuration', () => {
+    it('should use default config', () => {
+      const config = adapter.getConfig();
+      expect(config.url).toBe('http://localhost:8080/webhooks');
+      expect(config.maxRetries).toBe(3);
+      expect(config.retryDelayMs).toBe(200);
+      expect(config.timeoutMs).toBe(5000);
+    });
+
+    it('should accept custom config', () => {
+      const custom = new WebhookNotificationAdapter({
+        url: 'https://api.example.com/hooks',
+        maxRetries: 5,
+        timeoutMs: 10000,
+      });
+      const config = custom.getConfig();
+      expect(config.url).toBe('https://api.example.com/hooks');
+      expect(config.maxRetries).toBe(5);
+      expect(config.timeoutMs).toBe(10000);
+      expect(config.retryDelayMs).toBe(200); // still default
+    });
+  });
+
+  describe('clearDeliveries', () => {
+    it('should clear delivery history', async () => {
+      await adapter.send({
+        type: 'order:confirmation',
+        recipient: 'user-123',
+        subject: 'Test',
+        body: 'Test',
+      });
+
+      expect(adapter.getDeliveries()).toHaveLength(1);
+      adapter.clearDeliveries();
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+  });
+
+  describe('channel', () => {
+    it('should report webhook as its channel', () => {
+      expect(adapter.channel).toBe('webhook');
+    });
+  });
+});
+
+describe('isValidWebhookUrl', () => {
+  it('should accept valid HTTP URLs', () => {
+    expect(isValidWebhookUrl('http://localhost:8080/webhooks')).toBe(true);
+    expect(isValidWebhookUrl('http://example.com/hook')).toBe(true);
+  });
+
+  it('should accept valid HTTPS URLs', () => {
+    expect(isValidWebhookUrl('https://api.example.com/webhooks')).toBe(true);
+    expect(isValidWebhookUrl('https://hooks.slack.com/services/T00/B00/xxx')).toBe(true);
+  });
+
+  it('should reject invalid URLs', () => {
+    expect(isValidWebhookUrl('not-a-url')).toBe(false);
+    expect(isValidWebhookUrl('')).toBe(false);
+    expect(isValidWebhookUrl('ftp://example.com/hook')).toBe(false);
+    expect(isValidWebhookUrl('ws://example.com/hook')).toBe(false);
+  });
+});
+
+describe('formatWebhookPayload', () => {
+  it('should format notification payload as webhook body', () => {
+    const payload: NotificationPayload = {
+      type: 'order:confirmation',
+      recipient: 'user-123',
+      subject: 'Order Confirmation: order-1',
+      body: 'Items: Widget x2',
+      metadata: { orderId: 'order-1' },
+    };
+
+    const result = formatWebhookPayload(payload);
+
+    expect(result.type).toBe('order:confirmation');
+    expect(result.recipient).toBe('user-123');
+    expect(result.subject).toBe('Order Confirmation: order-1');
+    expect(result.body).toBe('Items: Widget x2');
+    expect(result.metadata).toEqual({ orderId: 'order-1' });
+    expect(result.timestamp).toBeDefined();
+  });
+
+  it('should handle payload without metadata', () => {
+    const payload: NotificationPayload = {
+      type: 'user:welcome',
+      recipient: 'user-456',
+      subject: 'Welcome!',
+      body: 'Hello!',
+    };
+
+    const result = formatWebhookPayload(payload);
+
+    expect(result.metadata).toBeUndefined();
+    expect(result.type).toBe('user:welcome');
+  });
+});
