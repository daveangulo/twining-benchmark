+++ b/tests/adapters/sms.adapter.test.ts
@@ -0,0 +1,233 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  SmsAdapter,
+  InMemorySmsTransport,
+  type SmsTransport,
+} from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function createPayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order:confirmation',
+    channel: 'sms',
+    recipient: '+15551234567',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    priority: 'normal',
+    createdAt: new Date(),
+    ...overrides,
+  };
+}
+
+describe('SmsAdapter', () => {
+  let adapter: SmsAdapter;
+  let transport: InMemorySmsTransport;
+
+  beforeEach(() => {
+    transport = new InMemorySmsTransport();
+    adapter = new SmsAdapter({ transport });
+  });
+
+  describe('send', () => {
+    it('should deliver an SMS through the transport', async () => {
+      const payload = createPayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('sms');
+
+      const sent = transport.getSentMessages();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.to).toBe('+15551234567');
+    });
+
+    it('should use configured from number', async () => {
+      adapter = new SmsAdapter({
+        transport,
+        fromNumber: '+18005551234',
+      });
+
+      await adapter.send(createPayload());
+
+      const sent = transport.getSentMessages();
+      expect(sent[0]?.from).toBe('+18005551234');
+    });
+
+    it('should use default from number when not configured', async () => {
+      await adapter.send(createPayload());
+
+      const sent = transport.getSentMessages();
+      expect(sent[0]?.from).toBe('+10000000000');
+    });
+
+    it('should track sent messages', async () => {
+      await adapter.send(createPayload());
+      await adapter.send(createPayload({ id: 'notif-0002', recipient: '+15559876543' }));
+
+      expect(adapter.getSentMessages()).toHaveLength(2);
+    });
+
+    it('should clear sent messages', async () => {
+      await adapter.send(createPayload());
+      adapter.clearSentMessages();
+
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should fail for invalid recipient', async () => {
+      const payload = createPayload({ recipient: 'not-a-phone-number' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid phone number');
+      expect(transport.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should fail for empty recipient', async () => {
+      const payload = createPayload({ recipient: '' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+    });
+
+    it('should fail for phone number without country code', async () => {
+      const payload = createPayload({ recipient: '5551234567' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid phone number');
+    });
+
+    it('should handle transport errors gracefully', async () => {
+      const failingTransport: SmsTransport = {
+        sendSms: async () => {
+          throw new Error('SMS gateway unavailable');
+        },
+      };
+
+      adapter = new SmsAdapter({ transport: failingTransport });
+      const result = await adapter.send(createPayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('SMS gateway unavailable');
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should handle non-Error transport throws', async () => {
+      const failingTransport: SmsTransport = {
+        sendSms: async () => {
+          throw 'string error';
+        },
+      };
+
+      adapter = new SmsAdapter({ transport: failingTransport });
+      const result = await adapter.send(createPayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Unknown transport error');
+    });
+  });
+
+  describe('resolveRecipient', () => {
+    it('should trim whitespace', () => {
+      expect(adapter.resolveRecipient('  +15551234567  ')).toBe('+15551234567');
+    });
+
+    it('should return null for invalid phone numbers', () => {
+      expect(adapter.resolveRecipient('not-a-number')).toBeNull();
+      expect(adapter.resolveRecipient('12345')).toBeNull();
+      expect(adapter.resolveRecipient('+0123456789')).toBeNull();
+      expect(adapter.resolveRecipient('')).toBeNull();
+    });
+
+    it('should accept valid E.164 phone numbers', () => {
+      expect(adapter.resolveRecipient('+15551234567')).toBe('+15551234567');
+      expect(adapter.resolveRecipient('+442071234567')).toBe('+442071234567');
+      expect(adapter.resolveRecipient('+8613812345678')).toBe('+8613812345678');
+    });
+  });
+
+  describe('renderTemplate', () => {
+    it('should render order confirmation template', () => {
+      const payload = createPayload({ type: 'order:confirmation' });
+      const body = adapter.renderTemplate(payload);
+
+      expect(body).toContain('Order confirmed');
+      expect(body).toContain('TaskFlow Pro');
+    });
+
+    it('should render order status update template', () => {
+      const payload = createPayload({
+        type: 'order:status-update',
+        body: 'Your order status has changed from pending to confirmed.',
+      });
+      const body = adapter.renderTemplate(payload);
+
+      expect(body).toContain('pending to confirmed');
+      expect(body).toContain('TaskFlow Pro');
+    });
+
+    it('should render user welcome template', () => {
+      const payload = createPayload({
+        type: 'user:welcome',
+        body: 'Welcome aboard!',
+      });
+      const body = adapter.renderTemplate(payload);
+
+      expect(body).toContain('Welcome to TaskFlow Pro');
+      expect(body).toContain('Welcome aboard!');
+    });
+
+    it('should render user profile-updated template', () => {
+      const payload = createPayload({
+        type: 'user:profile-updated',
+        body: 'Your profile has been updated.',
+      });
+      const body = adapter.renderTemplate(payload);
+
+      expect(body).toContain('Your profile has been updated');
+    });
+
+    it('should use custom app name in templates', () => {
+      adapter = new SmsAdapter({ transport, appName: 'MyApp' });
+      const payload = createPayload({ type: 'user:welcome', body: 'Hi!' });
+      const body = adapter.renderTemplate(payload);
+
+      expect(body).toContain('Welcome to MyApp');
+    });
+  });
+
+  describe('InMemorySmsTransport', () => {
+    it('should generate sequential message IDs', async () => {
+      const t = new InMemorySmsTransport();
+      const message = { to: '+15551234567', from: '+10000000000', body: 'Test' };
+
+      const r1 = await t.sendSms(message);
+      const r2 = await t.sendSms(message);
+
+      expect(r1.messageId).toBe('sms-0001');
+      expect(r2.messageId).toBe('sms-0002');
+    });
+
+    it('should store and retrieve sent messages', async () => {
+      const t = new InMemorySmsTransport();
+      await t.sendSms({ to: '+15551234567', from: '+10000000000', body: 'Test' });
+
+      expect(t.getSentMessages()).toHaveLength(1);
+      expect(t.getSentMessages()[0]?.to).toBe('+15551234567');
+    });
+
+    it('should clear sent messages and reset counter', async () => {
+      const t = new InMemorySmsTransport();
+      await t.sendSms({ to: '+15551234567', from: '+10000000000', body: 'Test' });
+
+      t.clear();
+      expect(t.getSentMessages()).toHaveLength(0);
+
+      const r = await t.sendSms({ to: '+15551234567', from: '+10000000000', body: 'Test' });
+      expect(r.messageId).toBe('sms-0001');
+    });
+  });
+});
