@@ -0,0 +1,82 @@
+/**
+ * Notification models and types.
+ *
+ * Defines the core types for the notification system. All notifications
+ * flow through the EventBus and are dispatched to NotificationAdapter
+ * implementations for delivery.
+ */
+
+/**
+ * Supported notification channels.
+ */
+export type NotificationChannel = 'email' | 'webhook' | 'in-app';
+
+/**
+ * Notification priority levels.
+ */
+export type NotificationPriority = 'low' | 'normal' | 'high' | 'urgent';
+
+/**
+ * Categorizes the type of notification being sent.
+ */
+export type NotificationType =
+  | 'order:confirmation'
+  | 'order:status-update'
+  | 'user:welcome'
+  | 'user:profile-updated';
+
+/**
+ * The payload passed to notification adapters for delivery.
+ * This is the canonical shape that all adapters receive.
+ */
+export interface NotificationPayload {
+  /** Unique notification ID. */
+  id: string;
+  /** The type/category of this notification. */
+  type: NotificationType;
+  /** The delivery channel. */
+  channel: NotificationChannel;
+  /** Recipient identifier (email address, user ID, webhook URL, etc.). */
+  recipient: string;
+  /** Notification subject/title. */
+  subject: string;
+  /** Notification body content. */
+  body: string;
+  /** Priority level. */
+  priority: NotificationPriority;
+  /** When the notification was created. */
+  createdAt: Date;
+  /** Optional metadata for adapter-specific needs. */
+  metadata?: Record<string, unknown>;
+}
+
+/**
+ * Result of a notification delivery attempt.
+ */
+export interface NotificationResult {
+  /** The notification ID. */
+  notificationId: string;
+  /** The channel that handled delivery. */
+  channel: NotificationChannel;
+  /** Whether delivery succeeded. */
+  success: boolean;
+  /** Error message if delivery failed. */
+  error?: string;
+  /** Timestamp of the delivery attempt. */
+  deliveredAt: Date;
+}
+
+/**
+ * Stored notification record combining payload and delivery result.
+ */
+export interface Notification {
+  id: string;
+  recipient: string;
+  subject: string;
+  body: string;
+  type: NotificationType;
+  channel: NotificationChannel;
+  priority: NotificationPriority;
+  sentAt: Date;
+  metadata?: Record<string, unknown>;
+}
