diff --git a/tests/adapters/sms.adapter.test.ts b/tests/adapters/sms.adapter.test.ts
new file mode 100644
index 0000000..f2551e7
--- /dev/null
+++ b/tests/adapters/sms.adapter.test.ts
@@ -0,0 +1,206 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  SmsAdapter,
+  InMemorySmsTransport,
+  FailingSmsTransport,
+} from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    type: 'order:confirmation',
+    recipient: '+14155551234',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    channel: 'sms',
+    priority: 'normal',
+    metadata: { orderId: 'order-1', notificationId: 'notif-0001' },
+    ...overrides,
+  };
+}
+
+describe('SmsAdapter', () => {
+  let transport: InMemorySmsTransport;
+  let adapter: SmsAdapter;
+
+  beforeEach(() => {
+    transport = new InMemorySmsTransport();
+    adapter = new SmsAdapter({
+      fromNumber: '+15550000000',
+      transport,
+    });
+  });
+
+  it('has channel set to sms', () => {
+    expect(adapter.channel).toBe('sms');
+  });
+
+  describe('resolveRecipient', () => {
+    it('accepts valid E.164 phone numbers', () => {
+      expect(adapter.resolveRecipient('+14155551234')).toBe('+14155551234');
+      expect(adapter.resolveRecipient('+442071234567')).toBe('+442071234567');
+    });
+
+    it('trims whitespace', () => {
+      expect(adapter.resolveRecipient('  +14155551234  ')).toBe('+14155551234');
+    });
+
+    it('throws on invalid phone number', () => {
+      expect(() => adapter.resolveRecipient('not-a-phone')).toThrow('Invalid phone number');
+    });
+
+    it('throws on empty string', () => {
+      expect(() => adapter.resolveRecipient('')).toThrow('Invalid phone number');
+    });
+
+    it('throws on number without + prefix', () => {
+      expect(() => adapter.resolveRecipient('14155551234')).toThrow('Invalid phone number');
+    });
+
+    it('throws on number starting with +0', () => {
+      expect(() => adapter.resolveRecipient('+04155551234')).toThrow('Invalid phone number');
+    });
+
+    it('throws on number that is too short', () => {
+      expect(() => adapter.resolveRecipient('+1234567')).toThrow('Invalid phone number');
+    });
+  });
+
+  describe('formatMessage', () => {
+    it('formats payload into SMS message with subject and body', () => {
+      const message = adapter.formatMessage(makePayload());
+
+      expect(message.to).toBe('+14155551234');
+      expect(message.body).toContain('Order Confirmation: order-1');
+      expect(message.body).toContain('Your order has been placed');
+    });
+
+    it('formats all notification types', () => {
+      const types = [
+        'order:confirmation',
+        'order:status-update',
+        'user:welcome',
+        'user:profile-updated',
+      ] as const;
+
+      for (const type of types) {
+        const message = adapter.formatMessage(makePayload({ type, subject: `Test: ${type}` }));
+        expect(message.body).toContain(`Test: ${type}`);
+      }
+    });
+  });
+
+  describe('send', () => {
+    it('sends SMS and returns success', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('sms');
+      expect(result.error).toBeUndefined();
+
+      expect(transport.sent).toHaveLength(1);
+      expect(transport.sent[0]?.to).toBe('+14155551234');
+    });
+
+    it('returns failure when transport throws', async () => {
+      const failAdapter = new SmsAdapter({
+        fromNumber: '+15550000000',
+        transport: new FailingSmsTransport('Gateway timeout'),
+      });
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Gateway timeout');
+      expect(result.channel).toBe('sms');
+    });
+
+    it('returns failure for invalid recipient', async () => {
+      const payload = makePayload({ recipient: 'bad-number' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid phone number');
+    });
+
+    it('uses notificationId from metadata', async () => {
+      const payload = makePayload({
+        metadata: { notificationId: 'custom-id' },
+      });
+      const result = await adapter.send(payload);
+      expect(result.notificationId).toBe('custom-id');
+    });
+
+    it('falls back to unknown when no notificationId in metadata', async () => {
+      const payload = makePayload({ metadata: undefined });
+      const result = await adapter.send(payload);
+      expect(result.notificationId).toBe('unknown');
+    });
+
+    it('sends multiple SMS messages independently', async () => {
+      await adapter.send(makePayload({ recipient: '+14155551111' }));
+      await adapter.send(makePayload({ recipient: '+14155552222' }));
+
+      expect(transport.sent).toHaveLength(2);
+      expect(transport.sent[0]?.to).toBe('+14155551111');
+      expect(transport.sent[1]?.to).toBe('+14155552222');
+    });
+
+    it('preserves payload content in message body', async () => {
+      const payload = makePayload({
+        type: 'order:status-update',
+        subject: 'Status Changed',
+        body: 'Order updated to shipped',
+      });
+      await adapter.send(payload);
+
+      expect(transport.sent[0]?.body).toContain('Status Changed');
+      expect(transport.sent[0]?.body).toContain('Order updated to shipped');
+    });
+  });
+
+  describe('InMemorySmsTransport', () => {
+    it('records sent messages and increments messageId', async () => {
+      const t = new InMemorySmsTransport();
+      const message = adapter.formatMessage(makePayload());
+
+      const r1 = await t.sendSms(message);
+      const r2 = await t.sendSms(message);
+
+      expect(r1.messageId).toBe('sms-1');
+      expect(r2.messageId).toBe('sms-2');
+      expect(r1.accepted).toBe(true);
+      expect(t.sent).toHaveLength(2);
+    });
+
+    it('clears sent messages', async () => {
+      const t = new InMemorySmsTransport();
+      await t.sendSms(adapter.formatMessage(makePayload()));
+      t.clear();
+      expect(t.sent).toHaveLength(0);
+    });
+  });
+
+  describe('FailingSmsTransport', () => {
+    it('throws with configured error message', async () => {
+      const t = new FailingSmsTransport('Custom error');
+      const message = adapter.formatMessage(makePayload());
+      await expect(t.sendSms(message)).rejects.toThrow('Custom error');
+    });
+
+    it('uses default error message when none provided', async () => {
+      const t = new FailingSmsTransport();
+      const message = adapter.formatMessage(makePayload());
+      await expect(t.sendSms(message)).rejects.toThrow('SMS gateway unavailable');
+    });
+  });
+
+  describe('integration with NotificationService pattern', () => {
+    it('conforms to NotificationAdapter interface', () => {
+      expect(typeof adapter.channel).toBe('string');
+      expect(typeof adapter.send).toBe('function');
+    });
+  });
+});
