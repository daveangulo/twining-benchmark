+/**
+ * Email notification adapter — delivers notifications via email.
+ *
+ * This is a stub implementation that logs sends rather than connecting
+ * to a real SMTP server. The interface is real and production-ready;
+ * swap the send() implementation for actual email transport.
+ */
+
+import type { NotificationPayload, NotificationResult } from '../models/notification.js';
+import type { NotificationAdapter } from './notification.adapter.js';
+import { Logger } from '../utils/logger.js';
+
+export interface EmailConfig {
+  /** SMTP host (e.g. 'smtp.example.com'). */
+  host: string;
+  /** SMTP port (e.g. 587). */
+  port: number;
+  /** Sender email address. */
+  from: string;
+}
+
+export const defaultEmailConfig: EmailConfig = {
+  host: 'localhost',
+  port: 587,
+  from: 'noreply@taskflowpro.com',
+};
+
+export class EmailNotificationAdapter implements NotificationAdapter {
+  readonly channel = 'email' as const;
+  private logger = new Logger('EmailAdapter');
+  private sentEmails: NotificationPayload[] = [];
+
+  constructor(private config: EmailConfig = defaultEmailConfig) {}
+
+  /**
+   * Send an email notification.
+   * Stub implementation — logs the send and stores in memory.
+   */
+  async send(payload: NotificationPayload): Promise<NotificationResult> {
+    try {
+      this.logger.info(
+        `Sending email to ${payload.recipient}: "${payload.subject}" (from: ${this.config.from})`,
+      );
+
+      // Stub: store in memory instead of actual SMTP send
+      this.sentEmails.push(payload);
+
+      return {
+        success: true,
+        notificationId: payload.id,
+        channel: 'email',
+        deliveredAt: new Date(),
+      };
+    } catch (err) {
+      const message = err instanceof Error ? err.message : 'Unknown email error';
+      this.logger.error(`Failed to send email to ${payload.recipient}: ${message}`);
+
+      return {
+        success: false,
+        notificationId: payload.id,
+        channel: 'email',
+        deliveredAt: new Date(),
+        error: message,
+      };
+    }
+  }
+
+  /**
+   * Get all emails sent through this adapter (useful for testing).
+   */
+  getSentEmails(): NotificationPayload[] {
+    return [...this.sentEmails];
+  }
+
+  /**
+   * Clear sent emails (useful for testing).
+   */
+  clearSentEmails(): void {
+    this.sentEmails = [];
+  }
+}
