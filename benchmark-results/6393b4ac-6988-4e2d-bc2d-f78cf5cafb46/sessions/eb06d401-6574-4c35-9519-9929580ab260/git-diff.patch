@@ -0,0 +1,77 @@
+/**
+ * Notification model — types and interfaces for the notification system.
+ *
+ * Architectural constraint: All notifications flow through the EventBus.
+ * Services emit domain events; the NotificationService listens and dispatches
+ * to registered NotificationAdapters (email, webhook, SMS, etc.).
+ */
+
+/** Supported notification types — maps to the kind of event that triggered it. */
+export type NotificationType =
+  | 'order_confirmation'
+  | 'order_status_update'
+  | 'welcome'
+  | 'account_updated';
+
+/** Delivery channels for notifications. */
+export type NotificationChannel = 'email' | 'webhook' | 'sms' | 'in_app';
+
+/** Priority levels for notification delivery. */
+export type NotificationPriority = 'low' | 'normal' | 'high' | 'urgent';
+
+/**
+ * The payload passed to NotificationAdapters for delivery.
+ * Adapters receive this and handle channel-specific formatting/transport.
+ */
+export interface NotificationPayload {
+  /** Unique notification ID. */
+  id: string;
+  /** The type of notification being sent. */
+  type: NotificationType;
+  /** The channel this payload targets. */
+  channel: NotificationChannel;
+  /** Recipient identifier (email address, user ID, webhook URL, etc.). */
+  recipient: string;
+  /** Notification subject / title. */
+  subject: string;
+  /** Notification body content. */
+  body: string;
+  /** Priority level. */
+  priority: NotificationPriority;
+  /** When the notification was created. */
+  createdAt: Date;
+  /** Optional structured metadata for adapter-specific use. */
+  metadata?: Record<string, unknown>;
+}
+
+/** Delivery result returned by adapters. */
+export interface NotificationResult {
+  /** Whether delivery succeeded. */
+  success: boolean;
+  /** The notification ID that was delivered. */
+  notificationId: string;
+  /** The channel used for delivery. */
+  channel: NotificationChannel;
+  /** Timestamp of the delivery attempt. */
+  deliveredAt: Date;
+  /** Error message if delivery failed. */
+  error?: string;
+}
+
+/**
+ * A stored notification record with delivery status.
+ */
+export interface Notification {
+  id: string;
+  type: NotificationType;
+  recipient: string;
+  subject: string;
+  body: string;
+  channel: NotificationChannel;
+  priority: NotificationPriority;
+  status: 'pending' | 'sent' | 'failed';
+  createdAt: Date;
+  sentAt?: Date;
+  error?: string;
+  metadata?: Record<string, unknown>;
+}
