+/**
+ * NotificationAdapter interface — the contract all delivery adapters must implement.
+ *
+ * ARCHITECTURAL CONSTRAINT:
+ * All notification delivery adapters (email, webhook, SMS, in-app, etc.) MUST
+ * implement this interface. The NotificationService dispatches to adapters
+ * based on the channel field of the NotificationPayload.
+ *
+ * To add a new notification channel:
+ * 1. Add the channel name to NotificationChannel in src/models/notification.ts
+ * 2. Create an adapter class implementing this interface
+ * 3. Register it with NotificationService via registerAdapter()
+ *
+ * Adapters are responsible for:
+ * - Formatting the payload for their specific channel
+ * - Handling transport (HTTP, SMTP, etc.)
+ * - Returning a NotificationResult indicating success or failure
+ * - NOT throwing exceptions — return { success: false, error: ... } instead
+ */
+
+import type { NotificationChannel, NotificationPayload, NotificationResult } from '../models/notification.js';
+
+export interface NotificationAdapter {
+  /** The channel this adapter handles. Must match a NotificationChannel value. */
+  readonly channel: NotificationChannel;
+
+  /**
+   * Send a notification through this adapter's channel.
+   * Must not throw — return a failed NotificationResult on error.
+   */
+  send(payload: NotificationPayload): Promise<NotificationResult>;
+}
