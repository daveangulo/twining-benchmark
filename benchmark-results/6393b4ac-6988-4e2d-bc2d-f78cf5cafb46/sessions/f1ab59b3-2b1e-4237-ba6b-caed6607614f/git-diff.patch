@@ -0,0 +1,280 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { WebhookAdapter, formatWebhookPayload } from '../../src/adapters/webhook.adapter.js';
+import type { WebhookTransport, WebhookPayload } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: 'user-1',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    notificationType: 'order_confirmation',
+    channel: 'webhook',
+    priority: 'normal',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+function createMockTransport(statusCode = 200) {
+  const sent: { url: string; payload: WebhookPayload; headers: Record<string, string> }[] = [];
+  const transport: WebhookTransport = {
+    async post(url, payload, headers) {
+      sent.push({ url, payload, headers });
+      return { statusCode };
+    },
+  };
+  return { transport, sent };
+}
+
+describe('WebhookAdapter', () => {
+  describe('constructor', () => {
+    it('should set the channel to webhook', () => {
+      const adapter = new WebhookAdapter({ url: 'https://example.com/hook' });
+      expect(adapter.channel).toBe('webhook');
+    });
+  });
+
+  describe('formatWebhookPayload', () => {
+    it('should format a notification payload into a webhook payload', () => {
+      const payload = makePayload();
+      const result = formatWebhookPayload(payload);
+
+      expect(result.event).toBe('order_confirmation');
+      expect(result.recipient).toBe('user-1');
+      expect(result.subject).toBe('Order Confirmation: order-1');
+      expect(result.body).toContain('Widget x2');
+      expect(result.priority).toBe('normal');
+      expect(result.metadata).toEqual({ orderId: 'order-1', userId: 'user-1' });
+      expect(result.timestamp).toBeDefined();
+    });
+
+    it('should handle missing metadata', () => {
+      const payload = makePayload({ metadata: undefined });
+      const result = formatWebhookPayload(payload);
+
+      expect(result.metadata).toBeUndefined();
+    });
+
+    it('should include an ISO timestamp', () => {
+      const payload = makePayload();
+      const result = formatWebhookPayload(payload);
+
+      // Verify it's a valid ISO 8601 string
+      expect(new Date(result.timestamp).toISOString()).toBe(result.timestamp);
+    });
+  });
+
+  describe('send', () => {
+    it('should POST to the configured URL and return success', async () => {
+      const { transport, sent } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('webhook');
+      expect(result.error).toBeUndefined();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]!.url).toBe('https://example.com/hook');
+      expect(sent[0]!.payload.event).toBe('order_confirmation');
+    });
+
+    it('should include Content-Type header', async () => {
+      const { transport, sent } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      await adapter.send(makePayload());
+
+      expect(sent[0]!.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should include Authorization header when secret is configured', async () => {
+      const { transport, sent } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        secret: 'my-secret-token',
+        transport,
+      });
+
+      await adapter.send(makePayload());
+
+      expect(sent[0]!.headers['Authorization']).toBe('Bearer my-secret-token');
+    });
+
+    it('should not include Authorization header when no secret is configured', async () => {
+      const { transport, sent } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      await adapter.send(makePayload());
+
+      expect(sent[0]!.headers['Authorization']).toBeUndefined();
+    });
+
+    it('should include custom headers', async () => {
+      const { transport, sent } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        headers: { 'X-Custom': 'value' },
+        transport,
+      });
+
+      await adapter.send(makePayload());
+
+      expect(sent[0]!.headers['X-Custom']).toBe('value');
+      expect(sent[0]!.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should return failure for non-2xx status codes', async () => {
+      const { transport } = createMockTransport(500);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.channel).toBe('webhook');
+      expect(result.error).toBe('Webhook endpoint returned status 500');
+    });
+
+    it('should return failure for 4xx status codes', async () => {
+      const { transport } = createMockTransport(404);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Webhook endpoint returned status 404');
+    });
+
+    it('should return success for 201 status code', async () => {
+      const { transport } = createMockTransport(201);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+    });
+
+    it('should return failure when transport throws an Error', async () => {
+      const transport: WebhookTransport = {
+        async post() {
+          throw new Error('Connection refused');
+        },
+      };
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.channel).toBe('webhook');
+      expect(result.error).toBe('Connection refused');
+    });
+
+    it('should handle non-Error throws gracefully', async () => {
+      const transport: WebhookTransport = {
+        async post() {
+          throw 'string error';
+        },
+      };
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Unknown webhook transport error');
+    });
+
+    it('should use logging transport when no transport is provided', async () => {
+      const adapter = new WebhookAdapter({ url: 'https://example.com/hook' });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('webhook');
+    });
+
+    it('should send correct payload for different notification types', async () => {
+      const { transport, sent } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      await adapter.send(
+        makePayload({
+          notificationType: 'welcome',
+          subject: 'Welcome!',
+          body: 'Welcome aboard!',
+          priority: 'high',
+          metadata: {},
+        }),
+      );
+
+      expect(sent[0]!.payload.event).toBe('welcome');
+      expect(sent[0]!.payload.subject).toBe('Welcome!');
+      expect(sent[0]!.payload.body).toBe('Welcome aboard!');
+      expect(sent[0]!.payload.priority).toBe('high');
+    });
+  });
+
+  describe('integration with NotificationService pattern', () => {
+    it('should conform to the NotificationAdapter interface', async () => {
+      const { transport } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      // Verify it has the required shape
+      expect(adapter.channel).toBe('webhook');
+      expect(typeof adapter.send).toBe('function');
+
+      // Verify send returns the correct shape
+      const result = await adapter.send(makePayload());
+      expect(result).toHaveProperty('success');
+      expect(result).toHaveProperty('channel');
+    });
+
+    it('should be registrable with NotificationService', async () => {
+      // Import here to avoid circular dependency issues in test setup
+      const { EventBus } = await import('../../src/events/event-bus.js');
+      const { NotificationService } = await import('../../src/services/notification.service.js');
+
+      const { transport } = createMockTransport(200);
+      const adapter = new WebhookAdapter({
+        url: 'https://example.com/hook',
+        transport,
+      });
+
+      const eventBus = new EventBus();
+      const service = new NotificationService(eventBus);
+
+      // Should not throw
+      service.registerAdapter(adapter);
+    });
+  });
+});
