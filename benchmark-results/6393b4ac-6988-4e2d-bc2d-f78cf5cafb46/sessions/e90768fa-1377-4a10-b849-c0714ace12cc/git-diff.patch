+// ---------------------------------------------------------------------------
+// RecipientResolver that can resolve user IDs to emails (for integration tests)
+// ---------------------------------------------------------------------------
+
+class TestRecipientResolver implements RecipientResolver {
+  private userEmails = new Map<string, string>();
+
+  registerUser(userId: string, email: string): void {
+    this.userEmails.set(userId, email);
+  }
+
+  async resolve(recipient: string): Promise<string | null> {
+    // If it already looks like an email, return as-is
+    if (recipient.includes('@')) return recipient;
+    // Otherwise try to resolve user ID to email
+    return this.userEmails.get(recipient) ?? null;
+  }
+}
