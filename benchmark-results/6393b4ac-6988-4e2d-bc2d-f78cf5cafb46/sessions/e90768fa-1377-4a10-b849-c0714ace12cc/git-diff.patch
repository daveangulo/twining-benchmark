+// ---------------------------------------------------------------------------
+
+function makeUser(overrides: Partial<User> = {}): User {
+  return {
+    id: 'user-1',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member',
+    createdAt: new Date('2026-01-01'),
+    updatedAt: new Date('2026-01-01'),
+    ...overrides,
+  };
+}
+
+function makeOrder(overrides: Partial<Order> = {}): Order {
+  return {
+    id: 'order-1',
+    userId: 'user-1',
+    items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+    total: 20,
+    status: 'pending',
+    createdAt: new Date('2026-01-01'),
+    updatedAt: new Date('2026-01-01'),
+    ...overrides,
+  };
+}
+
+function makePreferences(
+  userId: string,
+  overrides: Partial<UserNotificationPreferences> = {},
+): UserNotificationPreferences {
+  const now = new Date();
+  return {
+    id: `pref-${userId}`,
+    userId,
+    email: {
+      enabled: true,
+      frequency: 'immediate',
+      categories: {
+        'order-confirmation': true,
+        'order-status-update': true,
+        welcome: true,
+        'user-updated': true,
+      },
+    },
+    sms: {
+      enabled: true,
+      categories: {
+        'order-confirmation': true,
+        'order-status-update': true,
+        welcome: true,
+        'user-updated': true,
+      },
+    },
+    webhook: {
+      enabled: true,
+      categories: {
+        'order-confirmation': true,
+        'order-status-update': true,
+        welcome: true,
+        'user-updated': true,
+      },
+    },
+    createdAt: now,
+    updatedAt: now,
+    ...overrides,
+  };
+}
