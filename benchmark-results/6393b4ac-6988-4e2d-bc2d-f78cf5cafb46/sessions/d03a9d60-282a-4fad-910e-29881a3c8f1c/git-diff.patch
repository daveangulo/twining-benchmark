diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..d0a1f1b
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,161 @@
+/**
+ * Preferences service — manages user notification preferences.
+ *
+ * Provides CRUD for notification preferences and a check method
+ * that the NotificationService uses before sending.
+ *
+ * Depends on:
+ * - PreferencesRepository for persistence
+ * - UserRepository to validate user existence
+ */
+
+import type { PreferencesRepository } from '../repositories/preferences.repository.js';
+import type { UserRepository } from '../repositories/user.repository.js';
+import type {
+  UserNotificationPreferences,
+  UpdateEmailPreferencesInput,
+} from '../models/user-preferences.js';
+import type { NotificationType, NotificationChannel } from '../models/notification.js';
+import { defaultEmailPreferences } from '../models/user-preferences.js';
+import { Logger } from '../utils/logger.js';
+
+let nextId = 1;
+
+function generatePreferencesId(): string {
+  return `pref-${String(nextId++).padStart(4, '0')}`;
+}
+
+export function resetPreferencesIdCounter(): void {
+  nextId = 1;
+}
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(
+    private preferencesRepo: PreferencesRepository,
+    private userRepo: UserRepository,
+  ) {}
+
+  /**
+   * Get preferences for a user. If none exist yet, returns default preferences
+   * without persisting them (lazy initialization on first update).
+   */
+  getPreferences(userId: string): UserNotificationPreferences {
+    const existing = this.preferencesRepo.findByUserId(userId);
+    if (existing) {
+      return existing;
+    }
+
+    // Return transient defaults — not persisted until the user explicitly updates
+    return {
+      id: '',
+      userId,
+      email: defaultEmailPreferences(),
+      updatedAt: new Date(),
+    };
+  }
+
+  /**
+   * Update email notification preferences for a user.
+   * Creates the preferences record on first update (upsert semantics).
+   */
+  updateEmailPreferences(
+    userId: string,
+    input: UpdateEmailPreferencesInput,
+  ): UserNotificationPreferences {
+    const user = this.userRepo.findById(userId);
+    if (!user) {
+      throw new Error(`User not found: ${userId}`);
+    }
+
+    const existing = this.preferencesRepo.findByUserId(userId);
+
+    if (existing) {
+      const updatedEmail = {
+        ...existing.email,
+        ...('enabled' in input ? { enabled: input.enabled! } : {}),
+        ...('frequency' in input ? { frequency: input.frequency! } : {}),
+        categories: {
+          ...existing.email.categories,
+          ...(input.categories ?? {}),
+        },
+      };
+
+      const updated = this.preferencesRepo.update(existing.id, {
+        email: updatedEmail,
+        updatedAt: new Date(),
+      } as Partial<UserNotificationPreferences>);
+
+      this.logger.info(`Updated email preferences for user ${userId}`);
+      return updated;
+    }
+
+    // First-time save — merge input onto defaults
+    const defaults = defaultEmailPreferences();
+    const emailPrefs = {
+      ...defaults,
+      ...('enabled' in input ? { enabled: input.enabled! } : {}),
+      ...('frequency' in input ? { frequency: input.frequency! } : {}),
+      categories: {
+        ...defaults.categories,
+        ...(input.categories ?? {}),
+      },
+    };
+
+    const prefs: UserNotificationPreferences = {
+      id: generatePreferencesId(),
+      userId,
+      email: emailPrefs,
+      updatedAt: new Date(),
+    };
+
+    this.preferencesRepo.save(prefs);
+    this.logger.info(`Created email preferences for user ${userId}`);
+    return prefs;
+  }
+
+  /**
+   * Check whether a notification should be delivered to a user on a given channel.
+   * Returns true if the notification is allowed, false if it should be suppressed.
+   *
+   * Rules:
+   * 1. If no preferences exist, notifications are allowed (opt-out model).
+   * 2. If the email channel is disabled, all email notifications are suppressed.
+   * 3. If the specific category is disabled, that notification is suppressed.
+   * 4. If the frequency is 'none', all email notifications are suppressed.
+   */
+  shouldSend(
+    userId: string,
+    channel: NotificationChannel,
+    type: NotificationType,
+  ): boolean {
+    // Only email preferences are supported for now
+    if (channel !== 'email') {
+      return true;
+    }
+
+    const prefs = this.preferencesRepo.findByUserId(userId);
+    if (!prefs) {
+      // No preferences stored — default is to send everything
+      return true;
+    }
+
+    if (!prefs.email.enabled) {
+      this.logger.debug(`Email disabled for user ${userId}, suppressing ${type}`);
+      return false;
+    }
+
+    if (prefs.email.frequency === 'none') {
+      this.logger.debug(`Email frequency=none for user ${userId}, suppressing ${type}`);
+      return false;
+    }
+
+    if (prefs.email.categories[type] === false) {
+      this.logger.debug(`Category ${type} disabled for user ${userId}, suppressing`);
+      return false;
+    }
+
+    return true;
+  }
+}
diff --git a/tests/services/preferences.service.test.ts b/tests/services/preferences.service.test.ts
new file mode 100644
index 0000000..34e5afb
--- /dev/null
+++ b/tests/services/preferences.service.test.ts
@@ -0,0 +1,189 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import { defaultEmailPreferences } from '../../src/models/user-preferences.js';
+import type { User } from '../../src/models/user.js';
+
+function createTestUser(db: Database, overrides: Partial<User> = {}): User {
+  const user: User = {
+    id: 'user-0001',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+    ...overrides,
+  };
+  const repo = new UserRepository(db);
+  return repo.save(user);
+}
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let prefsRepo: PreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    prefsRepo = new PreferencesRepository(db);
+    service = new PreferencesService(prefsRepo, userRepo);
+    resetPreferencesIdCounter();
+  });
+
+  describe('getPreferences', () => {
+    it('should return default preferences when none are saved', () => {
+      const prefs = service.getPreferences('user-0001');
+
+      expect(prefs.userId).toBe('user-0001');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.categories['order-confirmation']).toBe(true);
+      expect(prefs.email.categories['system-alert']).toBe(true);
+    });
+
+    it('should return saved preferences when they exist', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', { frequency: 'daily-digest' });
+
+      const prefs = service.getPreferences('user-0001');
+      expect(prefs.email.frequency).toBe('daily-digest');
+      expect(prefs.id).toBe('pref-0001');
+    });
+  });
+
+  describe('updateEmailPreferences', () => {
+    it('should create preferences on first update', () => {
+      createTestUser(db);
+      const prefs = service.updateEmailPreferences('user-0001', {
+        frequency: 'weekly-digest',
+      });
+
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-0001');
+      expect(prefs.email.frequency).toBe('weekly-digest');
+      expect(prefs.email.enabled).toBe(true); // default preserved
+    });
+
+    it('should throw if user does not exist', () => {
+      expect(() =>
+        service.updateEmailPreferences('nonexistent', { enabled: false }),
+      ).toThrow('User not found: nonexistent');
+    });
+
+    it('should update enabled flag', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', { enabled: false });
+
+      const prefs = service.getPreferences('user-0001');
+      expect(prefs.email.enabled).toBe(false);
+    });
+
+    it('should update individual categories without affecting others', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', {
+        categories: { 'order-confirmation': false },
+      });
+
+      const prefs = service.getPreferences('user-0001');
+      expect(prefs.email.categories['order-confirmation']).toBe(false);
+      expect(prefs.email.categories['order-status-update']).toBe(true);
+      expect(prefs.email.categories['system-alert']).toBe(true);
+    });
+
+    it('should merge updates onto existing preferences', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', { frequency: 'daily-digest' });
+      service.updateEmailPreferences('user-0001', {
+        categories: { 'user-welcome': false },
+      });
+
+      const prefs = service.getPreferences('user-0001');
+      expect(prefs.email.frequency).toBe('daily-digest'); // first update preserved
+      expect(prefs.email.categories['user-welcome']).toBe(false); // second update applied
+    });
+
+    it('should update frequency on existing preferences', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', { frequency: 'daily-digest' });
+      service.updateEmailPreferences('user-0001', { frequency: 'none' });
+
+      const prefs = service.getPreferences('user-0001');
+      expect(prefs.email.frequency).toBe('none');
+    });
+  });
+
+  describe('shouldSend', () => {
+    it('should allow notifications when no preferences exist', () => {
+      expect(service.shouldSend('user-0001', 'email', 'order-confirmation')).toBe(true);
+    });
+
+    it('should allow notifications for non-email channels regardless of preferences', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', { enabled: false });
+
+      // Non-email channels are unaffected
+      expect(service.shouldSend('user-0001', 'sms', 'system-alert')).toBe(true);
+      expect(service.shouldSend('user-0001', 'webhook', 'system-alert')).toBe(true);
+      expect(service.shouldSend('user-0001', 'in-app', 'system-alert')).toBe(true);
+    });
+
+    it('should suppress when email is disabled', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', { enabled: false });
+
+      expect(service.shouldSend('user-0001', 'email', 'order-confirmation')).toBe(false);
+      expect(service.shouldSend('user-0001', 'email', 'system-alert')).toBe(false);
+    });
+
+    it('should suppress when frequency is none', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', { frequency: 'none' });
+
+      expect(service.shouldSend('user-0001', 'email', 'order-confirmation')).toBe(false);
+    });
+
+    it('should suppress when specific category is disabled', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', {
+        categories: { 'order-confirmation': false },
+      });
+
+      expect(service.shouldSend('user-0001', 'email', 'order-confirmation')).toBe(false);
+      expect(service.shouldSend('user-0001', 'email', 'order-status-update')).toBe(true);
+    });
+
+    it('should allow when email is enabled and category is enabled', () => {
+      createTestUser(db);
+      service.updateEmailPreferences('user-0001', {
+        enabled: true,
+        frequency: 'daily-digest',
+        categories: { 'order-confirmation': true },
+      });
+
+      expect(service.shouldSend('user-0001', 'email', 'order-confirmation')).toBe(true);
+    });
+  });
+});
+
+describe('defaultEmailPreferences', () => {
+  it('should return all categories enabled', () => {
+    const defaults = defaultEmailPreferences();
+    expect(defaults.enabled).toBe(true);
+    expect(defaults.frequency).toBe('immediate');
+    expect(Object.values(defaults.categories).every(Boolean)).toBe(true);
+  });
+
+  it('should return independent copies', () => {
+    const a = defaultEmailPreferences();
+    const b = defaultEmailPreferences();
+    a.categories['order-confirmation'] = false;
+    expect(b.categories['order-confirmation']).toBe(true);
+  });
+});
