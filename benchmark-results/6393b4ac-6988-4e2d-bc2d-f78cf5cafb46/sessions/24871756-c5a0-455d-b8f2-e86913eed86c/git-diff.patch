+++ b/tests/validators/user.validator.test.ts
@@ -0,0 +1,54 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateUserExists,
+  validateEmailNotTaken,
+  validateEmailNotInUse,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const testUser: User = {
+  id: 'user-1',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+};
+
+describe('User Validators', () => {
+  describe('validateUserExists', () => {
+    it('should pass when user exists', () => {
+      expect(() => validateUserExists(testUser, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists(undefined, 'user-99')).toThrow(
+        'User not found: user-99',
+      );
+    });
+  });
+
+  describe('validateEmailNotTaken', () => {
+    it('should pass when no existing user with that email', () => {
+      expect(() => validateEmailNotTaken(undefined, 'new@example.com')).not.toThrow();
+    });
+
+    it('should throw when email is already taken', () => {
+      expect(() => validateEmailNotTaken(testUser, 'alice@example.com')).toThrow(
+        'User with email alice@example.com already exists',
+      );
+    });
+  });
+
+  describe('validateEmailNotInUse', () => {
+    it('should pass when email is not in use', () => {
+      expect(() => validateEmailNotInUse(undefined, 'new@example.com')).not.toThrow();
+    });
+
+    it('should throw when email is already in use', () => {
+      expect(() => validateEmailNotInUse(testUser, 'alice@example.com')).toThrow(
+        'Email alice@example.com is already in use',
+      );
+    });
+  });
+});
