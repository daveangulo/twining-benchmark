--- /dev/null
+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,221 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookNotificationAdapter,
+  InMemoryWebhookTransport,
+  defaultWebhookConfig,
+} from '../../src/adapters/webhook.adapter.js';
+import type {
+  WebhookTransport,
+  WebhookPayload,
+} from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order-confirmation',
+    channel: 'webhook',
+    recipient: 'https://hooks.example.com/notify',
+    subject: 'Order Confirmation: order-42',
+    body: 'Your order has been placed.',
+    priority: 'normal',
+    createdAt: new Date('2026-01-01'),
+    ...overrides,
+  };
+}
+
+describe('WebhookNotificationAdapter', () => {
+  let transport: InMemoryWebhookTransport;
+  let adapter: WebhookNotificationAdapter;
+
+  beforeEach(() => {
+    transport = new InMemoryWebhookTransport();
+    adapter = new WebhookNotificationAdapter({ transport });
+  });
+
+  it('has channel "webhook"', () => {
+    expect(adapter.channel).toBe('webhook');
+  });
+
+  describe('send', () => {
+    it('sends webhook successfully for a URL recipient', async () => {
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('webhook');
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+    });
+
+    it('delivers webhook via transport with JSON payload', async () => {
+      await adapter.send(makePayload());
+
+      const deliveries = transport.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]!.url).toBe('https://hooks.example.com/notify');
+      expect(deliveries[0]!.method).toBe('POST');
+      expect(deliveries[0]!.headers['Content-Type']).toBe('application/json');
+
+      const body = JSON.parse(deliveries[0]!.body);
+      expect(body.id).toBe('notif-0001');
+      expect(body.type).toBe('order-confirmation');
+      expect(body.subject).toContain('Order Confirmation');
+      expect(body.body).toContain('Your order has been placed.');
+    });
+
+    it('includes metadata in webhook body', async () => {
+      await adapter.send(makePayload({ metadata: { orderId: 'order-99', total: 50 } }));
+
+      const body = JSON.parse(transport.getDeliveries()[0]!.body);
+      expect(body.metadata.orderId).toBe('order-99');
+      expect(body.metadata.total).toBe(50);
+    });
+
+    it('returns failure when recipient is not a URL and no default URL configured', async () => {
+      const result = await adapter.send(makePayload({ recipient: 'user-123' }));
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Cannot resolve webhook URL');
+      expect(transport.getDeliveries()).toHaveLength(0);
+    });
+
+    it('uses config.url as fallback when recipient is not a URL', async () => {
+      const adapterWithUrl = new WebhookNotificationAdapter({
+        transport,
+        config: { url: 'https://default.example.com/webhook' },
+      });
+
+      const result = await adapterWithUrl.send(makePayload({ recipient: 'user-123' }));
+
+      expect(result.success).toBe(true);
+      expect(transport.getDeliveries()[0]!.url).toBe('https://default.example.com/webhook');
+    });
+
+    it('returns failure when transport throws', async () => {
+      const failingTransport: WebhookTransport = {
+        post: async () => {
+          throw new Error('Connection refused');
+        },
+      };
+      const adapterWithFailing = new WebhookNotificationAdapter({
+        transport: failingTransport,
+      });
+
+      const result = await adapterWithFailing.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Connection refused');
+    });
+
+    it('never throws, even on unexpected errors', async () => {
+      const failingTransport: WebhookTransport = {
+        post: async () => {
+          throw 'string error';
+        },
+      };
+      const adapterWithFailing = new WebhookNotificationAdapter({
+        transport: failingTransport,
+      });
+
+      const result = await adapterWithFailing.send(makePayload());
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('string error');
+    });
+
+    it('returns failure for non-2xx status codes', async () => {
+      const errorTransport: WebhookTransport = {
+        post: async () => ({ statusCode: 500, body: 'Internal Server Error' }),
+      };
+      const adapterWith500 = new WebhookNotificationAdapter({
+        transport: errorTransport,
+      });
+
+      const result = await adapterWith500.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('status 500');
+    });
+
+    it('succeeds for various 2xx status codes', async () => {
+      const transport202: WebhookTransport = {
+        post: async () => ({ statusCode: 202 }),
+      };
+      const adapterWith202 = new WebhookNotificationAdapter({
+        transport: transport202,
+      });
+
+      const result = await adapterWith202.send(makePayload());
+      expect(result.success).toBe(true);
+    });
+  });
+
+  describe('custom headers', () => {
+    it('includes custom headers from config', async () => {
+      const adapterWithHeaders = new WebhookNotificationAdapter({
+        transport,
+        config: {
+          headers: {
+            'Authorization': 'Bearer secret-token',
+            'X-Custom': 'value',
+          },
+        },
+      });
+
+      await adapterWithHeaders.send(makePayload());
+
+      const delivery = transport.getDeliveries()[0]!;
+      expect(delivery.headers['Authorization']).toBe('Bearer secret-token');
+      expect(delivery.headers['X-Custom']).toBe('value');
+      expect(delivery.headers['Content-Type']).toBe('application/json');
+    });
+  });
+
+  describe('URL resolution', () => {
+    it('uses recipient as URL when it starts with https://', async () => {
+      await adapter.send(makePayload({ recipient: 'https://my-hook.example.com/path' }));
+      expect(transport.getDeliveries()[0]!.url).toBe('https://my-hook.example.com/path');
+    });
+
+    it('uses recipient as URL when it starts with http://', async () => {
+      await adapter.send(makePayload({ recipient: 'http://localhost:3000/hook' }));
+      expect(transport.getDeliveries()[0]!.url).toBe('http://localhost:3000/hook');
+    });
+  });
+
+  describe('InMemoryWebhookTransport', () => {
+    it('stores sent webhooks', async () => {
+      const t = new InMemoryWebhookTransport();
+      const webhookPayload: WebhookPayload = {
+        url: 'https://test.example.com/hook',
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: '{"test":true}',
+      };
+
+      const result = await t.post(webhookPayload);
+
+      expect(result.statusCode).toBe(200);
+      expect(t.getDeliveries()).toHaveLength(1);
+      expect(t.getDeliveries()[0]!.url).toBe('https://test.example.com/hook');
+    });
+
+    it('clears deliveries', async () => {
+      const t = new InMemoryWebhookTransport();
+      await t.post({
+        url: 'https://test.example.com',
+        method: 'POST',
+        headers: {},
+        body: '{}',
+      });
+
+      t.clear();
+      expect(t.getDeliveries()).toHaveLength(0);
+    });
+  });
+
+  describe('defaults', () => {
+    it('has default timeout config', () => {
+      expect(defaultWebhookConfig.timeoutMs).toBe(5000);
+    });
+  });
+});
