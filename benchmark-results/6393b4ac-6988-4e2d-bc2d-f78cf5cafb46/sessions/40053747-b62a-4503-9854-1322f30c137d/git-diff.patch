diff --git a/tests/adapters/sms.adapter.test.ts b/tests/adapters/sms.adapter.test.ts
new file mode 100644
index 0000000..356d4b0
--- /dev/null
+++ b/tests/adapters/sms.adapter.test.ts
@@ -0,0 +1,252 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  SmsNotificationAdapter,
+  InMemorySmsTransport,
+  isValidPhoneNumber,
+} from '../../src/adapters/sms.adapter.js';
+import type {
+  SmsConfig,
+  SmsTransport,
+  RenderedSms,
+} from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order_confirmation',
+    channel: 'sms',
+    recipient: '+15551234567',
+    subject: 'Order Confirmation',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    createdAt: new Date('2026-01-01'),
+    ...overrides,
+  };
+}
+
+const defaultConfig: SmsConfig = {
+  from: '+15550000000',
+};
+
+describe('isValidPhoneNumber', () => {
+  it('should accept valid E.164 phone numbers', () => {
+    expect(isValidPhoneNumber('+15551234567')).toBe(true);
+    expect(isValidPhoneNumber('+441234567890')).toBe(true);
+    expect(isValidPhoneNumber('+8613800138000')).toBe(true);
+    expect(isValidPhoneNumber('+1234567')).toBe(true);
+  });
+
+  it('should reject invalid phone numbers', () => {
+    expect(isValidPhoneNumber('')).toBe(false);
+    expect(isValidPhoneNumber('5551234567')).toBe(false);
+    expect(isValidPhoneNumber('+0123456789')).toBe(false);
+    expect(isValidPhoneNumber('+1')).toBe(false);
+    expect(isValidPhoneNumber('+1234')).toBe(false);
+    expect(isValidPhoneNumber('not-a-number')).toBe(false);
+    expect(isValidPhoneNumber('+1' + '2'.repeat(15))).toBe(false);
+  });
+});
+
+describe('InMemorySmsTransport', () => {
+  let transport: InMemorySmsTransport;
+
+  beforeEach(() => {
+    transport = new InMemorySmsTransport();
+  });
+
+  it('should capture sent messages', async () => {
+    const sms: RenderedSms = {
+      from: '+15550000000',
+      to: '+15551234567',
+      body: 'Test message',
+    };
+
+    const result = await transport.send(sms);
+    expect(result.messageId).toBe('sms-1');
+    expect(transport.getSentMessages()).toHaveLength(1);
+    expect(transport.getSentMessages()[0]?.to).toBe('+15551234567');
+  });
+
+  it('should increment message IDs', async () => {
+    const sms: RenderedSms = {
+      from: '+15550000000',
+      to: '+15551234567',
+      body: 'Test',
+    };
+
+    await transport.send(sms);
+    const result = await transport.send(sms);
+    expect(result.messageId).toBe('sms-2');
+  });
+
+  it('should clear sent messages', async () => {
+    const sms: RenderedSms = {
+      from: '+15550000000',
+      to: '+15551234567',
+      body: 'Test',
+    };
+
+    await transport.send(sms);
+    transport.clear();
+    expect(transport.getSentMessages()).toHaveLength(0);
+  });
+});
+
+describe('SmsNotificationAdapter', () => {
+  let adapter: SmsNotificationAdapter;
+  let transport: InMemorySmsTransport;
+
+  beforeEach(() => {
+    transport = new InMemorySmsTransport();
+    adapter = new SmsNotificationAdapter(defaultConfig, transport);
+  });
+
+  describe('channel', () => {
+    it('should report sms channel', () => {
+      expect(adapter.channel).toBe('sms');
+    });
+  });
+
+  describe('resolveRecipient', () => {
+    it('should trim whitespace from phone number', () => {
+      expect(adapter.resolveRecipient('  +15551234567  ')).toBe('+15551234567');
+    });
+
+    it('should throw for empty recipient', () => {
+      expect(() => adapter.resolveRecipient('')).toThrow('cannot be empty');
+      expect(() => adapter.resolveRecipient('   ')).toThrow('cannot be empty');
+    });
+
+    it('should throw for invalid phone number', () => {
+      expect(() => adapter.resolveRecipient('not-a-number')).toThrow('Invalid phone number');
+    });
+
+    it('should throw for overly long phone number', () => {
+      expect(() => adapter.resolveRecipient('+1' + '2'.repeat(16))).toThrow(
+        'exceeds maximum length',
+      );
+    });
+  });
+
+  describe('formatMessage', () => {
+    it('should format message with subject prefix', () => {
+      const payload = makePayload();
+      const rendered = adapter.formatMessage(payload);
+
+      expect(rendered.from).toBe('+15550000000');
+      expect(rendered.to).toBe('+15551234567');
+      expect(rendered.body).toContain('Order Confirmation: ');
+      expect(rendered.body).toContain('Widget x2');
+    });
+
+    it('should truncate long messages with ellipsis', () => {
+      const longBody = 'A'.repeat(200);
+      const payload = makePayload({ body: longBody });
+      const rendered = adapter.formatMessage(payload);
+
+      expect(rendered.body.length).toBeLessThanOrEqual(160);
+      expect(rendered.body).toContain('...');
+    });
+
+    it('should respect custom maxMessageLength', () => {
+      const customAdapter = new SmsNotificationAdapter(
+        { ...defaultConfig, maxMessageLength: 50 },
+        transport,
+      );
+      const payload = makePayload({ body: 'A'.repeat(100) });
+      const rendered = customAdapter.formatMessage(payload);
+
+      expect(rendered.body.length).toBeLessThanOrEqual(50);
+    });
+
+    it('should not truncate short messages', () => {
+      const payload = makePayload({ subject: 'Hi', body: 'Hello' });
+      const rendered = adapter.formatMessage(payload);
+
+      expect(rendered.body).toBe('Hi: Hello');
+    });
+  });
+
+  describe('send', () => {
+    it('should send a valid notification and return success', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('sms');
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+
+      const sent = transport.getSentMessages();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.to).toBe('+15551234567');
+      expect(sent[0]?.from).toBe('+15550000000');
+    });
+
+    it('should trim recipient phone number before sending', async () => {
+      const payload = makePayload({ recipient: '  +15551234567  ' });
+      await adapter.send(payload);
+
+      const sent = transport.getSentMessages();
+      expect(sent[0]?.to).toBe('+15551234567');
+    });
+
+    it('should return failure for invalid recipient', async () => {
+      const payload = makePayload({ recipient: 'not-a-number' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid phone number');
+      expect(transport.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should return failure for empty recipient', async () => {
+      const payload = makePayload({ recipient: '' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('cannot be empty');
+    });
+
+    it('should return failure when transport throws', async () => {
+      const failingTransport: SmsTransport = {
+        send: async () => {
+          throw new Error('SMS gateway unavailable');
+        },
+      };
+      const failAdapter = new SmsNotificationAdapter(defaultConfig, failingTransport);
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('SMS gateway unavailable');
+    });
+  });
+
+  describe('getSentMessages / clearSentMessages', () => {
+    it('should return sent messages from in-memory transport', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentMessages()).toHaveLength(1);
+    });
+
+    it('should clear sent messages', async () => {
+      await adapter.send(makePayload());
+      adapter.clearSentMessages();
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should return empty array when using non-InMemory transport', () => {
+      const customTransport: SmsTransport = {
+        send: async () => ({ messageId: 'x' }),
+      };
+      const customAdapter = new SmsNotificationAdapter(defaultConfig, customTransport);
+      expect(customAdapter.getSentMessages()).toEqual([]);
+    });
+  });
+
+  describe('getTransport', () => {
+    it('should return the underlying transport', () => {
+      expect(adapter.getTransport()).toBe(transport);
+    });
+  });
+});
