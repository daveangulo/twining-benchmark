diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..b64ef36
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,57 @@
+/**
+ * Pure validation functions for order operations.
+ *
+ * These validators perform input and business-rule checks without
+ * side effects or database calls. Services fetch the required data
+ * and pass it in as arguments.
+ */
+
+import type { Order, OrderItem, OrderStatus } from '../models/order.js';
+
+/**
+ * Allowed status transitions. Exported so other modules (e.g. tests)
+ * can reference the same source of truth.
+ */
+export const ORDER_STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Validate that an order has at least one item.
+ * Throws if the items array is empty.
+ */
+export function validateOrderHasItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Validate that an order exists.
+ * Throws if the order is undefined.
+ */
+export function validateOrderExists(id: string, order: Order | undefined): void {
+  if (!order) {
+    throw new Error(`Order not found: ${id}`);
+  }
+}
+
+/**
+ * Check whether a status transition is valid.
+ */
+export function isValidStatusTransition(from: OrderStatus, to: OrderStatus): boolean {
+  return ORDER_STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate a status transition, throwing if it is not allowed.
+ */
+export function validateStatusTransition(from: OrderStatus, to: OrderStatus): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(`Invalid status transition: ${from} -> ${to}`);
+  }
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..7af7b27
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,39 @@
+/**
+ * Pure validation functions for user operations.
+ *
+ * These validators perform input and business-rule checks without
+ * side effects or database calls. Services fetch the required data
+ * and pass it in as arguments.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that an email is not already taken by another user.
+ * Throws if the existing user is defined.
+ */
+export function validateEmailNotTaken(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that a user exists.
+ * Throws if the user is undefined.
+ */
+export function validateUserExists(id: string, user: User | undefined): void {
+  if (!user) {
+    throw new Error(`User not found: ${id}`);
+  }
+}
+
+/**
+ * Validate that updating an email does not conflict with an existing user.
+ * Throws if the email is already in use by a different user.
+ */
+export function validateEmailNotInUse(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..551d893
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,106 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateOrderHasItems,
+  validateOrderExists,
+  isValidStatusTransition,
+  validateStatusTransition,
+  ORDER_STATUS_TRANSITIONS,
+} from '../../src/validators/order.validator.js';
+import type { Order, OrderStatus } from '../../src/models/order.js';
+
+const makeOrder = (overrides: Partial<Order> = {}): Order => ({
+  id: 'order-0001',
+  userId: 'user-0001',
+  items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+  total: 10,
+  status: 'pending',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+  ...overrides,
+});
+
+describe('order validators', () => {
+  describe('validateOrderHasItems', () => {
+    it('should pass when items are present', () => {
+      expect(() =>
+        validateOrderHasItems([{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }]),
+      ).not.toThrow();
+    });
+
+    it('should throw when items array is empty', () => {
+      expect(() => validateOrderHasItems([])).toThrow('Order must have at least one item');
+    });
+  });
+
+  describe('validateOrderExists', () => {
+    it('should pass when order exists', () => {
+      const order = makeOrder();
+      expect(() => validateOrderExists('order-0001', order)).not.toThrow();
+    });
+
+    it('should throw when order is undefined', () => {
+      expect(() => validateOrderExists('order-9999', undefined)).toThrow(
+        'Order not found: order-9999',
+      );
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      const statuses: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'cancelled'];
+      for (const s of statuses) {
+        expect(isValidStatusTransition('delivered', s)).toBe(false);
+      }
+    });
+
+    it('should reject cancelled -> any', () => {
+      const statuses: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'delivered'];
+      for (const s of statuses) {
+        expect(isValidStatusTransition('cancelled', s)).toBe(false);
+      }
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transition', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transition', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+  });
+
+  describe('ORDER_STATUS_TRANSITIONS', () => {
+    it('should define transitions for all statuses', () => {
+      const expected: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'];
+      expect(Object.keys(ORDER_STATUS_TRANSITIONS).sort()).toEqual(expected.sort());
+    });
+  });
+});
diff --git a/tests/validators/user.validator.test.ts b/tests/validators/user.validator.test.ts
new file mode 100644
index 0000000..5705f1f
--- /dev/null
+++ b/tests/validators/user.validator.test.ts
@@ -0,0 +1,58 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateEmailNotTaken,
+  validateUserExists,
+  validateEmailNotInUse,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const makeUser = (overrides: Partial<User> = {}): User => ({
+  id: 'user-0001',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+  ...overrides,
+});
+
+describe('user validators', () => {
+  describe('validateEmailNotTaken', () => {
+    it('should pass when no existing user', () => {
+      expect(() => validateEmailNotTaken('new@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when email is already taken', () => {
+      const existing = makeUser({ email: 'taken@example.com' });
+      expect(() => validateEmailNotTaken('taken@example.com', existing)).toThrow(
+        'User with email taken@example.com already exists',
+      );
+    });
+  });
+
+  describe('validateUserExists', () => {
+    it('should pass when user exists', () => {
+      const user = makeUser();
+      expect(() => validateUserExists('user-0001', user)).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists('user-9999', undefined)).toThrow(
+        'User not found: user-9999',
+      );
+    });
+  });
+
+  describe('validateEmailNotInUse', () => {
+    it('should pass when no user has the email', () => {
+      expect(() => validateEmailNotInUse('free@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when the email is in use', () => {
+      const existing = makeUser({ email: 'taken@example.com' });
+      expect(() => validateEmailNotInUse('taken@example.com', existing)).toThrow(
+        'Email taken@example.com is already in use',
+      );
+    });
+  });
+});
