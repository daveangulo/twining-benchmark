diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..3fc7166
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,52 @@
+/**
+ * Pure validation functions for order operations.
+ *
+ * These functions contain no side effects and no database calls.
+ * They validate inputs and state transitions for the order domain.
+ */
+
+import type { OrderItem, OrderStatus } from '../models/order.js';
+
+/**
+ * Valid status transitions for orders.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate that a status transition is allowed. Throws if not.
+ */
+export function validateStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(
+      `Invalid status transition: ${from} -> ${to}`,
+    );
+  }
+}
+
+/**
+ * Validate that an order has at least one item. Throws if empty.
+ */
+export function validateOrderItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
diff --git a/src/validators/preferences.validator.ts b/src/validators/preferences.validator.ts
new file mode 100644
index 0000000..d808ac8
--- /dev/null
+++ b/src/validators/preferences.validator.ts
@@ -0,0 +1,33 @@
+/**
+ * Pure validation functions for notification preferences.
+ *
+ * These functions contain no side effects and no database calls.
+ * They evaluate preference rules given a preferences object.
+ */
+
+import type { EmailPreferences } from '../models/user-preferences.js';
+import type { NotificationType } from '../models/notification.js';
+
+/**
+ * Determine whether an email notification should be sent based on preferences.
+ * Returns true if email is enabled, frequency is not 'never', and the
+ * notification type is in the user's subscribed categories.
+ */
+export function shouldSendEmailNotification(
+  prefs: EmailPreferences,
+  notificationType: NotificationType,
+): boolean {
+  if (!prefs.enabled) {
+    return false;
+  }
+
+  if (prefs.frequency === 'never') {
+    return false;
+  }
+
+  if (!prefs.subscribedCategories.includes(notificationType)) {
+    return false;
+  }
+
+  return true;
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..bb3fbd3
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,37 @@
+/**
+ * Pure validation functions for user operations.
+ *
+ * These functions contain no side effects and no database calls.
+ * They accept lookup results and validate business rules.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that an email is not already taken.
+ * Accepts the result of an email lookup — if a user was found, the email is taken.
+ */
+export function validateEmailUnique(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not taken by another user on update.
+ * Accepts the result of an email lookup — if a user was found, the email is in use.
+ */
+export function validateEmailNotInUse(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
+
+/**
+ * Validate that a user exists. Throws if not found.
+ */
+export function validateUserExists<T>(entity: T | undefined, id: string): asserts entity is T {
+  if (!entity) {
+    throw new Error(`User not found: ${id}`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..2feff34
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,68 @@
+import { describe, it, expect } from 'vitest';
+import {
+  isValidStatusTransition,
+  validateStatusTransition,
+  validateOrderItems,
+} from '../../src/validators/order.validator.js';
+
+describe('order.validator', () => {
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(isValidStatusTransition('delivered', 'pending')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'cancelled')).toBe(false);
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(isValidStatusTransition('cancelled', 'pending')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'confirmed')).toBe(false);
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+  });
+
+  describe('validateOrderItems', () => {
+    it('should not throw for non-empty items', () => {
+      expect(() =>
+        validateOrderItems([{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }]),
+      ).not.toThrow();
+    });
+
+    it('should throw for empty items', () => {
+      expect(() => validateOrderItems([])).toThrow('Order must have at least one item');
+    });
+  });
+});
diff --git a/tests/validators/preferences.validator.test.ts b/tests/validators/preferences.validator.test.ts
new file mode 100644
index 0000000..fbd3cbe
--- /dev/null
+++ b/tests/validators/preferences.validator.test.ts
@@ -0,0 +1,40 @@
+import { describe, it, expect } from 'vitest';
+import { shouldSendEmailNotification } from '../../src/validators/preferences.validator.js';
+import type { EmailPreferences } from '../../src/models/user-preferences.js';
+
+const makePrefs = (overrides: Partial<EmailPreferences> = {}): EmailPreferences => ({
+  enabled: true,
+  frequency: 'immediate',
+  subscribedCategories: ['order_confirmation', 'order_status_update', 'user_welcome', 'user_updated'],
+  ...overrides,
+});
+
+describe('preferences.validator', () => {
+  describe('shouldSendEmailNotification', () => {
+    it('should return true when email is enabled and type is subscribed', () => {
+      expect(shouldSendEmailNotification(makePrefs(), 'order_confirmation')).toBe(true);
+    });
+
+    it('should return false when email is disabled', () => {
+      expect(shouldSendEmailNotification(makePrefs({ enabled: false }), 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false when frequency is never', () => {
+      expect(shouldSendEmailNotification(makePrefs({ frequency: 'never' }), 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false when notification type is not subscribed', () => {
+      expect(
+        shouldSendEmailNotification(makePrefs({ subscribedCategories: ['user_welcome'] }), 'order_confirmation'),
+      ).toBe(false);
+    });
+
+    it('should return true for daily_digest frequency', () => {
+      expect(shouldSendEmailNotification(makePrefs({ frequency: 'daily_digest' }), 'order_confirmation')).toBe(true);
+    });
+
+    it('should return true for weekly_digest frequency', () => {
+      expect(shouldSendEmailNotification(makePrefs({ frequency: 'weekly_digest' }), 'order_confirmation')).toBe(true);
+    });
+  });
+});
