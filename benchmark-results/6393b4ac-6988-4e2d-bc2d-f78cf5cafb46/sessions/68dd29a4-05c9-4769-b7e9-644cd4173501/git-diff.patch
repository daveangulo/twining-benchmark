+/**
+ * SMS notification adapter — delivers notifications via SMS.
+ *
+ * Features:
+ * - Message formatting per notification type (plain text, SMS-length aware)
+ * - Phone number validation (E.164 format)
+ * - Configurable sender ID
+ * - In-memory send log for testing
+ *
+ * Implements NotificationAdapter so the NotificationService can
+ * route sms-channel notifications here.
+ */
+
+import type { NotificationAdapter } from './notification.adapter.js';
+import type { NotificationPayload, NotificationType } from '../models/notification.js';
+import { Logger } from '../utils/logger.js';
+
+export interface SmsConfig {
+  /** Sender ID or phone number shown as the sender. */
+  fromNumber: string;
+  /** Maximum message length before truncation. */
+  maxLength: number;
+}
+
+const defaultSmsConfig: SmsConfig = {
+  fromNumber: '+15551234567',
+  maxLength: 160,
+};
+
+export interface SentSms {
+  to: string;
+  from: string;
+  body: string;
+  sentAt: Date;
+}
+
+/**
+ * SMS message templates keyed by notification type.
+ * Each template receives the payload and returns a plain text string.
+ * Messages are kept short to fit within SMS length limits.
+ */
+const smsTemplates: Record<NotificationType, (payload: NotificationPayload) => string> = {
+  order_confirmation(payload) {
+    const orderId = (payload.metadata?.orderId as string) ?? 'N/A';
+    return `TaskFlow Pro: Order ${orderId} confirmed. ${payload.body}`;
+  },
+
+  order_status_update(payload) {
+    const orderId = (payload.metadata?.orderId as string) ?? 'N/A';
+    const newStatus = (payload.metadata?.newStatus as string) ?? '';
+    return `TaskFlow Pro: Order ${orderId} is now ${newStatus}.`;
+  },
+
+  user_welcome(payload) {
+    return `Welcome to TaskFlow Pro, ${payload.recipient}! Your account is ready.`;
+  },
+
+  user_updated(payload) {
+    return `TaskFlow Pro: Your account has been updated.`;
+  },
+};
+
+/**
+ * Validate phone number in E.164 format: + followed by 7-15 digits.
+ */
+function isValidPhoneNumber(phone: string): boolean {
+  return /^\+[1-9]\d{6,14}$/.test(phone);
+}
+
+export class SmsAdapter implements NotificationAdapter {
+  readonly channel = 'sms' as const;
+  private logger = new Logger('SmsAdapter');
+  private sentMessages: SentSms[] = [];
+
+  constructor(private config: SmsConfig = defaultSmsConfig) {}
+
+  /**
+   * Render the notification body into a plain text SMS message
+   * using the appropriate template for the notification type.
+   * Truncates to maxLength if necessary.
+   */
+  renderTemplate(payload: NotificationPayload): string {
+    const templateFn = smsTemplates[payload.notificationType];
+    const message = templateFn(payload);
+
+    if (message.length > this.config.maxLength) {
+      return message.substring(0, this.config.maxLength - 3) + '...';
+    }
+    return message;
+  }
+
+  /**
+   * Resolve and validate the recipient phone number.
+   * Returns the validated phone number or null if invalid.
+   */
+  resolveRecipient(payload: NotificationPayload): string | null {
+    const phone = payload.recipient.trim();
+    if (!phone || !isValidPhoneNumber(phone)) {
+      this.logger.warn(`Invalid recipient phone number: "${payload.recipient}"`);
+      return null;
+    }
+    return phone;
+  }
+
+  /**
+   * Send an SMS notification.
+   *
+   * 1. Validates the recipient phone number.
+   * 2. Renders the message body from templates.
+   * 3. Records the SMS (in-memory for testing; swap for real provider in production).
+   */
+  async send(payload: NotificationPayload): Promise<boolean> {
+    try {
+      const recipient = this.resolveRecipient(payload);
+      if (!recipient) {
+        return false;
+      }
+
+      const body = this.renderTemplate(payload);
+
+      this.logger.info(`Sending SMS from "${this.config.fromNumber}" to ${recipient}: ${body.substring(0, 50)}...`);
+
+      this.sentMessages.push({
+        to: recipient,
+        from: this.config.fromNumber,
+        body,
+        sentAt: new Date(),
+      });
+
+      return true;
+    } catch (error) {
+      this.logger.error(
+        `Failed to send SMS to ${payload.recipient}: ${error instanceof Error ? error.message : String(error)}`,
+      );
+      return false;
+    }
+  }
+
+  /**
+   * Get all SMS messages sent through this adapter (for testing).
+   */
+  getSentMessages(): SentSms[] {
+    return [...this.sentMessages];
+  }
+
+  /**
+   * Clear sent message history (for testing).
+   */
+  clearSentMessages(): void {
+    this.sentMessages = [];
+  }
+}
