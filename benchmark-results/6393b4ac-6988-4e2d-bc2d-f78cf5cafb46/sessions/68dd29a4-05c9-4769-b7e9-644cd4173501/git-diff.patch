@@ -0,0 +1,194 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { SmsAdapter } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides: Partial<NotificationPayload> = {}): NotificationPayload {
+  return {
+    recipient: '+15559876543',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    channel: 'sms',
+    notificationType: 'order_confirmation',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+describe('SmsAdapter', () => {
+  let adapter: SmsAdapter;
+
+  beforeEach(() => {
+    adapter = new SmsAdapter();
+  });
+
+  describe('send', () => {
+    it('should send an SMS and return true on success', async () => {
+      const result = await adapter.send(makePayload());
+
+      expect(result).toBe(true);
+      const sent = adapter.getSentMessages();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.to).toBe('+15559876543');
+      expect(sent[0]?.body).toContain('order-1');
+    });
+
+    it('should return false for invalid phone number', async () => {
+      const result = await adapter.send(makePayload({ recipient: 'not-a-phone' }));
+      expect(result).toBe(false);
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should return false for empty recipient', async () => {
+      const result = await adapter.send(makePayload({ recipient: '' }));
+      expect(result).toBe(false);
+    });
+
+    it('should return false for recipient with spaces only', async () => {
+      const result = await adapter.send(makePayload({ recipient: '   ' }));
+      expect(result).toBe(false);
+    });
+
+    it('should return false for phone number without + prefix', async () => {
+      const result = await adapter.send(makePayload({ recipient: '15559876543' }));
+      expect(result).toBe(false);
+    });
+
+    it('should return false for phone number starting with +0', async () => {
+      const result = await adapter.send(makePayload({ recipient: '+05559876543' }));
+      expect(result).toBe(false);
+    });
+
+    it('should include from number in sent message', async () => {
+      await adapter.send(makePayload());
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]?.from).toBe('+15551234567');
+    });
+
+    it('should use custom config when provided', async () => {
+      const custom = new SmsAdapter({
+        fromNumber: '+44700000000',
+        maxLength: 160,
+      });
+
+      await custom.send(makePayload());
+
+      const sent = custom.getSentMessages();
+      expect(sent[0]?.from).toBe('+44700000000');
+    });
+
+    it('should record sentAt timestamp', async () => {
+      const before = new Date();
+      await adapter.send(makePayload());
+      const after = new Date();
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]?.sentAt.getTime()).toBeGreaterThanOrEqual(before.getTime());
+      expect(sent[0]?.sentAt.getTime()).toBeLessThanOrEqual(after.getTime());
+    });
+  });
+
+  describe('renderTemplate', () => {
+    it('should render order_confirmation template with order ID', () => {
+      const body = adapter.renderTemplate(makePayload());
+      expect(body).toContain('order-1');
+      expect(body).toContain('TaskFlow Pro');
+    });
+
+    it('should render order_status_update template', () => {
+      const body = adapter.renderTemplate(
+        makePayload({
+          notificationType: 'order_status_update',
+          metadata: { orderId: 'order-1', previousStatus: 'pending', newStatus: 'confirmed' },
+        }),
+      );
+      expect(body).toContain('order-1');
+      expect(body).toContain('confirmed');
+    });
+
+    it('should render user_welcome template', () => {
+      const body = adapter.renderTemplate(
+        makePayload({
+          notificationType: 'user_welcome',
+          subject: 'Welcome to TaskFlow Pro',
+          body: 'Welcome! Your account has been created.',
+        }),
+      );
+      expect(body).toContain('Welcome to TaskFlow Pro');
+    });
+
+    it('should render user_updated template', () => {
+      const body = adapter.renderTemplate(
+        makePayload({
+          notificationType: 'user_updated',
+          subject: 'Account Updated',
+          body: 'Your account has been updated.',
+        }),
+      );
+      expect(body).toContain('updated');
+    });
+
+    it('should truncate messages exceeding maxLength', () => {
+      const shortAdapter = new SmsAdapter({ fromNumber: '+15551234567', maxLength: 30 });
+      const body = shortAdapter.renderTemplate(makePayload());
+      expect(body.length).toBeLessThanOrEqual(30);
+      expect(body).toMatch(/\.\.\.$/);
+    });
+
+    it('should not truncate messages within maxLength', () => {
+      const longAdapter = new SmsAdapter({ fromNumber: '+15551234567', maxLength: 500 });
+      const body = longAdapter.renderTemplate(makePayload());
+      expect(body).not.toMatch(/\.\.\.$/);
+    });
+  });
+
+  describe('resolveRecipient', () => {
+    it('should return valid E.164 phone number', () => {
+      const result = adapter.resolveRecipient(makePayload());
+      expect(result).toBe('+15559876543');
+    });
+
+    it('should return null for invalid phone number', () => {
+      expect(adapter.resolveRecipient(makePayload({ recipient: 'bad' }))).toBeNull();
+    });
+
+    it('should return null for phone number too short', () => {
+      expect(adapter.resolveRecipient(makePayload({ recipient: '+1234' }))).toBeNull();
+    });
+
+    it('should return null for phone number with letters', () => {
+      expect(adapter.resolveRecipient(makePayload({ recipient: '+1555abc4567' }))).toBeNull();
+    });
+
+    it('should trim whitespace from recipient', () => {
+      const result = adapter.resolveRecipient(makePayload({ recipient: '  +15559876543  ' }));
+      expect(result).toBe('+15559876543');
+    });
+  });
+
+  describe('channel', () => {
+    it('should report sms as its channel', () => {
+      expect(adapter.channel).toBe('sms');
+    });
+  });
+
+  describe('getSentMessages / clearSentMessages', () => {
+    it('should return empty array initially', () => {
+      expect(adapter.getSentMessages()).toEqual([]);
+    });
+
+    it('should return a copy of sent messages', async () => {
+      await adapter.send(makePayload());
+      const first = adapter.getSentMessages();
+      const second = adapter.getSentMessages();
+      expect(first).toEqual(second);
+      expect(first).not.toBe(second);
+    });
+
+    it('should clear all sent messages', async () => {
+      await adapter.send(makePayload());
+      adapter.clearSentMessages();
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+});
