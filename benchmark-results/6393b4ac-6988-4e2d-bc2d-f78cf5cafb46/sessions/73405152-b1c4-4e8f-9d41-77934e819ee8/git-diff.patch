+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { Database } from '../../src/utils/database.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { OrderCreatedEvent, UserCreatedEvent } from '../../src/events/event-types.js';
+import type { UserNotificationPreferences } from '../../src/models/user-preferences.js';
+
+describe('NotificationService with preferences', () => {
+  let eventBus: EventBus;
+  let db: Database;
+  let prefsRepo: PreferencesRepository;
+  let service: NotificationService;
+  let emailAdapter: EmailAdapter;
+
+  const alice = {
+    id: 'user-0001',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member' as const,
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  };
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    db = new Database();
+    prefsRepo = new PreferencesRepository(db);
+    service = new NotificationService(eventBus, prefsRepo);
+    emailAdapter = new EmailAdapter();
+    service.registerAdapter(emailAdapter);
+    resetNotificationIdCounter();
+  });
+
+  it('should send notification when user has no preferences (defaults)', async () => {
+    const event: OrderCreatedEvent = {
+      type: 'order:created',
+      order: {
+        id: 'order-1',
+        userId: 'user-0001',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        total: 10,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: alice,
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+
+    expect(emailAdapter.getSentEmails()).toHaveLength(1);
+    expect(service.getNotifications()).toHaveLength(1);
+    expect(service.getNotifications()[0]?.status).toBe('sent');
+  });
+
+  it('should suppress notification when email is globally disabled', async () => {
+    const now = new Date();
+    const prefs: UserNotificationPreferences = {
+      id: 'pref-0001',
+      userId: 'user-0001',
+      email: {
+        enabled: false,
+        frequency: 'immediate',
+        categories: {
+          'order-confirmation': true,
+          'order-status-update': true,
+          'welcome': true,
+          'user-updated': true,
+        },
+      },
+      createdAt: now,
+      updatedAt: now,
+    };
+    prefsRepo.save(prefs);
+
+    const event: OrderCreatedEvent = {
+      type: 'order:created',
+      order: {
+        id: 'order-1',
+        userId: 'user-0001',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        total: 10,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: alice,
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+
+    expect(emailAdapter.getSentEmails()).toHaveLength(0);
+  });
+
+  it('should suppress notification when specific category is disabled', async () => {
+    const now = new Date();
+    const prefs: UserNotificationPreferences = {
+      id: 'pref-0001',
+      userId: 'user-0001',
+      email: {
+        enabled: true,
+        frequency: 'immediate',
+        categories: {
+          'order-confirmation': false,
+          'order-status-update': true,
+          'welcome': true,
+          'user-updated': true,
+        },
+      },
+      createdAt: now,
+      updatedAt: now,
+    };
+    prefsRepo.save(prefs);
+
+    const event: OrderCreatedEvent = {
+      type: 'order:created',
+      order: {
+        id: 'order-1',
+        userId: 'user-0001',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        total: 10,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: alice,
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+
+    expect(emailAdapter.getSentEmails()).toHaveLength(0);
+  });
+
+  it('should send notification when category is enabled', async () => {
+    const now = new Date();
+    const prefs: UserNotificationPreferences = {
+      id: 'pref-0001',
+      userId: 'user-0001',
+      email: {
+        enabled: true,
+        frequency: 'immediate',
+        categories: {
+          'order-confirmation': true,
+          'order-status-update': false,
+          'welcome': false,
+          'user-updated': false,
+        },
+      },
+      createdAt: now,
+      updatedAt: now,
+    };
+    prefsRepo.save(prefs);
+
+    const event: OrderCreatedEvent = {
+      type: 'order:created',
+      order: {
+        id: 'order-1',
+        userId: 'user-0001',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        total: 10,
+        status: 'pending',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      user: alice,
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+
+    expect(emailAdapter.getSentEmails()).toHaveLength(1);
+  });
+
+  it('should suppress welcome notification when welcome category is disabled', async () => {
+    const now = new Date();
+    const prefs: UserNotificationPreferences = {
+      id: 'pref-0001',
+      userId: 'user-0001',
+      email: {
+        enabled: true,
+        frequency: 'immediate',
+        categories: {
+          'order-confirmation': true,
+          'order-status-update': true,
+          'welcome': false,
+          'user-updated': true,
+        },
+      },
+      createdAt: now,
+      updatedAt: now,
+    };
+    prefsRepo.save(prefs);
+
+    const event: UserCreatedEvent = {
+      type: 'user:created',
+      user: alice,
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+
+    expect(emailAdapter.getSentEmails()).toHaveLength(0);
+  });
+
+  it('should work without preferences repository (backward compatible)', async () => {
+    // Create service without preferences repo
+    const serviceNoPref = new NotificationService(eventBus);
+    serviceNoPref.registerAdapter(emailAdapter);
+
+    const event: UserCreatedEvent = {
+      type: 'user:created',
+      user: alice,
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+
+    // Both services received the event; the one without prefs should always send
+    const emails = emailAdapter.getSentEmails();
+    expect(emails.length).toBeGreaterThanOrEqual(1);
+  });
+});
