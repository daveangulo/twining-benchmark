+/**
+ * Preferences validation — pure validation functions for notification preferences.
+ *
+ * These validators contain no side effects and no database calls.
+ * They evaluate preference rules against in-memory preference data.
+ */
+
+import type { UserNotificationPreferences } from '../models/user-preferences.js';
+import type { NotificationChannel, NotificationType } from '../models/notification.js';
+
+/**
+ * Check whether a notification is allowed by the user's preferences.
+ *
+ * Rules:
+ * 1. If no preferences exist (null), notifications are allowed (opt-out model).
+ * 2. If the email channel is disabled, all email notifications are suppressed.
+ * 3. If the frequency is 'none', all email notifications are suppressed.
+ * 4. If the specific category is disabled, that notification is suppressed.
+ * 5. Non-email channels are always allowed (only email preferences are supported).
+ */
+export function isNotificationAllowed(
+  prefs: UserNotificationPreferences | null,
+  channel: NotificationChannel,
+  type: NotificationType,
+): boolean {
+  // Only email preferences are supported for now
+  if (channel !== 'email') {
+    return true;
+  }
+
+  // No preferences stored — default is to send everything
+  if (!prefs) {
+    return true;
+  }
+
+  if (!prefs.email.enabled) {
+    return false;
+  }
+
+  if (prefs.email.frequency === 'none') {
+    return false;
+  }
+
+  if (prefs.email.categories[type] === false) {
+    return false;
+  }
+
+  return true;
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..2e96455
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,92 @@
+import { describe, it, expect } from 'vitest';
+import {
+  isValidStatusTransition,
+  validateStatusTransition,
+  validateOrderItems,
+} from '../../src/validators/order.validator.js';
+import type { OrderItem, OrderStatus } from '../../src/models/order.js';
+
+describe('Order Validators', () => {
+  describe('validateOrderItems', () => {
+    it('should pass for non-empty items', () => {
+      const items: OrderItem[] = [
+        { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+      ];
+      expect(() => validateOrderItems(items)).not.toThrow();
+    });
+
+    it('should throw for empty items', () => {
+      expect(() => validateOrderItems([])).toThrow('at least one item');
+    });
+
+    it('should pass for multiple items', () => {
+      const items: OrderItem[] = [
+        { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+        { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+      ];
+      expect(() => validateOrderItems(items)).not.toThrow();
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject pending -> shipped', () => {
+      expect(isValidStatusTransition('pending', 'shipped')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      const statuses: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'cancelled'];
+      for (const status of statuses) {
+        expect(isValidStatusTransition('delivered', status)).toBe(false);
+      }
+    });
+
+    it('should reject cancelled -> any', () => {
+      const statuses: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'delivered'];
+      for (const status of statuses) {
+        expect(isValidStatusTransition('cancelled', status)).toBe(false);
+      }
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+
+    it('should throw for transitions from terminal states', () => {
+      expect(() => validateStatusTransition('cancelled', 'pending')).toThrow(
+        'Invalid status transition',
+      );
+    });
+  });
+});
