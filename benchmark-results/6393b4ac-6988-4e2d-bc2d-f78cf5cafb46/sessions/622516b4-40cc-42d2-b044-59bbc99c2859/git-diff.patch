+
+  describe('notification ordering', () => {
+    it('should deliver notifications for the same recipient in order even with variable adapter latency', async () => {
+      const deliveryOrder: string[] = [];
+
+      // Adapter where the first call is slow and the second is fast.
+      // Without per-recipient queueing, the second notification would arrive first.
+      let callCount = 0;
+      const slowThenFastAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          const thisCall = callCount++;
+          if (thisCall === 0) {
+            // First notification: slow (50ms)
+            await new Promise((r) => setTimeout(r, 50));
+          }
+          // Second notification: immediate
+          deliveryOrder.push(payload.type);
+          return { success: true, notificationId: payload.id, channel: payload.channel };
+        },
+      };
+
+      const orderedEventBus = new EventBus();
+      const orderedService = new NotificationService(orderedEventBus);
+      orderedService.registerAdapter(slowThenFastAdapter);
+
+      // Fire both events concurrently for the same recipient — without ordering
+      // guarantees, the status update (fast) would be delivered before order
+      // confirmation (slow).
+      const orderCreatedEvent: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      const statusChangedEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'alice@example.com',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      // Emit concurrently — do NOT await the first before emitting the second
+      await Promise.all([
+        orderedEventBus.emit(orderCreatedEvent),
+        orderedEventBus.emit(statusChangedEvent),
+      ]);
+
+      // Order confirmation must be delivered before status update
+      expect(deliveryOrder).toEqual(['order_confirmation', 'order_status_update']);
+
+      const notifications = orderedService.getNotifications();
+      expect(notifications).toHaveLength(2);
+      expect(notifications[0]?.type).toBe('order_confirmation');
+      expect(notifications[1]?.type).toBe('order_status_update');
+    });
+  });
 });
