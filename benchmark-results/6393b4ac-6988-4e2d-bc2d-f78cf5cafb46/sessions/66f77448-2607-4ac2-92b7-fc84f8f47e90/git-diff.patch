+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,222 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookAdapter,
+  InMemoryWebhookTransport,
+} from '../../src/adapters/webhook.adapter.js';
+import type {
+  WebhookTransport,
+  WebhookRequestBody,
+} from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: 'user-1',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    channel: 'webhook',
+    type: 'order_confirmation',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+const TEST_URL = 'https://hooks.example.com/notify';
+
+describe('WebhookAdapter', () => {
+  let adapter: WebhookAdapter;
+  let transport: InMemoryWebhookTransport;
+
+  beforeEach(() => {
+    transport = new InMemoryWebhookTransport();
+    adapter = new WebhookAdapter({ url: TEST_URL, transport });
+  });
+
+  describe('channel', () => {
+    it('should report webhook channel', () => {
+      expect(adapter.channel).toBe('webhook');
+    });
+  });
+
+  describe('constructor validation', () => {
+    it('should reject invalid URLs', () => {
+      expect(() => new WebhookAdapter({ url: 'not-a-url', transport })).toThrow('Invalid webhook URL');
+    });
+
+    it('should reject URLs without http/https protocol', () => {
+      expect(() => new WebhookAdapter({ url: 'ftp://example.com', transport })).toThrow('Invalid webhook URL');
+    });
+
+    it('should accept http URLs', () => {
+      expect(() => new WebhookAdapter({ url: 'http://example.com/hook', transport })).not.toThrow();
+    });
+
+    it('should accept https URLs', () => {
+      expect(() => new WebhookAdapter({ url: 'https://example.com/hook', transport })).not.toThrow();
+    });
+  });
+
+  describe('formatPayload', () => {
+    it('should format notification payload as webhook JSON body', () => {
+      const payload = makePayload();
+      const body = adapter.formatPayload(payload);
+
+      expect(body.type).toBe('order_confirmation');
+      expect(body.recipient).toBe('user-1');
+      expect(body.subject).toBe('Order Confirmation: order-1');
+      expect(body.body).toContain('Widget x2');
+      expect(body.metadata).toEqual({ orderId: 'order-1', userId: 'user-1' });
+      expect(body.timestamp).toBeTruthy();
+    });
+
+    it('should include ISO timestamp', () => {
+      const body = adapter.formatPayload(makePayload());
+      expect(() => new Date(body.timestamp)).not.toThrow();
+      expect(new Date(body.timestamp).toISOString()).toBe(body.timestamp);
+    });
+
+    it('should handle payload without metadata', () => {
+      const payload = makePayload({ metadata: undefined });
+      const body = adapter.formatPayload(payload);
+      expect(body.metadata).toBeUndefined();
+    });
+  });
+
+  describe('send', () => {
+    it('should POST payload to configured URL and return success', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('webhook');
+
+      const requests = transport.getRequests();
+      expect(requests).toHaveLength(1);
+      expect(requests[0]?.url).toBe(TEST_URL);
+      expect(requests[0]?.body.type).toBe('order_confirmation');
+      expect(requests[0]?.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should include secret header when configured', async () => {
+      const secretAdapter = new WebhookAdapter({
+        url: TEST_URL,
+        secret: 'my-secret-token',
+        transport,
+      });
+
+      await secretAdapter.send(makePayload());
+
+      const requests = transport.getRequests();
+      expect(requests[0]?.headers['X-Webhook-Secret']).toBe('my-secret-token');
+    });
+
+    it('should not include secret header when not configured', async () => {
+      await adapter.send(makePayload());
+
+      const requests = transport.getRequests();
+      expect(requests[0]?.headers['X-Webhook-Secret']).toBeUndefined();
+    });
+
+    it('should handle non-success HTTP status codes', async () => {
+      const failTransport: WebhookTransport = {
+        post: async () => ({ statusCode: 500 }),
+      };
+      const failAdapter = new WebhookAdapter({ url: TEST_URL, transport: failTransport });
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('status 500');
+    });
+
+    it('should handle 4xx status codes as failure', async () => {
+      const failTransport: WebhookTransport = {
+        post: async () => ({ statusCode: 404 }),
+      };
+      const failAdapter = new WebhookAdapter({ url: TEST_URL, transport: failTransport });
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('status 404');
+    });
+
+    it('should handle transport errors gracefully', async () => {
+      const failTransport: WebhookTransport = {
+        post: async () => {
+          throw new Error('Connection refused');
+        },
+      };
+      const failAdapter = new WebhookAdapter({ url: TEST_URL, transport: failTransport });
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Connection refused');
+    });
+
+    it('should handle non-Error throw from transport', async () => {
+      const failTransport: WebhookTransport = {
+        post: async () => {
+          throw 'string error';
+        },
+      };
+      const failAdapter = new WebhookAdapter({ url: TEST_URL, transport: failTransport });
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('string error');
+    });
+
+    it('should send multiple webhooks independently', async () => {
+      await adapter.send(makePayload({ type: 'order_confirmation' }));
+      await adapter.send(makePayload({ type: 'welcome' }));
+
+      const requests = transport.getRequests();
+      expect(requests).toHaveLength(2);
+      expect(requests[0]?.body.type).toBe('order_confirmation');
+      expect(requests[1]?.body.type).toBe('welcome');
+    });
+  });
+});
+
+describe('InMemoryWebhookTransport', () => {
+  let transport: InMemoryWebhookTransport;
+
+  beforeEach(() => {
+    transport = new InMemoryWebhookTransport();
+  });
+
+  it('should store posted requests', async () => {
+    const body: WebhookRequestBody = {
+      type: 'order_confirmation',
+      recipient: 'user-1',
+      subject: 'Test',
+      body: 'Hello',
+      timestamp: new Date().toISOString(),
+    };
+
+    const result = await transport.post('https://example.com/hook', body, { 'Content-Type': 'application/json' });
+    expect(result.statusCode).toBe(200);
+
+    const requests = transport.getRequests();
+    expect(requests).toHaveLength(1);
+    expect(requests[0]?.url).toBe('https://example.com/hook');
+    expect(requests[0]?.postedAt).toBeInstanceOf(Date);
+  });
+
+  it('should clear stored requests', async () => {
+    const body: WebhookRequestBody = {
+      type: 'welcome',
+      recipient: 'user-1',
+      subject: 'Test',
+      body: 'Hello',
+      timestamp: new Date().toISOString(),
+    };
+
+    await transport.post('https://example.com/hook', body, {});
+    transport.clear();
+    expect(transport.getRequests()).toHaveLength(0);
+  });
+});
