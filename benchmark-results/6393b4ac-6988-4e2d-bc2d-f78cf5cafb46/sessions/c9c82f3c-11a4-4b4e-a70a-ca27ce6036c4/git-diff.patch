+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,209 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookNotificationAdapter,
+  isValidWebhookUrl,
+  formatWebhookBody,
+} from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides: Partial<NotificationPayload> = {}): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order_confirmation',
+    channel: 'webhook',
+    recipient: 'user-1',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    priority: 'normal',
+    createdAt: new Date('2026-01-15T12:00:00Z'),
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+describe('isValidWebhookUrl', () => {
+  it('should accept valid HTTP URLs', () => {
+    expect(isValidWebhookUrl('http://example.com/webhook')).toBe(true);
+    expect(isValidWebhookUrl('https://hooks.example.com/notify')).toBe(true);
+    expect(isValidWebhookUrl('https://example.com:8080/api/webhook')).toBe(true);
+  });
+
+  it('should reject invalid URLs', () => {
+    expect(isValidWebhookUrl('')).toBe(false);
+    expect(isValidWebhookUrl('not-a-url')).toBe(false);
+    expect(isValidWebhookUrl('ftp://example.com/webhook')).toBe(false);
+    expect(isValidWebhookUrl('mailto:user@example.com')).toBe(false);
+  });
+});
+
+describe('formatWebhookBody', () => {
+  it('should format a notification payload as a webhook body', () => {
+    const payload = makePayload();
+    const body = formatWebhookBody(payload);
+
+    expect(body.notificationId).toBe('notif-0001');
+    expect(body.type).toBe('order_confirmation');
+    expect(body.channel).toBe('webhook');
+    expect(body.recipient).toBe('user-1');
+    expect(body.subject).toBe('Order Confirmation: order-1');
+    expect(body.body).toBe('Your order has been placed. Items: Widget x2. Total: $20.00');
+    expect(body.priority).toBe('normal');
+    expect(body.createdAt).toBe('2026-01-15T12:00:00.000Z');
+    expect(body.metadata).toEqual({ orderId: 'order-1', userId: 'user-1' });
+  });
+
+  it('should handle payload without metadata', () => {
+    const payload = makePayload({ metadata: undefined });
+    const body = formatWebhookBody(payload);
+
+    expect(body.metadata).toBeUndefined();
+  });
+});
+
+describe('WebhookNotificationAdapter', () => {
+  let adapter: WebhookNotificationAdapter;
+
+  beforeEach(() => {
+    adapter = new WebhookNotificationAdapter({
+      url: 'https://hooks.example.com/notify',
+    });
+  });
+
+  it('should have channel set to webhook', () => {
+    expect(adapter.channel).toBe('webhook');
+  });
+
+  describe('send', () => {
+    it('should send a valid webhook and return success', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('webhook');
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+    });
+
+    it('should store the delivered webhook with request details', async () => {
+      const payload = makePayload();
+      await adapter.send(payload);
+
+      const delivered = adapter.getDeliveredWebhooks();
+      expect(delivered).toHaveLength(1);
+      expect(delivered[0]!.payload).toEqual(payload);
+      expect(delivered[0]!.request.url).toBe('https://hooks.example.com/notify');
+      expect(delivered[0]!.request.method).toBe('POST');
+      expect(delivered[0]!.request.headers['Content-Type']).toBe('application/json');
+      expect(delivered[0]!.request.headers['X-Notification-Id']).toBe('notif-0001');
+      expect(delivered[0]!.request.headers['X-Notification-Type']).toBe('order_confirmation');
+      expect(delivered[0]!.request.body.notificationId).toBe('notif-0001');
+      expect(delivered[0]!.request.body.type).toBe('order_confirmation');
+    });
+
+    it('should include custom headers when configured', async () => {
+      const customAdapter = new WebhookNotificationAdapter({
+        url: 'https://hooks.example.com/notify',
+        headers: { 'X-Custom-Header': 'custom-value' },
+      });
+
+      await customAdapter.send(makePayload());
+
+      const delivered = customAdapter.getDeliveredWebhooks();
+      expect(delivered[0]!.request.headers['X-Custom-Header']).toBe('custom-value');
+      expect(delivered[0]!.request.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should fail for invalid webhook URL', async () => {
+      const badAdapter = new WebhookNotificationAdapter({
+        url: 'not-a-valid-url',
+      });
+
+      const result = await badAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid webhook URL');
+      expect(badAdapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+
+    it('should fail for non-HTTP URL', async () => {
+      const badAdapter = new WebhookNotificationAdapter({
+        url: 'ftp://example.com/webhook',
+      });
+
+      const result = await badAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid webhook URL');
+    });
+
+    it('should handle different notification types', async () => {
+      const payload = makePayload({
+        type: 'order_status_update',
+        subject: 'Order Update: order-1',
+        priority: 'high',
+        metadata: { orderId: 'order-1', previousStatus: 'pending', newStatus: 'cancelled' },
+      });
+
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const delivered = adapter.getDeliveredWebhooks();
+      expect(delivered[0]!.request.body.type).toBe('order_status_update');
+      expect(delivered[0]!.request.body.priority).toBe('high');
+    });
+  });
+
+  describe('getDeliveredWebhooks / clearDeliveredWebhooks', () => {
+    it('should return a copy of delivered webhooks', async () => {
+      await adapter.send(makePayload());
+      const webhooks = adapter.getDeliveredWebhooks();
+      webhooks.pop();
+      expect(adapter.getDeliveredWebhooks()).toHaveLength(1);
+    });
+
+    it('should clear all delivered webhooks', async () => {
+      await adapter.send(makePayload());
+      adapter.clearDeliveredWebhooks();
+      expect(adapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+  });
+});
+
+describe('WebhookNotificationAdapter integration with NotificationService', () => {
+  it('should work end-to-end with EventBus and NotificationService', async () => {
+    const { EventBus } = await import('../../src/events/event-bus.js');
+    const { NotificationService, resetNotificationIdCounter } = await import(
+      '../../src/services/notification.service.js'
+    );
+
+    const eventBus = new EventBus();
+    const service = new NotificationService(eventBus);
+    const adapter = new WebhookNotificationAdapter({
+      url: 'https://hooks.example.com/notify',
+    });
+    resetNotificationIdCounter();
+
+    service.registerAdapter(adapter);
+
+    // Send a webhook notification directly through the service
+    await service.send({
+      type: 'order_confirmation',
+      channel: 'webhook',
+      recipient: 'user-1',
+      subject: 'Order Confirmation: order-42',
+      body: 'Your order has been placed. Items: Widget x3. Total: $45.00',
+      priority: 'normal',
+      metadata: { orderId: 'order-42', userId: 'user-1' },
+    });
+
+    const notifications = service.getNotifications();
+    expect(notifications).toHaveLength(1);
+    expect(notifications[0]!.status).toBe('sent');
+    expect(notifications[0]!.channel).toBe('webhook');
+
+    const delivered = adapter.getDeliveredWebhooks();
+    expect(delivered).toHaveLength(1);
+    expect(delivered[0]!.request.url).toBe('https://hooks.example.com/notify');
+    expect(delivered[0]!.request.body.subject).toContain('order-42');
+  });
+});
