+  describe('notification delivery ordering', () => {
+    it('should deliver notifications to the same recipient in order even with variable adapter latency', async () => {
+      const deliveryOrder: string[] = [];
+      let callCount = 0;
+
+      // Adapter that takes longer for the first call than subsequent ones,
+      // simulating variable network latency that would cause out-of-order delivery
+      const slowFirstAdapter: NotificationAdapter = {
+        channel: 'email',
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          const thisCall = callCount++;
+          const delay = thisCall === 0 ? 50 : 5; // First notification is slow
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.subject);
+          return { success: true, notificationId: payload.metadata?.notificationId ?? '', channel: 'email' };
+        },
+      };
+
+      service.registerAdapter(slowFirstAdapter);
+
+      // Fire two notifications concurrently for the same recipient
+      const send1 = service.send({
+        type: 'order:confirmation',
+        recipient: 'alice@example.com',
+        subject: 'Order Placed',
+        body: 'Your order has been placed.',
+        channel: 'email',
+        priority: 'normal',
+      });
+      const send2 = service.send({
+        type: 'order:status-update',
+        recipient: 'alice@example.com',
+        subject: 'Payment Confirmed',
+        body: 'Your payment has been confirmed.',
+        channel: 'email',
+        priority: 'normal',
+      });
+
+      await Promise.all([send1, send2]);
+
+      // Despite the first adapter call being slower, delivery order must match send order
+      expect(deliveryOrder).toEqual(['Order Placed', 'Payment Confirmed']);
+    });
+
+    it('should not serialize notifications for different recipients', async () => {
+      const deliveryOrder: string[] = [];
+      let callCount = 0;
+
+      const variableLatencyAdapter: NotificationAdapter = {
+        channel: 'email',
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          const thisCall = callCount++;
+          const delay = thisCall === 0 ? 50 : 5; // First call is slow
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryOrder.push(payload.recipient);
+          return { success: true, notificationId: payload.metadata?.notificationId ?? '', channel: 'email' };
+        },
+      };
+
+      service.registerAdapter(variableLatencyAdapter);
+
+      // Fire notifications concurrently for different recipients
+      const send1 = service.send({
+        type: 'order:confirmation',
+        recipient: 'alice@example.com',
+        subject: 'Order Placed',
+        body: 'Body',
+        channel: 'email',
+        priority: 'normal',
+      });
+      const send2 = service.send({
+        type: 'order:confirmation',
+        recipient: 'bob@example.com',
+        subject: 'Order Placed',
+        body: 'Body',
+        channel: 'email',
+        priority: 'normal',
+      });
+
+      await Promise.all([send1, send2]);
+
+      // Bob's faster notification should complete first (not blocked by Alice's slow one)
+      expect(deliveryOrder).toEqual(['bob@example.com', 'alice@example.com']);
+    });
+  });
