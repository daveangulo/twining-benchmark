@@ -0,0 +1,206 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { WebhookAdapter } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides: Partial<NotificationPayload> = {}): NotificationPayload {
+  return {
+    recipient: 'user-1',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    channel: 'webhook',
+    notificationType: 'order_confirmation',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+describe('WebhookAdapter', () => {
+  let adapter: WebhookAdapter;
+
+  beforeEach(() => {
+    adapter = new WebhookAdapter({ url: 'https://hooks.example.com/notify', timeoutMs: 5000 });
+  });
+
+  describe('send', () => {
+    it('should send a webhook and return true on success', async () => {
+      const result = await adapter.send(makePayload());
+
+      expect(result).toBe(true);
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.url).toBe('https://hooks.example.com/notify');
+      expect(deliveries[0]?.payload.subject).toBe('Order Confirmation: order-1');
+    });
+
+    it('should return false for invalid URL', async () => {
+      const badAdapter = new WebhookAdapter({ url: 'not-a-url', timeoutMs: 5000 });
+      const result = await badAdapter.send(makePayload());
+      expect(result).toBe(false);
+      expect(badAdapter.getDeliveries()).toHaveLength(0);
+    });
+
+    it('should return false for empty URL', async () => {
+      const badAdapter = new WebhookAdapter({ url: '', timeoutMs: 5000 });
+      const result = await badAdapter.send(makePayload());
+      expect(result).toBe(false);
+    });
+
+    it('should return false for whitespace-only URL', async () => {
+      const badAdapter = new WebhookAdapter({ url: '   ', timeoutMs: 5000 });
+      const result = await badAdapter.send(makePayload());
+      expect(result).toBe(false);
+    });
+
+    it('should include Content-Type header in delivery', async () => {
+      await adapter.send(makePayload());
+
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries[0]?.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should include secret header when configured', async () => {
+      const secretAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+        timeoutMs: 5000,
+        secret: 'my-secret-key',
+      });
+
+      await secretAdapter.send(makePayload());
+
+      const deliveries = secretAdapter.getDeliveries();
+      expect(deliveries[0]?.headers['X-Webhook-Secret']).toBe('my-secret-key');
+    });
+
+    it('should not include secret header when not configured', async () => {
+      await adapter.send(makePayload());
+
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries[0]?.headers['X-Webhook-Secret']).toBeUndefined();
+    });
+
+    it('should include custom headers when configured', async () => {
+      const customAdapter = new WebhookAdapter({
+        url: 'https://hooks.example.com/notify',
+        timeoutMs: 5000,
+        headers: { 'X-Custom': 'value' },
+      });
+
+      await customAdapter.send(makePayload());
+
+      const deliveries = customAdapter.getDeliveries();
+      expect(deliveries[0]?.headers['X-Custom']).toBe('value');
+    });
+
+    it('should record deliveredAt timestamp', async () => {
+      const before = new Date();
+      await adapter.send(makePayload());
+      const after = new Date();
+
+      const deliveries = adapter.getDeliveries();
+      expect(deliveries[0]?.deliveredAt.getTime()).toBeGreaterThanOrEqual(before.getTime());
+      expect(deliveries[0]?.deliveredAt.getTime()).toBeLessThanOrEqual(after.getTime());
+    });
+
+    it('should accept http URLs', async () => {
+      const httpAdapter = new WebhookAdapter({ url: 'http://localhost:3000/webhook', timeoutMs: 5000 });
+      const result = await httpAdapter.send(makePayload());
+      expect(result).toBe(true);
+    });
+  });
+
+  describe('formatPayload', () => {
+    it('should include event type from notification type', () => {
+      const body = adapter.formatPayload(makePayload());
+      expect(body.event).toBe('order_confirmation');
+    });
+
+    it('should include recipient, subject, and body', () => {
+      const payload = makePayload();
+      const body = adapter.formatPayload(payload);
+      expect(body.recipient).toBe(payload.recipient);
+      expect(body.subject).toBe(payload.subject);
+      expect(body.body).toBe(payload.body);
+    });
+
+    it('should include metadata when present', () => {
+      const body = adapter.formatPayload(makePayload());
+      expect(body.metadata).toEqual({ orderId: 'order-1', userId: 'user-1' });
+    });
+
+    it('should include ISO timestamp', () => {
+      const body = adapter.formatPayload(makePayload());
+      expect(body.timestamp).toMatch(/^\d{4}-\d{2}-\d{2}T/);
+    });
+
+    it('should format order_status_update correctly', () => {
+      const body = adapter.formatPayload(
+        makePayload({
+          notificationType: 'order_status_update',
+          subject: 'Order Update: order-1',
+          body: 'Your order status has changed from pending to confirmed.',
+          metadata: { orderId: 'order-1', previousStatus: 'pending', newStatus: 'confirmed' },
+        }),
+      );
+      expect(body.event).toBe('order_status_update');
+      expect(body.metadata?.newStatus).toBe('confirmed');
+    });
+
+    it('should format user_welcome correctly', () => {
+      const body = adapter.formatPayload(
+        makePayload({
+          notificationType: 'user_welcome',
+          subject: 'Welcome to TaskFlow Pro',
+          body: 'Welcome, Alice! Your account has been created.',
+        }),
+      );
+      expect(body.event).toBe('user_welcome');
+    });
+  });
+
+  describe('resolveUrl', () => {
+    it('should return valid https URL', () => {
+      expect(adapter.resolveUrl()).toBe('https://hooks.example.com/notify');
+    });
+
+    it('should return null for invalid URL', () => {
+      const badAdapter = new WebhookAdapter({ url: 'ftp://bad', timeoutMs: 5000 });
+      expect(badAdapter.resolveUrl()).toBeNull();
+    });
+
+    it('should return null for empty URL', () => {
+      const badAdapter = new WebhookAdapter({ url: '', timeoutMs: 5000 });
+      expect(badAdapter.resolveUrl()).toBeNull();
+    });
+
+    it('should trim whitespace from URL', () => {
+      const spaceyAdapter = new WebhookAdapter({ url: '  https://hooks.example.com/notify  ', timeoutMs: 5000 });
+      expect(spaceyAdapter.resolveUrl()).toBe('https://hooks.example.com/notify');
+    });
+  });
+
+  describe('channel', () => {
+    it('should report webhook as its channel', () => {
+      expect(adapter.channel).toBe('webhook');
+    });
+  });
+
+  describe('getDeliveries / clearDeliveries', () => {
+    it('should return empty array initially', () => {
+      expect(adapter.getDeliveries()).toEqual([]);
+    });
+
+    it('should return a copy of deliveries', async () => {
+      await adapter.send(makePayload());
+      const first = adapter.getDeliveries();
+      const second = adapter.getDeliveries();
+      expect(first).toEqual(second);
+      expect(first).not.toBe(second);
+    });
+
+    it('should clear all deliveries', async () => {
+      await adapter.send(makePayload());
+      adapter.clearDeliveries();
+      expect(adapter.getDeliveries()).toHaveLength(0);
+    });
+  });
+});
