+import { describe, it, expect, beforeEach } from 'vitest';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: 'alice@example.com',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    channel: 'email',
+    notificationType: 'order_confirmation',
+    ...overrides,
+  };
+}
+
+describe('EmailAdapter', () => {
+  let adapter: EmailAdapter;
+
+  beforeEach(() => {
+    adapter = new EmailAdapter();
+  });
+
+  describe('channel property', () => {
+    it('should be email', () => {
+      expect(adapter.channel).toBe('email');
+    });
+  });
+
+  describe('resolveRecipient', () => {
+    it('should return valid email addresses as-is', () => {
+      expect(adapter.resolveRecipient('alice@example.com')).toBe('alice@example.com');
+    });
+
+    it('should return null for non-email identifiers without a resolver', () => {
+      expect(adapter.resolveRecipient('user-123')).toBeNull();
+    });
+
+    it('should use custom resolver when configured', () => {
+      const customAdapter = new EmailAdapter({
+        resolveRecipient: (id) => (id === 'user-1' ? 'alice@example.com' : null),
+      });
+      expect(customAdapter.resolveRecipient('user-1')).toBe('alice@example.com');
+      expect(customAdapter.resolveRecipient('user-unknown')).toBeNull();
+    });
+  });
+
+  describe('renderTemplate', () => {
+    it('should render order_confirmation template with HTML', () => {
+      const rendered = adapter.renderTemplate(makePayload());
+      expect(rendered.to).toBe('alice@example.com');
+      expect(rendered.from).toBe('noreply@taskflow.example.com');
+      expect(rendered.subject).toBe('Order Confirmation: order-1');
+      expect(rendered.html).toContain('Order Confirmed');
+      expect(rendered.html).toContain('Widget x2');
+      expect(rendered.text).toContain('Order Confirmed');
+    });
+
+    it('should render order_status_update template', () => {
+      const rendered = adapter.renderTemplate(
+        makePayload({
+          notificationType: 'order_status_update',
+          subject: 'Order Update: order-1',
+          body: 'Your order status has changed from pending to confirmed.',
+        }),
+      );
+      expect(rendered.html).toContain('Order Status Update');
+      expect(rendered.text).toContain('pending to confirmed');
+    });
+
+    it('should render welcome template', () => {
+      const rendered = adapter.renderTemplate(
+        makePayload({
+          notificationType: 'welcome',
+          subject: 'Welcome!',
+          body: 'Welcome aboard, Alice!',
+        }),
+      );
+      expect(rendered.html).toContain('Welcome to TaskFlow Pro');
+      expect(rendered.text).toContain('Welcome aboard, Alice!');
+    });
+
+    it('should render account_updated template', () => {
+      const rendered = adapter.renderTemplate(
+        makePayload({
+          notificationType: 'account_updated',
+          subject: 'Account Updated',
+          body: 'Your email has been changed.',
+        }),
+      );
+      expect(rendered.html).toContain('Account Updated');
+      expect(rendered.text).toContain('Your email has been changed.');
+    });
+
+    it('should escape HTML in body', () => {
+      const rendered = adapter.renderTemplate(
+        makePayload({ body: '<script>alert("xss")</script>' }),
+      );
+      expect(rendered.html).not.toContain('<script>');
+      expect(rendered.html).toContain('&lt;script&gt;');
+    });
+
+    it('should include orderId metadata when present', () => {
+      const rendered = adapter.renderTemplate(
+        makePayload({ metadata: { orderId: 'order-42' } }),
+      );
+      expect(rendered.html).toContain('order-42');
+    });
+
+    it('should use custom from address', () => {
+      const customAdapter = new EmailAdapter({ defaultFrom: 'team@company.com' });
+      const rendered = customAdapter.renderTemplate(makePayload());
+      expect(rendered.from).toBe('team@company.com');
+    });
+  });
+
+  describe('send', () => {
+    it('should send and record email for valid recipient', async () => {
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      const sent = adapter.getSentEmails();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.to).toBe('alice@example.com');
+      expect(sent[0]?.subject).toBe('Order Confirmation: order-1');
+      expect(sent[0]?.html).toContain('Order Confirmed');
+      expect(sent[0]?.notificationType).toBe('order_confirmation');
+    });
+
+    it('should fail for unresolvable recipient', async () => {
+      const result = await adapter.send(makePayload({ recipient: 'user-123' }));
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Cannot resolve recipient');
+      expect(adapter.getSentEmails()).toHaveLength(0);
+    });
+
+    it('should use custom transport when configured', async () => {
+      const transported: string[] = [];
+      const customAdapter = new EmailAdapter({
+        transport: async (email) => {
+          transported.push(email.to);
+          return true;
+        },
+      });
+
+      const result = await customAdapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(transported).toEqual(['alice@example.com']);
+      expect(customAdapter.getSentEmails()).toHaveLength(1);
+    });
+
+    it('should fail when transport returns false', async () => {
+      const customAdapter = new EmailAdapter({
+        transport: async () => false,
+      });
+
+      const result = await customAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Transport rejected');
+      expect(customAdapter.getSentEmails()).toHaveLength(0);
+    });
+
+    it('should catch transport errors and return failure', async () => {
+      const customAdapter = new EmailAdapter({
+        transport: async () => {
+          throw new Error('Connection refused');
+        },
+      });
+
+      const result = await customAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Connection refused');
+      expect(customAdapter.getSentEmails()).toHaveLength(0);
+    });
+
+    it('should send multiple emails and track all', async () => {
+      await adapter.send(makePayload());
+      await adapter.send(makePayload({ recipient: 'bob@example.com' }));
+
+      expect(adapter.getSentEmails()).toHaveLength(2);
+    });
+  });
+
+  describe('clearSentEmails', () => {
+    it('should clear all recorded emails', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentEmails()).toHaveLength(1);
+
+      adapter.clearSentEmails();
+      expect(adapter.getSentEmails()).toHaveLength(0);
+    });
+  });
+
+  describe('integration with NotificationService', () => {
+    it('should work when registered with notification service', async () => {
+      // Import dynamically to avoid circular dependency issues in test setup
+      const { EventBus } = await import('../../src/events/event-bus.js');
+      const { NotificationService, resetNotificationIdCounter } = await import(
+        '../../src/services/notification.service.js'
+      );
+
+      resetNotificationIdCounter();
+      const eventBus = new EventBus();
+      const service = new NotificationService(eventBus);
+      const emailAdapter = new EmailAdapter();
+      service.registerAdapter(emailAdapter);
+
+      await eventBus.emit({
+        type: 'order:created' as const,
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+          total: 20,
+          status: 'pending' as const,
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member' as const,
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      // Give the async adapter.send() a tick to complete
+      await new Promise((r) => setTimeout(r, 10));
+
+      const sent = emailAdapter.getSentEmails();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]?.to).toBe('alice@example.com');
+      expect(sent[0]?.html).toContain('Order Confirmed');
+
+      const notifications = service.getNotifications();
+      expect(notifications).toHaveLength(1);
+      expect(notifications[0]?.status).toBe('sent');
+    });
+  });
+});
