+/**
+ * Notification log model for tracking sent notification history.
+ *
+ * Each log entry captures the details of a notification that was dispatched,
+ * including its delivery status. Used by NotificationHistoryService for
+ * querying historical notification data.
+ */
+
+import type { NotificationType, NotificationChannel } from './notification.js';
+
+export type DeliveryStatus = 'sent' | 'failed';
+
+export interface NotificationLog {
+  id: string;
+  notificationId: string;
+  recipient: string;
+  channel: NotificationChannel;
+  type: NotificationType;
+  status: DeliveryStatus;
+  subject: string;
+  body: string;
+  error?: string;
+  metadata?: Record<string, unknown>;
+  timestamp: Date;
+}
+
+export interface NotificationLogQuery {
+  recipient?: string;
+  type?: NotificationType;
+  channel?: NotificationChannel;
+  status?: DeliveryStatus;
+  startDate?: Date;
+  endDate?: Date;
+}
diff --git a/src/repositories/notification-log.repository.ts b/src/repositories/notification-log.repository.ts
new file mode 100644
index 0000000..6a32fa8
--- /dev/null
+++ b/src/repositories/notification-log.repository.ts
@@ -0,0 +1,80 @@
+/**
+ * Repository for NotificationLog data access.
+ *
+ * Extends BaseRepository with notification-log-specific query methods
+ * for filtering by recipient, type, channel, status, and date range.
+ */
+
+import type { DatabaseRecord } from '../utils/database.js';
+import type { Database } from '../utils/database.js';
+import type { NotificationLog, NotificationLogQuery } from '../models/notification-log.js';
+import type { NotificationType } from '../models/notification.js';
+import type { NotificationChannel } from '../models/notification.js';
+import type { DeliveryStatus } from '../models/notification-log.js';
+import { BaseRepository } from './base.repository.js';
+
+export class NotificationLogRepository extends BaseRepository<NotificationLog> {
+  constructor(db: Database) {
+    super(db, 'notification_logs');
+  }
+
+  protected toDomain(record: DatabaseRecord): NotificationLog {
+    return {
+      id: record['id'] as string,
+      notificationId: record['notificationId'] as string,
+      recipient: record['recipient'] as string,
+      channel: record['channel'] as NotificationChannel,
+      type: record['type'] as NotificationType,
+      status: record['status'] as DeliveryStatus,
+      subject: record['subject'] as string,
+      body: record['body'] as string,
+      error: record['error'] as string | undefined,
+      metadata: record['metadata'] ? JSON.parse(record['metadata'] as string) as Record<string, unknown> : undefined,
+      timestamp: new Date(record['timestamp'] as string),
+    };
+  }
+
+  protected toRecord(entity: NotificationLog): DatabaseRecord {
+    return {
+      id: entity.id,
+      notificationId: entity.notificationId,
+      recipient: entity.recipient,
+      channel: entity.channel,
+      type: entity.type,
+      status: entity.status,
+      subject: entity.subject,
+      body: entity.body,
+      error: entity.error,
+      metadata: entity.metadata ? JSON.stringify(entity.metadata) : undefined,
+      timestamp: entity.timestamp.toISOString(),
+    };
+  }
+
+  findByRecipient(recipient: string): NotificationLog[] {
+    return this.findAll((log) => log.recipient === recipient);
+  }
+
+  findByType(type: NotificationType): NotificationLog[] {
+    return this.findAll((log) => log.type === type);
+  }
+
+  findByChannel(channel: NotificationChannel): NotificationLog[] {
+    return this.findAll((log) => log.channel === channel);
+  }
+
+  findByStatus(status: DeliveryStatus): NotificationLog[] {
+    return this.findAll((log) => log.status === status);
+  }
+
+  query(params: NotificationLogQuery): NotificationLog[] {
+    return this.findAll((log) => {
+      if (params.recipient && log.recipient !== params.recipient) return false;
+      if (params.type && log.type !== params.type) return false;
+      if (params.channel && log.channel !== params.channel) return false;
+      if (params.status && log.status !== params.status) return false;
+      if (params.startDate && log.timestamp < params.startDate) return false;
+      if (params.endDate && log.timestamp > params.endDate) return false;
+      return true;
+    });
+  }
+}
diff --git a/src/services/notification-history.service.ts b/src/services/notification-history.service.ts
new file mode 100644
index 0000000..bab9101
--- /dev/null
+++ b/src/services/notification-history.service.ts
@@ -0,0 +1,106 @@
+/**
+ * Notification history service — logs every dispatched notification and
+ * provides query capabilities over the history.
+ *
+ * Architecture:
+ * - Listens to notification:sent and notification:failed events on EventBus.
+ * - Persists each notification as a NotificationLog entry via NotificationLogRepository.
+ * - Provides query methods for filtering history by recipient, type, date range, etc.
+ *
+ * Depends on:
+ * - EventBus for receiving notification lifecycle events
+ * - NotificationLogRepository for persistence
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type { NotificationSentEvent, NotificationFailedEvent } from '../events/event-types.js';
+import type { NotificationLog, NotificationLogQuery, DeliveryStatus } from '../models/notification-log.js';
+import type { NotificationType, NotificationChannel } from '../models/notification.js';
+import { NotificationLogRepository } from '../repositories/notification-log.repository.js';
+import { Logger } from '../utils/logger.js';
+
+let nextLogId = 1;
+
+function generateLogId(): string {
+  return `nlog-${String(nextLogId++).padStart(4, '0')}`;
+}
+
+export function resetLogIdCounter(): void {
+  nextLogId = 1;
+}
+
+export class NotificationHistoryService {
+  private logger = new Logger('NotificationHistoryService');
+  private repository: NotificationLogRepository;
+
+  constructor(eventBus: EventBus, repository: NotificationLogRepository) {
+    this.repository = repository;
+    this.registerHandlers(eventBus);
+  }
+
+  private registerHandlers(eventBus: EventBus): void {
+    eventBus.on<NotificationSentEvent>('notification:sent', (event) => {
+      this.logNotification(event.notification, 'sent', event.timestamp);
+    });
+
+    eventBus.on<NotificationFailedEvent>('notification:failed', (event) => {
+      this.logNotification(event.notification, 'failed', event.timestamp, event.error);
+    });
+  }
+
+  private logNotification(
+    notification: { id: string; type: NotificationType; channel: NotificationChannel; recipient: string; subject: string; body: string; metadata?: Record<string, unknown>; error?: string },
+    status: DeliveryStatus,
+    timestamp: Date,
+    error?: string,
+  ): void {
+    const logEntry: NotificationLog = {
+      id: generateLogId(),
+      notificationId: notification.id,
+      recipient: notification.recipient,
+      channel: notification.channel,
+      type: notification.type,
+      status,
+      subject: notification.subject,
+      body: notification.body,
+      error: error ?? notification.error,
+      metadata: notification.metadata,
+      timestamp,
+    };
+
+    this.repository.save(logEntry);
+    this.logger.info(`Logged notification ${notification.id} with status ${status}`);
+  }
+
+  getLogs(): NotificationLog[] {
+    return this.repository.findAll();
+  }
+
+  getLogsByRecipient(recipient: string): NotificationLog[] {
+    return this.repository.findByRecipient(recipient);
+  }
+
+  getLogsByType(type: NotificationType): NotificationLog[] {
+    return this.repository.findByType(type);
+  }
+
+  getLogsByChannel(channel: NotificationChannel): NotificationLog[] {
+    return this.repository.findByChannel(channel);
+  }
+
+  getLogsByStatus(status: DeliveryStatus): NotificationLog[] {
+    return this.repository.findByStatus(status);
+  }
+
+  getLogsByDateRange(startDate: Date, endDate: Date): NotificationLog[] {
+    return this.repository.query({ startDate, endDate });
+  }
+
+  query(params: NotificationLogQuery): NotificationLog[] {
+    return this.repository.query(params);
+  }
+
+  getLogCount(): number {
+    return this.repository.count();
+  }
+}
diff --git a/tests/services/notification-history.service.test.ts b/tests/services/notification-history.service.test.ts
new file mode 100644
index 0000000..0d0b62d
--- /dev/null
+++ b/tests/services/notification-history.service.test.ts
@@ -0,0 +1,324 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { Database } from '../../src/utils/database.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import {
+  NotificationHistoryService,
+  resetLogIdCounter,
+} from '../../src/services/notification-history.service.js';
+import { NotificationLogRepository } from '../../src/repositories/notification-log.repository.js';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import { WebhookAdapter } from '../../src/adapters/webhook.adapter.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+function makeUser(overrides?: Partial<OrderCreatedEvent['user']>) {
+  return {
+    id: 'user-1',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member' as const,
+    createdAt: new Date('2024-01-01'),
+    updatedAt: new Date('2024-01-01'),
+    ...overrides,
+  };
+}
+
+function makeOrder(overrides?: Partial<OrderCreatedEvent['order']>) {
+  return {
+    id: 'order-1',
+    userId: 'user-1',
+    items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+    total: 20,
+    status: 'pending' as const,
+    createdAt: new Date('2024-01-01'),
+    updatedAt: new Date('2024-01-01'),
+    ...overrides,
+  };
+}
+
+describe('NotificationHistoryService', () => {
+  let eventBus: EventBus;
+  let db: Database;
+  let notificationService: NotificationService;
+  let historyService: NotificationHistoryService;
+  let emailAdapter: EmailAdapter;
+  let logRepo: NotificationLogRepository;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    db = new Database();
+    logRepo = new NotificationLogRepository(db);
+    emailAdapter = new EmailAdapter();
+
+    notificationService = new NotificationService(eventBus);
+    notificationService.registerAdapter(emailAdapter);
+
+    historyService = new NotificationHistoryService(eventBus, logRepo);
+
+    resetNotificationIdCounter();
+    resetLogIdCounter();
+  });
+
+  describe('logging sent notifications', () => {
+    it('should log a notification when notification:sent is emitted', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: new Date('2024-06-15T10:00:00Z'),
+      };
+
+      await eventBus.emit(event);
+
+      const logs = historyService.getLogs();
+      expect(logs).toHaveLength(1);
+      expect(logs[0]?.notificationId).toBe('notif-0001');
+      expect(logs[0]?.recipient).toBe('alice@example.com');
+      expect(logs[0]?.channel).toBe('email');
+      expect(logs[0]?.type).toBe('order_confirmation');
+      expect(logs[0]?.status).toBe('sent');
+      expect(logs[0]?.subject).toContain('Order Confirmation');
+    });
+
+    it('should generate sequential log IDs', async () => {
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: new Date(),
+      });
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: makeOrder({ status: 'confirmed' }),
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      const logs = historyService.getLogs();
+      expect(logs).toHaveLength(2);
+      expect(logs[0]?.id).toBe('nlog-0001');
+      expect(logs[1]?.id).toBe('nlog-0002');
+    });
+
+    it('should log failed notifications', async () => {
+      const badAdapter = new EmailAdapter();
+      const badService = new NotificationService(eventBus);
+      // Register adapter that will fail for invalid email
+      badService.registerAdapter(badAdapter);
+
+      // Emit an order:created with an invalid email — the email adapter will fail
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser({ email: 'not-an-email' }),
+        timestamp: new Date(),
+      });
+
+      const logs = historyService.getLogs();
+      const failedLogs = logs.filter((l) => l.status === 'failed');
+      expect(failedLogs.length).toBeGreaterThanOrEqual(1);
+      expect(failedLogs[0]?.error).toBeDefined();
+    });
+  });
+
+  describe('querying by recipient', () => {
+    it('should return logs for a specific recipient', async () => {
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser({ email: 'alice@example.com' }),
+        timestamp: new Date(),
+      });
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder({ id: 'order-2', userId: 'user-2' }),
+        user: makeUser({ id: 'user-2', email: 'bob@example.com' }),
+        timestamp: new Date(),
+      });
+
+      const aliceLogs = historyService.getLogsByRecipient('alice@example.com');
+      expect(aliceLogs).toHaveLength(1);
+      expect(aliceLogs[0]?.recipient).toBe('alice@example.com');
+
+      const bobLogs = historyService.getLogsByRecipient('bob@example.com');
+      expect(bobLogs).toHaveLength(1);
+
+      const noLogs = historyService.getLogsByRecipient('nobody@example.com');
+      expect(noLogs).toHaveLength(0);
+    });
+  });
+
+  describe('querying by type', () => {
+    it('should return logs for a specific notification type', async () => {
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: new Date(),
+      });
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: makeOrder({ status: 'confirmed' }),
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      const confirmationLogs = historyService.getLogsByType('order_confirmation');
+      expect(confirmationLogs).toHaveLength(1);
+
+      const statusLogs = historyService.getLogsByType('order_status_update');
+      expect(statusLogs).toHaveLength(1);
+
+      const welcomeLogs = historyService.getLogsByType('user_welcome');
+      expect(welcomeLogs).toHaveLength(0);
+    });
+  });
+
+  describe('querying by date range', () => {
+    it('should return logs within a date range', async () => {
+      // The notification:sent event timestamp is set to "now" by NotificationService,
+      // so we use a range that includes the current time.
+      const now = new Date();
+      const pastStart = new Date(now.getTime() - 60_000);
+      const futureEnd = new Date(now.getTime() + 60_000);
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: now,
+      });
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder({ id: 'order-2' }),
+        user: makeUser(),
+        timestamp: now,
+      });
+
+      const inRange = historyService.getLogsByDateRange(pastStart, futureEnd);
+      expect(inRange).toHaveLength(2);
+
+      const outOfRange = historyService.getLogsByDateRange(
+        new Date('2020-01-01'),
+        new Date('2020-12-31'),
+      );
+      expect(outOfRange).toHaveLength(0);
+    });
+  });
+
+  describe('querying by channel', () => {
+    it('should return logs for a specific channel', async () => {
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: new Date(),
+      });
+
+      const emailLogs = historyService.getLogsByChannel('email');
+      expect(emailLogs).toHaveLength(1);
+
+      const webhookLogs = historyService.getLogsByChannel('webhook');
+      expect(webhookLogs).toHaveLength(0);
+    });
+  });
+
+  describe('querying by status', () => {
+    it('should return logs for a specific status', async () => {
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: new Date(),
+      });
+
+      const sentLogs = historyService.getLogsByStatus('sent');
+      expect(sentLogs).toHaveLength(1);
+
+      const failedLogs = historyService.getLogsByStatus('failed');
+      expect(failedLogs).toHaveLength(0);
+    });
+  });
+
+  describe('combined query', () => {
+    it('should filter by multiple criteria', async () => {
+      const now = new Date();
+      const pastStart = new Date(now.getTime() - 60_000);
+      const futureEnd = new Date(now.getTime() + 60_000);
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: now,
+      });
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: makeOrder({ status: 'confirmed' }),
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: now,
+      });
+
+      const results = historyService.query({
+        recipient: 'alice@example.com',
+        type: 'order_confirmation',
+        channel: 'email',
+        status: 'sent',
+        startDate: pastStart,
+        endDate: futureEnd,
+      });
+
+      expect(results).toHaveLength(1);
+      expect(results[0]?.type).toBe('order_confirmation');
+    });
+
+    it('should return empty when no logs match', () => {
+      const results = historyService.query({
+        recipient: 'nobody@example.com',
+      });
+      expect(results).toHaveLength(0);
+    });
+  });
+
+  describe('log count', () => {
+    it('should return the count of logs', async () => {
+      expect(historyService.getLogCount()).toBe(0);
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: new Date(),
+      });
+
+      expect(historyService.getLogCount()).toBe(1);
+    });
+  });
+
+  describe('persistence via repository', () => {
+    it('should persist logs in the database', async () => {
+      await eventBus.emit({
+        type: 'order:created',
+        order: makeOrder(),
+        user: makeUser(),
+        timestamp: new Date('2024-06-15T10:00:00Z'),
+      });
+
+      // Query directly from repository to confirm persistence
+      const repoLogs = logRepo.findByRecipient('alice@example.com');
+      expect(repoLogs).toHaveLength(1);
+      expect(repoLogs[0]?.notificationId).toBe('notif-0001');
+    });
+  });
+});
