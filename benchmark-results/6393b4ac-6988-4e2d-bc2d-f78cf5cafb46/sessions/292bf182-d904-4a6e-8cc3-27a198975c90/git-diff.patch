--- /dev/null
+++ b/src/adapters/sms.adapter.ts
@@ -0,0 +1,189 @@
+/**
+ * SMS notification adapter — delivers notifications via SMS.
+ *
+ * Implements phone number validation, message formatting for SMS character
+ * limits, and structured delivery. In non-production environments, messages
+ * are captured in memory for testing and inspection.
+ *
+ * NOTE ON USER PREFERENCES:
+ * The current UserPreferences model (src/models/user-preferences.ts) was designed
+ * with an email-only assumption. It has an `email: EmailPreferences` field but no
+ * equivalent `sms: SmsPreferences` field. The PreferencesService only exposes
+ * `shouldSendEmail()` — there is no `shouldSendSms()` method.
+ *
+ * Before SMS notifications can be gated by user preferences, the following
+ * changes are needed:
+ *   1. Add an SmsPreferences interface to src/models/user-preferences.ts
+ *      (enabled, subscribedCategories — frequency is less relevant for SMS).
+ *   2. Add an `sms` field to the UserPreferences interface.
+ *   3. Update getDefaultEmailPreferences() → getDefaultPreferences() or add
+ *      a getDefaultSmsPreferences() helper.
+ *   4. Add `shouldSendSms(userId, type)` to PreferencesService.
+ *   5. Update PreferencesRepository serialization to handle the new field.
+ *   6. Update NotificationService.isAllowedByPreferences() to call
+ *      shouldSendSms() when channel === 'sms'.
+ *
+ * Until then, SMS notifications bypass preference checks (isAllowedByPreferences
+ * returns true for unknown channels).
+ */
+
+import type { NotificationPayload, NotificationResult } from '../models/notification.js';
+import type { NotificationAdapter } from './notification.adapter.js';
+import { Logger } from '../utils/logger.js';
+
+export interface SmsConfig {
+  /** SMS provider identifier (e.g. 'twilio', 'sns'). */
+  provider: string;
+  /** Sender phone number or short code (e.g. '+15551234567'). */
+  fromNumber: string;
+  /** Maximum message length before truncation (default: 160). */
+  maxLength?: number;
+}
+
+export const defaultSmsConfig: SmsConfig = {
+  provider: 'default',
+  fromNumber: '+15550000000',
+  maxLength: 160,
+};
+
+/** A sent SMS record for inspection/testing. */
+export interface SentSms {
+  payload: NotificationPayload;
+  message: FormattedSms;
+  sentAt: Date;
+}
+
+/** Formatted SMS ready for transport. */
+export interface FormattedSms {
+  from: string;
+  to: string;
+  body: string;
+  truncated: boolean;
+}
+
+/**
+ * Validate a phone number format.
+ * Accepts E.164 format: optional +, followed by digits only, 7-15 digits total.
+ */
+export function isValidPhoneNumber(phone: string): boolean {
+  if (!phone || typeof phone !== 'string') return false;
+  return /^\+?[1-9]\d{6,14}$/.test(phone);
+}
+
+/**
+ * Resolve a recipient identifier to a deliverable phone number.
+ * If the recipient is already a valid phone number, use it directly.
+ * Otherwise, check metadata for a phoneNumber field.
+ */
+export function resolveRecipient(
+  recipient: string,
+  metadata?: Record<string, unknown>,
+): string | null {
+  if (isValidPhoneNumber(recipient)) {
+    return recipient;
+  }
+
+  if (metadata?.phoneNumber && typeof metadata.phoneNumber === 'string' && isValidPhoneNumber(metadata.phoneNumber)) {
+    return metadata.phoneNumber;
+  }
+
+  return null;
+}
+
+/**
+ * Format a notification payload into an SMS message body.
+ * Truncates to maxLength with an ellipsis if the message is too long.
+ */
+export function formatSmsBody(payload: NotificationPayload, maxLength: number): { body: string; truncated: boolean } {
+  const prefix = payload.priority === 'high' || payload.priority === 'urgent'
+    ? `[${payload.priority.toUpperCase()}] `
+    : '';
+
+  const full = `${prefix}${payload.subject}: ${payload.body}`;
+
+  if (full.length <= maxLength) {
+    return { body: full, truncated: false };
+  }
+
+  return { body: full.substring(0, maxLength - 3) + '...', truncated: true };
+}
+
+export class SmsNotificationAdapter implements NotificationAdapter {
+  readonly channel = 'sms' as const;
+  private logger = new Logger('SmsAdapter');
+  private sentMessages: SentSms[] = [];
+
+  constructor(private config: SmsConfig = defaultSmsConfig) {}
+
+  /**
+   * Send an SMS notification.
+   * Validates recipient phone number, formats message, and delivers.
+   */
+  async send(payload: NotificationPayload): Promise<NotificationResult> {
+    try {
+      const toNumber = resolveRecipient(payload.recipient, payload.metadata);
+
+      if (!toNumber) {
+        this.logger.error(
+          `Cannot resolve recipient "${payload.recipient}" to a valid phone number`,
+        );
+        return {
+          success: false,
+          notificationId: payload.id,
+          channel: 'sms',
+          deliveredAt: new Date(),
+          error: `Invalid recipient: ${payload.recipient}`,
+        };
+      }
+
+      const maxLength = this.config.maxLength ?? 160;
+      const { body, truncated } = formatSmsBody(payload, maxLength);
+
+      if (truncated) {
+        this.logger.info(`SMS message truncated to ${maxLength} characters for ${payload.id}`);
+      }
+
+      const message: FormattedSms = {
+        from: this.config.fromNumber,
+        to: toNumber,
+        body,
+        truncated,
+      };
+
+      // In-memory transport for now — swap for real SMS provider in production
+      this.logger.info(
+        `Sending SMS to ${toNumber}: "${payload.subject}" (from: ${this.config.fromNumber})`,
+      );
+
+      this.sentMessages.push({ payload, message, sentAt: new Date() });
+
+      return {
+        success: true,
+        notificationId: payload.id,
+        channel: 'sms',
+        deliveredAt: new Date(),
+      };
+    } catch (err) {
+      const message = err instanceof Error ? err.message : 'Unknown SMS error';
+      this.logger.error(`Failed to send SMS to ${payload.recipient}: ${message}`);
+
+      return {
+        success: false,
+        notificationId: payload.id,
+        channel: 'sms',
+        deliveredAt: new Date(),
+        error: message,
+      };
+    }
+  }
+
+  /** Get all SMS messages sent through this adapter (useful for testing). */
+  getSentMessages(): SentSms[] {
+    return [...this.sentMessages];
+  }
+
+  /** Clear sent messages (useful for testing). */
+  clearSentMessages(): void {
+    this.sentMessages = [];
+  }
+}
diff --git a/tests/adapters/sms.adapter.test.ts b/tests/adapters/sms.adapter.test.ts
new file mode 100644
index 0000000..5fdead7
--- /dev/null
+++ b/tests/adapters/sms.adapter.test.ts
@@ -0,0 +1,247 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  SmsNotificationAdapter,
+  isValidPhoneNumber,
+  resolveRecipient,
+  formatSmsBody,
+} from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides: Partial<NotificationPayload> = {}): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order_confirmation',
+    channel: 'sms',
+    recipient: '+15551234567',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    priority: 'normal',
+    createdAt: new Date('2026-01-15T12:00:00Z'),
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+describe('isValidPhoneNumber', () => {
+  it('should accept valid E.164 phone numbers', () => {
+    expect(isValidPhoneNumber('+15551234567')).toBe(true);
+    expect(isValidPhoneNumber('+447911123456')).toBe(true);
+    expect(isValidPhoneNumber('15551234567')).toBe(true);
+    expect(isValidPhoneNumber('+1234567')).toBe(true);
+  });
+
+  it('should reject invalid phone numbers', () => {
+    expect(isValidPhoneNumber('')).toBe(false);
+    expect(isValidPhoneNumber('not-a-number')).toBe(false);
+    expect(isValidPhoneNumber('abc123')).toBe(false);
+    expect(isValidPhoneNumber('+0123456')).toBe(false);
+    expect(isValidPhoneNumber('123')).toBe(false);
+    expect(isValidPhoneNumber('+1234567890123456')).toBe(false);
+  });
+});
+
+describe('resolveRecipient', () => {
+  it('should return recipient directly if it is a valid phone number', () => {
+    expect(resolveRecipient('+15551234567')).toBe('+15551234567');
+  });
+
+  it('should fall back to metadata phoneNumber', () => {
+    expect(resolveRecipient('user-1', { phoneNumber: '+15559876543' })).toBe('+15559876543');
+  });
+
+  it('should return null if recipient is not a phone number and no metadata', () => {
+    expect(resolveRecipient('user-1')).toBeNull();
+  });
+
+  it('should return null if metadata phoneNumber is invalid', () => {
+    expect(resolveRecipient('user-1', { phoneNumber: 'bad' })).toBeNull();
+  });
+});
+
+describe('formatSmsBody', () => {
+  it('should format a short message without truncation', () => {
+    const payload = makePayload({ subject: 'Hi', body: 'Hello' });
+    const result = formatSmsBody(payload, 160);
+
+    expect(result.body).toBe('Hi: Hello');
+    expect(result.truncated).toBe(false);
+  });
+
+  it('should truncate a long message', () => {
+    const payload = makePayload({
+      subject: 'Order Confirmation',
+      body: 'A'.repeat(200),
+    });
+    const result = formatSmsBody(payload, 160);
+
+    expect(result.body.length).toBe(160);
+    expect(result.body.endsWith('...')).toBe(true);
+    expect(result.truncated).toBe(true);
+  });
+
+  it('should prepend priority prefix for high priority', () => {
+    const payload = makePayload({ subject: 'Alert', body: 'Urgent matter', priority: 'high' });
+    const result = formatSmsBody(payload, 160);
+
+    expect(result.body).toBe('[HIGH] Alert: Urgent matter');
+    expect(result.truncated).toBe(false);
+  });
+
+  it('should prepend priority prefix for urgent priority', () => {
+    const payload = makePayload({ subject: 'Alert', body: 'Critical', priority: 'urgent' });
+    const result = formatSmsBody(payload, 160);
+
+    expect(result.body).toBe('[URGENT] Alert: Critical');
+  });
+
+  it('should not prepend priority for normal or low', () => {
+    const payload = makePayload({ subject: 'Info', body: 'Details', priority: 'low' });
+    const result = formatSmsBody(payload, 160);
+
+    expect(result.body).toBe('Info: Details');
+  });
+});
+
+describe('SmsNotificationAdapter', () => {
+  let adapter: SmsNotificationAdapter;
+
+  beforeEach(() => {
+    adapter = new SmsNotificationAdapter({
+      provider: 'test',
+      fromNumber: '+15550000000',
+    });
+  });
+
+  it('should have channel set to sms', () => {
+    expect(adapter.channel).toBe('sms');
+  });
+
+  describe('send', () => {
+    it('should send a valid SMS and return success', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('sms');
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+    });
+
+    it('should store the sent message with formatted details', async () => {
+      const payload = makePayload();
+      await adapter.send(payload);
+
+      const sent = adapter.getSentMessages();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]!.payload).toEqual(payload);
+      expect(sent[0]!.message.from).toBe('+15550000000');
+      expect(sent[0]!.message.to).toBe('+15551234567');
+      expect(sent[0]!.message.body).toContain('Order Confirmation');
+      expect(sent[0]!.sentAt).toBeInstanceOf(Date);
+    });
+
+    it('should resolve phone number from metadata when recipient is a user ID', async () => {
+      const payload = makePayload({
+        recipient: 'user-1',
+        metadata: { orderId: 'order-1', userId: 'user-1', phoneNumber: '+15559876543' },
+      });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.message.to).toBe('+15559876543');
+    });
+
+    it('should fail for invalid recipient with no phone metadata', async () => {
+      const payload = makePayload({ recipient: 'user-1', metadata: { orderId: 'order-1' } });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid recipient');
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should truncate long messages to configured maxLength', async () => {
+      const shortAdapter = new SmsNotificationAdapter({
+        provider: 'test',
+        fromNumber: '+15550000000',
+        maxLength: 50,
+      });
+
+      const payload = makePayload();
+      await shortAdapter.send(payload);
+
+      const sent = shortAdapter.getSentMessages();
+      expect(sent[0]!.message.body.length).toBe(50);
+      expect(sent[0]!.message.truncated).toBe(true);
+    });
+
+    it('should handle high priority notifications', async () => {
+      const payload = makePayload({
+        priority: 'high',
+        subject: 'Order Cancelled',
+        body: 'Your order has been cancelled.',
+      });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.message.body).toContain('[HIGH]');
+    });
+  });
+
+  describe('getSentMessages / clearSentMessages', () => {
+    it('should return a copy of sent messages', async () => {
+      await adapter.send(makePayload());
+      const messages = adapter.getSentMessages();
+      messages.pop();
+      expect(adapter.getSentMessages()).toHaveLength(1);
+    });
+
+    it('should clear all sent messages', async () => {
+      await adapter.send(makePayload());
+      adapter.clearSentMessages();
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+});
+
+describe('SmsNotificationAdapter integration with NotificationService', () => {
+  it('should work end-to-end with EventBus and NotificationService', async () => {
+    const { EventBus } = await import('../../src/events/event-bus.js');
+    const { NotificationService, resetNotificationIdCounter } = await import(
+      '../../src/services/notification.service.js'
+    );
+
+    const eventBus = new EventBus();
+    const service = new NotificationService(eventBus);
+    const adapter = new SmsNotificationAdapter({
+      provider: 'test',
+      fromNumber: '+15550000000',
+    });
+    resetNotificationIdCounter();
+
+    service.registerAdapter(adapter);
+
+    // Send an SMS notification directly through the service
+    await service.send({
+      type: 'order_confirmation',
+      channel: 'sms',
+      recipient: '+15551234567',
+      subject: 'Order Confirmation: order-42',
+      body: 'Your order has been placed. Items: Widget x3. Total: $45.00',
+      priority: 'normal',
+      metadata: { orderId: 'order-42', userId: 'user-1' },
+    });
+
+    const notifications = service.getNotifications();
+    expect(notifications).toHaveLength(1);
+    expect(notifications[0]!.status).toBe('sent');
+    expect(notifications[0]!.channel).toBe('sms');
+
+    const sent = adapter.getSentMessages();
+    expect(sent).toHaveLength(1);
+    expect(sent[0]!.message.to).toBe('+15551234567');
+    expect(sent[0]!.message.body).toContain('order-42');
+  });
+});
