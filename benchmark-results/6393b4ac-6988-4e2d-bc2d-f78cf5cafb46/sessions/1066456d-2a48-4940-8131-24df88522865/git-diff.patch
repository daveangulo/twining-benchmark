+import { describe, it, expect } from 'vitest';
+import {
+  validateEmailNotTaken,
+  validateEmailAvailableForUpdate,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const existingUser: User = {
+  id: 'user-0001',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+};
+
+describe('user.validator', () => {
+  describe('validateEmailNotTaken', () => {
+    it('should not throw when no existing user with that email', () => {
+      expect(() =>
+        validateEmailNotTaken('new@example.com', undefined),
+      ).not.toThrow();
+    });
+
+    it('should throw when email is already taken', () => {
+      expect(() =>
+        validateEmailNotTaken('alice@example.com', existingUser),
+      ).toThrow('User with email alice@example.com already exists');
+    });
+  });
+
+  describe('validateEmailAvailableForUpdate', () => {
+    it('should not throw when no existing user with that email', () => {
+      expect(() =>
+        validateEmailAvailableForUpdate('new@example.com', undefined),
+      ).not.toThrow();
+    });
+
+    it('should throw when email is already in use', () => {
+      expect(() =>
+        validateEmailAvailableForUpdate('alice@example.com', existingUser),
+      ).toThrow('Email alice@example.com is already in use');
+    });
+  });
+});
