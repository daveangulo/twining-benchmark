diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..aaef9b6
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,111 @@
+/**
+ * Preferences service — business logic for managing user notification preferences.
+ *
+ * Depends on:
+ * - PreferencesRepository (data layer) for persistence
+ *
+ * Preferences are created with defaults when first accessed for a user.
+ * The notification service consults this service before sending.
+ */
+
+import type { PreferencesRepository } from '../repositories/preferences.repository.js';
+import type { UserPreferences, UpdateEmailPreferencesInput } from '../models/user-preferences.js';
+import type { NotificationType } from '../models/notification.js';
+import { getDefaultEmailPreferences } from '../models/user-preferences.js';
+import { Logger } from '../utils/logger.js';
+
+let nextId = 1;
+
+function generateId(): string {
+  return `pref-${String(nextId++).padStart(4, '0')}`;
+}
+
+/** Reset ID counter (for testing). */
+export function resetPreferencesIdCounter(): void {
+  nextId = 1;
+}
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(private preferencesRepository: PreferencesRepository) {}
+
+  /**
+   * Get preferences for a user, creating defaults if none exist.
+   */
+  getOrCreatePreferences(userId: string): UserPreferences {
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (existing) {
+      return existing;
+    }
+
+    this.logger.info(`Creating default preferences for user ${userId}`);
+    const now = new Date();
+    const prefs: UserPreferences = {
+      id: generateId(),
+      userId,
+      email: getDefaultEmailPreferences(),
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    this.preferencesRepository.save(prefs);
+    return prefs;
+  }
+
+  /**
+   * Update email preferences for a user.
+   */
+  updateEmailPreferences(userId: string, input: UpdateEmailPreferencesInput): UserPreferences {
+    this.logger.info(`Updating email preferences for user ${userId}`);
+
+    const prefs = this.getOrCreatePreferences(userId);
+    const updatedEmail = { ...prefs.email };
+
+    if (input.enabled !== undefined) {
+      updatedEmail.enabled = input.enabled;
+    }
+    if (input.frequency !== undefined) {
+      updatedEmail.frequency = input.frequency;
+    }
+    if (input.subscribedCategories !== undefined) {
+      updatedEmail.subscribedCategories = [...input.subscribedCategories];
+    }
+
+    return this.preferencesRepository.update(prefs.id, {
+      email: updatedEmail,
+      updatedAt: new Date(),
+    });
+  }
+
+  /**
+   * Check whether a notification should be sent to a user via email.
+   * Returns true if the user has email enabled and is subscribed to the category.
+   */
+  shouldSendEmail(userId: string, notificationType: NotificationType): boolean {
+    const prefs = this.getOrCreatePreferences(userId);
+
+    if (!prefs.email.enabled) {
+      this.logger.info(`Email disabled for user ${userId}, skipping ${notificationType}`);
+      return false;
+    }
+
+    if (!prefs.email.subscribedCategories.includes(notificationType)) {
+      this.logger.info(`User ${userId} not subscribed to ${notificationType}, skipping`);
+      return false;
+    }
+
+    return true;
+  }
+
+  /**
+   * Delete preferences for a user.
+   */
+  deletePreferences(userId: string): boolean {
+    const prefs = this.preferencesRepository.findByUserId(userId);
+    if (!prefs) {
+      return false;
+    }
+    return this.preferencesRepository.delete(prefs.id);
+  }
+}
diff --git a/tests/services/preferences.service.test.ts b/tests/services/preferences.service.test.ts
new file mode 100644
index 0000000..f50ecb5
--- /dev/null
+++ b/tests/services/preferences.service.test.ts
@@ -0,0 +1,272 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let repository: PreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    repository = new PreferencesRepository(db);
+    service = new PreferencesService(repository);
+    resetPreferencesIdCounter();
+  });
+
+  describe('getOrCreatePreferences', () => {
+    it('should create default preferences for a new user', () => {
+      const prefs = service.getOrCreatePreferences('user-1');
+
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.subscribedCategories).toEqual([
+        'order_confirmation',
+        'order_status_update',
+        'welcome',
+        'account_updated',
+      ]);
+    });
+
+    it('should return existing preferences on subsequent calls', () => {
+      const first = service.getOrCreatePreferences('user-1');
+      const second = service.getOrCreatePreferences('user-1');
+
+      expect(first.id).toBe(second.id);
+      expect(first.userId).toBe(second.userId);
+    });
+
+    it('should create separate preferences per user', () => {
+      const prefs1 = service.getOrCreatePreferences('user-1');
+      const prefs2 = service.getOrCreatePreferences('user-2');
+
+      expect(prefs1.id).not.toBe(prefs2.id);
+      expect(prefs1.userId).toBe('user-1');
+      expect(prefs2.userId).toBe('user-2');
+    });
+  });
+
+  describe('updateEmailPreferences', () => {
+    it('should disable email notifications', () => {
+      service.getOrCreatePreferences('user-1');
+      const updated = service.updateEmailPreferences('user-1', { enabled: false });
+
+      expect(updated.email.enabled).toBe(false);
+      expect(updated.email.frequency).toBe('immediate');
+      expect(updated.email.subscribedCategories).toHaveLength(4);
+    });
+
+    it('should update frequency', () => {
+      service.getOrCreatePreferences('user-1');
+      const updated = service.updateEmailPreferences('user-1', { frequency: 'daily_digest' });
+
+      expect(updated.email.frequency).toBe('daily_digest');
+      expect(updated.email.enabled).toBe(true);
+    });
+
+    it('should update subscribed categories', () => {
+      service.getOrCreatePreferences('user-1');
+      const updated = service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['order_confirmation'],
+      });
+
+      expect(updated.email.subscribedCategories).toEqual(['order_confirmation']);
+    });
+
+    it('should create preferences if none exist before updating', () => {
+      const updated = service.updateEmailPreferences('user-1', { enabled: false });
+
+      expect(updated.userId).toBe('user-1');
+      expect(updated.email.enabled).toBe(false);
+    });
+
+    it('should handle multiple updates', () => {
+      service.updateEmailPreferences('user-1', { enabled: false });
+      const updated = service.updateEmailPreferences('user-1', {
+        enabled: true,
+        frequency: 'weekly_digest',
+        subscribedCategories: ['welcome'],
+      });
+
+      expect(updated.email.enabled).toBe(true);
+      expect(updated.email.frequency).toBe('weekly_digest');
+      expect(updated.email.subscribedCategories).toEqual(['welcome']);
+    });
+  });
+
+  describe('shouldSendEmail', () => {
+    it('should return true with default preferences', () => {
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(true);
+    });
+
+    it('should return false when email is disabled', () => {
+      service.updateEmailPreferences('user-1', { enabled: false });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false for unsubscribed category', () => {
+      service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['welcome'],
+      });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+      expect(service.shouldSendEmail('user-1', 'welcome')).toBe(true);
+    });
+
+    it('should return false when email disabled even if subscribed', () => {
+      service.updateEmailPreferences('user-1', {
+        enabled: false,
+        subscribedCategories: ['order_confirmation'],
+      });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+    });
+  });
+
+  describe('deletePreferences', () => {
+    it('should delete existing preferences', () => {
+      service.getOrCreatePreferences('user-1');
+      expect(service.deletePreferences('user-1')).toBe(true);
+    });
+
+    it('should return false for non-existent preferences', () => {
+      expect(service.deletePreferences('user-999')).toBe(false);
+    });
+  });
+});
+
+describe('NotificationService with preferences', () => {
+  let db: Database;
+  let eventBus: EventBus;
+  let notificationService: NotificationService;
+  let preferencesService: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    eventBus = new EventBus();
+    notificationService = new NotificationService(eventBus);
+    const repository = new PreferencesRepository(db);
+    preferencesService = new PreferencesService(repository);
+    notificationService.setPreferencesService(preferencesService);
+    resetNotificationIdCounter();
+    resetPreferencesIdCounter();
+  });
+
+  const orderCreatedEvent: OrderCreatedEvent = {
+    type: 'order:created',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+      total: 20,
+      status: 'pending',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    user: {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    timestamp: new Date(),
+  };
+
+  const statusChangedEvent: OrderStatusChangedEvent = {
+    type: 'order:status-changed',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [],
+      total: 20,
+      status: 'confirmed',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    previousStatus: 'pending',
+    newStatus: 'confirmed',
+    timestamp: new Date(),
+  };
+
+  it('should send notifications with default preferences', async () => {
+    await eventBus.emit(orderCreatedEvent);
+    expect(notificationService.getNotificationCount()).toBe(1);
+  });
+
+  it('should skip order confirmation when user unsubscribes', async () => {
+    preferencesService.updateEmailPreferences('user-1', {
+      subscribedCategories: ['order_status_update'],
+    });
+
+    await eventBus.emit(orderCreatedEvent);
+    expect(notificationService.getNotificationCount()).toBe(0);
+  });
+
+  it('should skip all notifications when email is disabled', async () => {
+    preferencesService.updateEmailPreferences('user-1', { enabled: false });
+
+    await eventBus.emit(orderCreatedEvent);
+    await eventBus.emit(statusChangedEvent);
+    expect(notificationService.getNotificationCount()).toBe(0);
+  });
+
+  it('should still send welcome email regardless of preferences', async () => {
+    preferencesService.updateEmailPreferences('user-1', { enabled: false });
+
+    await eventBus.emit({
+      type: 'user:created',
+      user: {
+        id: 'user-1',
+        name: 'Alice',
+        email: 'alice@example.com',
+        role: 'member',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      timestamp: new Date(),
+    });
+
+    expect(notificationService.getNotificationCount()).toBe(1);
+    expect(notificationService.getNotifications()[0]?.type).toBe('welcome');
+  });
+
+  it('should send status update but not order confirmation when selectively subscribed', async () => {
+    preferencesService.updateEmailPreferences('user-1', {
+      subscribedCategories: ['order_status_update'],
+    });
+
+    await eventBus.emit(orderCreatedEvent);
+    await eventBus.emit(statusChangedEvent);
+
+    const notifications = notificationService.getNotifications();
+    expect(notifications).toHaveLength(1);
+    expect(notifications[0]?.type).toBe('order_status_update');
+  });
+
+  it('should work without preferences service (backwards compatible)', async () => {
+    const plainService = new NotificationService(eventBus);
+    // No setPreferencesService call — should send everything
+    resetNotificationIdCounter();
+
+    const bus = new EventBus();
+    const svc = new NotificationService(bus);
+
+    await bus.emit(orderCreatedEvent);
+    expect(svc.getNotificationCount()).toBe(1);
+  });
+});
