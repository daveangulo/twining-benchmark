+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      timestamp: new Date(),
+    };
+
+    await eventBus.emit(event);
+    expect(notificationService.getNotificationCount()).toBe(1);
+  });
+
+  it('should suppress notification when user has disabled email', async () => {
+    preferencesService.createPreferences('user-1', {
+      email: { enabled: false },
