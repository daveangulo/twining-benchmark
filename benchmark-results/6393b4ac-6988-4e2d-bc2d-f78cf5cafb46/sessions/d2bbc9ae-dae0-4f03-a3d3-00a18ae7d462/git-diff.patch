diff --git a/tests/adapters/sms.adapter.test.ts b/tests/adapters/sms.adapter.test.ts
new file mode 100644
index 0000000..0a583f6
--- /dev/null
+++ b/tests/adapters/sms.adapter.test.ts
@@ -0,0 +1,190 @@
+import { describe, it, expect } from 'vitest';
+import { SmsAdapter, formatSmsBody } from '../../src/adapters/sms.adapter.js';
+import type { SmsTransport, SmsMessage } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    recipient: '+15551234567',
+    subject: 'Order Confirmation',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    notificationType: 'order_confirmation',
+    channel: 'sms',
+    priority: 'normal',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+function createMockTransport() {
+  const sent: SmsMessage[] = [];
+  const transport: SmsTransport = {
+    async sendSms(message) {
+      sent.push(message);
+      return { messageId: `mock-sms-${sent.length}` };
+    },
+  };
+  return { transport, sent };
+}
+
+describe('SmsAdapter', () => {
+  describe('constructor', () => {
+    it('should set the channel to sms', () => {
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999' });
+      expect(adapter.channel).toBe('sms');
+    });
+  });
+
+  describe('formatSmsBody', () => {
+    it('should combine subject and body', () => {
+      const payload = makePayload();
+      const result = formatSmsBody(payload);
+      expect(result).toBe('Order Confirmation: Your order has been placed. Items: Widget x2. Total: $20.00');
+    });
+
+    it('should truncate messages longer than 160 characters', () => {
+      const payload = makePayload({
+        subject: 'Important Notification',
+        body: 'This is a very long message body that will exceed the maximum SMS length of 160 characters when combined with the subject line prefix and should be truncated properly.',
+      });
+      const result = formatSmsBody(payload);
+      expect(result.length).toBe(160);
+      expect(result.endsWith('...')).toBe(true);
+    });
+
+    it('should not truncate messages at exactly 160 characters', () => {
+      const subject = 'Hi';
+      // "Hi: " is 4 chars, so body needs to be 156 chars to total exactly 160
+      const body = 'x'.repeat(156);
+      const payload = makePayload({ subject, body });
+      const result = formatSmsBody(payload);
+      expect(result.length).toBe(160);
+      expect(result.endsWith('...')).toBe(false);
+    });
+
+    it('should not truncate short messages', () => {
+      const payload = makePayload({ subject: 'Hi', body: 'Hello!' });
+      const result = formatSmsBody(payload);
+      expect(result).toBe('Hi: Hello!');
+    });
+  });
+
+  describe('formatMessage', () => {
+    it('should build an SmsMessage with correct fields', () => {
+      const { transport } = createMockTransport();
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+      const payload = makePayload();
+
+      const message = adapter.formatMessage(payload);
+
+      expect(message.to).toBe('+15551234567');
+      expect(message.from).toBe('+15559999999');
+      expect(message.body).toContain('Order Confirmation');
+    });
+
+    it('should trim whitespace from recipient', () => {
+      const { transport } = createMockTransport();
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+      const payload = makePayload({ recipient: '  +15551234567  ' });
+
+      const message = adapter.formatMessage(payload);
+
+      expect(message.to).toBe('+15551234567');
+    });
+  });
+
+  describe('send', () => {
+    it('should send via transport and return success', async () => {
+      const { transport, sent } = createMockTransport();
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('sms');
+      expect(result.error).toBeUndefined();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]!.to).toBe('+15551234567');
+      expect(sent[0]!.from).toBe('+15559999999');
+    });
+
+    it('should return failure when transport throws an Error', async () => {
+      const transport: SmsTransport = {
+        async sendSms() {
+          throw new Error('SMS provider unavailable');
+        },
+      };
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.channel).toBe('sms');
+      expect(result.error).toBe('SMS provider unavailable');
+    });
+
+    it('should handle non-Error throws gracefully', async () => {
+      const transport: SmsTransport = {
+        async sendSms() {
+          throw 'string error';
+        },
+      };
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Unknown SMS transport error');
+    });
+
+    it('should use logging transport when no transport is provided', async () => {
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999' });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('sms');
+    });
+
+    it('should send correct body for different notification types', async () => {
+      const { transport, sent } = createMockTransport();
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+
+      await adapter.send(makePayload({
+        notificationType: 'welcome',
+        subject: 'Welcome!',
+        body: 'Welcome aboard!',
+      }));
+
+      expect(sent[0]!.body).toBe('Welcome!: Welcome aboard!');
+    });
+  });
+
+  describe('integration with NotificationService pattern', () => {
+    it('should conform to the NotificationAdapter interface', async () => {
+      const { transport } = createMockTransport();
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+
+      expect(adapter.channel).toBe('sms');
+      expect(typeof adapter.send).toBe('function');
+
+      const result = await adapter.send(makePayload());
+      expect(result).toHaveProperty('success');
+      expect(result).toHaveProperty('channel');
+    });
+
+    it('should be registrable with NotificationService', async () => {
+      const { EventBus } = await import('../../src/events/event-bus.js');
+      const { NotificationService } = await import('../../src/services/notification.service.js');
+
+      const { transport } = createMockTransport();
+      const adapter = new SmsAdapter({ fromNumber: '+15559999999', transport });
+
+      const eventBus = new EventBus();
+      const service = new NotificationService(eventBus);
+
+      // Should not throw
+      service.registerAdapter(adapter);
+    });
+  });
+});
