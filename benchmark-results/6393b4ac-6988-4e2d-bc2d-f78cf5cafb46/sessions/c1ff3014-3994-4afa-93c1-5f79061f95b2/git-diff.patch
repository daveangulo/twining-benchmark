+
+  describe('notification ordering', () => {
+    it('should deliver notifications in dispatch order even with variable adapter latency', async () => {
+      // Create an adapter with variable delay to simulate network jitter
+      const deliveryLog: string[] = [];
+      let callIndex = 0;
+      const delays = [50, 10, 30]; // first call is slowest to provoke reordering without the queue
+
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          const delay = delays[callIndex++] ?? 0;
+          await new Promise((resolve) => setTimeout(resolve, delay));
+          deliveryLog.push(payload.type);
+          return {
+            notificationId: payload.id,
+            channel: 'email',
+            success: true,
+            deliveredAt: new Date(),
+          };
+        },
+      };
+
+      const eventBusLocal = new EventBus();
+      const svc = new NotificationService(eventBusLocal);
+      svc.registerAdapter(slowAdapter);
+
+      // Fire three notifications concurrently (simulates rapid event bursts)
+      const p1 = svc.dispatchNotification({
+        type: 'order-confirmation',
+        channel: 'email',
+        recipient: 'user@test.com',
+        subject: 'Order Placed',
+        body: 'Your order has been placed.',
+        priority: 'normal',
+      });
+      const p2 = svc.dispatchNotification({
+        type: 'order-status-update',
+        channel: 'email',
+        recipient: 'user@test.com',
+        subject: 'Payment Confirmed',
+        body: 'Your payment has been confirmed.',
+        priority: 'normal',
+      });
+      const p3 = svc.dispatchNotification({
+        type: 'welcome',
+        channel: 'email',
+        recipient: 'user@test.com',
+        subject: 'Welcome',
+        body: 'Welcome!',
+        priority: 'normal',
+      });
+
+      await Promise.all([p1, p2, p3]);
+
+      // Delivery order must match dispatch order despite variable latency
+      expect(deliveryLog).toEqual([
+        'order-confirmation',
+        'order-status-update',
+        'welcome',
+      ]);
+
+      // Stored notifications must also be in order
+      const notifications = svc.getNotifications();
+      expect(notifications.map((n) => n.payload.type)).toEqual([
+        'order-confirmation',
+        'order-status-update',
+        'welcome',
+      ]);
+    });
+  });
 });
