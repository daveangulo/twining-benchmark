+  /**
+   * Enqueue a notification handler for a specific user, ensuring that
+   * notifications for the same user are processed in FIFO order even when
+   * multiple events are emitted concurrently.
+   *
+   * Without this queue, concurrent event emissions (e.g., 'order:created'
+   * and 'order:status-changed' fired back-to-back) can cause handlers to
+   * interleave, delivering notifications out of order. The queue serialises
+   * per-user work so that an earlier event's notifications are always
+   * dispatched before a later event's notifications for the same user.
+   *
+   * @param userId - The user whose queue to append to.
+   * @param handler - The async work to perform.
+   * @returns A promise that resolves when the handler completes.
+   */
+  private enqueueForUser(userId: string, handler: () => Promise<void>): Promise<void> {
+    const previous = this.userQueues.get(userId) ?? Promise.resolve();
+    const next = previous.then(() => handler(), () => handler());
+    this.userQueues.set(userId, next);
+    return next;
+  }
+
