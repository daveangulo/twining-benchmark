diff --git a/tests/services/notification.service.test.ts b/tests/services/notification.service.test.ts
index 6b20c48..0128ca2 100644
--- a/tests/services/notification.service.test.ts
+++ b/tests/services/notification.service.test.ts
@@ -340,4 +340,115 @@ describe('NotificationService', () => {
       expect(notification.priority).toBe('normal');
     });
   });
+
+  describe('notification delivery ordering', () => {
+    it('should deliver notifications in order when order:created is followed by order:status-changed', async () => {
+      const emailAdapter = new EmailAdapter();
+      emailAdapter.registerRecipient('user-1', 'alice@example.com');
+      service.registerAdapter(emailAdapter);
+
+      const orderCreatedEvent: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+          ],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      const statusChangedEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      // Emit both events sequentially — the fix ensures the first notification
+      // is fully delivered before the second begins, preserving order.
+      await eventBus.emit(orderCreatedEvent);
+      await eventBus.emit(statusChangedEvent);
+
+      const sentEmails = emailAdapter.getSentEmails();
+      expect(sentEmails).toHaveLength(2);
+
+      // "Order Confirmation" must arrive before "Order Update"
+      expect(sentEmails[0]?.subject).toContain('Order Confirmation');
+      expect(sentEmails[1]?.subject).toContain('Order Update');
+
+      // In-memory notification records should also be in order
+      const notifications = service.getNotifications();
+      expect(notifications).toHaveLength(2);
+      expect(notifications[0]?.subject).toContain('Order Confirmation');
+      expect(notifications[1]?.subject).toContain('Order Update');
+
+      // Sequential IDs confirm ordering
+      expect(notifications[0]?.id).toBe('notif-0001');
+      expect(notifications[1]?.id).toBe('notif-0002');
+    });
+
+    it('should deliver multiple status change notifications in sequence', async () => {
+      const emailAdapter = new EmailAdapter();
+      emailAdapter.registerRecipient('user-1', 'alice@example.com');
+      service.registerAdapter(emailAdapter);
+
+      const statuses = [
+        { from: 'pending', to: 'confirmed' },
+        { from: 'confirmed', to: 'shipped' },
+        { from: 'shipped', to: 'delivered' },
+      ];
+
+      for (const { from, to } of statuses) {
+        await eventBus.emit({
+          type: 'order:status-changed',
+          order: {
+            id: 'order-1',
+            userId: 'user-1',
+            items: [],
+            total: 10,
+            status: to,
+            createdAt: new Date(),
+            updatedAt: new Date(),
+          },
+          previousStatus: from,
+          newStatus: to,
+          timestamp: new Date(),
+        } as OrderStatusChangedEvent);
+      }
+
+      const sentEmails = emailAdapter.getSentEmails();
+      expect(sentEmails).toHaveLength(3);
+
+      // Verify delivery order matches emission order
+      expect(sentEmails[0]?.body).toContain('pending');
+      expect(sentEmails[0]?.body).toContain('confirmed');
+      expect(sentEmails[1]?.body).toContain('confirmed');
+      expect(sentEmails[1]?.body).toContain('shipped');
+      expect(sentEmails[2]?.body).toContain('shipped');
+      expect(sentEmails[2]?.body).toContain('delivered');
+    });
+  });
 });
