diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..5d7a5f4
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,204 @@
+/**
+ * Preferences service — business logic for managing user notification preferences.
+ *
+ * Provides CRUD operations for user notification preferences, including
+ * default initialization and partial updates. Uses an opt-out model:
+ * new users receive all notifications until they explicitly configure preferences.
+ *
+ * Depends on:
+ * - PreferencesRepository (data layer) for persistence
+ * - EventBus (event system) for publishing preference lifecycle events
+ *
+ * Usage by other services:
+ * - NotificationService uses getPreferences() to check whether a notification
+ *   should be sent before dispatching to an adapter.
+ */
+
+import type {
+  UserPreferences,
+  CreateUserPreferencesInput,
+  UpdateUserPreferencesInput,
+  NotificationCategory,
+} from '../models/user-preferences.js';
+import { DEFAULT_EMAIL_PREFERENCES } from '../models/user-preferences.js';
+import type { PreferencesRepository } from '../repositories/preferences.repository.js';
+import type { EventBus } from '../events/event-bus.js';
+import { Logger } from '../utils/logger.js';
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(
+    private preferencesRepository: PreferencesRepository,
+    private eventBus: EventBus,
+  ) {}
+
+  // ---------------------------------------------------------------------------
+  // Preferences CRUD
+  // ---------------------------------------------------------------------------
+
+  /**
+   * Create notification preferences for a user.
+   *
+   * Merges provided email settings with defaults so callers only need to
+   * specify the fields they want to override.
+   *
+   * @param input - User ID and optional partial email preferences.
+   * @returns The created UserPreferences record with all defaults applied.
+   * @throws Error if preferences already exist for this user.
+   */
+  createPreferences(input: CreateUserPreferencesInput): UserPreferences {
+    this.logger.info(`Creating preferences for user: ${input.userId}`);
+
+    // Check for existing preferences
+    const existing = this.preferencesRepository.findByUserId(input.userId);
+    if (existing) {
+      throw new Error(`Preferences already exist for user: ${input.userId}`);
+    }
+
+    const now = new Date();
+    const preferences: UserPreferences = {
+      id: input.userId,
+      userId: input.userId,
+      email: {
+        enabled: input.email?.enabled ?? DEFAULT_EMAIL_PREFERENCES.enabled,
+        frequency: input.email?.frequency ?? DEFAULT_EMAIL_PREFERENCES.frequency,
+        subscribedCategories:
+          input.email?.subscribedCategories ??
+          [...DEFAULT_EMAIL_PREFERENCES.subscribedCategories],
+      },
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    this.preferencesRepository.save(preferences);
+    this.logger.info(`Preferences created for user: ${input.userId}`);
+
+    return preferences;
+  }
+
+  /**
+   * Get notification preferences for a user.
+   *
+   * @param userId - The user ID to look up.
+   * @returns The user's preferences, or undefined if none are configured.
+   */
+  getPreferences(userId: string): UserPreferences | undefined {
+    return this.preferencesRepository.findByUserId(userId);
+  }
+
+  /**
+   * Update notification preferences for a user.
+   *
+   * Only provided fields are updated; missing fields retain their current values.
+   * Supports partial updates to the email preferences object.
+   *
+   * @param userId - The user whose preferences to update.
+   * @param input - Partial preference updates to apply.
+   * @returns The updated UserPreferences record.
+   * @throws Error if no preferences exist for this user.
+   */
+  updatePreferences(userId: string, input: UpdateUserPreferencesInput): UserPreferences {
+    this.logger.info(`Updating preferences for user: ${userId}`);
+
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (!existing) {
+      throw new Error(`Preferences not found for user: ${userId}`);
+    }
+
+    const updatedEmail = {
+      enabled: input.email?.enabled ?? existing.email.enabled,
+      frequency: input.email?.frequency ?? existing.email.frequency,
+      subscribedCategories:
+        input.email?.subscribedCategories ?? [...existing.email.subscribedCategories],
+    };
+
+    const updated = this.preferencesRepository.update(userId, {
+      email: updatedEmail,
+      updatedAt: new Date(),
+    });
+
+    this.logger.info(`Preferences updated for user: ${userId}`);
+    return updated;
+  }
+
+  /**
+   * Delete notification preferences for a user.
+   * After deletion, the user reverts to default behavior (all notifications enabled).
+   *
+   * @param userId - The user whose preferences to delete.
+   * @returns true if preferences were deleted, false if none existed.
+   */
+  deletePreferences(userId: string): boolean {
+    this.logger.info(`Deleting preferences for user: ${userId}`);
+    return this.preferencesRepository.delete(userId);
+  }
+
+  /**
+   * Get or create preferences for a user, ensuring defaults are applied.
+   * If no preferences exist, creates a record with default settings.
+   *
+   * @param userId - The user ID.
+   * @returns The user's preferences (existing or newly created with defaults).
+   */
+  getOrCreatePreferences(userId: string): UserPreferences {
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (existing) {
+      return existing;
+    }
+    return this.createPreferences({ userId });
+  }
+
+  // ---------------------------------------------------------------------------
+  // Preference Queries — used by NotificationService
+  // ---------------------------------------------------------------------------
+
+  /**
+   * Check if a specific notification category is enabled for a user.
+   *
+   * This is the primary method used by NotificationService to decide whether
+   * to dispatch a notification. It checks both the master email toggle and
+   * the category subscription.
+   *
+   * Returns true (send notification) when:
+   * - No preferences exist for the user (opt-out model: default is enabled)
+   * - Email is enabled AND the category is in the subscribed list
+   *
+   * @param userId - The user to check.
+   * @param category - The notification category to check.
+   * @returns true if the notification should be sent.
+   */
+  isNotificationEnabled(userId: string, category: NotificationCategory): boolean {
+    const prefs = this.preferencesRepository.findByUserId(userId);
+
+    // No preferences configured → opt-out model, send everything
+    if (!prefs) {
+      return true;
+    }
+
+    // Master email toggle
+    if (!prefs.email.enabled) {
+      return false;
+    }
+
+    // Category subscription check
+    return prefs.email.subscribedCategories.includes(category);
+  }
+
+  /**
+   * Check if email notifications are enabled for a user (master toggle only).
+   *
+   * @param userId - The user to check.
+   * @returns true if email is enabled or no preferences exist.
+   */
+  isEmailEnabled(userId: string): boolean {
+    const prefs = this.preferencesRepository.findByUserId(userId);
+
+    // No preferences → default is enabled
+    if (!prefs) {
+      return true;
+    }
+
+    return prefs.email.enabled;
+  }
+}
diff --git a/tests/repositories/preferences.repository.test.ts b/tests/repositories/preferences.repository.test.ts
new file mode 100644
index 0000000..ae78193
--- /dev/null
+++ b/tests/repositories/preferences.repository.test.ts
@@ -0,0 +1,119 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import type { UserPreferences } from '../../src/models/user-preferences.js';
+import { ALL_NOTIFICATION_CATEGORIES } from '../../src/models/user-preferences.js';
+
+describe('PreferencesRepository', () => {
+  let db: Database;
+  let repo: PreferencesRepository;
+
+  const createPreferences = (userId: string): UserPreferences => ({
+    id: userId,
+    userId,
+    email: {
+      enabled: true,
+      frequency: 'immediate',
+      subscribedCategories: [...ALL_NOTIFICATION_CATEGORIES],
+    },
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  });
+
+  beforeEach(() => {
+    db = new Database();
+    repo = new PreferencesRepository(db);
+  });
+
+  it('should save and retrieve preferences', () => {
+    const prefs = createPreferences('user-0001');
+    repo.save(prefs);
+
+    const found = repo.findById('user-0001');
+    expect(found).toBeDefined();
+    expect(found?.userId).toBe('user-0001');
+    expect(found?.email.enabled).toBe(true);
+    expect(found?.email.frequency).toBe('immediate');
+  });
+
+  it('should find preferences by user ID', () => {
+    const prefs = createPreferences('user-0001');
+    repo.save(prefs);
+
+    const found = repo.findByUserId('user-0001');
+    expect(found).toBeDefined();
+    expect(found?.userId).toBe('user-0001');
+  });
+
+  it('should return undefined for non-existent user', () => {
+    const found = repo.findByUserId('user-9999');
+    expect(found).toBeUndefined();
+  });
+
+  it('should correctly serialize and deserialize subscribed categories', () => {
+    const prefs = createPreferences('user-0001');
+    prefs.email.subscribedCategories = ['order_confirmations', 'promotions'];
+    repo.save(prefs);
+
+    const found = repo.findById('user-0001');
+    expect(found?.email.subscribedCategories).toEqual([
+      'order_confirmations',
+      'promotions',
+    ]);
+  });
+
+  it('should handle empty subscribed categories', () => {
+    const prefs = createPreferences('user-0001');
+    prefs.email.subscribedCategories = [];
+    repo.save(prefs);
+
+    const found = repo.findById('user-0001');
+    expect(found?.email.subscribedCategories).toEqual([]);
+  });
+
+  it('should update preferences', () => {
+    const prefs = createPreferences('user-0001');
+    repo.save(prefs);
+
+    repo.update('user-0001', {
+      email: {
+        enabled: false,
+        frequency: 'daily_digest',
+        subscribedCategories: ['order_confirmations'],
+      },
+    });
+
+    const found = repo.findById('user-0001');
+    expect(found?.email.enabled).toBe(false);
+    expect(found?.email.frequency).toBe('daily_digest');
+    expect(found?.email.subscribedCategories).toEqual(['order_confirmations']);
+  });
+
+  it('should delete preferences', () => {
+    const prefs = createPreferences('user-0001');
+    repo.save(prefs);
+
+    expect(repo.delete('user-0001')).toBe(true);
+    expect(repo.findById('user-0001')).toBeUndefined();
+  });
+
+  it('should correctly round-trip date serialization', () => {
+    const prefs = createPreferences('user-0001');
+    const originalCreatedAt = prefs.createdAt;
+    repo.save(prefs);
+
+    const found = repo.findById('user-0001');
+    expect(found?.createdAt).toBeInstanceOf(Date);
+    expect(found?.createdAt.getTime()).toBe(originalCreatedAt.getTime());
+  });
+
+  it('should count preferences records', () => {
+    expect(repo.count()).toBe(0);
+
+    repo.save(createPreferences('user-0001'));
+    expect(repo.count()).toBe(1);
+
+    repo.save(createPreferences('user-0002'));
+    expect(repo.count()).toBe(2);
+  });
+});
