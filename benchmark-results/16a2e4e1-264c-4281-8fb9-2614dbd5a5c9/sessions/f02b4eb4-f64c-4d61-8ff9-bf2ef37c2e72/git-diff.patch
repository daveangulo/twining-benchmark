+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let preferencesRepo: PreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    preferencesRepo = new PreferencesRepository(db);
+    service = new PreferencesService(preferencesRepo);
+    resetPreferencesIdCounter();
+  });
+
+  describe('getPreferences', () => {
+    it('should return undefined when no preferences exist', () => {
+      expect(service.getPreferences('user-0001')).toBeUndefined();
+    });
+
+    it('should return existing preferences', () => {
+      service.getOrCreatePreferences('user-0001');
+      const prefs = service.getPreferences('user-0001');
+      expect(prefs).toBeDefined();
+      expect(prefs?.userId).toBe('user-0001');
+    });
+  });
+
+  describe('getOrCreatePreferences', () => {
+    it('should create default preferences when none exist', () => {
+      const prefs = service.getOrCreatePreferences('user-0001');
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-0001');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.categories.order_confirmation).toBe(true);
+      expect(prefs.email.categories.order_status_update).toBe(true);
+      expect(prefs.email.categories.welcome).toBe(true);
+      expect(prefs.email.categories.account_updated).toBe(true);
+    });
+
+    it('should return existing preferences without creating new ones', () => {
+      const first = service.getOrCreatePreferences('user-0001');
+      const second = service.getOrCreatePreferences('user-0001');
+      expect(first.id).toBe(second.id);
+    });
+
+    it('should generate sequential IDs', () => {
+      const a = service.getOrCreatePreferences('user-0001');
+      const b = service.getOrCreatePreferences('user-0002');
+      expect(a.id).toBe('pref-0001');
+      expect(b.id).toBe('pref-0002');
+    });
+
+    it('should set createdAt and updatedAt', () => {
+      const prefs = service.getOrCreatePreferences('user-0001');
+      expect(prefs.createdAt).toBeInstanceOf(Date);
+      expect(prefs.updatedAt).toBeInstanceOf(Date);
+    });
+  });
+
+  describe('updatePreferences', () => {
+    it('should disable email globally', () => {
+      service.getOrCreatePreferences('user-0001');
+      const updated = service.updatePreferences('user-0001', {
+        email: { enabled: false },
+      });
+      expect(updated.email.enabled).toBe(false);
+      // Categories remain unchanged
+      expect(updated.email.categories.order_confirmation).toBe(true);
+    });
+
+    it('should disable a specific category', () => {
+      service.getOrCreatePreferences('user-0001');
+      const updated = service.updatePreferences('user-0001', {
+        email: { categories: { order_status_update: false } },
+      });
+      expect(updated.email.categories.order_status_update).toBe(false);
+      // Other categories unchanged
+      expect(updated.email.categories.order_confirmation).toBe(true);
+      expect(updated.email.categories.welcome).toBe(true);
+      expect(updated.email.categories.account_updated).toBe(true);
+    });
+
+    it('should disable multiple categories at once', () => {
+      service.getOrCreatePreferences('user-0001');
+      const updated = service.updatePreferences('user-0001', {
+        email: {
+          categories: {
+            order_status_update: false,
+            welcome: false,
+          },
+        },
+      });
+      expect(updated.email.categories.order_status_update).toBe(false);
+      expect(updated.email.categories.welcome).toBe(false);
+      expect(updated.email.categories.order_confirmation).toBe(true);
+    });
+
+    it('should re-enable a previously disabled category', () => {
+      service.getOrCreatePreferences('user-0001');
+      service.updatePreferences('user-0001', {
+        email: { categories: { welcome: false } },
+      });
+      const updated = service.updatePreferences('user-0001', {
+        email: { categories: { welcome: true } },
+      });
+      expect(updated.email.categories.welcome).toBe(true);
+    });
+
+    it('should create preferences if none exist before updating', () => {
+      const updated = service.updatePreferences('user-0001', {
+        email: { enabled: false },
+      });
+      expect(updated.userId).toBe('user-0001');
+      expect(updated.email.enabled).toBe(false);
+    });
+
+    it('should update both enabled and categories together', () => {
+      service.getOrCreatePreferences('user-0001');
+      const updated = service.updatePreferences('user-0001', {
+        email: {
+          enabled: false,
+          categories: { order_confirmation: false },
+        },
+      });
+      expect(updated.email.enabled).toBe(false);
+      expect(updated.email.categories.order_confirmation).toBe(false);
+    });
+
+    it('should persist changes across reads', () => {
+      service.getOrCreatePreferences('user-0001');
+      service.updatePreferences('user-0001', {
+        email: { categories: { welcome: false } },
+      });
+      const prefs = service.getPreferences('user-0001');
+      expect(prefs?.email.categories.welcome).toBe(false);
+    });
+  });
+
+  describe('isEmailEnabled', () => {
+    it('should return true when no preferences exist (default)', () => {
+      expect(service.isEmailEnabled('user-0001', 'order_confirmation')).toBe(true);
+      expect(service.isEmailEnabled('user-0001', 'welcome')).toBe(true);
+    });
+
+    it('should return true when all defaults are in place', () => {
+      service.getOrCreatePreferences('user-0001');
+      expect(service.isEmailEnabled('user-0001', 'order_confirmation')).toBe(true);
+    });
+
+    it('should return false when email is globally disabled', () => {
+      service.getOrCreatePreferences('user-0001');
+      service.updatePreferences('user-0001', { email: { enabled: false } });
+      expect(service.isEmailEnabled('user-0001', 'order_confirmation')).toBe(false);
+      expect(service.isEmailEnabled('user-0001', 'order_status_update')).toBe(false);
+    });
+
+    it('should return false for a disabled category', () => {
+      service.getOrCreatePreferences('user-0001');
+      service.updatePreferences('user-0001', {
+        email: { categories: { order_status_update: false } },
+      });
+      expect(service.isEmailEnabled('user-0001', 'order_status_update')).toBe(false);
+      expect(service.isEmailEnabled('user-0001', 'order_confirmation')).toBe(true);
+    });
+
+    it('should return false when email is disabled even if category is enabled', () => {
+      service.getOrCreatePreferences('user-0001');
+      service.updatePreferences('user-0001', { email: { enabled: false } });
+      // Categories are still all true, but email is globally off
+      expect(service.isEmailEnabled('user-0001', 'order_confirmation')).toBe(false);
+    });
+  });
+});
+
+describe('NotificationService with preferences', () => {
+  let db: Database;
+  let eventBus: EventBus;
+  let notificationService: NotificationService;
+  let preferencesService: PreferencesService;
+  let preferencesRepo: PreferencesRepository;
+
+  beforeEach(() => {
+    db = new Database();
+    eventBus = new EventBus();
+    notificationService = new NotificationService(eventBus);
+    preferencesRepo = new PreferencesRepository(db);
+    preferencesService = new PreferencesService(preferencesRepo);
+    notificationService.setPreferencesService(preferencesService);
+    resetNotificationIdCounter();
+    resetPreferencesIdCounter();
+  });
+
+  const makeOrderCreatedEvent = (userId: string, email: string): OrderCreatedEvent => ({
+    type: 'order:created',
+    order: {
+      id: 'order-1',
+      userId,
+      items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+      total: 10,
+      status: 'pending',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    user: {
+      id: userId,
+      name: 'Alice',
+      email,
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    timestamp: new Date(),
+  });
