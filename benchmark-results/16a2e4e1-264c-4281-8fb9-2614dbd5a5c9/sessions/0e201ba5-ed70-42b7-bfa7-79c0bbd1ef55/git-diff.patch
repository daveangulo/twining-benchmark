+/**
+ * NotificationAdapter — the interface all notification delivery adapters must implement.
+ *
+ * Architecture constraint: Every notification channel (email, webhook, in-app, SMS, etc.)
+ * MUST implement this interface. The NotificationService dispatches NotificationPayloads
+ * to adapters based on channel type. Adapters are registered with the NotificationService
+ * at construction time via dependency injection.
+ *
+ * To add a new notification channel:
+ * 1. Add the channel name to NotificationChannel in src/models/notification.ts
+ * 2. Create an adapter class implementing this interface in src/adapters/
+ * 3. Register the adapter with NotificationService via its constructor
+ *
+ * Adapters must:
+ * - Be stateless (no notification history — that's the service's job)
+ * - Handle their own errors and return NotificationResult with success: false
+ * - Never throw — always return a result
+ */
+
+import type {
+  NotificationChannel,
+  NotificationPayload,
+  NotificationResult,
+} from '../models/notification.js';
+
+export interface NotificationAdapter {
+  /** The channel this adapter handles. Must match a NotificationChannel value. */
+  readonly channel: NotificationChannel;
+
+  /**
+   * Send a notification through this adapter's channel.
+   *
+   * @param payload - The notification to deliver
+   * @returns The result of the delivery attempt (never throws)
+   */
+  send(payload: NotificationPayload): Promise<NotificationResult>;
+}
