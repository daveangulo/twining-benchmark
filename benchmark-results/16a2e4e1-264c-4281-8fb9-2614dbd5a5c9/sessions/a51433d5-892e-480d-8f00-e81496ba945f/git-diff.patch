+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { SmsAdapter, isValidPhoneNumber } from '../../src/adapters/sms.adapter.js';
+import type { SmsTransport } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides: Partial<NotificationPayload> = {}): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order_confirmation',
+    channel: 'sms',
+    recipient: '+14155551234',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    priority: 'normal',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    createdAt: new Date(),
+    ...overrides,
+  };
+}
+
+describe('isValidPhoneNumber', () => {
+  it('should accept valid E.164 phone numbers', () => {
+    expect(isValidPhoneNumber('+14155551234')).toBe(true);
+    expect(isValidPhoneNumber('+442071234567')).toBe(true);
+    expect(isValidPhoneNumber('+8613800138000')).toBe(true);
+  });
+
+  it('should reject invalid phone numbers', () => {
+    expect(isValidPhoneNumber('')).toBe(false);
+    expect(isValidPhoneNumber('not-a-phone')).toBe(false);
+    expect(isValidPhoneNumber('14155551234')).toBe(false);
+    expect(isValidPhoneNumber('+0123456789')).toBe(false);
+    expect(isValidPhoneNumber('+1')).toBe(false);
+    expect(isValidPhoneNumber('+1234')).toBe(false);
+  });
+});
+
+describe('SmsAdapter', () => {
+  let adapter: SmsAdapter;
+  let transport: SmsTransport;
+
+  beforeEach(() => {
+    transport = vi.fn(async () => {});
+    adapter = new SmsAdapter(
+      { fromNumber: '+15550000000' },
+      transport,
+    );
+  });
+
+  describe('channel', () => {
+    it('should report channel as sms', () => {
+      expect(adapter.channel).toBe('sms');
+    });
+  });
+
+  describe('resolveRecipient', () => {
+    it('should accept valid phone numbers', () => {
+      expect(adapter.resolveRecipient('+14155551234')).toBe('+14155551234');
+    });
+
+    it('should trim whitespace', () => {
+      expect(adapter.resolveRecipient('  +14155551234  ')).toBe('+14155551234');
+    });
+
+    it('should throw for invalid phone numbers', () => {
+      expect(() => adapter.resolveRecipient('not-valid')).toThrow('Invalid phone number');
+    });
+  });
+
+  describe('formatMessage', () => {
+    it('should format payload into SMS message', () => {
+      const payload = makePayload();
+      const message = adapter.formatMessage(payload);
+
+      expect(message.from).toBe('+15550000000');
+      expect(message.to).toBe('+14155551234');
+      expect(message.body).toContain('Order Confirmation');
+      expect(message.body).toContain('Widget x2');
+    });
+
+    it('should combine subject and body', () => {
+      const payload = makePayload({
+        subject: 'Order Update',
+        body: 'Status changed to shipped.',
+      });
+      const message = adapter.formatMessage(payload);
+
+      expect(message.body).toBe('Order Update: Status changed to shipped.');
+    });
+  });
+
+  describe('send', () => {
+    it('should return success for a valid phone number', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('sms');
+      expect(result.error).toBeUndefined();
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+    });
+
+    it('should call the transport with formatted message', async () => {
+      const payload = makePayload();
+      await adapter.send(payload);
+
+      expect(transport).toHaveBeenCalledOnce();
+      const message = (transport as ReturnType<typeof vi.fn>).mock.calls[0]![0];
+      expect(message.to).toBe('+14155551234');
+      expect(message.from).toBe('+15550000000');
+      expect(message.body).toContain('Order Confirmation');
+    });
+
+    it('should record sent messages', async () => {
+      const payload = makePayload();
+      await adapter.send(payload);
+
+      const sent = adapter.getSentMessages();
+      expect(sent).toHaveLength(1);
+      expect(sent[0]!.payload.recipient).toBe('+14155551234');
+      expect(sent[0]!.message.body).toContain('Order Confirmation');
+    });
+
+    it('should return failure for invalid recipient', async () => {
+      const payload = makePayload({ recipient: 'bad-phone' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.channel).toBe('sms');
+      expect(result.error).toContain('Invalid phone number');
+    });
+
+    it('should not call transport when recipient is invalid', async () => {
+      const payload = makePayload({ recipient: 'bad-phone' });
+      await adapter.send(payload);
+
+      expect(transport).not.toHaveBeenCalled();
+    });
+
+    it('should return failure when transport throws', async () => {
+      const failingTransport: SmsTransport = async () => {
+        throw new Error('SMS gateway unavailable');
+      };
+      const failAdapter = new SmsAdapter(undefined, failingTransport);
+
+      const payload = makePayload();
+      const result = await failAdapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('SMS gateway unavailable');
+    });
+
+    it('should trim whitespace from recipient', async () => {
+      const payload = makePayload({ recipient: '  +14155551234  ' });
+      await adapter.send(payload);
+
+      const sent = adapter.getSentMessages();
+      expect(sent[0]!.payload.recipient).toBe('+14155551234');
+    });
+  });
+
+  describe('getSentMessages / clearSentMessages', () => {
+    it('should start with no sent messages', () => {
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should clear sent messages', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentMessages()).toHaveLength(1);
+
+      adapter.clearSentMessages();
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+
+    it('should return a copy of the array', async () => {
+      await adapter.send(makePayload());
+      const first = adapter.getSentMessages();
+      const second = adapter.getSentMessages();
+      expect(first).not.toBe(second);
+      expect(first).toEqual(second);
+    });
+  });
+
+  describe('default config', () => {
+    it('should use default config when none provided', () => {
+      const defaultAdapter = new SmsAdapter();
+      const payload = makePayload();
+      const message = defaultAdapter.formatMessage(payload);
+
+      expect(message.from).toBe('+15550000000');
+    });
+  });
+
+  describe('integration with NotificationService', () => {
+    it('should work when wired into NotificationService via constructor', async () => {
+      const { EventBus } = await import('../../src/events/event-bus.js');
+      const { NotificationService, resetNotificationIdCounter } = await import(
+        '../../src/services/notification.service.js'
+      );
+
+      resetNotificationIdCounter();
+      const eventBus = new EventBus();
+      const smsAdapter = new SmsAdapter(undefined, transport);
+      const service = new NotificationService(eventBus, [smsAdapter]);
+
+      // Manually dispatch an SMS notification via the service's internal flow.
+      // The default event handlers target 'email', so we emit and check that
+      // the SMS adapter is registered and accessible.
+      expect(service.getNotificationCount()).toBe(0);
+
+      // The SMS adapter is registered — verify by checking that an event
+      // dispatched to email channel doesn't go to SMS (channels are separate).
+      await eventBus.emit({
+        type: 'user:created',
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      // The default handlers dispatch to 'email' channel, which has no adapter here.
+      // The notification should be recorded as failed (no email adapter).
+      const records = service.getNotificationRecords();
+      expect(records).toHaveLength(1);
+      expect(records[0]!.result.success).toBe(false);
+      expect(records[0]!.result.error).toContain('No adapter for channel: email');
+
+      // But the SMS adapter IS registered and can send directly
+      const smsResult = await smsAdapter.send(makePayload());
+      expect(smsResult.success).toBe(true);
+      expect(transport).toHaveBeenCalledOnce();
+    });
+  });
+});
