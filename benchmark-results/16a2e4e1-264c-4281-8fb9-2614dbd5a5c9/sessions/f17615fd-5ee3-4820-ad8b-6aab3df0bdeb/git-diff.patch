+        //   - @aws-sdk/client-ses for Amazon SES
+        throw new Error('Real email delivery not implemented. Set stubMode: true for development.');
+    }
+    /**
+     * Simple delay utility for retry backoff.
+     */
+    delay(ms) {
+        // Use globalThis to access the timer API in a way that
+        // compiles cleanly regardless of which lib types are loaded.
+        const timer = globalThis;
