diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..ec21cab
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,258 @@
+/**
+ * Preferences service — business logic for user notification preferences.
+ *
+ * Manages CRUD operations on notification preferences and provides a
+ * query interface for the NotificationService to check whether a given
+ * notification should be delivered to a user.
+ *
+ * Design decisions:
+ * - Opt-out model: users without stored preferences receive all notifications.
+ * - The `email.enabled` flag is a master switch; if false, all email
+ *   notifications are suppressed regardless of category settings.
+ * - Categories not explicitly listed in `categoryPreferences` default to enabled.
+ * - This service does NOT emit events — it is a passive data service queried
+ *   by the NotificationService during dispatch.
+ *
+ * Depends on:
+ * - PreferencesRepository (data layer) for persistence
+ */
+
+import type { PreferencesRepository } from '../repositories/preferences.repository.js';
+import type {
+  UserNotificationPreferences,
+  CreatePreferencesInput,
+  UpdatePreferencesInput,
+  EmailPreferences,
+} from '../models/user-preferences.js';
+import type { NotificationType, NotificationChannel } from '../models/notification.js';
+import { getDefaultEmailPreferences } from '../models/user-preferences.js';
+import { Logger } from '../utils/logger.js';
+
+let nextId = 1;
+
+function generatePreferencesId(): string {
+  return `pref-${String(nextId++).padStart(4, '0')}`;
+}
+
+/** Reset the ID counter. Used in tests. */
+export function resetPreferencesIdCounter(): void {
+  nextId = 1;
+}
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(private preferencesRepository: PreferencesRepository) {}
+
+  // ---------------------------------------------------------------------------
+  // CRUD Operations
+  // ---------------------------------------------------------------------------
+
+  /**
+   * Create notification preferences for a user.
+   *
+   * If the user already has preferences, throws an error. Use
+   * `updatePreferences` to modify existing preferences.
+   *
+   * @param input - The preferences to create. Defaults are applied for omitted fields.
+   * @returns The created preferences.
+   */
+  createPreferences(input: CreatePreferencesInput): UserNotificationPreferences {
+    this.logger.info(`Creating preferences for user: ${input.userId}`);
+
+    const existing = this.preferencesRepository.findByUserId(input.userId);
+    if (existing) {
+      throw new Error(`Preferences already exist for user: ${input.userId}`);
+    }
+
+    const defaults = getDefaultEmailPreferences();
+    const emailPrefs: EmailPreferences = {
+      enabled: input.email?.enabled ?? defaults.enabled,
+      frequency: input.email?.frequency ?? defaults.frequency,
+      categoryPreferences:
+        input.email?.categoryPreferences ?? defaults.categoryPreferences,
+    };
+
+    const now = new Date();
+    const preferences: UserNotificationPreferences = {
+      id: generatePreferencesId(),
+      userId: input.userId,
+      email: emailPrefs,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    this.preferencesRepository.save(preferences);
+    this.logger.info(`Preferences created: ${preferences.id} for user ${input.userId}`);
+
+    return preferences;
+  }
+
+  /**
+   * Get notification preferences for a user.
+   *
+   * @param userId - The user ID to look up.
+   * @returns The user's preferences, or undefined if none are stored.
+   */
+  getPreferences(userId: string): UserNotificationPreferences | undefined {
+    return this.preferencesRepository.findByUserId(userId);
+  }
+
+  /**
+   * Update notification preferences for a user.
+   *
+   * Only the provided fields are changed; all others remain as-is.
+   *
+   * @param userId - The user whose preferences to update.
+   * @param input - The fields to update.
+   * @returns The updated preferences.
+   * @throws Error if no preferences exist for the user.
+   */
+  updatePreferences(
+    userId: string,
+    input: UpdatePreferencesInput,
+  ): UserNotificationPreferences {
+    this.logger.info(`Updating preferences for user: ${userId}`);
+
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (!existing) {
+      throw new Error(`No preferences found for user: ${userId}`);
+    }
+
+    const updatedEmail: EmailPreferences = {
+      enabled: input.email?.enabled ?? existing.email.enabled,
+      frequency: input.email?.frequency ?? existing.email.frequency,
+      categoryPreferences:
+        input.email?.categoryPreferences ?? existing.email.categoryPreferences,
+    };
+
+    const updated = this.preferencesRepository.update(existing.id, {
+      email: updatedEmail,
+      updatedAt: new Date(),
+    });
+
+    this.logger.info(`Preferences updated: ${existing.id} for user ${userId}`);
+
+    return updated;
+  }
+
+  /**
+   * Delete notification preferences for a user.
+   *
+   * After deletion, the user will receive all notifications (default behaviour).
+   *
+   * @param userId - The user whose preferences to delete.
+   * @returns true if preferences were deleted, false if none existed.
+   */
+  deletePreferences(userId: string): boolean {
+    this.logger.info(`Deleting preferences for user: ${userId}`);
+
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (!existing) {
+      return false;
+    }
+
+    return this.preferencesRepository.delete(existing.id);
+  }
+
+  /**
+   * Get or create preferences for a user.
+   *
+   * If the user has no stored preferences, creates default preferences.
+   * This is a convenience method for the notification check flow.
+   *
+   * @param userId - The user ID.
+   * @returns The user's preferences (existing or newly created defaults).
+   */
+  getOrCreatePreferences(userId: string): UserNotificationPreferences {
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (existing) {
+      return existing;
+    }
+    return this.createPreferences({ userId });
+  }
+
+  // ---------------------------------------------------------------------------
+  // Notification Check Interface
+  // ---------------------------------------------------------------------------
+
+  /**
+   * Check whether a notification should be sent to a user on a given channel.
+   *
+   * This is the primary query used by the NotificationService before dispatching.
+   * It checks:
+   * 1. Whether the channel is enabled (master switch).
+   * 2. Whether the specific notification category is enabled.
+   *
+   * Users without stored preferences are assumed to want all notifications
+   * (opt-out model).
+   *
+   * @param userId - The user to check.
+   * @param channel - The notification channel (currently only 'email').
+   * @param notificationType - The type of notification being sent.
+   * @returns true if the notification should be sent, false if suppressed.
+   */
+  shouldSendNotification(
+    userId: string,
+    channel: NotificationChannel,
+    notificationType: NotificationType,
+  ): boolean {
+    const preferences = this.preferencesRepository.findByUserId(userId);
+
+    // No stored preferences — opt-out model means send everything.
+    if (!preferences) {
+      this.logger.debug(
+        `No preferences for user ${userId}; defaulting to send`,
+      );
+      return true;
+    }
+
+    // Currently only email channel is supported.
+    if (channel === 'email') {
+      return this.shouldSendEmail(preferences, notificationType);
+    }
+
+    // Unknown or unsupported channels default to sending.
+    return true;
+  }
+
+  /**
+   * Check whether a specific email notification should be sent based on
+   * user preferences.
+   *
+   * @param preferences - The user's stored preferences.
+   * @param notificationType - The notification type to check.
+   * @returns true if the email should be sent.
+   */
+  private shouldSendEmail(
+    preferences: UserNotificationPreferences,
+    notificationType: NotificationType,
+  ): boolean {
+    // Master switch check.
+    if (!preferences.email.enabled) {
+      this.logger.debug(
+        `Email disabled for user ${preferences.userId}; suppressing ${notificationType}`,
+      );
+      return false;
+    }
+
+    // Category-level check.
+    const categoryPref = preferences.email.categoryPreferences.find(
+      (cp) => cp.category === notificationType,
+    );
+
+    // Categories not explicitly listed default to enabled.
+    if (!categoryPref) {
+      return true;
+    }
+
+    if (!categoryPref.enabled) {
+      this.logger.debug(
+        `Category ${notificationType} disabled for user ${preferences.userId}; suppressing`,
+      );
+      return false;
+    }
+
+    return true;
+  }
+}
diff --git a/tests/services/preferences.service.test.ts b/tests/services/preferences.service.test.ts
new file mode 100644
index 0000000..45d34a8
--- /dev/null
+++ b/tests/services/preferences.service.test.ts
@@ -0,0 +1,532 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { UserCreatedEvent, OrderCreatedEvent } from '../../src/events/event-types.js';
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let repo: PreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    repo = new PreferencesRepository(db);
+    service = new PreferencesService(repo);
+    resetPreferencesIdCounter();
+  });
+
+  describe('createPreferences', () => {
+    it('should create default preferences for a user', () => {
+      const prefs = service.createPreferences({ userId: 'user-1' });
+
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.categoryPreferences).toHaveLength(4);
+      expect(prefs.createdAt).toBeInstanceOf(Date);
+      expect(prefs.updatedAt).toBeInstanceOf(Date);
+    });
+
+    it('should create preferences with custom email settings', () => {
+      const prefs = service.createPreferences({
+        userId: 'user-1',
+        email: {
+          enabled: true,
+          frequency: 'daily',
+          categoryPreferences: [
+            { category: 'order_confirmation', enabled: true },
+            { category: 'order_status_update', enabled: true },
+            { category: 'welcome', enabled: false },
+            { category: 'account_updated', enabled: false },
+          ],
+        },
+      });
+
+      expect(prefs.email.frequency).toBe('daily');
+      expect(prefs.email.categoryPreferences).toHaveLength(4);
+      const welcomePref = prefs.email.categoryPreferences.find(
+        (cp) => cp.category === 'welcome',
+      );
+      expect(welcomePref?.enabled).toBe(false);
+    });
+
+    it('should apply defaults for omitted email fields', () => {
+      const prefs = service.createPreferences({
+        userId: 'user-1',
+        email: { frequency: 'weekly' },
+      });
+
+      expect(prefs.email.enabled).toBe(true); // default
+      expect(prefs.email.frequency).toBe('weekly'); // overridden
+      expect(prefs.email.categoryPreferences).toHaveLength(4); // default
+    });
+
+    it('should throw if preferences already exist for user', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      expect(() => {
+        service.createPreferences({ userId: 'user-1' });
+      }).toThrow('Preferences already exist for user: user-1');
+    });
+
+    it('should generate sequential preference IDs', () => {
+      const prefs1 = service.createPreferences({ userId: 'user-1' });
+      const prefs2 = service.createPreferences({ userId: 'user-2' });
+
+      expect(prefs1.id).toBe('pref-0001');
+      expect(prefs2.id).toBe('pref-0002');
+    });
+  });
+
+  describe('getPreferences', () => {
+    it('should return preferences for an existing user', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const prefs = service.getPreferences('user-1');
+      expect(prefs).toBeDefined();
+      expect(prefs?.userId).toBe('user-1');
+    });
+
+    it('should return undefined for a user without preferences', () => {
+      const prefs = service.getPreferences('user-999');
+      expect(prefs).toBeUndefined();
+    });
+  });
+
+  describe('updatePreferences', () => {
+    it('should update email enabled flag', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.updatePreferences('user-1', {
+        email: { enabled: false },
+      });
+
+      expect(updated.email.enabled).toBe(false);
+      expect(updated.email.frequency).toBe('immediate'); // unchanged
+    });
+
+    it('should update email frequency', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.updatePreferences('user-1', {
+        email: { frequency: 'daily' },
+      });
+
+      expect(updated.email.frequency).toBe('daily');
+      expect(updated.email.enabled).toBe(true); // unchanged
+    });
+
+    it('should update category preferences', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.updatePreferences('user-1', {
+        email: {
+          categoryPreferences: [
+            { category: 'order_confirmation', enabled: true },
+            { category: 'order_status_update', enabled: false },
+            { category: 'welcome', enabled: true },
+            { category: 'account_updated', enabled: false },
+          ],
+        },
+      });
+
+      const statusUpdatePref = updated.email.categoryPreferences.find(
+        (cp) => cp.category === 'order_status_update',
+      );
+      expect(statusUpdatePref?.enabled).toBe(false);
+    });
+
+    it('should throw if preferences do not exist', () => {
+      expect(() => {
+        service.updatePreferences('user-999', {
+          email: { enabled: false },
+        });
+      }).toThrow('No preferences found for user: user-999');
+    });
+
+    it('should update the updatedAt timestamp', () => {
+      const created = service.createPreferences({ userId: 'user-1' });
+      const createdTime = created.updatedAt.getTime();
+
+      // Small delay to ensure distinct timestamp
+      const updated = service.updatePreferences('user-1', {
+        email: { frequency: 'weekly' },
+      });
+
+      expect(updated.updatedAt.getTime()).toBeGreaterThanOrEqual(createdTime);
+    });
+  });
+
+  describe('deletePreferences', () => {
+    it('should delete existing preferences', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const result = service.deletePreferences('user-1');
+      expect(result).toBe(true);
+
+      const prefs = service.getPreferences('user-1');
+      expect(prefs).toBeUndefined();
+    });
+
+    it('should return false if no preferences exist', () => {
+      const result = service.deletePreferences('user-999');
+      expect(result).toBe(false);
+    });
+  });
+
+  describe('getOrCreatePreferences', () => {
+    it('should return existing preferences', () => {
+      service.createPreferences({
+        userId: 'user-1',
+        email: { frequency: 'daily' },
+      });
+
+      const prefs = service.getOrCreatePreferences('user-1');
+      expect(prefs.email.frequency).toBe('daily');
+    });
+
+    it('should create default preferences if none exist', () => {
+      const prefs = service.getOrCreatePreferences('user-1');
+
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('immediate');
+    });
+  });
+
+  describe('shouldSendNotification', () => {
+    it('should return true if no preferences are stored (opt-out model)', () => {
+      const result = service.shouldSendNotification(
+        'user-1',
+        'email',
+        'order_confirmation',
+      );
+      expect(result).toBe(true);
+    });
+
+    it('should return true when email is enabled and category is enabled', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const result = service.shouldSendNotification(
+        'user-1',
+        'email',
+        'order_confirmation',
+      );
+      expect(result).toBe(true);
+    });
+
+    it('should return false when email master switch is disabled', () => {
+      service.createPreferences({ userId: 'user-1' });
+      service.updatePreferences('user-1', { email: { enabled: false } });
+
