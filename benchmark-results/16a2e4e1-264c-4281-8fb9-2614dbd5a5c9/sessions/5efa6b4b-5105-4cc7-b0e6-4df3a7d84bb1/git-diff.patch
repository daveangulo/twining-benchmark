+ *
+ * Configuration is injected via constructor to support different
+ * environments (dev, staging, production).
+ */
+import { Logger } from '../utils/logger.js';
+/**
+ * Default configuration for development/testing.
+ */
+export const defaultWebhookConfig = {
+    url: 'https://localhost/webhook',
+    stubMode: true,
+    maxRetries: 3,
+    timeoutMs: 5000,
+};
+// ---------------------------------------------------------------------------
+// URL Validation
+// ---------------------------------------------------------------------------
+/**
+ * Validates a webhook URL format.
+ *
+ * Checks:
+ * - Is a non-empty string
+ * - Starts with http:// or https://
+ * - Can be parsed by the URL constructor
+ *
+ * @param url - The webhook URL to validate.
+ * @returns true if the URL format is valid.
+ */
+export function isValidWebhookUrl(url) {
+    if (!url || typeof url !== 'string') {
+        return false;
+    }
+    const trimmed = url.trim();
+    if (trimmed.length === 0) {
+        return false;
+    }
+    // Must start with http:// or https://
+    // Followed by a valid host (IP or hostname) and optional port/path/query
+    const urlRegex = /^https?:\/\/[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?(:\d+)?(\/[^\s]*)?$/;
+    return urlRegex.test(trimmed);
+}
+// ---------------------------------------------------------------------------
+// Webhook Payload Formatting
+// ---------------------------------------------------------------------------
+/**
+ * Formats a notification payload as a JSON webhook body.
+ *
+ * Creates a structured JSON object suitable for POSTing to a webhook
+ * endpoint. Includes all relevant notification fields plus a timestamp.
+ *
+ * @param payload - The notification payload to format.
+ * @returns A structured webhook payload body.
+ */
+export function formatWebhookPayload(payload) {
+    return {
+        notificationType: payload.type,
+        recipient: payload.recipient,
+        subject: payload.subject,
+        body: payload.body,
+        channel: 'webhook',
+        priority: payload.priority,
+        timestamp: new Date().toISOString(),
+        metadata: payload.metadata,
+    };
+}
+// ---------------------------------------------------------------------------
+// WebhookAdapter Implementation
+// ---------------------------------------------------------------------------
+/**
+ * Webhook notification adapter.
+ *
+ * Sends notifications via HTTP POST with JSON payloads. In stub mode
+ * (default), logs the webhook details and records them in memory instead
+ * of actually delivering.
+ *
+ * Pipeline:
+ * 1. Validate webhook URL configuration.
+ * 2. Format notification into a JSON webhook payload.
+ * 3. Deliver via stub (log + record) or production (HTTP POST).
+ * 4. Return success/failure result (never throws).
+ */
+export class WebhookAdapter {
+    channel = 'webhook';
+    logger = new Logger('WebhookAdapter');
+    config;
+    deliveries = [];
+    constructor(config) {
+        this.config = { ...defaultWebhookConfig, ...config };
+    }
+    /**
+     * Send a notification via webhook.
+     *
+     * Full pipeline:
+     * 1. Validates the webhook URL.
+     * 2. Formats the notification as a JSON payload.
+     * 3. Delivers via stub (records in memory) or production mode.
+     *
+     * @param payload - The notification payload to deliver via webhook.
+     * @returns Result indicating success or failure. Never throws.
+     */
+    async send(payload) {
+        const result = {
+            success: false,
+            notificationId: '',
+            channel: 'webhook',
+        };
+        try {
+            // Step 1: Validate webhook URL
+            if (!isValidWebhookUrl(this.config.url)) {
+                result.failureReason = `Invalid webhook URL: "${this.config.url}"`;
+                this.logger.warn(result.failureReason);
+                return result;
+            }
+            // Step 2: Format webhook payload
+            const webhookBody = formatWebhookPayload(payload);
+            // Step 3: Deliver
+            const record = {
+                url: this.config.url,
+                payload: webhookBody,
+                deliveredAt: new Date(),
+                notificationType: payload.type,
+            };
+            if (this.config.stubMode) {
+                // Stub mode: log and record instead of sending
+                this.logger.info(`[STUB] Webhook POST to ${this.config.url}: "${payload.subject}"`);
+                this.deliveries.push(record);
+            }
+            else {
+                // Production mode: attempt real delivery with retries
+                await this.deliverWithRetry(webhookBody);
