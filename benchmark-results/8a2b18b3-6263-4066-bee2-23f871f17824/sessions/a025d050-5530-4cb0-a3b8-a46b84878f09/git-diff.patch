diff --git a/src/notifications/webhook-handler.ts b/src/notifications/webhook-handler.ts
new file mode 100644
index 0000000..112e1cb
--- /dev/null
+++ b/src/notifications/webhook-handler.ts
@@ -0,0 +1,211 @@
+/**
+ * Webhook handler — dispatches HTTP callbacks to registered URLs
+ * when order lifecycle events occur.
+ *
+ * Follows the same EventBus subscription pattern as NotificationService
+ * and EmailNotificationHandler. Subscribes to order events and fires
+ * webhook deliveries to registered endpoint URLs.
+ *
+ * Depends on:
+ * - EventBus (event system) for receiving order lifecycle events
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type {
+  OrderCreatedEvent,
+  OrderStatusChangedEvent,
+  EventType,
+} from '../events/event-types.js';
+import { Logger } from '../utils/logger.js';
+
+export interface WebhookRegistration {
+  id: string;
+  url: string;
+  eventType: EventType;
+  createdAt: Date;
+}
+
+export interface WebhookDelivery {
+  id: string;
+  webhookId: string;
+  url: string;
+  eventType: EventType;
+  payload: Record<string, unknown>;
+  status: 'success' | 'failure';
+  statusCode: number | null;
+  deliveredAt: Date;
+}
+
+export type WebhookSender = (
+  url: string,
+  payload: Record<string, unknown>,
+) => Promise<{ success: boolean; statusCode: number | null }>;
+
+let nextWebhookId = 1;
+let nextDeliveryId = 1;
+
+function generateWebhookId(): string {
+  return `webhook-${String(nextWebhookId++).padStart(4, '0')}`;
+}
+
+function generateDeliveryId(): string {
+  return `delivery-${String(nextDeliveryId++).padStart(4, '0')}`;
+}
+
+export function resetWebhookIdCounters(): void {
+  nextWebhookId = 1;
+  nextDeliveryId = 1;
+}
+
+/**
+ * Default no-op sender. In production, replace with an HTTP client
+ * by passing a custom WebhookSender to the constructor.
+ */
+const defaultSender: WebhookSender = async () => {
+  return { success: false, statusCode: null };
+};
+
+export class WebhookHandler {
+  private logger = new Logger('WebhookHandler');
+  private registrations: WebhookRegistration[] = [];
+  private deliveries: WebhookDelivery[] = [];
+  private sender: WebhookSender;
+
+  constructor(
+    private eventBus: EventBus,
+    sender?: WebhookSender,
+  ) {
+    this.sender = sender ?? defaultSender;
+    this.registerHandlers();
+  }
+
+  /**
+   * Register event handlers for webhook triggers.
+   */
+  private registerHandlers(): void {
+    this.eventBus.on<OrderCreatedEvent>('order:created', (event) => {
+      return this.deliverWebhooks('order:created', {
+        eventType: event.type,
+        orderId: event.order.id,
+        userId: event.user.id,
+        items: event.order.items,
+        total: event.order.total,
+        status: event.order.status,
+        timestamp: event.timestamp.toISOString(),
+      });
+    });
+
+    this.eventBus.on<OrderStatusChangedEvent>('order:status-changed', (event) => {
+      return this.deliverWebhooks('order:status-changed', {
+        eventType: event.type,
+        orderId: event.order.id,
+        previousStatus: event.previousStatus,
+        newStatus: event.newStatus,
+        timestamp: event.timestamp.toISOString(),
+      });
+    });
+  }
+
+  /**
+   * Register a webhook URL to receive callbacks for a specific event type.
+   */
+  registerWebhook(url: string, eventType: EventType): WebhookRegistration {
+    const registration: WebhookRegistration = {
+      id: generateWebhookId(),
+      url,
+      eventType,
+      createdAt: new Date(),
+    };
+    this.registrations.push(registration);
+    this.logger.info(`Webhook registered: ${registration.id} -> ${url} for ${eventType}`);
+    return registration;
+  }
+
+  /**
+   * Unregister a webhook by ID.
+   */
+  unregisterWebhook(id: string): boolean {
+    const index = this.registrations.findIndex((r) => r.id === id);
+    if (index < 0) {
+      return false;
+    }
+    this.registrations.splice(index, 1);
+    this.logger.info(`Webhook unregistered: ${id}`);
+    return true;
+  }
+
+  /**
+   * Get all registered webhooks.
+   */
+  getRegistrations(): WebhookRegistration[] {
+    return [...this.registrations];
+  }
+
+  /**
+   * Get registrations for a specific event type.
+   */
+  getRegistrationsForEvent(eventType: EventType): WebhookRegistration[] {
+    return this.registrations.filter((r) => r.eventType === eventType);
+  }
+
+  /**
+   * Get all deliveries.
+   */
+  getDeliveries(): WebhookDelivery[] {
+    return [...this.deliveries];
+  }
+
+  /**
+   * Get deliveries for a specific webhook.
+   */
+  getDeliveriesForWebhook(webhookId: string): WebhookDelivery[] {
+    return this.deliveries.filter((d) => d.webhookId === webhookId);
+  }
+
+  /**
+   * Get the count of deliveries.
+   */
+  getDeliveryCount(): number {
+    return this.deliveries.length;
+  }
+
+  /**
+   * Clear all registrations and deliveries (useful for testing).
+   */
+  clearAll(): void {
+    this.registrations = [];
+    this.deliveries = [];
+  }
+
+  /**
+   * Deliver webhook payload to all registered URLs for the given event type.
+   */
+  private async deliverWebhooks(
+    eventType: EventType,
+    payload: Record<string, unknown>,
+  ): Promise<void> {
+    const targets = this.registrations.filter((r) => r.eventType === eventType);
+
+    for (const target of targets) {
+      this.logger.info(`Delivering webhook ${target.id} to ${target.url}`);
+
+      const result = await this.sender(target.url, payload);
+
+      const delivery: WebhookDelivery = {
+        id: generateDeliveryId(),
+        webhookId: target.id,
+        url: target.url,
+        eventType,
+        payload,
+        status: result.success ? 'success' : 'failure',
+        statusCode: result.statusCode,
+        deliveredAt: new Date(),
+      };
+      this.deliveries.push(delivery);
+
+      this.logger.info(
+        `Webhook delivery ${delivery.id}: ${delivery.status} (${delivery.statusCode ?? 'no response'})`,
+      );
+    }
+  }
+}
diff --git a/tests/notifications/webhook-handler.test.ts b/tests/notifications/webhook-handler.test.ts
new file mode 100644
index 0000000..9548a3b
--- /dev/null
+++ b/tests/notifications/webhook-handler.test.ts
@@ -0,0 +1,269 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  WebhookHandler,
+  resetWebhookIdCounters,
+} from '../../src/notifications/webhook-handler.js';
+import type { WebhookSender } from '../../src/notifications/webhook-handler.js';
+import type {
+  OrderCreatedEvent,
+  OrderStatusChangedEvent,
+} from '../../src/events/event-types.js';
+
+function mockSender(
+  success = true,
+  statusCode = 200,
+): WebhookSender & { calls: { url: string; payload: Record<string, unknown> }[] } {
+  const calls: { url: string; payload: Record<string, unknown> }[] = [];
+  const fn = async (url: string, payload: Record<string, unknown>) => {
+    calls.push({ url, payload });
+    return { success, statusCode };
+  };
+  fn.calls = calls;
+  return fn;
+}
+
+const makeOrderCreatedEvent = (): OrderCreatedEvent => ({
+  type: 'order:created',
+  order: {
+    id: 'order-1',
+    userId: 'user-1',
+    items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+    total: 20,
+    status: 'pending',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  },
+  user: {
+    id: 'user-1',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  },
+  timestamp: new Date(),
+});
+
+const makeStatusChangedEvent = (): OrderStatusChangedEvent => ({
+  type: 'order:status-changed',
+  order: {
+    id: 'order-1',
+    userId: 'user-1',
+    items: [],
+    total: 20,
+    status: 'confirmed',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+  },
+  previousStatus: 'pending',
+  newStatus: 'confirmed',
+  timestamp: new Date(),
+});
+
+describe('WebhookHandler', () => {
+  let eventBus: EventBus;
+  let sender: ReturnType<typeof mockSender>;
+  let handler: WebhookHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    sender = mockSender();
+    handler = new WebhookHandler(eventBus, sender);
+    resetWebhookIdCounters();
+  });
+
+  describe('webhook registration', () => {
+    it('should register a webhook and return the registration', () => {
+      const reg = handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      expect(reg.id).toBe('webhook-0001');
+      expect(reg.url).toBe('https://example.com/hook');
+      expect(reg.eventType).toBe('order:created');
+      expect(reg.createdAt).toBeInstanceOf(Date);
+    });
+
+    it('should generate sequential webhook IDs', () => {
+      const r1 = handler.registerWebhook('https://a.com', 'order:created');
+      const r2 = handler.registerWebhook('https://b.com', 'order:status-changed');
+
+      expect(r1.id).toBe('webhook-0001');
+      expect(r2.id).toBe('webhook-0002');
+    });
+
+    it('should list all registrations', () => {
+      handler.registerWebhook('https://a.com', 'order:created');
+      handler.registerWebhook('https://b.com', 'order:status-changed');
+
+      expect(handler.getRegistrations()).toHaveLength(2);
+    });
+
+    it('should filter registrations by event type', () => {
+      handler.registerWebhook('https://a.com', 'order:created');
+      handler.registerWebhook('https://b.com', 'order:status-changed');
+      handler.registerWebhook('https://c.com', 'order:created');
+
+      expect(handler.getRegistrationsForEvent('order:created')).toHaveLength(2);
+      expect(handler.getRegistrationsForEvent('order:status-changed')).toHaveLength(1);
+    });
+
+    it('should unregister a webhook by ID', () => {
+      const reg = handler.registerWebhook('https://a.com', 'order:created');
+
+      expect(handler.unregisterWebhook(reg.id)).toBe(true);
+      expect(handler.getRegistrations()).toHaveLength(0);
+    });
+
+    it('should return false when unregistering a non-existent webhook', () => {
+      expect(handler.unregisterWebhook('webhook-9999')).toBe(false);
+    });
+  });
+
+  describe('order:created delivery', () => {
+    it('should deliver webhook to registered URL on order created', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(sender.calls).toHaveLength(1);
+      expect(sender.calls[0]?.url).toBe('https://example.com/hook');
+    });
+
+    it('should include order details in payload', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const payload = sender.calls[0]!.payload;
+      expect(payload.eventType).toBe('order:created');
+      expect(payload.orderId).toBe('order-1');
+      expect(payload.userId).toBe('user-1');
+      expect(payload.total).toBe(20);
+      expect(payload.status).toBe('pending');
+    });
+
+    it('should not fire for unregistered event types', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(sender.calls).toHaveLength(0);
+    });
+
+    it('should deliver to multiple registered URLs', async () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(sender.calls).toHaveLength(2);
+      expect(sender.calls[0]?.url).toBe('https://a.com/hook');
+      expect(sender.calls[1]?.url).toBe('https://b.com/hook');
+    });
+  });
+
+  describe('order:status-changed delivery', () => {
+    it('should deliver webhook on status change', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed');
+
+      await eventBus.emit(makeStatusChangedEvent());
+
+      expect(sender.calls).toHaveLength(1);
+      const payload = sender.calls[0]!.payload;
+      expect(payload.eventType).toBe('order:status-changed');
+      expect(payload.orderId).toBe('order-1');
+      expect(payload.previousStatus).toBe('pending');
+      expect(payload.newStatus).toBe('confirmed');
+    });
+  });
+
+  describe('delivery tracking', () => {
+    it('should record successful deliveries', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.id).toBe('delivery-0001');
+      expect(deliveries[0]?.status).toBe('success');
+      expect(deliveries[0]?.statusCode).toBe(200);
+    });
+
+    it('should record failed deliveries', async () => {
+      const failSender = mockSender(false, 500);
+      const failHandler = new WebhookHandler(eventBus, failSender);
+      failHandler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = failHandler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.status).toBe('failure');
+      expect(deliveries[0]?.statusCode).toBe(500);
+    });
+
+    it('should record null statusCode on network error', async () => {
+      const errorSender = mockSender(false, null as unknown as number);
+      const errorHandler = new WebhookHandler(eventBus, errorSender);
+      errorHandler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = errorHandler.getDeliveries();
+      expect(deliveries[0]?.statusCode).toBeNull();
+    });
+
+    it('should generate sequential delivery IDs', async () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries[0]?.id).toBe('delivery-0001');
+      expect(deliveries[1]?.id).toBe('delivery-0002');
+    });
+
+    it('should filter deliveries by webhook ID', async () => {
+      const reg1 = handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(handler.getDeliveriesForWebhook(reg1.id)).toHaveLength(1);
+    });
+
+    it('should count deliveries', async () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+
+      expect(handler.getDeliveryCount()).toBe(0);
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(handler.getDeliveryCount()).toBe(1);
+    });
+  });
+
+  describe('cleanup', () => {
+    it('should clear all registrations and deliveries', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      handler.clearAll();
+
+      expect(handler.getRegistrations()).toHaveLength(0);
+      expect(handler.getDeliveries()).toHaveLength(0);
+    });
+
+    it('should not deliver to unregistered webhooks', async () => {
+      const reg = handler.registerWebhook('https://example.com/hook', 'order:created');
+      handler.unregisterWebhook(reg.id);
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(sender.calls).toHaveLength(0);
+      expect(handler.getDeliveryCount()).toBe(0);
+    });
+  });
+});
