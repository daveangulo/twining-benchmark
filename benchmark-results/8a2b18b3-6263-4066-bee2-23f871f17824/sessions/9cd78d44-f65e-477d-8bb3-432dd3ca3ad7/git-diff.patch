+++ b/src/notifications/email-handler.ts
@@ -0,0 +1,184 @@
+/**
+ * Email notification handler for order lifecycle events.
+ *
+ * Subscribes to order events via EventBus and formats email-specific
+ * notifications with rich content (HTML-like templates, status-specific
+ * messaging). Integrates with the existing NotificationService by
+ * following the same EventBus subscription pattern.
+ *
+ * Depends on:
+ * - EventBus (event system) for receiving order events
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../events/event-types.js';
+import type { OrderStatus } from '../models/order.js';
+import { Logger } from '../utils/logger.js';
+
+export interface EmailMessage {
+  to: string;
+  subject: string;
+  htmlBody: string;
+  textBody: string;
+  sentAt: Date;
+}
+
+const STATUS_LABELS: Record<OrderStatus, string> = {
+  pending: 'Pending',
+  confirmed: 'Confirmed',
+  shipped: 'Shipped',
+  delivered: 'Delivered',
+  cancelled: 'Cancelled',
+};
+
+const STATUS_DESCRIPTIONS: Record<OrderStatus, string> = {
+  pending: 'Your order has been received and is awaiting confirmation.',
+  confirmed: 'Your order has been confirmed and is being prepared.',
+  shipped: 'Your order has been shipped and is on its way.',
+  delivered: 'Your order has been delivered. Thank you for your purchase!',
+  cancelled: 'Your order has been cancelled.',
+};
+
+export class EmailNotificationHandler {
+  private logger = new Logger('EmailNotificationHandler');
+  private sentEmails: EmailMessage[] = [];
+
+  constructor(private eventBus: EventBus) {
+    this.registerHandlers();
+  }
+
+  /**
+   * Register event handlers via EventBus — same pattern as NotificationService.
+   */
+  private registerHandlers(): void {
+    this.eventBus.on<OrderCreatedEvent>('order:created', (event) => {
+      this.handleOrderCreated(event);
+    });
+
+    this.eventBus.on<OrderStatusChangedEvent>('order:status-changed', (event) => {
+      this.handleOrderStatusChanged(event);
+    });
+  }
+
+  /**
+   * Handle order created — send a confirmation email with order details.
+   */
+  private handleOrderCreated(event: OrderCreatedEvent): void {
+    this.logger.info(`Sending order confirmation email for ${event.order.id}`);
+
+    const itemRows = event.order.items
+      .map(
+        (item) =>
+          `<tr><td>${item.name}</td><td>${item.quantity}</td><td>$${item.unitPrice.toFixed(2)}</td><td>$${(item.quantity * item.unitPrice).toFixed(2)}</td></tr>`,
+      )
+      .join('');
+
+    const itemList = event.order.items
+      .map((item) => `- ${item.name} x${item.quantity} @ $${item.unitPrice.toFixed(2)}`)
+      .join('\n');
+
+    const htmlBody = `<h1>Order Confirmation</h1>
+<p>Hi ${event.user.name},</p>
+<p>Thank you for your order! Here are the details:</p>
+<p><strong>Order ID:</strong> ${event.order.id}</p>
+<table>
+<tr><th>Item</th><th>Qty</th><th>Price</th><th>Subtotal</th></tr>
+${itemRows}
+</table>
+<p><strong>Total: $${event.order.total.toFixed(2)}</strong></p>
+<p>${STATUS_DESCRIPTIONS.pending}</p>`;
+
+    const textBody = `Order Confirmation
+
+Hi ${event.user.name},
+
+Thank you for your order! Here are the details:
+
+Order ID: ${event.order.id}
+${itemList}
+
+Total: $${event.order.total.toFixed(2)}
+
+${STATUS_DESCRIPTIONS.pending}`;
+
+    this.sendEmail({
+      to: event.user.email,
+      subject: `Order Confirmation - ${event.order.id}`,
+      htmlBody,
+      textBody,
+    });
+  }
+
+  /**
+   * Handle order status change — send a status update email.
+   */
+  private handleOrderStatusChanged(event: OrderStatusChangedEvent): void {
+    const newStatus = event.newStatus as OrderStatus;
+    this.logger.info(
+      `Sending status update email for ${event.order.id}: ${event.previousStatus} -> ${newStatus}`,
+    );
+
+    const statusLabel = STATUS_LABELS[newStatus] ?? newStatus;
+    const statusDescription = STATUS_DESCRIPTIONS[newStatus] ?? '';
+
+    const htmlBody = `<h1>Order Status Update</h1>
+<p>Your order <strong>${event.order.id}</strong> has been updated.</p>
+<p><strong>New Status:</strong> ${statusLabel}</p>
+<p>${statusDescription}</p>`;
+
+    const textBody = `Order Status Update
+
+Your order ${event.order.id} has been updated.
+
+New Status: ${statusLabel}
+
+${statusDescription}`;
+
+    this.sendEmail({
+      to: event.order.userId,
+      subject: `Order ${statusLabel} - ${event.order.id}`,
+      htmlBody,
+      textBody,
+    });
+  }
+
+  /**
+   * Send an email (in-memory for this demo, would integrate with SMTP/API in production).
+   */
+  private sendEmail(params: Omit<EmailMessage, 'sentAt'>): void {
+    const email: EmailMessage = {
+      ...params,
+      sentAt: new Date(),
+    };
+    this.sentEmails.push(email);
+    this.logger.info(`Email sent to ${params.to}: ${params.subject}`);
+  }
+
+  /**
+   * Get all sent emails.
+   */
+  getSentEmails(): EmailMessage[] {
+    return [...this.sentEmails];
+  }
+
+  /**
+   * Get sent emails for a specific recipient.
+   */
+  getEmailsForRecipient(recipient: string): EmailMessage[] {
+    return this.sentEmails.filter((e) => e.to === recipient);
+  }
+
+  /**
+   * Get the count of sent emails.
+   */
+  getEmailCount(): number {
+    return this.sentEmails.length;
+  }
+
+  /**
+   * Clear all sent emails (useful for testing).
+   */
+  clearEmails(): void {
+    this.sentEmails = [];
+  }
+}
diff --git a/tests/notifications/email-handler.test.ts b/tests/notifications/email-handler.test.ts
new file mode 100644
index 0000000..ff8f187
--- /dev/null
+++ b/tests/notifications/email-handler.test.ts
@@ -0,0 +1,232 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { EmailNotificationHandler } from '../../src/notifications/email-handler.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+function makeOrderCreatedEvent(overrides?: Partial<OrderCreatedEvent>): OrderCreatedEvent {
+  return {
+    type: 'order:created',
+    order: {
+      id: 'order-0001',
+      userId: 'user-0001',
+      items: [
+        { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+      ],
+      total: 20,
+      status: 'pending',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    user: {
+      id: 'user-0001',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    timestamp: new Date(),
+    ...overrides,
+  };
+}
+
+function makeStatusChangedEvent(
+  previousStatus: string,
+  newStatus: string,
+): OrderStatusChangedEvent {
+  return {
+    type: 'order:status-changed',
+    order: {
+      id: 'order-0001',
+      userId: 'user-0001',
+      items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+      total: 20,
+      status: newStatus as 'confirmed',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    previousStatus,
+    newStatus,
+    timestamp: new Date(),
+  };
+}
+
+describe('EmailNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: EmailNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    handler = new EmailNotificationHandler(eventBus);
+  });
+
+  describe('order:created emails', () => {
+    it('should send a confirmation email when an order is created', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('alice@example.com');
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[0]?.subject).toContain('order-0001');
+    });
+
+    it('should include item details in the HTML body', async () => {
+      const event = makeOrderCreatedEvent({
+        order: {
+          id: 'order-0001',
+          userId: 'user-0001',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+      });
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Widget');
+      expect(email.htmlBody).toContain('Gadget');
+      expect(email.htmlBody).toContain('$45.00');
+    });
+
+    it('should include item details in the text body', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.textBody).toContain('Widget x2');
+      expect(email.textBody).toContain('$20.00');
+      expect(email.textBody).toContain('Hi Alice');
+    });
+
+    it('should include the user name in the email', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Hi Alice');
+    });
+  });
+
+  describe('order:status-changed emails', () => {
+    it('should send an email when order status changes to confirmed', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Confirmed');
+      expect(emails[0]?.subject).toContain('order-0001');
+      expect(emails[0]?.htmlBody).toContain('confirmed and is being prepared');
+    });
+
+    it('should send an email when order status changes to shipped', async () => {
+      await eventBus.emit(makeStatusChangedEvent('confirmed', 'shipped'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Shipped');
+      expect(email.htmlBody).toContain('shipped and is on its way');
+    });
+
+    it('should send an email when order status changes to delivered', async () => {
+      await eventBus.emit(makeStatusChangedEvent('shipped', 'delivered'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Delivered');
+      expect(email.htmlBody).toContain('delivered');
+      expect(email.textBody).toContain('Thank you for your purchase');
+    });
+
+    it('should send an email when order is cancelled', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'cancelled'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Cancelled');
+      expect(email.htmlBody).toContain('cancelled');
+    });
+
+    it('should send email to the order userId', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      expect(handler.getSentEmails()[0]?.to).toBe('user-0001');
+    });
+  });
+
+  describe('email management', () => {
+    it('should count emails', async () => {
+      expect(handler.getEmailCount()).toBe(0);
+
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+      expect(handler.getEmailCount()).toBe(1);
+
+      await eventBus.emit(makeStatusChangedEvent('confirmed', 'shipped'));
+      expect(handler.getEmailCount()).toBe(2);
+    });
+
+    it('should filter emails by recipient', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(handler.getEmailsForRecipient('alice@example.com')).toHaveLength(1);
+      expect(handler.getEmailsForRecipient('bob@example.com')).toHaveLength(0);
+    });
+
+    it('should clear emails', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+      expect(handler.getEmailCount()).toBe(1);
+
+      handler.clearEmails();
+      expect(handler.getEmailCount()).toBe(0);
+    });
+  });
+
+  describe('integration with NotificationService', () => {
+    it('should work alongside NotificationService on the same EventBus', async () => {
+      // Both handlers subscribe to the same EventBus
+      const { NotificationService } = await import(
+        '../../src/services/notification.service.js'
+      );
+      const notificationService = new NotificationService(eventBus);
+
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      // Both services should have processed the event
+      expect(handler.getEmailCount()).toBe(1);
+      expect(notificationService.getNotificationCount()).toBe(1);
+    });
+
+    it('should handle multiple status transitions in sequence', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+      await eventBus.emit(makeStatusChangedEvent('confirmed', 'shipped'));
+      await eventBus.emit(makeStatusChangedEvent('shipped', 'delivered'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(3);
+      expect(emails[0]?.subject).toContain('Confirmed');
+      expect(emails[1]?.subject).toContain('Shipped');
+      expect(emails[2]?.subject).toContain('Delivered');
+    });
+  });
+
+  describe('email content format', () => {
+    it('should include both HTML and text body', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('<h1>');
+      expect(email.textBody).not.toContain('<h1>');
+    });
+
+    it('should record sentAt timestamp', async () => {
+      const before = new Date();
+      await eventBus.emit(makeOrderCreatedEvent());
+      const after = new Date();
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.sentAt.getTime()).toBeGreaterThanOrEqual(before.getTime());
+      expect(email.sentAt.getTime()).toBeLessThanOrEqual(after.getTime());
+    });
+  });
+});
