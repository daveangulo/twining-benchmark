+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { EmailNotificationHandler } from '../../src/notifications/email.handler.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('EmailNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: EmailNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    handler = new EmailNotificationHandler(eventBus);
+  });
+
+  describe('order:created email', () => {
+    it('should send confirmation email on order created', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('alice@example.com');
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[0]?.subject).toContain('order-1');
+    });
+
+    it('should include item details in html body', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Widget');
+      expect(email.htmlBody).toContain('Gadget');
+      expect(email.htmlBody).toContain('$45.00');
+      expect(email.htmlBody).toContain('Alice');
+    });
+
+    it('should include item details in text body', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.textBody).toContain('Widget x2');
+      expect(email.textBody).toContain('$20.00');
+      expect(email.textBody).toContain('Alice');
+    });
+  });
+
+  describe('order:status-changed email', () => {
+    const makeStatusEvent = (
+      previousStatus: string,
+      newStatus: string,
+    ): OrderStatusChangedEvent => ({
+      type: 'order:status-changed',
+      order: {
+        id: 'order-1',
+        userId: 'user-1',
+        items: [],
+        total: 20,
+        status: newStatus as 'confirmed',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      previousStatus,
+      newStatus,
+      timestamp: new Date(),
+    });
+
+    it('should send email on status change', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('user-1');
+      expect(emails[0]?.subject).toContain('Confirmed');
+      expect(emails[0]?.subject).toContain('order-1');
+    });
+
+    it('should include status labels in email body', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'confirmed'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Pending');
+      expect(email.htmlBody).toContain('Confirmed');
+      expect(email.textBody).toContain('Pending');
+      expect(email.textBody).toContain('Confirmed');
+    });
+
+    it('should include friendly message for shipped status', async () => {
+      await eventBus.emit(makeStatusEvent('confirmed', 'shipped'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.textBody).toContain('on its way');
+      expect(email.subject).toContain('Shipped');
+    });
+
+    it('should include friendly message for delivered status', async () => {
+      await eventBus.emit(makeStatusEvent('shipped', 'delivered'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.textBody).toContain('delivered');
+      expect(email.textBody).toContain('Enjoy');
+    });
+
+    it('should include friendly message for cancelled status', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'cancelled'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.textBody).toContain('cancelled');
+      expect(email.subject).toContain('Cancelled');
+    });
+  });
+
+  describe('email management', () => {
+    it('should count sent emails', async () => {
+      expect(handler.getSentEmailCount()).toBe(0);
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getSentEmailCount()).toBe(1);
+    });
+
+    it('should filter emails by recipient', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+          ],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      expect(handler.getEmailsForRecipient('alice@example.com')).toHaveLength(1);
+      expect(handler.getEmailsForRecipient('bob@example.com')).toHaveLength(0);
+    });
+
+    it('should clear sent emails', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      handler.clearSentEmails();
+      expect(handler.getSentEmailCount()).toBe(0);
+    });
+
+    it('should work alongside NotificationService on same EventBus', async () => {
+      // Both handlers can subscribe to the same EventBus
+      const { NotificationService, resetNotificationIdCounter } = await import(
+        '../../src/services/notification.service.js'
+      );
+      resetNotificationIdCounter();
+      const notificationService = new NotificationService(eventBus);
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      // Both handlers should have received the event
+      expect(handler.getSentEmailCount()).toBe(1);
+      expect(notificationService.getNotificationCount()).toBe(1);
+    });
+  });
+});
