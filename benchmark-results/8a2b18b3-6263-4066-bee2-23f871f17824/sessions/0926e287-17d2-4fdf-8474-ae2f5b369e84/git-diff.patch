+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { EmailNotificationHandler } from '../../src/notifications/email-handler.js';
+import { statusChangeCallbacks } from '../../src/utils/callback-registry.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('EmailNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: EmailNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    statusChangeCallbacks.clear();
+    handler = new EmailNotificationHandler(eventBus);
+  });
+
+  describe('order:created email', () => {
+    it('should send confirmation email on order created', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('alice@example.com');
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[0]?.subject).toContain('order-1');
+    });
+
+    it('should include HTML and text versions', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      // HTML body should contain HTML tags and item details
+      expect(email.htmlBody).toContain('<h1>Order Confirmation</h1>');
+      expect(email.htmlBody).toContain('Widget');
+      expect(email.htmlBody).toContain('$20.00');
+      // Text body should contain plain text version
+      expect(email.textBody).toContain('Order Confirmation');
+      expect(email.textBody).toContain('Widget x2');
+      expect(email.textBody).toContain('$20.00');
+    });
+
+    it('should include user name in email body', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 5 },
+          ],
+          total: 5,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Bob',
+          email: 'bob@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Hi Bob');
+      expect(email.textBody).toContain('Hi Bob');
+    });
+
+    it('should include all items in confirmation email', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.textBody).toContain('Widget x2');
+      expect(email.textBody).toContain('Gadget x1');
+      expect(email.htmlBody).toContain('Widget');
+      expect(email.htmlBody).toContain('Gadget');
+    });
+  });
+
+  describe('order:status-changed email', () => {
+    it('should send status update email on status change', () => {
+      const event: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      statusChangeCallbacks.notify(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('user-1');
+      expect(emails[0]?.subject).toContain('order-1');
+      expect(emails[0]?.subject).toContain('Confirmed');
+    });
+
+    it('should include previous and new status in email body', () => {
+      const event: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'shipped',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      };
+
+      statusChangeCallbacks.notify(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Confirmed');
+      expect(email.htmlBody).toContain('Shipped');
+      expect(email.textBody).toContain('Confirmed');
+      expect(email.textBody).toContain('Shipped');
+    });
+
+    it('should handle delivered status', () => {
+      const event: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-2',
+          userId: 'user-2',
+          items: [],
+          total: 50,
+          status: 'delivered',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'shipped',
+        newStatus: 'delivered',
+        timestamp: new Date(),
+      };
+
+      statusChangeCallbacks.notify(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Delivered');
+      expect(email.textBody).toContain('Shipped');
+      expect(email.textBody).toContain('Delivered');
+    });
+
+    it('should handle cancelled status', () => {
+      const event: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-3',
+          userId: 'user-3',
+          items: [],
+          total: 30,
+          status: 'cancelled',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'cancelled',
+        timestamp: new Date(),
+      };
+
+      statusChangeCallbacks.notify(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Cancelled');
+    });
+  });
+
+  describe('email management', () => {
+    it('should count sent emails', () => {
+      expect(handler.getEmailCount()).toBe(0);
+
+      statusChangeCallbacks.notify({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getEmailCount()).toBe(1);
+    });
+
+    it('should filter emails by recipient', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+          ],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      expect(handler.getEmailsForRecipient('alice@example.com')).toHaveLength(1);
+      expect(handler.getEmailsForRecipient('bob@example.com')).toHaveLength(0);
+    });
+
+    it('should clear emails', () => {
+      statusChangeCallbacks.notify({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getEmailCount()).toBe(1);
+      handler.clearEmails();
+      expect(handler.getEmailCount()).toBe(0);
+    });
+  });
+});
