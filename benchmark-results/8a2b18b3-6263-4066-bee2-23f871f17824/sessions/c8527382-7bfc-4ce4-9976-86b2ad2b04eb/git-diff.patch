diff --git a/src/notifications/webhook-notification.handler.ts b/src/notifications/webhook-notification.handler.ts
new file mode 100644
index 0000000..3f2adcf
--- /dev/null
+++ b/src/notifications/webhook-notification.handler.ts
@@ -0,0 +1,211 @@
+/**
+ * Webhook notification handler — fires HTTP callbacks to registered URLs
+ * in response to order lifecycle events.
+ *
+ * Follows the same event-driven pattern as NotificationService and
+ * EmailNotificationHandler: subscribes to EventBus events and handles
+ * them independently, with no direct coupling to producing services.
+ *
+ * Depends on:
+ * - EventBus (event system) for receiving order lifecycle events
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type { EventType } from '../events/event-types.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../events/event-types.js';
+import { Logger } from '../utils/logger.js';
+
+export interface WebhookRegistration {
+  id: string;
+  url: string;
+  eventType: EventType;
+  createdAt: Date;
+}
+
+export interface WebhookDelivery {
+  id: string;
+  webhookId: string;
+  url: string;
+  eventType: EventType;
+  payload: Record<string, unknown>;
+  status: 'success' | 'failure';
+  deliveredAt: Date;
+}
+
+export type WebhookSender = (url: string, payload: Record<string, unknown>) => Promise<boolean>;
+
+let nextWebhookId = 1;
+let nextDeliveryId = 1;
+
+function generateWebhookId(): string {
+  return `webhook-${String(nextWebhookId++).padStart(4, '0')}`;
+}
+
+function generateDeliveryId(): string {
+  return `delivery-${String(nextDeliveryId++).padStart(4, '0')}`;
+}
+
+export function resetWebhookIdCounters(): void {
+  nextWebhookId = 1;
+  nextDeliveryId = 1;
+}
+
+export class WebhookNotificationHandler {
+  private logger = new Logger('WebhookNotificationHandler');
+  private registrations: WebhookRegistration[] = [];
+  private deliveries: WebhookDelivery[] = [];
+  private sender: WebhookSender;
+
+  constructor(
+    private eventBus: EventBus,
+    sender?: WebhookSender,
+  ) {
+    // Default sender simulates a successful HTTP POST.
+    // In production, this would use fetch() or an HTTP client.
+    this.sender = sender ?? (async () => true);
+    this.registerHandlers();
+  }
+
+  /**
+   * Register event handlers for webhook triggers.
+   * All events are received via EventBus subscriptions.
+   */
+  private registerHandlers(): void {
+    this.eventBus.on<OrderCreatedEvent>('order:created', (event) => {
+      return this.handleEvent('order:created', {
+        eventType: 'order:created',
+        orderId: event.order.id,
+        userId: event.order.userId,
+        items: event.order.items,
+        total: event.order.total,
+        status: event.order.status,
+        timestamp: event.timestamp.toISOString(),
+      });
+    });
+
+    this.eventBus.on<OrderStatusChangedEvent>('order:status-changed', (event) => {
+      return this.handleEvent('order:status-changed', {
+        eventType: 'order:status-changed',
+        orderId: event.order.id,
+        userId: event.order.userId,
+        previousStatus: event.previousStatus,
+        newStatus: event.newStatus,
+        timestamp: event.timestamp.toISOString(),
+      });
+    });
+  }
+
+  /**
+   * Dispatch webhook deliveries to all URLs registered for the given event type.
+   */
+  private async handleEvent(
+    eventType: EventType,
+    payload: Record<string, unknown>,
+  ): Promise<void> {
+    const matchingRegistrations = this.registrations.filter(
+      (r) => r.eventType === eventType,
+    );
+
+    for (const registration of matchingRegistrations) {
+      this.logger.info(
+        `Delivering webhook ${registration.id} to ${registration.url} for ${eventType}`,
+      );
+
+      let status: 'success' | 'failure';
+      try {
+        const ok = await this.sender(registration.url, payload);
+        status = ok ? 'success' : 'failure';
+      } catch {
+        status = 'failure';
+      }
+
+      const delivery: WebhookDelivery = {
+        id: generateDeliveryId(),
+        webhookId: registration.id,
+        url: registration.url,
+        eventType,
+        payload,
+        status,
+        deliveredAt: new Date(),
+      };
+      this.deliveries.push(delivery);
+
+      this.logger.info(
+        `Webhook delivery ${delivery.id}: ${status} for ${registration.url}`,
+      );
+    }
+  }
+
+  /**
+   * Register a URL to receive callbacks for a specific event type.
+   */
+  registerWebhook(url: string, eventType: EventType): WebhookRegistration {
+    const registration: WebhookRegistration = {
+      id: generateWebhookId(),
+      url,
+      eventType,
+      createdAt: new Date(),
+    };
+    this.registrations.push(registration);
+    this.logger.info(
+      `Registered webhook ${registration.id}: ${url} for ${eventType}`,
+    );
+    return registration;
+  }
+
+  /**
+   * Unregister a webhook by ID.
+   */
+  unregisterWebhook(id: string): boolean {
+    const index = this.registrations.findIndex((r) => r.id === id);
+    if (index >= 0) {
+      this.registrations.splice(index, 1);
+      this.logger.info(`Unregistered webhook ${id}`);
+      return true;
+    }
+    return false;
+  }
+
+  /**
+   * Get all registered webhooks.
+   */
+  getRegistrations(): WebhookRegistration[] {
+    return [...this.registrations];
+  }
+
+  /**
+   * Get registrations for a specific event type.
+   */
+  getRegistrationsForEvent(eventType: EventType): WebhookRegistration[] {
+    return this.registrations.filter((r) => r.eventType === eventType);
+  }
+
+  /**
+   * Get all webhook deliveries.
+   */
+  getDeliveries(): WebhookDelivery[] {
+    return [...this.deliveries];
+  }
+
+  /**
+   * Get deliveries for a specific webhook registration.
+   */
+  getDeliveriesForWebhook(webhookId: string): WebhookDelivery[] {
+    return this.deliveries.filter((d) => d.webhookId === webhookId);
+  }
+
+  /**
+   * Get the count of deliveries.
+   */
+  getDeliveryCount(): number {
+    return this.deliveries.length;
+  }
+
+  /**
+   * Clear all registrations and deliveries (useful for testing).
+   */
+  clearAll(): void {
+    this.registrations = [];
+    this.deliveries = [];
+  }
+}
diff --git a/tests/notifications/webhook-notification.handler.test.ts b/tests/notifications/webhook-notification.handler.test.ts
new file mode 100644
index 0000000..4a9d529
--- /dev/null
+++ b/tests/notifications/webhook-notification.handler.test.ts
@@ -0,0 +1,277 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  WebhookNotificationHandler,
+  resetWebhookIdCounters,
+} from '../../src/notifications/webhook-notification.handler.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('WebhookNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: WebhookNotificationHandler;
+  let sender: ReturnType<typeof vi.fn>;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    sender = vi.fn().mockResolvedValue(true);
+    handler = new WebhookNotificationHandler(eventBus, sender);
+    resetWebhookIdCounters();
+  });
+
+  const makeOrderCreatedEvent = (overrides?: Partial<OrderCreatedEvent>): OrderCreatedEvent => ({
+    type: 'order:created',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+      total: 20,
+      status: 'pending',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    user: {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    timestamp: new Date('2024-01-01T00:00:00Z'),
+    ...overrides,
+  });
+
+  const makeStatusChangedEvent = (
+    previousStatus: string,
+    newStatus: string,
+  ): OrderStatusChangedEvent => ({
+    type: 'order:status-changed',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [],
+      total: 20,
+      status: newStatus as OrderStatusChangedEvent['order']['status'],
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    previousStatus,
+    newStatus,
+    timestamp: new Date('2024-01-01T00:00:00Z'),
+  });
+
+  describe('webhook registration', () => {
+    it('should register a webhook and return the registration', () => {
+      const reg = handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      expect(reg.id).toBe('webhook-0001');
+      expect(reg.url).toBe('https://example.com/hook');
+      expect(reg.eventType).toBe('order:created');
+      expect(reg.createdAt).toBeInstanceOf(Date);
+    });
+
+    it('should generate sequential webhook IDs', () => {
+      const reg1 = handler.registerWebhook('https://a.com/hook', 'order:created');
+      const reg2 = handler.registerWebhook('https://b.com/hook', 'order:status-changed');
+
+      expect(reg1.id).toBe('webhook-0001');
+      expect(reg2.id).toBe('webhook-0002');
+    });
+
+    it('should list all registrations', () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:status-changed');
+
+      expect(handler.getRegistrations()).toHaveLength(2);
+    });
+
+    it('should filter registrations by event type', () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:status-changed');
+      handler.registerWebhook('https://c.com/hook', 'order:created');
+
+      expect(handler.getRegistrationsForEvent('order:created')).toHaveLength(2);
+      expect(handler.getRegistrationsForEvent('order:status-changed')).toHaveLength(1);
+    });
+
+    it('should unregister a webhook by ID', () => {
+      const reg = handler.registerWebhook('https://a.com/hook', 'order:created');
+      expect(handler.unregisterWebhook(reg.id)).toBe(true);
+      expect(handler.getRegistrations()).toHaveLength(0);
+    });
+
+    it('should return false when unregistering a non-existent webhook', () => {
+      expect(handler.unregisterWebhook('webhook-9999')).toBe(false);
+    });
+  });
+
+  describe('order:created webhook delivery', () => {
+    it('should deliver to registered webhooks on order created', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(sender).toHaveBeenCalledOnce();
+      expect(sender).toHaveBeenCalledWith(
+        'https://example.com/hook',
+        expect.objectContaining({
+          eventType: 'order:created',
+          orderId: 'order-1',
+          userId: 'user-1',
+          total: 20,
+          status: 'pending',
+        }),
+      );
+    });
+
+    it('should include items in the payload', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const payload = sender.mock.calls[0]![1] as Record<string, unknown>;
+      expect(payload.items).toEqual([
+        { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+      ]);
+    });
+
+    it('should record successful delivery', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.status).toBe('success');
+      expect(deliveries[0]?.url).toBe('https://example.com/hook');
+      expect(deliveries[0]?.eventType).toBe('order:created');
+    });
+
+    it('should not deliver to webhooks registered for other event types', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(sender).not.toHaveBeenCalled();
+      expect(handler.getDeliveryCount()).toBe(0);
+    });
+
+    it('should deliver to multiple registered webhooks', async () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(sender).toHaveBeenCalledTimes(2);
+      expect(handler.getDeliveryCount()).toBe(2);
+    });
+  });
+
+  describe('order:status-changed webhook delivery', () => {
+    it('should deliver to registered webhooks on status change', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed');
+
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      expect(sender).toHaveBeenCalledWith(
+        'https://example.com/hook',
+        expect.objectContaining({
+          eventType: 'order:status-changed',
+          orderId: 'order-1',
+          previousStatus: 'pending',
+          newStatus: 'confirmed',
+        }),
+      );
+    });
+
+    it('should record delivery for status change', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed');
+
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.eventType).toBe('order:status-changed');
+    });
+  });
+
+  describe('delivery failure handling', () => {
+    it('should record failure when sender returns false', async () => {
+      sender.mockResolvedValue(false);
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.status).toBe('failure');
+    });
+
+    it('should record failure when sender throws', async () => {
+      sender.mockRejectedValue(new Error('Network error'));
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.status).toBe('failure');
+    });
+  });
+
+  describe('delivery management', () => {
+    it('should generate sequential delivery IDs', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries[0]?.id).toBe('delivery-0001');
+      expect(deliveries[1]?.id).toBe('delivery-0002');
+    });
+
+    it('should filter deliveries by webhook ID', async () => {
+      const reg1 = handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:created');
+
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(handler.getDeliveriesForWebhook(reg1.id)).toHaveLength(1);
+      expect(handler.getDeliveriesForWebhook(reg1.id)[0]?.url).toBe('https://a.com/hook');
+    });
+
+    it('should clear all registrations and deliveries', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      handler.clearAll();
+
+      expect(handler.getRegistrations()).toHaveLength(0);
+      expect(handler.getDeliveryCount()).toBe(0);
+    });
+  });
+
+  describe('coexistence with other handlers', () => {
+    it('should work alongside NotificationService on the same EventBus', async () => {
+      const { NotificationService, resetNotificationIdCounter } = await import(
+        '../../src/services/notification.service.js'
+      );
+      resetNotificationIdCounter();
+
+      const sharedBus = new EventBus();
+      const notificationService = new NotificationService(sharedBus);
+      const sharedSender = vi.fn().mockResolvedValue(true);
+      const webhookHandler = new WebhookNotificationHandler(sharedBus, sharedSender);
+      resetWebhookIdCounters();
+
+      webhookHandler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await sharedBus.emit<OrderCreatedEvent>(makeOrderCreatedEvent());
+
+      expect(notificationService.getNotificationCount()).toBe(1);
+      expect(webhookHandler.getDeliveryCount()).toBe(1);
+      expect(sharedSender).toHaveBeenCalledOnce();
+    });
+  });
+});
