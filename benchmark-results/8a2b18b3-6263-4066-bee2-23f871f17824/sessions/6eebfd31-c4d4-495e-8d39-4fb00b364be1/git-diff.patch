+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import {
+  EmailNotificationHandler,
+  resetEmailIdCounter,
+} from '../../src/notifications/email-handler.js';
+import { statusChangeCallbacks } from '../../src/utils/callback-registry.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+function makeStatusChangedEvent(
+  overrides: Partial<OrderStatusChangedEvent> & { previousStatus: string; newStatus: string },
+): OrderStatusChangedEvent {
+  return {
+    type: 'order:status-changed',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [],
+      total: 20,
+      status: overrides.newStatus as OrderStatusChangedEvent['order']['status'],
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    previousStatus: overrides.previousStatus,
+    newStatus: overrides.newStatus,
+    timestamp: new Date(),
+    ...overrides,
+  };
+}
+
+describe('EmailNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: EmailNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    statusChangeCallbacks.clear();
+    handler = new EmailNotificationHandler(eventBus);
+    resetEmailIdCounter();
+  });
+
+  describe('order:created email', () => {
+    it('should send confirmation email on order created', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('alice@example.com');
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[0]?.subject).toContain('order-1');
+    });
+
+    it('should include item details in email body', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Widget');
+      expect(email.htmlBody).toContain('Gadget');
+      expect(email.htmlBody).toContain('$45.00');
+      expect(email.plainBody).toContain('Widget x2');
+      expect(email.plainBody).toContain('Gadget x1');
+      expect(email.plainBody).toContain('$45.00');
+    });
+
+    it('should include user name in email body', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+          ],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Bob',
+          email: 'bob@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Bob');
+      expect(email.plainBody).toContain('Bob');
+    });
+  });
+
+  describe('order:status-changed email', () => {
+    it('should send email on status change', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'pending', newStatus: 'confirmed' }),
+      );
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Confirmed');
+      expect(emails[0]?.to).toBe('user-1');
+    });
+
+    it('should include previous and new status in body', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'pending', newStatus: 'confirmed' }),
+      );
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.plainBody).toContain('Pending');
+      expect(email.plainBody).toContain('Confirmed');
+      expect(email.htmlBody).toContain('Pending');
+      expect(email.htmlBody).toContain('Confirmed');
+    });
+
+    it('should provide appropriate message for shipped status', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'confirmed', newStatus: 'shipped' }),
+      );
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.plainBody).toContain('shipped and is on its way');
+    });
+
+    it('should provide appropriate message for delivered status', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'shipped', newStatus: 'delivered' }),
+      );
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.plainBody).toContain('delivered');
+      expect(email.plainBody).toContain('enjoy your purchase');
+    });
+
+    it('should provide appropriate message for cancelled status', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'pending', newStatus: 'cancelled' }),
+      );
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.plainBody).toContain('cancelled');
+      expect(email.plainBody).toContain('contact support');
+    });
+  });
+
+  describe('email management', () => {
+    it('should count emails', () => {
+      expect(handler.getEmailCount()).toBe(0);
+
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'pending', newStatus: 'confirmed' }),
+      );
+
+      expect(handler.getEmailCount()).toBe(1);
+    });
+
+    it('should filter emails by recipient', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'pending', newStatus: 'confirmed' }),
+      );
+
+      expect(handler.getEmailsForRecipient('user-1')).toHaveLength(1);
+      expect(handler.getEmailsForRecipient('user-999')).toHaveLength(0);
+    });
+
+    it('should clear emails', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'pending', newStatus: 'confirmed' }),
+      );
+
+      handler.clearEmails();
+      expect(handler.getEmailCount()).toBe(0);
+    });
+
+    it('should generate sequential email IDs', () => {
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'pending', newStatus: 'confirmed' }),
+      );
+      statusChangeCallbacks.notify(
+        makeStatusChangedEvent({ previousStatus: 'confirmed', newStatus: 'shipped' }),
+      );
+
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.id).toBe('email-0001');
+      expect(emails[1]?.id).toBe('email-0002');
+    });
+  });
+});
