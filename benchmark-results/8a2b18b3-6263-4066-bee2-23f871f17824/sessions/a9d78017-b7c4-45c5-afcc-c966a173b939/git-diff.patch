+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { WebhookHandler, resetWebhookIdCounters } from '../../src/notifications/webhook-handler.js';
+import type { WebhookSender, WebhookPayload } from '../../src/notifications/webhook-handler.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('WebhookHandler', () => {
+  let eventBus: EventBus;
+  let mockSender: WebhookSender;
+  let sentRequests: Array<{ url: string; payload: WebhookPayload; secret?: string }>;
+  let handler: WebhookHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    sentRequests = [];
+    resetWebhookIdCounters();
+
+    mockSender = vi.fn(async (url, payload, secret) => {
+      sentRequests.push({ url, payload, secret });
+      return { success: true, statusCode: 200 };
+    });
+
+    handler = new WebhookHandler(eventBus, mockSender);
+  });
+
+  describe('webhook registration', () => {
+    it('should register a webhook and return registration', () => {
+      const reg = handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      expect(reg.id).toBe('wh-0001');
+      expect(reg.url).toBe('https://example.com/hook');
+      expect(reg.eventType).toBe('order:created');
+      expect(reg.createdAt).toBeInstanceOf(Date);
+    });
+
+    it('should register a webhook with a secret', () => {
+      const reg = handler.registerWebhook('https://example.com/hook', 'order:created', 'my-secret');
+
+      expect(reg.secret).toBe('my-secret');
+    });
+
+    it('should list all registrations', () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:status-changed');
+
+      expect(handler.getRegistrations()).toHaveLength(2);
+    });
+
+    it('should filter registrations by event type', () => {
+      handler.registerWebhook('https://a.com/hook', 'order:created');
+      handler.registerWebhook('https://b.com/hook', 'order:status-changed');
+      handler.registerWebhook('https://c.com/hook', 'order:created');
+
+      expect(handler.getRegistrationsForEvent('order:created')).toHaveLength(2);
+      expect(handler.getRegistrationsForEvent('order:status-changed')).toHaveLength(1);
+    });
+
+    it('should unregister a webhook by ID', () => {
+      const reg = handler.registerWebhook('https://a.com/hook', 'order:created');
+
+      expect(handler.unregisterWebhook(reg.id)).toBe(true);
+      expect(handler.getRegistrations()).toHaveLength(0);
+    });
+
+    it('should return false when unregistering unknown ID', () => {
+      expect(handler.unregisterWebhook('wh-9999')).toBe(false);
+    });
+  });
+
+  describe('order:created webhooks', () => {
+    it('should fire webhook when order is created', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date('2026-01-15T10:00:00Z'),
+      };
+
+      await eventBus.emit(event);
+
+      expect(sentRequests).toHaveLength(1);
+      expect(sentRequests[0]?.url).toBe('https://example.com/hook');
+      expect(sentRequests[0]?.payload.event).toBe('order:created');
+      expect(sentRequests[0]?.payload.data.orderId).toBe('order-1');
+      expect(sentRequests[0]?.payload.data.total).toBe(20);
+      expect(sentRequests[0]?.payload.timestamp).toBe('2026-01-15T10:00:00.000Z');
+    });
+
+    it('should include order items in payload', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      const items = sentRequests[0]?.payload.data.items as any[];
+      expect(items).toHaveLength(2);
+      expect(items[0]?.name).toBe('Widget');
+    });
+
+    it('should not fire for unregistered event types', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed');
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      expect(sentRequests).toHaveLength(0);
+    });
+  });
+
+  describe('order:status-changed webhooks', () => {
+    it('should fire webhook when order status changes', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed');
+
+      const event: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date('2026-01-15T12:00:00Z'),
+      };
+
+      await eventBus.emit(event);
+
+      expect(sentRequests).toHaveLength(1);
+      expect(sentRequests[0]?.payload.event).toBe('order:status-changed');
+      expect(sentRequests[0]?.payload.data.previousStatus).toBe('pending');
+      expect(sentRequests[0]?.payload.data.newStatus).toBe('confirmed');
+      expect(sentRequests[0]?.payload.data.orderId).toBe('order-1');
+    });
+
+    it('should fire to multiple registered URLs', async () => {
+      handler.registerWebhook('https://a.com/hook', 'order:status-changed');
+      handler.registerWebhook('https://b.com/hook', 'order:status-changed');
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'shipped',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      });
+
+      expect(sentRequests).toHaveLength(2);
+      expect(sentRequests[0]?.url).toBe('https://a.com/hook');
+      expect(sentRequests[1]?.url).toBe('https://b.com/hook');
+    });
+
+    it('should pass secret to sender', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:status-changed', 'secret-123');
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(sentRequests[0]?.secret).toBe('secret-123');
+    });
+  });
+
+  describe('delivery tracking', () => {
+    it('should record successful deliveries', async () => {
+      const reg = handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      const deliveries = handler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.webhookId).toBe(reg.id);
+      expect(deliveries[0]?.success).toBe(true);
+      expect(deliveries[0]?.statusCode).toBe(200);
+    });
+
+    it('should record failed deliveries', async () => {
+      const failingSender: WebhookSender = async () => ({
+        success: false,
+        statusCode: 500,
+        error: 'Internal Server Error',
+      });
+
+      const failHandler = new WebhookHandler(eventBus, failingSender);
+      failHandler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      const deliveries = failHandler.getDeliveries();
+      expect(deliveries).toHaveLength(1);
+      expect(deliveries[0]?.success).toBe(false);
+      expect(deliveries[0]?.statusCode).toBe(500);
+      expect(deliveries[0]?.error).toBe('Internal Server Error');
+    });
+
+    it('should filter deliveries by webhook ID', async () => {
+      const reg1 = handler.registerWebhook('https://a.com/hook', 'order:status-changed');
+      handler.registerWebhook('https://b.com/hook', 'order:status-changed');
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getDeliveriesForWebhook(reg1.id)).toHaveLength(1);
+      expect(handler.getDeliveries()).toHaveLength(2);
+    });
+  });
+
+  describe('clear', () => {
+    it('should clear all registrations and deliveries', async () => {
+      handler.registerWebhook('https://example.com/hook', 'order:created');
+
+      await eventBus.emit({
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      });
+
+      handler.clear();
+
+      expect(handler.getRegistrations()).toHaveLength(0);
+      expect(handler.getDeliveries()).toHaveLength(0);
+    });
+  });
+});
