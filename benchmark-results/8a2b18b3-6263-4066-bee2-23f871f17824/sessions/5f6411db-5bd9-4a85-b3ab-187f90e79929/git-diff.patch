+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { EmailNotificationHandler } from '../../src/notifications/email-notification-handler.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('EmailNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: EmailNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    handler = new EmailNotificationHandler(eventBus);
+  });
+
+  describe('order:created handler', () => {
+    it('should send confirmation email when order is created', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('alice@example.com');
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[0]?.htmlBody).toContain('Widget');
+      expect(emails[0]?.htmlBody).toContain('$20.00');
+      expect(emails[0]?.textBody).toContain('Widget x2');
+    });
+
+    it('should include all items in confirmation email', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.htmlBody).toContain('Widget');
+      expect(emails[0]?.htmlBody).toContain('Gadget');
+      expect(emails[0]?.textBody).toContain('Widget x2');
+      expect(emails[0]?.textBody).toContain('Gadget x1');
+    });
+  });
+
+  describe('order:status-changed handler', () => {
+    const makeStatusEvent = (
+      previousStatus: string,
+      newStatus: string,
+    ): OrderStatusChangedEvent => ({
+      type: 'order:status-changed',
+      order: {
+        id: 'order-1',
+        userId: 'user-1',
+        items: [],
+        total: 20,
+        status: newStatus as 'confirmed',
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      previousStatus,
+      newStatus,
+      timestamp: new Date(),
+    });
+
+    it('should send email on status change to confirmed', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('user-1');
+      expect(emails[0]?.subject).toContain('Confirmed');
+      expect(emails[0]?.htmlBody).toContain('Confirmed');
+      expect(emails[0]?.textBody).toContain('confirmed and is being prepared');
+    });
+
+    it('should send email on status change to shipped', async () => {
+      await eventBus.emit(makeStatusEvent('confirmed', 'shipped'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Shipped');
+      expect(emails[0]?.textBody).toContain('shipped and is on its way');
+    });
+
+    it('should send email on status change to delivered', async () => {
+      await eventBus.emit(makeStatusEvent('shipped', 'delivered'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Delivered');
+      expect(emails[0]?.textBody).toContain('delivered');
+    });
+
+    it('should send email on status change to cancelled', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'cancelled'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Cancelled');
+      expect(emails[0]?.textBody).toContain('cancelled');
+    });
+
+    it('should include order ID in subject and body', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.subject).toContain('order-1');
+      expect(emails[0]?.htmlBody).toContain('order-1');
+      expect(emails[0]?.textBody).toContain('order-1');
+    });
+
+    it('should include both HTML and text body', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.htmlBody).toContain('<h1>');
+      expect(emails[0]?.textBody).not.toContain('<h1>');
+    });
+  });
+
+  describe('email management', () => {
+    it('should count sent emails', async () => {
+      expect(handler.getSentEmailCount()).toBe(0);
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getSentEmailCount()).toBe(1);
+    });
+
+    it('should filter emails by recipient', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'alice@example.com',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getEmailsForRecipient('alice@example.com')).toHaveLength(1);
+      expect(handler.getEmailsForRecipient('bob@example.com')).toHaveLength(0);
+    });
+
+    it('should clear sent emails', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      handler.clearEmails();
+      expect(handler.getSentEmailCount()).toBe(0);
+    });
+
+    it('should track multiple emails across events', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'shipped',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getSentEmailCount()).toBe(2);
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.subject).toContain('Confirmed');
+      expect(emails[1]?.subject).toContain('Shipped');
+    });
+
+    it('should log events in the event bus', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'shipped',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      });
+
+      const log = eventBus.getEventLog();
+      expect(log).toHaveLength(1);
+      expect(log[0]?.type).toBe('order:status-changed');
+    });
+  });
+});
