diff --git a/src/notifications/email-notification-handler.ts b/src/notifications/email-notification-handler.ts
new file mode 100644
index 0000000..b66c9bf
--- /dev/null
+++ b/src/notifications/email-notification-handler.ts
@@ -0,0 +1,173 @@
+/**
+ * Email notification handler — formats and sends email notifications
+ * when order status changes occur.
+ *
+ * Integrates with the EventBus pattern used throughout the application.
+ * Subscribes to order lifecycle events and produces formatted email messages.
+ *
+ * Depends on:
+ * - EventBus (event system) for receiving order events
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../events/event-types.js';
+import type { OrderStatus } from '../models/order.js';
+import { Logger } from '../utils/logger.js';
+
+export interface EmailMessage {
+  to: string;
+  subject: string;
+  htmlBody: string;
+  textBody: string;
+  sentAt: Date;
+}
+
+const STATUS_LABELS: Record<OrderStatus, string> = {
+  pending: 'Pending',
+  confirmed: 'Confirmed',
+  shipped: 'Shipped',
+  delivered: 'Delivered',
+  cancelled: 'Cancelled',
+};
+
+export class EmailNotificationHandler {
+  private logger = new Logger('EmailNotificationHandler');
+  private sentEmails: EmailMessage[] = [];
+
+  constructor(private eventBus: EventBus) {
+    this.registerHandlers();
+  }
+
+  private registerHandlers(): void {
+    this.eventBus.on<OrderCreatedEvent>('order:created', (event) => {
+      this.handleOrderCreated(event);
+    });
+
+    this.eventBus.on<OrderStatusChangedEvent>('order:status-changed', (event) => {
+      this.handleOrderStatusChanged(event);
+    });
+  }
+
+  private handleOrderCreated(event: OrderCreatedEvent): void {
+    this.logger.info(`Sending order confirmation email for order ${event.order.id}`);
+
+    const itemRows = event.order.items
+      .map((item) => `<tr><td>${item.name}</td><td>${item.quantity}</td><td>$${item.unitPrice.toFixed(2)}</td></tr>`)
+      .join('\n');
+
+    const itemList = event.order.items
+      .map((item) => `- ${item.name} x${item.quantity} @ $${item.unitPrice.toFixed(2)}`)
+      .join('\n');
+
+    const htmlBody = `<h1>Order Confirmation</h1>
+<p>Thank you for your order, ${event.user.name}!</p>
+<p>Order ID: ${event.order.id}</p>
+<table>
+<tr><th>Item</th><th>Qty</th><th>Price</th></tr>
+${itemRows}
+</table>
+<p><strong>Total: $${event.order.total.toFixed(2)}</strong></p>`;
+
+    const textBody = `Order Confirmation
+
+Thank you for your order, ${event.user.name}!
+
+Order ID: ${event.order.id}
+
+Items:
+${itemList}
+
+Total: $${event.order.total.toFixed(2)}`;
+
+    this.sendEmail({
+      to: event.user.email,
+      subject: `Order Confirmation: ${event.order.id}`,
+      htmlBody,
+      textBody,
+    });
+  }
+
+  private handleOrderStatusChanged(event: OrderStatusChangedEvent): void {
+    const newLabel = STATUS_LABELS[event.newStatus as OrderStatus] ?? event.newStatus;
+    const prevLabel = STATUS_LABELS[event.previousStatus as OrderStatus] ?? event.previousStatus;
+
+    this.logger.info(
+      `Sending status change email for order ${event.order.id}: ${prevLabel} -> ${newLabel}`,
+    );
+
+    const htmlBody = `<h1>Order Status Update</h1>
+<p>Your order <strong>${event.order.id}</strong> has been updated.</p>
+<p>Status: <em>${prevLabel}</em> &rarr; <strong>${newLabel}</strong></p>
+${this.getStatusMessage(event.newStatus as OrderStatus)}`;
+
+    const textBody = `Order Status Update
+
+Your order ${event.order.id} has been updated.
+
+Status: ${prevLabel} -> ${newLabel}
+
+${this.getStatusMessageText(event.newStatus as OrderStatus)}`;
+
+    this.sendEmail({
+      to: event.order.userId,
+      subject: `Order ${event.order.id} — ${newLabel}`,
+      htmlBody,
+      textBody,
+    });
+  }
+
+  private getStatusMessage(status: OrderStatus): string {
+    switch (status) {
+      case 'confirmed':
+        return '<p>Your order has been confirmed and is being prepared.</p>';
+      case 'shipped':
+        return '<p>Your order has been shipped and is on its way!</p>';
+      case 'delivered':
+        return '<p>Your order has been delivered. Enjoy!</p>';
+      case 'cancelled':
+        return '<p>Your order has been cancelled.</p>';
+      default:
+        return '';
+    }
+  }
+
+  private getStatusMessageText(status: OrderStatus): string {
+    switch (status) {
+      case 'confirmed':
+        return 'Your order has been confirmed and is being prepared.';
+      case 'shipped':
+        return 'Your order has been shipped and is on its way!';
+      case 'delivered':
+        return 'Your order has been delivered. Enjoy!';
+      case 'cancelled':
+        return 'Your order has been cancelled.';
+      default:
+        return '';
+    }
+  }
+
+  private sendEmail(params: Omit<EmailMessage, 'sentAt'>): void {
+    const email: EmailMessage = {
+      ...params,
+      sentAt: new Date(),
+    };
+    this.sentEmails.push(email);
+    this.logger.info(`Email sent to ${params.to}: ${params.subject}`);
+  }
+
+  getSentEmails(): EmailMessage[] {
+    return [...this.sentEmails];
+  }
+
+  getSentEmailsForRecipient(recipient: string): EmailMessage[] {
+    return this.sentEmails.filter((e) => e.to === recipient);
+  }
+
+  getSentEmailCount(): number {
+    return this.sentEmails.length;
+  }
+
+  clearSentEmails(): void {
+    this.sentEmails = [];
+  }
+}
diff --git a/tests/services/email-notification-handler.test.ts b/tests/services/email-notification-handler.test.ts
