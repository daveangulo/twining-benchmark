+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { EmailNotificationHandler } from '../../src/notifications/email-handler.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+function makeOrderCreatedEvent(overrides?: Partial<OrderCreatedEvent>): OrderCreatedEvent {
+  return {
+    type: 'order:created',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [
+        { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+      ],
+      total: 20,
+      status: 'pending',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    user: {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    timestamp: new Date(),
+    ...overrides,
+  };
+}
+
+function makeStatusChangedEvent(
+  previousStatus: string,
+  newStatus: string,
+  orderId = 'order-1',
+): OrderStatusChangedEvent {
+  return {
+    type: 'order:status-changed',
+    order: {
+      id: orderId,
+      userId: 'user-1',
+      items: [],
+      total: 20,
+      status: newStatus as OrderStatusChangedEvent['order']['status'],
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    previousStatus,
+    newStatus,
+    timestamp: new Date(),
+  };
+}
+
+describe('EmailNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: EmailNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    handler = new EmailNotificationHandler(eventBus);
+  });
+
+  describe('order:created emails', () => {
+    it('should send a confirmation email when an order is created', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.to).toBe('alice@example.com');
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[0]?.subject).toContain('order-1');
+    });
+
+    it('should include item details in the email body', async () => {
+      const event = makeOrderCreatedEvent({
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+      });
+
+      await eventBus.emit(event);
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Widget');
+      expect(email.htmlBody).toContain('Gadget');
+      expect(email.textBody).toContain('Widget x2');
+      expect(email.textBody).toContain('Gadget x1');
+      expect(email.textBody).toContain('$45.00');
+    });
+
+    it('should include the user name in the email body', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('Alice');
+      expect(email.textBody).toContain('Alice');
+    });
+  });
+
+  describe('order:status-changed emails', () => {
+    it('should send an email when status changes to confirmed', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Order Confirmed');
+      expect(emails[0]?.htmlBody).toContain('pending');
+      expect(emails[0]?.htmlBody).toContain('confirmed');
+    });
+
+    it('should send an email when status changes to shipped', async () => {
+      await eventBus.emit(makeStatusChangedEvent('confirmed', 'shipped'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Order Shipped');
+      expect(email.textBody).toContain('confirmed');
+      expect(email.textBody).toContain('shipped');
+    });
+
+    it('should send an email when status changes to delivered', async () => {
+      await eventBus.emit(makeStatusChangedEvent('shipped', 'delivered'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Order Delivered');
+    });
+
+    it('should send an email when status changes to cancelled', async () => {
+      await eventBus.emit(makeStatusChangedEvent('confirmed', 'cancelled'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.subject).toContain('Order Cancelled');
+    });
+
+    it('should include the order ID in both HTML and text bodies', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed', 'order-42'));
+
+      const email = handler.getSentEmails()[0]!;
+      expect(email.htmlBody).toContain('order-42');
+      expect(email.textBody).toContain('order-42');
+    });
+
+    it('should send to the order userId', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      expect(handler.getSentEmails()[0]?.to).toBe('user-1');
+    });
+  });
+
+  describe('email management', () => {
+    it('should count sent emails', async () => {
+      expect(handler.getSentCount()).toBe(0);
+
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+      expect(handler.getSentCount()).toBe(1);
+
+      await eventBus.emit(makeStatusChangedEvent('confirmed', 'shipped'));
+      expect(handler.getSentCount()).toBe(2);
+    });
+
+    it('should filter emails by recipient', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+
+      expect(handler.getEmailsTo('alice@example.com')).toHaveLength(1);
+      expect(handler.getEmailsTo('bob@example.com')).toHaveLength(0);
+    });
+
+    it('should clear emails', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+      handler.clearEmails();
+      expect(handler.getSentCount()).toBe(0);
+    });
+  });
+
+  describe('integration with EventBus', () => {
+    it('should handle the full order lifecycle via EventBus', async () => {
+      await eventBus.emit(makeOrderCreatedEvent());
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+      await eventBus.emit(makeStatusChangedEvent('confirmed', 'shipped'));
+      await eventBus.emit(makeStatusChangedEvent('shipped', 'delivered'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(4);
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[1]?.subject).toContain('Order Confirmed');
+      expect(emails[2]?.subject).toContain('Order Shipped');
+      expect(emails[3]?.subject).toContain('Order Delivered');
+    });
+
+    it('should coexist with NotificationService on the same EventBus', async () => {
+      // Import NotificationService to verify both can subscribe
+      const { NotificationService, resetNotificationIdCounter } = await import(
+        '../../src/services/notification.service.js'
+      );
+      resetNotificationIdCounter();
+      const notifService = new NotificationService(eventBus);
+
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      // Both handlers should have processed the event
+      expect(handler.getSentCount()).toBe(1);
+      expect(notifService.getNotificationCount()).toBe(1);
+    });
+
+    it('should log events in the EventBus event log', async () => {
+      await eventBus.emit(makeStatusChangedEvent('pending', 'confirmed'));
+
+      const log = eventBus.getEventLog();
+      expect(log).toHaveLength(1);
+      expect(log[0]?.type).toBe('order:status-changed');
+    });
+  });
+});
