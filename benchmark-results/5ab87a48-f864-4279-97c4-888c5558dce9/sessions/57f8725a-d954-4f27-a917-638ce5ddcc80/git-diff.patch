+++ b/tests/services/analytics.service.test.ts
@@ -0,0 +1,189 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import type { User } from '../../src/models/user.js';
+import type { Order } from '../../src/models/order.js';
+
+describe('AnalyticsService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let orderRepo: OrderRepository;
+  let service: AnalyticsService;
+
+  function makeUser(overrides: Partial<User> = {}): User {
+    return {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date('2025-01-01'),
+      updatedAt: new Date('2025-01-01'),
+      ...overrides,
+    };
+  }
+
+  function makeOrder(overrides: Partial<Order> = {}): Order {
+    return {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+      total: 20,
+      status: 'pending',
+      createdAt: new Date('2025-03-15'),
+      updatedAt: new Date('2025-03-15'),
+      ...overrides,
+    };
+  }
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    orderRepo = new OrderRepository(db);
+    service = new AnalyticsService(userRepo, orderRepo);
+  });
+
+  describe('getSummary', () => {
+    it('should return zeros when no data exists', () => {
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(0);
+      expect(summary.totalOrders).toBe(0);
+      expect(summary.revenue).toBe(0);
+      expect(summary.activeUsers).toBe(0);
+    });
+
+    it('should aggregate stats from users and orders', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2', email: 'bob@example.com' }));
+      userRepo.save(makeUser({ id: 'user-3', email: 'carol@example.com' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 50 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', total: 30 }));
+      orderRepo.save(makeOrder({ id: 'order-3', userId: 'user-2', total: 20 }));
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(3);
+      expect(summary.totalOrders).toBe(3);
+      expect(summary.revenue).toBe(100);
+      expect(summary.activeUsers).toBe(2);
+    });
+  });
+
+  describe('getUserAnalytics', () => {
+    it('should throw for non-existent user', () => {
+      expect(() => service.getUserAnalytics('nonexistent')).toThrow('User not found');
+    });
+
+    it('should return analytics for user with no orders', () => {
+      const user = makeUser({ createdAt: new Date('2025-02-01') });
+      userRepo.save(user);
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.userId).toBe('user-1');
+      expect(analytics.orderCount).toBe(0);
+      expect(analytics.totalSpent).toBe(0);
+      expect(analytics.lastActive).toEqual(new Date('2025-02-01'));
+    });
+
+    it('should compute per-user order stats', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({
+        id: 'order-1',
+        total: 50,
+        createdAt: new Date('2025-03-10'),
+      }));
+      orderRepo.save(makeOrder({
+        id: 'order-2',
+        total: 30,
+        createdAt: new Date('2025-03-20'),
+      }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.orderCount).toBe(2);
+      expect(analytics.totalSpent).toBe(80);
+      expect(analytics.lastActive).toEqual(new Date('2025-03-20'));
+    });
+  });
+
+  describe('getTrends', () => {
+    it('should throw for unsupported metric', () => {
+      expect(() =>
+        service.getTrends('invalid', new Date('2025-01-01'), new Date('2025-12-31')),
+      ).toThrow('Unsupported metric');
+    });
+
+    it('should return empty array when no orders in range', () => {
+      const points = service.getTrends('orders', new Date('2025-01-01'), new Date('2025-01-31'));
+      expect(points).toHaveLength(0);
+    });
+
+    it('should return order count trend points grouped by day', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({
+        id: 'order-1',
+        createdAt: new Date('2025-03-10T10:00:00Z'),
+      }));
+      orderRepo.save(makeOrder({
+        id: 'order-2',
+        createdAt: new Date('2025-03-10T14:00:00Z'),
+      }));
+      orderRepo.save(makeOrder({
+        id: 'order-3',
+        createdAt: new Date('2025-03-12T09:00:00Z'),
+      }));
+
+      const points = service.getTrends('orders', new Date('2025-03-01'), new Date('2025-03-31'));
+
+      expect(points).toHaveLength(2);
+      expect(points[0].metric).toBe('orders');
+      expect(points[0].value).toBe(2); // two orders on March 10
+      expect(points[1].value).toBe(1); // one order on March 12
+    });
+
+    it('should return revenue trend points grouped by day', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({
+        id: 'order-1',
+        total: 50,
+        createdAt: new Date('2025-03-10T10:00:00Z'),
+      }));
+      orderRepo.save(makeOrder({
+        id: 'order-2',
+        total: 30,
+        createdAt: new Date('2025-03-10T14:00:00Z'),
+      }));
+
+      const points = service.getTrends('revenue', new Date('2025-03-01'), new Date('2025-03-31'));
+
+      expect(points).toHaveLength(1);
+      expect(points[0].metric).toBe('revenue');
+      expect(points[0].value).toBe(80);
+    });
+
+    it('should only include orders within the date range', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({
+        id: 'order-1',
+        createdAt: new Date('2025-02-28'),
+      }));
+      orderRepo.save(makeOrder({
+        id: 'order-2',
+        createdAt: new Date('2025-03-15'),
+      }));
+      orderRepo.save(makeOrder({
+        id: 'order-3',
+        createdAt: new Date('2025-04-01'),
+      }));
+
+      const points = service.getTrends('orders', new Date('2025-03-01'), new Date('2025-03-31'));
+
+      expect(points).toHaveLength(1);
+      expect(points[0].value).toBe(1);
+    });
+  });
+});
