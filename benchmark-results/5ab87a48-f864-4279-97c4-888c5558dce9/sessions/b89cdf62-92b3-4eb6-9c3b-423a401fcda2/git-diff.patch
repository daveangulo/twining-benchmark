+++ b/tests/services/analytics.service.test.ts
@@ -0,0 +1,448 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import type { Order } from '../../src/models/order.js';
+import type { User } from '../../src/models/user.js';
+import type { TimeSeriesQuery } from '../../src/models/analytics.js';
+
+function makeOrder(overrides: Partial<Order> & { id: string }): Order {
+  return {
+    userId: 'user-1',
+    items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+    total: 10,
+    status: 'pending',
+    createdAt: new Date('2026-01-15'),
+    updatedAt: new Date('2026-01-15'),
+    ...overrides,
+  };
+}
+
+function makeUser(overrides: Partial<User> & { id: string }): User {
+  return {
+    name: 'Test User',
+    email: 'test@example.com',
+    role: 'member',
+    createdAt: new Date(),
+    updatedAt: new Date(),
+    ...overrides,
+  };
+}
+
+describe('AnalyticsService', () => {
+  let db: Database;
+  let orderRepo: OrderRepository;
+  let userRepo: UserRepository;
+  let service: AnalyticsService;
+
+  beforeEach(() => {
+    db = new Database();
+    orderRepo = new OrderRepository(db);
+    userRepo = new UserRepository(db);
+    service = new AnalyticsService(orderRepo, userRepo);
+  });
+
+  // ---------- getOrderMetricSummary ----------
+
+  describe('getOrderMetricSummary', () => {
+    it('should return zeroes for empty dataset', () => {
+      const result = service.getOrderMetricSummary();
+      expect(result.totalOrders).toBe(0);
+      expect(result.totalRevenue).toBe(0);
+      expect(result.averageOrderValue).toBe(0);
+      expect(result.averageItemsPerOrder).toBe(0);
+      expect(result.ordersByStatus).toEqual({
+        pending: 0,
+        confirmed: 0,
+        shipped: 0,
+        delivered: 0,
+        cancelled: 0,
+      });
+    });
+
+    it('should compute correct metrics for a single order', () => {
+      orderRepo.save(makeOrder({
+        id: 'o1',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 3, unitPrice: 10 }],
+        total: 30,
+        status: 'pending',
+      }));
+
+      const result = service.getOrderMetricSummary();
+      expect(result.totalOrders).toBe(1);
+      expect(result.totalRevenue).toBe(30);
+      expect(result.averageOrderValue).toBe(30);
+      expect(result.averageItemsPerOrder).toBe(3);
+      expect(result.ordersByStatus.pending).toBe(1);
+    });
+
+    it('should compute correct metrics for multiple orders', () => {
+      orderRepo.save(makeOrder({ id: 'o1', total: 100, status: 'pending',
+        items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 50 }] }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 50, status: 'confirmed',
+        items: [{ productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 50 }] }));
+      orderRepo.save(makeOrder({ id: 'o3', total: 150, status: 'pending',
+        items: [
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 100 },
+          { productId: 'p3', name: 'Doohickey', quantity: 2, unitPrice: 25 },
+        ] }));
+
+      const result = service.getOrderMetricSummary();
+      expect(result.totalOrders).toBe(3);
+      expect(result.totalRevenue).toBe(300);
+      expect(result.averageOrderValue).toBe(100);
+      expect(result.averageItemsPerOrder).toBe(2);
+      expect(result.ordersByStatus.pending).toBe(2);
+      expect(result.ordersByStatus.confirmed).toBe(1);
+    });
+  });
+
+  // ---------- getUserMetricSummary ----------
+
+  describe('getUserMetricSummary', () => {
+    it('should return zero for no users', () => {
+      const result = service.getUserMetricSummary();
+      expect(result.totalUsers).toBe(0);
+      expect(result.usersByRole).toEqual({});
+    });
+
+    it('should count users by role', () => {
+      userRepo.save(makeUser({ id: 'u1', role: 'admin' }));
+      userRepo.save(makeUser({ id: 'u2', role: 'member', email: 'b@b.com' }));
+      userRepo.save(makeUser({ id: 'u3', role: 'member', email: 'c@c.com' }));
+      userRepo.save(makeUser({ id: 'u4', role: 'viewer', email: 'd@d.com' }));
+
+      const result = service.getUserMetricSummary();
+      expect(result.totalUsers).toBe(4);
+      expect(result.usersByRole).toEqual({ admin: 1, member: 2, viewer: 1 });
+    });
+  });
+
+  // ---------- getRevenueTimeSeries ----------
+
+  describe('getRevenueTimeSeries', () => {
+    it('should return empty buckets when no orders', () => {
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-03'),
+        granularity: 'day',
+      };
+      const result = service.getRevenueTimeSeries(query);
+      expect(result.metric).toBe('revenue');
+      expect(result.granularity).toBe('day');
+      expect(result.data).toHaveLength(3);
+      expect(result.data.every((d) => d.value === 0)).toBe(true);
+    });
+
+    it('should aggregate revenue into correct daily buckets', () => {
+      orderRepo.save(makeOrder({ id: 'o1', total: 100, createdAt: new Date('2026-01-01') }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 50, createdAt: new Date('2026-01-01') }));
+      orderRepo.save(makeOrder({ id: 'o3', total: 75, createdAt: new Date('2026-01-02') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-03'),
+        granularity: 'day',
+      };
+      const result = service.getRevenueTimeSeries(query);
+      expect(result.data).toHaveLength(3);
+      expect(result.data[0]).toEqual({ date: '2026-01-01', value: 150 });
+      expect(result.data[1]).toEqual({ date: '2026-01-02', value: 75 });
+      expect(result.data[2]).toEqual({ date: '2026-01-03', value: 0 });
+    });
+
+    it('should exclude orders outside the date range', () => {
+      orderRepo.save(makeOrder({ id: 'o1', total: 100, createdAt: new Date('2025-12-31') }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 50, createdAt: new Date('2026-01-04') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-03'),
+        granularity: 'day',
+      };
+      const result = service.getRevenueTimeSeries(query);
+      expect(result.data.every((d) => d.value === 0)).toBe(true);
+    });
+
+    it('should aggregate revenue into monthly buckets', () => {
+      orderRepo.save(makeOrder({ id: 'o1', total: 100, createdAt: new Date('2026-01-15') }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 200, createdAt: new Date('2026-02-10') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-03-01'),
+        granularity: 'month',
+      };
+      const result = service.getRevenueTimeSeries(query);
+      expect(result.data.length).toBeGreaterThanOrEqual(3);
+      const jan = result.data.find((d) => d.date === '2026-01');
+      const feb = result.data.find((d) => d.date === '2026-02');
+      expect(jan?.value).toBe(100);
+      expect(feb?.value).toBe(200);
+    });
+  });
+
+  // ---------- getOrderCountTimeSeries ----------
+
+  describe('getOrderCountTimeSeries', () => {
+    it('should return empty buckets when no orders', () => {
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-03'),
+        granularity: 'day',
+      };
+      const result = service.getOrderCountTimeSeries(query);
+      expect(result.metric).toBe('orders');
+      expect(result.data).toHaveLength(3);
+      expect(result.data.every((d) => d.value === 0)).toBe(true);
+    });
+
+    it('should count orders per day', () => {
+      orderRepo.save(makeOrder({ id: 'o1', createdAt: new Date('2026-01-01') }));
+      orderRepo.save(makeOrder({ id: 'o2', createdAt: new Date('2026-01-01') }));
+      orderRepo.save(makeOrder({ id: 'o3', createdAt: new Date('2026-01-02') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-02'),
+        granularity: 'day',
+      };
+      const result = service.getOrderCountTimeSeries(query);
+      expect(result.data).toHaveLength(2);
+      expect(result.data[0]).toEqual({ date: '2026-01-01', value: 2 });
+      expect(result.data[1]).toEqual({ date: '2026-01-02', value: 1 });
+    });
+  });
+
+  // ---------- getTopProducts ----------
+
+  describe('getTopProducts', () => {
+    it('should return empty array for no orders', () => {
+      const result = service.getTopProducts(5);
+      expect(result).toEqual([]);
+    });
+
+    it('should rank products by total quantity', () => {
+      orderRepo.save(makeOrder({
+        id: 'o1',
+        items: [
+          { productId: 'p1', name: 'Widget', quantity: 5, unitPrice: 10 },
+          { productId: 'p2', name: 'Gadget', quantity: 2, unitPrice: 20 },
+        ],
+        total: 90,
+      }));
+      orderRepo.save(makeOrder({
+        id: 'o2',
+        items: [
+          { productId: 'p2', name: 'Gadget', quantity: 10, unitPrice: 20 },
+        ],
+        total: 200,
+      }));
+
+      const result = service.getTopProducts(5);
+      expect(result).toHaveLength(2);
+      expect(result[0]!.productId).toBe('p2');
+      expect(result[0]!.totalQuantity).toBe(12);
+      expect(result[0]!.totalRevenue).toBe(240);
+      expect(result[1]!.productId).toBe('p1');
+      expect(result[1]!.totalQuantity).toBe(5);
+      expect(result[1]!.totalRevenue).toBe(50);
+    });
+
+    it('should respect the limit parameter', () => {
+      orderRepo.save(makeOrder({
+        id: 'o1',
+        items: [
+          { productId: 'p1', name: 'A', quantity: 10, unitPrice: 1 },
+          { productId: 'p2', name: 'B', quantity: 8, unitPrice: 1 },
+          { productId: 'p3', name: 'C', quantity: 6, unitPrice: 1 },
+        ],
+        total: 24,
+      }));
+
+      const result = service.getTopProducts(2);
+      expect(result).toHaveLength(2);
+      expect(result[0]!.productId).toBe('p1');
+      expect(result[1]!.productId).toBe('p2');
+    });
+  });
+
+  // ---------- getRevenueByStatus ----------
+
+  describe('getRevenueByStatus', () => {
+    it('should return zeroes for no orders', () => {
+      const result = service.getRevenueByStatus();
+      expect(result).toEqual({
+        pending: 0,
+        confirmed: 0,
+        shipped: 0,
+        delivered: 0,
+        cancelled: 0,
+      });
+    });
+
+    it('should group revenue by status', () => {
+      orderRepo.save(makeOrder({ id: 'o1', total: 100, status: 'pending' }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 200, status: 'delivered' }));
+      orderRepo.save(makeOrder({ id: 'o3', total: 50, status: 'pending' }));
+      orderRepo.save(makeOrder({ id: 'o4', total: 75, status: 'cancelled' }));
+
+      const result = service.getRevenueByStatus();
+      expect(result.pending).toBe(150);
+      expect(result.delivered).toBe(200);
+      expect(result.cancelled).toBe(75);
+      expect(result.confirmed).toBe(0);
+      expect(result.shipped).toBe(0);
+    });
+  });
+
+  // ---------- getUserOrderSummary ----------
+
+  describe('getUserOrderSummary', () => {
+    it('should return zeroes for user with no orders', () => {
+      const result = service.getUserOrderSummary('user-1');
+      expect(result.totalOrders).toBe(0);
+      expect(result.totalSpent).toBe(0);
+      expect(result.averageOrderValue).toBe(0);
+      expect(result.ordersByStatus).toEqual({
+        pending: 0,
+        confirmed: 0,
+        shipped: 0,
+        delivered: 0,
+        cancelled: 0,
+      });
+    });
+
+    it('should compute correct summary for a user', () => {
+      orderRepo.save(makeOrder({ id: 'o1', userId: 'user-1', total: 100, status: 'pending' }));
+      orderRepo.save(makeOrder({ id: 'o2', userId: 'user-1', total: 200, status: 'delivered' }));
+      orderRepo.save(makeOrder({ id: 'o3', userId: 'user-2', total: 50, status: 'pending' }));
+
+      const result = service.getUserOrderSummary('user-1');
+      expect(result.totalOrders).toBe(2);
+      expect(result.totalSpent).toBe(300);
+      expect(result.averageOrderValue).toBe(150);
+      expect(result.ordersByStatus.pending).toBe(1);
+      expect(result.ordersByStatus.delivered).toBe(1);
+    });
+
+    it('should not include other users orders', () => {
+      orderRepo.save(makeOrder({ id: 'o1', userId: 'user-2', total: 999 }));
+
+      const result = service.getUserOrderSummary('user-1');
+      expect(result.totalOrders).toBe(0);
+      expect(result.totalSpent).toBe(0);
+    });
+  });
+
+  // ---------- getDashboardData ----------
+
+  describe('getDashboardData', () => {
+    it('should compose all metrics into dashboard data', () => {
+      userRepo.save(makeUser({ id: 'u1', role: 'admin' }));
+      orderRepo.save(makeOrder({ id: 'o1', total: 100, createdAt: new Date('2026-01-15') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-31'),
+        granularity: 'day',
+      };
+      const result = service.getDashboardData(query);
+
+      expect(result.generatedAt).toBeInstanceOf(Date);
+      expect(result.orderMetrics.totalOrders).toBe(1);
+      expect(result.orderMetrics.totalRevenue).toBe(100);
+      expect(result.userMetrics.totalUsers).toBe(1);
+      expect(result.revenueTimeSeries.metric).toBe('revenue');
+      expect(result.ordersTimeSeries.metric).toBe('orders');
+      expect(result.topProducts).toHaveLength(1);
+    });
+
+    it('should work with empty data', () => {
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-03'),
+        granularity: 'day',
+      };
+      const result = service.getDashboardData(query);
+
+      expect(result.orderMetrics.totalOrders).toBe(0);
+      expect(result.userMetrics.totalUsers).toBe(0);
+      expect(result.topProducts).toEqual([]);
+    });
+  });
+
+  // ---------- Time series edge cases ----------
+
+  describe('time series edge cases', () => {
+    it('should handle single-day range', () => {
+      orderRepo.save(makeOrder({ id: 'o1', total: 42, createdAt: new Date('2026-03-15') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-03-15'),
+        endDate: new Date('2026-03-15'),
+        granularity: 'day',
+      };
+      const result = service.getRevenueTimeSeries(query);
+      expect(result.data).toHaveLength(1);
+      expect(result.data[0]).toEqual({ date: '2026-03-15', value: 42 });
+    });
+
+    it('should handle weekly granularity', () => {
+      // Monday Jan 5, 2026
+      orderRepo.save(makeOrder({ id: 'o1', total: 100, createdAt: new Date('2026-01-05') }));
+      // Wednesday Jan 7, 2026 (same week)
+      orderRepo.save(makeOrder({ id: 'o2', total: 50, createdAt: new Date('2026-01-07') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-05'),
+        endDate: new Date('2026-01-11'),
+        granularity: 'week',
+      };
+      const result = service.getRevenueTimeSeries(query);
+      // Both orders should be in the same weekly bucket
+      const totalRevenue = result.data.reduce((sum, d) => sum + d.value, 0);
+      expect(totalRevenue).toBe(150);
+    });
+
+    it('should produce data points sorted by date', () => {
+      orderRepo.save(makeOrder({ id: 'o1', total: 10, createdAt: new Date('2026-01-03') }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 20, createdAt: new Date('2026-01-01') }));
+
+      const query: TimeSeriesQuery = {
+        startDate: new Date('2026-01-01'),
+        endDate: new Date('2026-01-03'),
+        granularity: 'day',
+      };
+      const result = service.getRevenueTimeSeries(query);
+      for (let i = 1; i < result.data.length; i++) {
+        expect(result.data[i]!.date >= result.data[i - 1]!.date).toBe(true);
+      }
+    });
+  });
+
+  // ---------- Large dataset ----------
+
+  describe('large dataset handling', () => {
+    it('should handle many orders without error', () => {
+      for (let i = 0; i < 500; i++) {
+        orderRepo.save(makeOrder({
+          id: `o${i}`,
+          total: i * 10,
+          status: i % 2 === 0 ? 'pending' : 'delivered',
+          items: [{ productId: `p${i % 10}`, name: `Product ${i % 10}`, quantity: i + 1, unitPrice: 10 }],
+        }));
+      }
+
+      const summary = service.getOrderMetricSummary();
+      expect(summary.totalOrders).toBe(500);
+
+      const topProducts = service.getTopProducts(5);
+      expect(topProducts).toHaveLength(5);
+
+      const revenueByStatus = service.getRevenueByStatus();
+      expect(revenueByStatus.pending + revenueByStatus.delivered).toBe(summary.totalRevenue);
+    });
+  });
+});
