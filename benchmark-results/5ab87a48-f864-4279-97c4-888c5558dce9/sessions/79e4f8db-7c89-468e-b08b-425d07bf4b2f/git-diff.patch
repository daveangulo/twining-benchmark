@@ -0,0 +1,195 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import type { User } from '../../src/models/user.js';
+import type { Order } from '../../src/models/order.js';
+
+describe('AnalyticsService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let orderRepo: OrderRepository;
+  let service: AnalyticsService;
+
+  const makeUser = (overrides?: Partial<User>): User => ({
+    id: 'user-1',
+    name: 'Alice',
+    email: 'alice@example.com',
+    role: 'member',
+    createdAt: new Date('2024-01-01'),
+    updatedAt: new Date('2024-01-01'),
+    ...overrides,
+  });
+
+  const makeOrder = (overrides?: Partial<Order>): Order => ({
+    id: 'order-1',
+    userId: 'user-1',
+    items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+    total: 20,
+    status: 'pending',
+    createdAt: new Date('2024-01-15'),
+    updatedAt: new Date('2024-01-15'),
+    ...overrides,
+  });
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    orderRepo = new OrderRepository(db);
+    service = new AnalyticsService(userRepo, orderRepo);
+  });
+
+  describe('getSummary', () => {
+    it('should return zeros when no data exists', () => {
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(0);
+      expect(summary.totalOrders).toBe(0);
+      expect(summary.revenue).toBe(0);
+      expect(summary.activeUsers).toBe(0);
+    });
+
+    it('should aggregate stats from users and orders', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2', email: 'bob@example.com' }));
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 50 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', total: 30 }));
+      orderRepo.save(makeOrder({ id: 'order-3', userId: 'user-2', total: 20 }));
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(2);
+      expect(summary.totalOrders).toBe(3);
+      expect(summary.revenue).toBe(100);
+      expect(summary.activeUsers).toBe(2);
+    });
+
+    it('should count active users as those with orders', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2', email: 'bob@example.com' }));
+      userRepo.save(makeUser({ id: 'user-3', email: 'charlie@example.com' }));
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1' }));
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(3);
+      expect(summary.activeUsers).toBe(1);
+    });
+  });
+
+  describe('getUserAnalytics', () => {
+    it('should throw for non-existent user', () => {
+      expect(() => service.getUserAnalytics('nonexistent')).toThrow('User not found');
+    });
+
+    it('should return analytics for user with no orders', () => {
+      const user = makeUser({ createdAt: new Date('2024-01-01') });
+      userRepo.save(user);
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.userId).toBe('user-1');
+      expect(analytics.orderCount).toBe(0);
+      expect(analytics.totalSpent).toBe(0);
+      expect(analytics.lastActive).toEqual(new Date('2024-01-01'));
+    });
+
+    it('should calculate per-user order stats', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({ id: 'order-1', total: 50, createdAt: new Date('2024-02-01') }));
+      orderRepo.save(makeOrder({ id: 'order-2', total: 30, createdAt: new Date('2024-03-01') }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.orderCount).toBe(2);
+      expect(analytics.totalSpent).toBe(80);
+      expect(analytics.lastActive).toEqual(new Date('2024-03-01'));
+    });
+
+    it('should use the latest order date as lastActive', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({ id: 'order-1', createdAt: new Date('2024-03-15') }));
+      orderRepo.save(makeOrder({ id: 'order-2', createdAt: new Date('2024-01-10') }));
+      orderRepo.save(makeOrder({ id: 'order-3', createdAt: new Date('2024-02-20') }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.lastActive).toEqual(new Date('2024-03-15'));
+    });
+  });
+
+  describe('getTrends', () => {
+    it('should throw if startDate is after endDate', () => {
+      expect(() =>
+        service.getTrends('revenue', new Date('2024-02-01'), new Date('2024-01-01')),
+      ).toThrow('startDate must be before endDate');
+    });
+
+    it('should throw for unknown metric', () => {
+      expect(() =>
+        service.getTrends('unknown', new Date('2024-01-01'), new Date('2024-12-31')),
+      ).toThrow('Unknown metric: unknown');
+    });
+
+    it('should return empty array when no orders in range', () => {
+      const trends = service.getTrends('revenue', new Date('2024-01-01'), new Date('2024-12-31'));
+
+      expect(trends).toHaveLength(0);
+    });
+
+    it('should aggregate revenue by day', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({ id: 'o1', total: 50, createdAt: new Date('2024-01-15T10:00:00Z') }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 30, createdAt: new Date('2024-01-15T14:00:00Z') }));
+      orderRepo.save(makeOrder({ id: 'o3', total: 20, createdAt: new Date('2024-01-16T09:00:00Z') }));
+
+      const trends = service.getTrends('revenue', new Date('2024-01-01'), new Date('2024-01-31'));
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0].timestamp).toEqual(new Date('2024-01-15'));
+      expect(trends[0].metric).toBe('revenue');
+      expect(trends[0].value).toBe(80);
+      expect(trends[1].timestamp).toEqual(new Date('2024-01-16'));
+      expect(trends[1].value).toBe(20);
+    });
+
+    it('should aggregate order count by day', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({ id: 'o1', createdAt: new Date('2024-01-15T10:00:00Z') }));
+      orderRepo.save(makeOrder({ id: 'o2', createdAt: new Date('2024-01-15T14:00:00Z') }));
+      orderRepo.save(makeOrder({ id: 'o3', createdAt: new Date('2024-01-16T09:00:00Z') }));
+
+      const trends = service.getTrends('orders', new Date('2024-01-01'), new Date('2024-01-31'));
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0].value).toBe(2);
+      expect(trends[1].value).toBe(1);
+    });
+
+    it('should only include orders within the date range', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({ id: 'o1', total: 10, createdAt: new Date('2024-01-10') }));
+      orderRepo.save(makeOrder({ id: 'o2', total: 20, createdAt: new Date('2024-01-20') }));
+      orderRepo.save(makeOrder({ id: 'o3', total: 30, createdAt: new Date('2024-02-05') }));
+
+      const trends = service.getTrends('revenue', new Date('2024-01-15'), new Date('2024-01-31'));
+
+      expect(trends).toHaveLength(1);
+      expect(trends[0].value).toBe(20);
+    });
+
+    it('should return trend points sorted by timestamp', () => {
+      userRepo.save(makeUser());
+      orderRepo.save(makeOrder({ id: 'o1', createdAt: new Date('2024-01-20T10:00:00Z') }));
+      orderRepo.save(makeOrder({ id: 'o2', createdAt: new Date('2024-01-10T10:00:00Z') }));
+      orderRepo.save(makeOrder({ id: 'o3', createdAt: new Date('2024-01-15T10:00:00Z') }));
+
+      const trends = service.getTrends('orders', new Date('2024-01-01'), new Date('2024-01-31'));
+
+      expect(trends).toHaveLength(3);
+      expect(trends[0].timestamp.getTime()).toBeLessThan(trends[1].timestamp.getTime());
+      expect(trends[1].timestamp.getTime()).toBeLessThan(trends[2].timestamp.getTime());
+    });
+  });
+});
