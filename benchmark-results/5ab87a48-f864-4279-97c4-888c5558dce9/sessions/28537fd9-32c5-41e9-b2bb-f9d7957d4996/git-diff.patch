+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import type { User } from '../../src/models/user.js';
+import type { Order } from '../../src/models/order.js';
+
+describe('AnalyticsService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let orderRepo: OrderRepository;
+  let service: AnalyticsService;
+
+  const now = new Date('2025-06-15T12:00:00Z');
+
+  function createUser(id: string, name: string): User {
+    const user: User = {
+      id,
+      name,
+      email: `${name.toLowerCase()}@example.com`,
+      role: 'member',
+      createdAt: now,
+      updatedAt: now,
+    };
+    userRepo.save(user);
+    return user;
+  }
+
+  function createOrder(id: string, userId: string, total: number, createdAt: Date = now): Order {
+    const order: Order = {
+      id,
+      userId,
+      items: [{ productId: 'p1', name: 'Item', quantity: 1, unitPrice: total }],
+      total,
+      status: 'pending',
+      createdAt,
+      updatedAt: createdAt,
+    };
+    orderRepo.save(order);
+    return order;
+  }
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    orderRepo = new OrderRepository(db);
+    service = new AnalyticsService(userRepo, orderRepo);
+  });
+
+  describe('getSummary', () => {
+    it('should return zeros when no data exists', () => {
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(0);
+      expect(summary.totalOrders).toBe(0);
+      expect(summary.revenue).toBe(0);
+      expect(summary.activeUsers).toBe(0);
+    });
+
+    it('should aggregate stats from users and orders', () => {
+      createUser('u1', 'Alice');
+      createUser('u2', 'Bob');
+      createUser('u3', 'Charlie');
+
+      createOrder('o1', 'u1', 100);
+      createOrder('o2', 'u1', 50);
+      createOrder('o3', 'u2', 200);
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(3);
+      expect(summary.totalOrders).toBe(3);
+      expect(summary.revenue).toBe(350);
+      expect(summary.activeUsers).toBe(2);
+    });
+  });
+
+  describe('getUserAnalytics', () => {
+    it('should throw for non-existent user', () => {
+      expect(() => service.getUserAnalytics('nonexistent')).toThrow('User not found');
+    });
+
+    it('should return analytics for a user with no orders', () => {
+      const user = createUser('u1', 'Alice');
+
+      const analytics = service.getUserAnalytics('u1');
+
+      expect(analytics.userId).toBe('u1');
+      expect(analytics.orderCount).toBe(0);
+      expect(analytics.totalSpent).toBe(0);
+      expect(analytics.lastActive).toEqual(user.createdAt);
+    });
+
+    it('should return analytics for a user with orders', () => {
+      createUser('u1', 'Alice');
+
+      const laterDate = new Date('2025-06-20T12:00:00Z');
+      createOrder('o1', 'u1', 100, now);
+      createOrder('o2', 'u1', 50, laterDate);
+
+      const analytics = service.getUserAnalytics('u1');
+
+      expect(analytics.userId).toBe('u1');
+      expect(analytics.orderCount).toBe(2);
+      expect(analytics.totalSpent).toBe(150);
+      expect(analytics.lastActive).toEqual(laterDate);
+    });
+  });
+
+  describe('getTrends', () => {
+    it('should throw for unsupported metric', () => {
+      expect(() =>
+        service.getTrends('invalid', new Date(), new Date()),
+      ).toThrow('Unsupported metric');
+    });
+
+    it('should return empty array when no orders in range', () => {
+      const trends = service.getTrends(
+        'orders',
+        new Date('2025-01-01'),
+        new Date('2025-01-31'),
+      );
+
+      expect(trends).toHaveLength(0);
+    });
+
+    it('should return order count trends grouped by day', () => {
+      createUser('u1', 'Alice');
+
+      const day1 = new Date('2025-06-10T10:00:00Z');
+      const day1Later = new Date('2025-06-10T14:00:00Z');
+      const day2 = new Date('2025-06-11T09:00:00Z');
+
+      createOrder('o1', 'u1', 100, day1);
+      createOrder('o2', 'u1', 50, day1Later);
+      createOrder('o3', 'u1', 200, day2);
+
+      const trends = service.getTrends(
+        'orders',
+        new Date('2025-06-10'),
+        new Date('2025-06-12'),
+      );
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0]!.timestamp).toEqual(new Date('2025-06-10'));
+      expect(trends[0]!.metric).toBe('orders');
+      expect(trends[0]!.value).toBe(2);
+      expect(trends[1]!.timestamp).toEqual(new Date('2025-06-11'));
+      expect(trends[1]!.value).toBe(1);
+    });
+
+    it('should return revenue trends grouped by day', () => {
+      createUser('u1', 'Alice');
+
+      const day1 = new Date('2025-06-10T10:00:00Z');
+      const day2 = new Date('2025-06-11T09:00:00Z');
+
+      createOrder('o1', 'u1', 100, day1);
+      createOrder('o2', 'u1', 50, day1);
+      createOrder('o3', 'u1', 200, day2);
+
+      const trends = service.getTrends(
+        'revenue',
+        new Date('2025-06-10'),
+        new Date('2025-06-12'),
+      );
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0]!.value).toBe(150);
+      expect(trends[1]!.value).toBe(200);
+    });
+
+    it('should filter orders outside the date range', () => {
+      createUser('u1', 'Alice');
+
+      createOrder('o1', 'u1', 100, new Date('2025-06-09T23:00:00Z'));
+      createOrder('o2', 'u1', 50, new Date('2025-06-10T10:00:00Z'));
+      createOrder('o3', 'u1', 200, new Date('2025-06-13T10:00:00Z'));
+
+      const trends = service.getTrends(
+        'orders',
+        new Date('2025-06-10'),
+        new Date('2025-06-12'),
+      );
+
+      expect(trends).toHaveLength(1);
+      expect(trends[0]!.value).toBe(1);
+    });
+  });
+});
