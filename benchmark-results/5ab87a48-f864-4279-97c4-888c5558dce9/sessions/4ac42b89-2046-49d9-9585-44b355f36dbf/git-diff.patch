+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import type { User } from '../../src/models/user.js';
+import type { Order } from '../../src/models/order.js';
+
+describe('AnalyticsService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let orderRepo: OrderRepository;
+  let service: AnalyticsService;
+
+  const now = new Date('2025-06-15T12:00:00Z');
+
+  function makeUser(overrides: Partial<User> & { id: string }): User {
+    return {
+      name: 'Test User',
+      email: `${overrides.id}@example.com`,
+      role: 'member',
+      createdAt: now,
+      updatedAt: now,
+      ...overrides,
+    };
+  }
+
+  function makeOrder(overrides: Partial<Order> & { id: string; userId: string }): Order {
+    return {
+      items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 50 }],
+      total: 50,
+      status: 'pending',
+      createdAt: now,
+      updatedAt: now,
+      ...overrides,
+    };
+  }
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    orderRepo = new OrderRepository(db);
+    service = new AnalyticsService(userRepo, orderRepo);
+  });
+
+  describe('getSummary', () => {
+    it('should return zeros when no data exists', () => {
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(0);
+      expect(summary.totalOrders).toBe(0);
+      expect(summary.revenue).toBe(0);
+      expect(summary.activeUsers).toBe(0);
+    });
+
+    it('should aggregate user and order data', () => {
+      userRepo.save(makeUser({ id: 'user-1', name: 'Alice' }));
+      userRepo.save(makeUser({ id: 'user-2', name: 'Bob' }));
+      userRepo.save(makeUser({ id: 'user-3', name: 'Charlie' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 100 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', total: 200 }));
+      orderRepo.save(makeOrder({ id: 'order-3', userId: 'user-2', total: 50 }));
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(3);
+      expect(summary.totalOrders).toBe(3);
+      expect(summary.revenue).toBe(350);
+      expect(summary.activeUsers).toBe(2);
+    });
+
+    it('should count active users as those with orders', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1' }));
+
+      const summary = service.getSummary();
+
+      expect(summary.activeUsers).toBe(1);
+    });
+  });
+
+  describe('getUserAnalytics', () => {
+    it('should throw for non-existent user', () => {
+      expect(() => service.getUserAnalytics('nonexistent')).toThrow('User not found');
+    });
+
+    it('should return analytics for a user with no orders', () => {
+      userRepo.save(makeUser({ id: 'user-1', updatedAt: now }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.userId).toBe('user-1');
+      expect(analytics.orderCount).toBe(0);
+      expect(analytics.totalSpent).toBe(0);
+      expect(analytics.lastActive).toEqual(now);
+    });
+
+    it('should calculate order count and total spent', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 100 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', total: 75 }));
+      orderRepo.save(makeOrder({ id: 'order-3', userId: 'user-1', total: 25 }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.orderCount).toBe(3);
+      expect(analytics.totalSpent).toBe(200);
+    });
+
+    it('should use most recent order date as lastActive', () => {
+      const earlier = new Date('2025-06-10T12:00:00Z');
+      const later = new Date('2025-06-20T12:00:00Z');
+
+      userRepo.save(makeUser({ id: 'user-1', updatedAt: earlier }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', updatedAt: earlier }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', updatedAt: later }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.lastActive).toEqual(later);
+    });
+
+    it('should not include orders from other users', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 100 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-2', total: 200 }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.orderCount).toBe(1);
+      expect(analytics.totalSpent).toBe(100);
+    });
+  });
+
+  describe('getTrends', () => {
+    it('should throw for unsupported metric', () => {
+      expect(() =>
+        service.getTrends('invalid', now, now),
+      ).toThrow('Unsupported metric');
+    });
+
+    it('should return empty array when no orders in range', () => {
+      const startDate = new Date('2025-06-01T00:00:00Z');
+      const endDate = new Date('2025-06-30T23:59:59Z');
+
+      const trends = service.getTrends('orders', startDate, endDate);
+
+      expect(trends).toHaveLength(0);
+    });
+
+    it('should count orders per day for orders metric', () => {
+      const day1 = new Date('2025-06-10T10:00:00Z');
+      const day2 = new Date('2025-06-11T14:00:00Z');
+
+      userRepo.save(makeUser({ id: 'user-1' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', createdAt: day1 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', createdAt: day1 }));
+      orderRepo.save(makeOrder({ id: 'order-3', userId: 'user-1', createdAt: day2 }));
+
+      const trends = service.getTrends(
+        'orders',
+        new Date('2025-06-01T00:00:00Z'),
+        new Date('2025-06-30T23:59:59Z'),
+      );
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0]!.metric).toBe('orders');
+      expect(trends[0]!.value).toBe(2);
+      expect(trends[1]!.value).toBe(1);
+    });
+
+    it('should sum revenue per day for revenue metric', () => {
+      const day1 = new Date('2025-06-10T10:00:00Z');
+
+      userRepo.save(makeUser({ id: 'user-1' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 100, createdAt: day1 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', total: 50, createdAt: day1 }));
+
+      const trends = service.getTrends(
+        'revenue',
+        new Date('2025-06-01T00:00:00Z'),
+        new Date('2025-06-30T23:59:59Z'),
+      );
+
+      expect(trends).toHaveLength(1);
+      expect(trends[0]!.metric).toBe('revenue');
+      expect(trends[0]!.value).toBe(150);
+    });
+
+    it('should filter orders outside the date range', () => {
+      const inRange = new Date('2025-06-15T10:00:00Z');
+      const outOfRange = new Date('2025-07-15T10:00:00Z');
+
+      userRepo.save(makeUser({ id: 'user-1' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', createdAt: inRange }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', createdAt: outOfRange }));
+
+      const trends = service.getTrends(
+        'orders',
+        new Date('2025-06-01T00:00:00Z'),
+        new Date('2025-06-30T23:59:59Z'),
+      );
+
+      expect(trends).toHaveLength(1);
+      expect(trends[0]!.value).toBe(1);
+    });
+
+    it('should return trend points sorted by timestamp', () => {
+      const day1 = new Date('2025-06-20T10:00:00Z');
+      const day2 = new Date('2025-06-10T10:00:00Z');
+
+      userRepo.save(makeUser({ id: 'user-1' }));
+
+      // Insert in reverse chronological order
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', createdAt: day1 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', createdAt: day2 }));
+
+      const trends = service.getTrends(
+        'orders',
+        new Date('2025-06-01T00:00:00Z'),
+        new Date('2025-06-30T23:59:59Z'),
+      );
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0]!.timestamp.getTime()).toBeLessThan(trends[1]!.timestamp.getTime());
+    });
+  });
+});
