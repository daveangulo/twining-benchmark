+/**
+ * Analytics route handlers — framework-agnostic HTTP layer.
+ *
+ * This codebase has no HTTP framework dependency, so these handlers are
+ * plain async functions that accept typed request params and return typed
+ * response payloads. When an HTTP framework (Express, Fastify, Hono, etc.)
+ * is introduced, a thin adapter should map incoming requests to these
+ * functions.
+ *
+ * Route map:
+ *   GET /api/analytics/dashboard           → handleGetDashboard
+ *   GET /api/analytics/metrics/:metricType → handleGetMetric
+ *
+ * Each handler:
+ * 1. Parses & validates input (date strings → Date objects, enum checks).
+ * 2. Delegates to AnalyticsService.
+ * 3. Returns a typed response (or throws an Error for the framework to map
+ *    to an HTTP status code).
+ */
+
+import type { AnalyticsService } from '../services/analytics.service.js';
+import type {
+  AnalyticsQuery,
+  DashboardData,
+  MetricResponse,
+  MetricType,
+  TimeGranularity,
+} from '../models/analytics.js';
+
+// ---------------------------------------------------------------------------
+// Route definitions (for documentation / code-gen)
+// ---------------------------------------------------------------------------
+
+/**
+ * Describes a single API route for documentation or router registration.
+ */
+export interface RouteDefinition {
+  method: 'GET' | 'POST' | 'PUT' | 'DELETE';
+  path: string;
+  description: string;
+}
+
+/**
+ * All analytics routes. Use this array to auto-register routes in your
+ * framework of choice.
+ */
+export const analyticsRoutes: RouteDefinition[] = [
+  {
+    method: 'GET',
+    path: '/api/analytics/dashboard',
+    description: 'Full dashboard snapshot with all widgets',
+  },
+  {
+    method: 'GET',
+    path: '/api/analytics/metrics/:metricType',
+    description: 'Summary + time series for a single metric',
+  },
+];
+
+// ---------------------------------------------------------------------------
+// Shared validation helpers
+// ---------------------------------------------------------------------------
+
+const VALID_GRANULARITIES: TimeGranularity[] = ['hour', 'day', 'week', 'month'];
+const VALID_METRIC_TYPES: MetricType[] = [
+  'revenue',
+  'orders',
+  'users',
+  'average-order-value',
+];
+
+/**
+ * Raw query-string parameters before validation.
+ * Represents what the HTTP layer would pass in.
+ */
+export interface RawAnalyticsQueryParams {
+  startDate?: string;
+  endDate?: string;
+  granularity?: string;
+}
+
+/**
+ * Parse and validate common analytics query-string parameters.
+ * Throws descriptive errors that the HTTP layer can map to 400 responses.
+ */
+export function parseAnalyticsQuery(raw: RawAnalyticsQueryParams): AnalyticsQuery {
+  if (!raw.startDate) {
+    throw new Error('Missing required query parameter: startDate');
+  }
+  if (!raw.endDate) {
+    throw new Error('Missing required query parameter: endDate');
+  }
+
+  const startDate = new Date(raw.startDate);
+  const endDate = new Date(raw.endDate);
+
+  if (isNaN(startDate.getTime())) {
+    throw new Error(`Invalid startDate: ${raw.startDate}`);
+  }
+  if (isNaN(endDate.getTime())) {
+    throw new Error(`Invalid endDate: ${raw.endDate}`);
+  }
+  if (startDate >= endDate) {
+    throw new Error('startDate must be before endDate');
+  }
+
+  let granularity: TimeGranularity | undefined;
+  if (raw.granularity) {
+    if (!VALID_GRANULARITIES.includes(raw.granularity as TimeGranularity)) {
+      throw new Error(
+        `Invalid granularity "${raw.granularity}". Must be one of: ${VALID_GRANULARITIES.join(', ')}`,
+      );
+    }
+    granularity = raw.granularity as TimeGranularity;
+  }
+
+  return { startDate, endDate, granularity };
+}
+
+/**
+ * Validate a metric type path parameter.
+ */
+export function parseMetricType(raw: string): MetricType {
+  if (!VALID_METRIC_TYPES.includes(raw as MetricType)) {
+    throw new Error(
+      `Invalid metric type "${raw}". Must be one of: ${VALID_METRIC_TYPES.join(', ')}`,
+    );
+  }
+  return raw as MetricType;
+}
+
+// ---------------------------------------------------------------------------
+// Route handlers
+// ---------------------------------------------------------------------------
+
+/**
+ * Handler for GET /api/analytics/dashboard
+ *
+ * Query params: startDate, endDate, granularity (optional)
+ */
+export async function handleGetDashboard(
+  analyticsService: AnalyticsService,
+  queryParams: RawAnalyticsQueryParams,
+): Promise<DashboardData> {
+  const query = parseAnalyticsQuery(queryParams);
+  return analyticsService.getDashboard(query);
+}
+
+/**
+ * Handler for GET /api/analytics/metrics/:metricType
+ *
+ * Path params: metricType
+ * Query params: startDate, endDate, granularity (optional)
+ */
+export async function handleGetMetric(
+  analyticsService: AnalyticsService,
+  metricTypeParam: string,
+  queryParams: RawAnalyticsQueryParams,
+): Promise<MetricResponse> {
+  const metricType = parseMetricType(metricTypeParam);
+  const query = parseAnalyticsQuery(queryParams);
+  return analyticsService.getMetric({ ...query, metricType });
+}
