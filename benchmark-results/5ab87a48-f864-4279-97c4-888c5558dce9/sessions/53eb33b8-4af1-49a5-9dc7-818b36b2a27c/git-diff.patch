+/**
+ * Analytics data models for the dashboard API.
+ *
+ * These types define the contract between the analytics service layer
+ * and any consuming route handler or client. Downstream implementers
+ * should build aggregation logic that produces these shapes from the
+ * existing Order and User data.
+ */
+
+// ---------------------------------------------------------------------------
+// Query parameters
+// ---------------------------------------------------------------------------
+
+/**
+ * Granularity for time-series data points.
+ */
+export type TimeGranularity = 'hour' | 'day' | 'week' | 'month';
+
+/**
+ * Metric types the analytics API can return.
+ * Extensible — add new literals as new metrics are implemented.
+ */
+export type MetricType = 'revenue' | 'orders' | 'users' | 'average-order-value';
+
+/**
+ * Common query parameters shared by all analytics endpoints.
+ */
+export interface AnalyticsQuery {
+  /** Inclusive start of the date range */
+  startDate: Date;
+  /** Inclusive end of the date range */
+  endDate: Date;
+  /** Bucket size for time-series data (default: 'day') */
+  granularity?: TimeGranularity;
+}
+
+/**
+ * Query parameters for the metrics endpoint.
+ */
+export interface MetricsQuery extends AnalyticsQuery {
+  /** Which metric to retrieve */
+  metricType: MetricType;
+}
+
+// ---------------------------------------------------------------------------
+// Response shapes
+// ---------------------------------------------------------------------------
+
+/**
+ * A single data point in a time series.
+ */
+export interface TimeSeriesPoint {
+  /** Start of the time bucket (ISO-8601) */
+  timestamp: Date;
+  /** Aggregated value for this bucket */
+  value: number;
+  /** Optional label (e.g. "Mon", "Week 12") */
+  label?: string;
+}
+
+/**
+ * Summary statistics for a single metric.
+ */
+export interface MetricSummary {
+  /** Which metric this summarises */
+  metricType: MetricType;
+  /** Current value for the queried period */
+  currentValue: number;
+  /** Value for the previous period of equal length (for comparison) */
+  previousValue: number;
+  /** Percentage change: ((current - previous) / previous) * 100 */
+  changePercent: number;
+  /** Positive means improvement, negative means decline */
+  trend: 'up' | 'down' | 'flat';
+}
+
+/**
+ * Breakdown of orders by their current status.
+ */
+export interface OrderStatusBreakdown {
+  status: string;
+  count: number;
+  /** Percentage of total orders */
+  percent: number;
+}
+
+/**
+ * A row in the "top users" leaderboard.
+ */
+export interface TopUser {
+  userId: string;
+  userName: string;
+  totalOrders: number;
+  totalRevenue: number;
+}
+
+/**
+ * Full dashboard payload returned by GET /api/analytics/dashboard.
+ * Provides a high-level snapshot so the UI can render all widgets
+ * in a single request.
+ */
+export interface DashboardData {
+  /** Summary cards at the top of the dashboard */
+  metrics: MetricSummary[];
+  /** Revenue over time for the primary chart */
+  revenueTimeSeries: TimeSeriesPoint[];
+  /** Orders over time for the secondary chart */
+  ordersTimeSeries: TimeSeriesPoint[];
+  /** Donut / pie chart data */
+  orderStatusBreakdown: OrderStatusBreakdown[];
+  /** Leaderboard widget */
+  topUsers: TopUser[];
+  /** When this snapshot was computed */
+  generatedAt: Date;
+}
+
+/**
+ * Response wrapper for a single metric endpoint.
+ */
+export interface MetricResponse {
+  summary: MetricSummary;
+  timeSeries: TimeSeriesPoint[];
+  query: {
+    metricType: MetricType;
+    startDate: Date;
+    endDate: Date;
+    granularity: TimeGranularity;
+  };
+}
