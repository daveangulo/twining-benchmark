+/**
+ * Analytics data models for the dashboard feature.
+ *
+ * These interfaces define the shape of analytics data flowing through
+ * the system — from query parameters, through aggregation, to API responses.
+ *
+ * Design decisions:
+ * - TimeRange is explicit (start/end dates) rather than relative ("last 7 days")
+ *   so that aggregation logic is deterministic and testable.
+ * - MetricType is a union type to enable type-safe metric routing.
+ * - All response types include the query that produced them for debuggability.
+ */
+
+import type { OrderStatus } from './order.js';
+
+// ---------------------------------------------------------------------------
+// Query types — inputs to the analytics service
+// ---------------------------------------------------------------------------
+
+/**
+ * Supported metric categories for analytics queries.
+ */
+export type MetricType = 'revenue' | 'orders' | 'users' | 'conversion';
+
+/**
+ * Granularity for time-series data points.
+ */
+export type TimeGranularity = 'hour' | 'day' | 'week' | 'month';
+
+/**
+ * Time range for analytics queries. Both bounds are inclusive.
+ */
+export interface TimeRange {
+  /** Start of the query window (inclusive) */
+  start: Date;
+  /** End of the query window (inclusive) */
+  end: Date;
+}
+
+/**
+ * Query parameters for fetching analytics data.
+ * Used by both the dashboard endpoint and individual metric endpoints.
+ */
+export interface AnalyticsQuery {
+  /** Time range to aggregate over */
+  timeRange: TimeRange;
+  /** Granularity for time-series breakdown */
+  granularity: TimeGranularity;
+  /** Optional: filter to a specific metric type */
+  metricType?: MetricType;
+  /** Optional: filter to a specific user */
+  userId?: string;
+}
+
+// ---------------------------------------------------------------------------
+// Core data types — output from aggregation
+// ---------------------------------------------------------------------------
+
+/**
+ * A single point in a time-series dataset.
+ */
+export interface TimeSeriesPoint {
+  /** The timestamp this data point represents (start of the bucket) */
+  timestamp: Date;
+  /** The aggregated value for this time bucket */
+  value: number;
+  /** Optional label for display (e.g., "Mon", "Jan 2026") */
+  label: string;
+}
+
+/**
+ * Summary statistics for a single metric.
+ */
+export interface MetricSummary {
+  /** Which metric this summary describes */
+  type: MetricType;
+  /** Current value for the queried period */
+  currentValue: number;
+  /** Value from the previous equivalent period (for comparison) */
+  previousValue: number;
+  /** Percentage change from previous to current period */
+  changePercent: number;
+  /** Direction of change */
+  trend: 'up' | 'down' | 'flat';
+  /** Time-series breakdown for this metric */
+  timeSeries: TimeSeriesPoint[];
+}
+
+/**
+ * Breakdown of orders by their current status.
+ */
+export interface OrderStatusBreakdown {
+  /** The order status */
+  status: OrderStatus;
+  /** Number of orders in this status */
+  count: number;
+  /** Percentage of total orders */
+  percentage: number;
+}
+
+/**
+ * A row in the top-users leaderboard.
+ */
+export interface TopUser {
+  /** User ID */
+  userId: string;
+  /** User display name */
+  userName: string;
+  /** Total order count for this user in the period */
+  orderCount: number;
+  /** Total revenue from this user in the period */
+  totalRevenue: number;
+}
+
+// ---------------------------------------------------------------------------
+// API response types — what the route handlers return
+// ---------------------------------------------------------------------------
+
+/**
+ * Full dashboard response combining all metric summaries.
+ * Returned by GET /api/analytics/dashboard
+ */
+export interface DashboardData {
+  /** The query that produced this data */
+  query: AnalyticsQuery;
+  /** Summary for each metric type */
+  metrics: MetricSummary[];
+  /** Order status distribution */
+  orderStatusBreakdown: OrderStatusBreakdown[];
+  /** Top users by revenue in the period */
+  topUsers: TopUser[];
+  /** When this data was generated */
+  generatedAt: Date;
+}
+
+/**
+ * Response for a single metric detail endpoint.
+ * Returned by GET /api/analytics/metrics/:type
+ */
+export interface MetricDetailResponse {
+  /** The query that produced this data */
+  query: AnalyticsQuery;
+  /** Detailed summary for the requested metric */
+  metric: MetricSummary;
+  /** When this data was generated */
+  generatedAt: Date;
+}
+
+/**
+ * Response for the order status breakdown endpoint.
+ * Returned by GET /api/analytics/orders/status
+ */
+export interface OrderStatusResponse {
+  /** The query that produced this data */
+  query: AnalyticsQuery;
+  /** Breakdown by status */
+  breakdown: OrderStatusBreakdown[];
+  /** Total orders in the period */
+  totalOrders: number;
+  /** When this data was generated */
+  generatedAt: Date;
+}
+
+/**
+ * Response for the top users endpoint.
+ * Returned by GET /api/analytics/users/top
+ */
+export interface TopUsersResponse {
+  /** The query that produced this data */
+  query: AnalyticsQuery;
+  /** Ranked list of top users */
+  users: TopUser[];
+  /** How many users are included */
+  limit: number;
+  /** When this data was generated */
+  generatedAt: Date;
+}
