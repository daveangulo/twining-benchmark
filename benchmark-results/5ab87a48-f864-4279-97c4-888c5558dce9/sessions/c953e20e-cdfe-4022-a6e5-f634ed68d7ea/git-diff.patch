+// ---------------------------------------------------------------------------
+// Error response helper
+// ---------------------------------------------------------------------------
+
+/**
+ * Convert a caught error into a structured 400 error response.
+ * Validation errors from parse functions are treated as bad requests.
+ */
+function toErrorResponse(error: unknown): ApiResponse<never> {
+  const message =
+    error instanceof Error ? error.message : 'An unexpected error occurred';
+  return { success: false, status: 400, error: message };
