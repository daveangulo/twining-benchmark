+/**
+ * Standardized API response wrapper. All route handlers return this shape
+ * so framework adapters can map `status` to HTTP status codes consistently.
+ */
+export interface ApiResponse<T> {
+  /** Whether the request succeeded */
+  success: boolean;
+  /** HTTP-equivalent status code */
+  status: number;
+  /** Response payload (present on success) */
+  data?: T;
+  /** Error message (present on failure) */
+  error?: string;
+}
