+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import type { User } from '../../src/models/user.js';
+import type { Order } from '../../src/models/order.js';
+
+const makeUser = (overrides?: Partial<User>): User => ({
+  id: 'user-1',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date('2024-01-01'),
+  updatedAt: new Date('2024-01-01'),
+  ...overrides,
+});
+
+const makeOrder = (overrides?: Partial<Order>): Order => ({
+  id: 'order-1',
+  userId: 'user-1',
+  items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+  total: 20,
+  status: 'pending',
+  createdAt: new Date('2024-03-15'),
+  updatedAt: new Date('2024-03-15'),
+  ...overrides,
+});
+
+describe('AnalyticsService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let orderRepo: OrderRepository;
+  let service: AnalyticsService;
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    orderRepo = new OrderRepository(db);
+    service = new AnalyticsService(userRepo, orderRepo);
+  });
+
+  describe('getSummary', () => {
+    it('should return zeros when no data exists', () => {
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(0);
+      expect(summary.totalOrders).toBe(0);
+      expect(summary.revenue).toBe(0);
+      expect(summary.activeUsers).toBe(0);
+    });
+
+    it('should aggregate stats from users and orders', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2', email: 'bob@example.com' }));
+      userRepo.save(makeUser({ id: 'user-3', email: 'carol@example.com' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 50 }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', total: 30 }));
+      orderRepo.save(makeOrder({ id: 'order-3', userId: 'user-2', total: 20 }));
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(3);
+      expect(summary.totalOrders).toBe(3);
+      expect(summary.revenue).toBe(100);
+      expect(summary.activeUsers).toBe(2);
+    });
+
+    it('should count active users as those with orders', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2', email: 'bob@example.com' }));
+
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 10 }));
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(2);
+      expect(summary.activeUsers).toBe(1);
+    });
+  });
+
+  describe('getUserAnalytics', () => {
+    it('should return analytics for a user with orders', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      orderRepo.save(makeOrder({ id: 'order-1', userId: 'user-1', total: 50, createdAt: new Date('2024-02-01') }));
+      orderRepo.save(makeOrder({ id: 'order-2', userId: 'user-1', total: 30, createdAt: new Date('2024-03-01') }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.userId).toBe('user-1');
+      expect(analytics.orderCount).toBe(2);
+      expect(analytics.totalSpent).toBe(80);
+      expect(analytics.lastActive).toEqual(new Date('2024-03-01'));
+    });
+
+    it('should return user creation date as lastActive when no orders', () => {
+      const createdAt = new Date('2024-01-15');
+      userRepo.save(makeUser({ id: 'user-1', createdAt }));
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.orderCount).toBe(0);
+      expect(analytics.totalSpent).toBe(0);
+      expect(analytics.lastActive).toEqual(createdAt);
+    });
+
+    it('should throw for non-existent user', () => {
+      expect(() => service.getUserAnalytics('nonexistent')).toThrow('User not found');
+    });
+  });
+
+  describe('getTrends', () => {
+    it('should return empty array when no orders in range', () => {
+      const points = service.getTrends('orders', new Date('2024-01-01'), new Date('2024-01-31'));
+
+      expect(points).toEqual([]);
+    });
+
+    it('should return daily order count trends', () => {
+      orderRepo.save(makeOrder({ id: 'order-1', createdAt: new Date('2024-03-01T10:00:00Z'), total: 10 }));
+      orderRepo.save(makeOrder({ id: 'order-2', createdAt: new Date('2024-03-01T14:00:00Z'), total: 20 }));
+      orderRepo.save(makeOrder({ id: 'order-3', createdAt: new Date('2024-03-02T09:00:00Z'), total: 30 }));
+
+      const points = service.getTrends('orders', new Date('2024-03-01'), new Date('2024-03-31'));
+
+      expect(points).toHaveLength(2);
+      expect(points[0]!.metric).toBe('orders');
+      expect(points[0]!.value).toBe(2); // two orders on March 1
+      expect(points[1]!.value).toBe(1); // one order on March 2
+    });
+
+    it('should return daily revenue trends', () => {
+      orderRepo.save(makeOrder({ id: 'order-1', createdAt: new Date('2024-03-01T10:00:00Z'), total: 10 }));
+      orderRepo.save(makeOrder({ id: 'order-2', createdAt: new Date('2024-03-01T14:00:00Z'), total: 20 }));
+      orderRepo.save(makeOrder({ id: 'order-3', createdAt: new Date('2024-03-02T09:00:00Z'), total: 30 }));
+
+      const points = service.getTrends('revenue', new Date('2024-03-01'), new Date('2024-03-31'));
+
+      expect(points).toHaveLength(2);
+      expect(points[0]!.metric).toBe('revenue');
+      expect(points[0]!.value).toBe(30); // $10 + $20 on March 1
+      expect(points[1]!.value).toBe(30); // $30 on March 2
+    });
+
+    it('should filter orders outside the date range', () => {
+      orderRepo.save(makeOrder({ id: 'order-1', createdAt: new Date('2024-02-28'), total: 10 }));
+      orderRepo.save(makeOrder({ id: 'order-2', createdAt: new Date('2024-03-15'), total: 20 }));
+      orderRepo.save(makeOrder({ id: 'order-3', createdAt: new Date('2024-04-01'), total: 30 }));
+
+      const points = service.getTrends('orders', new Date('2024-03-01'), new Date('2024-03-31'));
+
+      expect(points).toHaveLength(1);
+      expect(points[0]!.value).toBe(1);
+    });
+
+    it('should return points sorted by date', () => {
+      orderRepo.save(makeOrder({ id: 'order-1', createdAt: new Date('2024-03-05T10:00:00Z'), total: 10 }));
+      orderRepo.save(makeOrder({ id: 'order-2', createdAt: new Date('2024-03-01T10:00:00Z'), total: 20 }));
+      orderRepo.save(makeOrder({ id: 'order-3', createdAt: new Date('2024-03-03T10:00:00Z'), total: 30 }));
+
+      const points = service.getTrends('orders', new Date('2024-03-01'), new Date('2024-03-31'));
+
+      expect(points).toHaveLength(3);
+      expect(points[0]!.timestamp).toEqual(new Date('2024-03-01'));
+      expect(points[1]!.timestamp).toEqual(new Date('2024-03-03'));
+      expect(points[2]!.timestamp).toEqual(new Date('2024-03-05'));
+    });
+
+    it('should throw for unsupported metric', () => {
+      expect(() => service.getTrends('invalid', new Date('2024-03-01'), new Date('2024-03-31'))).toThrow(
+        'Unsupported metric',
+      );
+    });
+  });
+});
