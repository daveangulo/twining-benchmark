+/**
+ * Resolve an AnalyticsQuery into a concrete TimeRange.
+ * Mirrors the logic in AnalyticsService.resolveTimeRange.
+ */
+function resolveTimeRange(query: AnalyticsQuery): TimeRange {
+  if (query.range) {
+    return query.range;
+  }
+  const preset = query.preset ?? '7d';
+  const end = new Date();
+  const start = new Date(end.getTime() - PRESET_DURATIONS[preset]);
+  return { start, end };
+}
