+/**
+ * Summary analytics across the entire system.
+ */
+export interface AnalyticsSummary {
+  totalUsers: number;
+  totalOrders: number;
+  revenue: number;
+  activeUsers: number;
+}
+
+/**
+ * Per-user analytics breakdown.
+ */
+export interface UserAnalytics {
+  userId: string;
+  orderCount: number;
+  totalSpent: number;
+  lastActive: Date;
+}
+
+/**
+ * A single data point in a time-series trend.
+ */
+export interface TrendPoint {
+  timestamp: Date;
+  metric: string;
+  value: number;
+}
diff --git a/src/services/analytics.service.ts b/src/services/analytics.service.ts
