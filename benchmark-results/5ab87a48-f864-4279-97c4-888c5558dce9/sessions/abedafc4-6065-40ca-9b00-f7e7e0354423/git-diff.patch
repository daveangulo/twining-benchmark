+import type { Order, OrderStatus } from '../models/order.js';
+import { BaseRepository } from './base.repository.js';
+export declare class OrderRepository extends BaseRepository<Order> {
+    constructor(db: Database);
+    protected toDomain(record: DatabaseRecord): Order;
+    protected toRecord(entity: Order): DatabaseRecord;
+    /**
+     * Find all orders for a specific user.
+     */
