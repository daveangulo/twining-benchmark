diff --git a/tests/integration/analytics-pipeline.test.ts b/tests/integration/analytics-pipeline.test.ts
new file mode 100644
index 0000000..bfef40e
--- /dev/null
+++ b/tests/integration/analytics-pipeline.test.ts
@@ -0,0 +1,377 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import {
+  createAnalyticsHandlers,
+  AnalyticsValidationError,
+} from '../../src/routes/analytics.routes.js';
+import type { AnalyticsHandlers } from '../../src/routes/analytics.routes.js';
+
+// ---------------------------------------------------------------------------
+// Full pipeline integration tests: route handlers → service → data models
+// ---------------------------------------------------------------------------
+
+describe('Analytics Pipeline Integration', () => {
+  let handlers: AnalyticsHandlers;
+
+  beforeEach(() => {
+    const db = new Database();
+    const orderRepo = new OrderRepository(db);
+    const userRepo = new UserRepository(db);
+    const service = new AnalyticsService(orderRepo, userRepo);
+    handlers = createAnalyticsHandlers(service);
+  });
+
+  // -------------------------------------------------------------------------
+  // GET /api/analytics/dashboard — handleGetDashboard
+  // -------------------------------------------------------------------------
+
+  describe('handleGetDashboard', () => {
+    it('should return a complete dashboard for a valid date range', () => {
+      const result = handlers.handleGetDashboard({
+        from: '2026-01-01',
+        to: '2026-01-31',
+      });
+
+      expect(result.dateRange).toEqual({ from: '2026-01-01', to: '2026-01-31' });
+
+      // KPIs present with correct shape
+      const kpiKeys = ['totalOrders', 'totalRevenue', 'averageOrderValue', 'totalUsers'] as const;
+      for (const key of kpiKeys) {
+        const kpi = result.kpis[key];
+        expect(kpi).toHaveProperty('name');
+        expect(kpi).toHaveProperty('label');
+        expect(typeof kpi.value).toBe('number');
+        expect(typeof kpi.previousValue).toBe('number');
+        expect(typeof kpi.changePercent).toBe('number');
+        expect(['up', 'down', 'flat']).toContain(kpi.trend);
+      }
+
+      // Arrays present
+      expect(Array.isArray(result.orderTimeSeries)).toBe(true);
+      expect(Array.isArray(result.revenueTimeSeries)).toBe(true);
+      expect(Array.isArray(result.ordersByStatus)).toBe(true);
+      expect(Array.isArray(result.topProducts)).toBe(true);
+    });
+
+    it('should accept optional granularity parameter', () => {
+      const result = handlers.handleGetDashboard({
+        from: '2026-01-01',
+        to: '2026-12-31',
+        granularity: 'month',
+      });
+
+      expect(result.dateRange).toEqual({ from: '2026-01-01', to: '2026-12-31' });
+      expect(result.kpis).toBeDefined();
+    });
+
+    it('should work with a short date range (single day)', () => {
+      const result = handlers.handleGetDashboard({
+        from: '2026-06-01T00:00:00Z',
+        to: '2026-06-01T23:59:59Z',
+      });
+
+      expect(result.dateRange.from).toBe('2026-06-01T00:00:00Z');
+      expect(result.dateRange.to).toBe('2026-06-01T23:59:59Z');
+    });
+
+    it('should work with a long date range (full year)', () => {
+      const result = handlers.handleGetDashboard({
+        from: '2025-01-01',
+        to: '2025-12-31',
+      });
+
+      expect(result.dateRange).toEqual({ from: '2025-01-01', to: '2025-12-31' });
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // GET /api/analytics/metrics/:type — handleGetMetric
+  // -------------------------------------------------------------------------
+
+  describe('handleGetMetric', () => {
+    const validParams = { from: '2026-01-01', to: '2026-01-31' };
+
+    it.each(['orders', 'revenue', 'users', 'average-order-value'] as const)(
+      'should return time series for metric type "%s"',
+      (metricType) => {
+        const result = handlers.handleGetMetric(metricType, validParams);
+
+        expect(result.metric).toBe(metricType);
+        expect(result.dateRange).toEqual({ from: '2026-01-01', to: '2026-01-31' });
+        expect(result.granularity).toBeDefined();
+        expect(result.summary).toBeDefined();
+        expect(result.summary.name).toBe(metricType);
+        expect(Array.isArray(result.series)).toBe(true);
+      },
+    );
+
+    it('should auto-resolve granularity to "hour" for <= 2 day range', () => {
+      const result = handlers.handleGetMetric('orders', {
+        from: '2026-03-01',
+        to: '2026-03-02',
+      });
+      expect(result.granularity).toBe('hour');
+    });
+
+    it('should auto-resolve granularity to "day" for <= 30 day range', () => {
+      const result = handlers.handleGetMetric('revenue', {
+        from: '2026-03-01',
+        to: '2026-03-15',
+      });
+      expect(result.granularity).toBe('day');
+    });
+
+    it('should auto-resolve granularity to "week" for <= 90 day range', () => {
+      const result = handlers.handleGetMetric('users', {
+        from: '2026-01-01',
+        to: '2026-03-15',
+      });
+      expect(result.granularity).toBe('week');
+    });
+
+    it('should auto-resolve granularity to "month" for > 90 day range', () => {
+      const result = handlers.handleGetMetric('orders', {
+        from: '2026-01-01',
+        to: '2026-12-31',
+      });
+      expect(result.granularity).toBe('month');
+    });
+
+    it('should use explicit granularity when provided', () => {
+      const result = handlers.handleGetMetric('revenue', {
+        from: '2026-01-01',
+        to: '2026-12-31',
+        granularity: 'day',
+      });
+      expect(result.granularity).toBe('day');
+    });
+
+    it('should return a valid MetricSummary in the response', () => {
+      const result = handlers.handleGetMetric('orders', validParams);
+      const { summary } = result;
+
+      expect(typeof summary.name).toBe('string');
+      expect(typeof summary.label).toBe('string');
+      expect(typeof summary.value).toBe('number');
+      expect(typeof summary.previousValue).toBe('number');
+      expect(typeof summary.changePercent).toBe('number');
+      expect(['up', 'down', 'flat']).toContain(summary.trend);
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // GET /api/analytics/top-products — handleGetTopProducts
+  // -------------------------------------------------------------------------
+
+  describe('handleGetTopProducts', () => {
+    it('should return an array of top products', () => {
+      const result = handlers.handleGetTopProducts({
+        from: '2026-01-01',
+        to: '2026-01-31',
+      });
+
+      expect(Array.isArray(result)).toBe(true);
+    });
+
+    it('should accept granularity parameter without error', () => {
+      const result = handlers.handleGetTopProducts({
+        from: '2026-01-01',
+        to: '2026-06-30',
+        granularity: 'week',
+      });
+
+      expect(Array.isArray(result)).toBe(true);
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // Validation error scenarios
+  // -------------------------------------------------------------------------
+
+  describe('Validation Errors', () => {
+    describe('missing or invalid "from" parameter', () => {
+      it('should throw when "from" is missing', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ to: '2026-01-31' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('should throw when "from" is not a string', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ from: 12345, to: '2026-01-31' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('should throw when "from" is an invalid date', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ from: 'not-a-date', to: '2026-01-31' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+    });
+
+    describe('missing or invalid "to" parameter', () => {
+      it('should throw when "to" is missing', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ from: '2026-01-01' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('should throw when "to" is not a string', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ from: '2026-01-01', to: null }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('should throw when "to" is an invalid date', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ from: '2026-01-01', to: 'bad' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+    });
+
+    describe('"from" must be before "to"', () => {
+      it('should throw when from equals to', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ from: '2026-01-15', to: '2026-01-15' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('should throw when from is after to', () => {
+        expect(() =>
+          handlers.handleGetDashboard({ from: '2026-02-01', to: '2026-01-01' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+    });
+
+    describe('invalid granularity', () => {
+      it('should throw for unrecognized granularity value', () => {
+        expect(() =>
+          handlers.handleGetDashboard({
+            from: '2026-01-01',
+            to: '2026-01-31',
+            granularity: 'yearly',
+          }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('should include the invalid value in the error message', () => {
+        expect(() =>
+          handlers.handleGetDashboard({
+            from: '2026-01-01',
+            to: '2026-01-31',
+            granularity: 'biweekly',
+          }),
+        ).toThrow(/biweekly/);
+      });
+    });
+
+    describe('invalid metric type', () => {
+      it('should throw for unrecognized metric type', () => {
+        expect(() =>
+          handlers.handleGetMetric('clicks', { from: '2026-01-01', to: '2026-01-31' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('should include the invalid metric type in the error message', () => {
+        expect(() =>
+          handlers.handleGetMetric('impressions', { from: '2026-01-01', to: '2026-01-31' }),
+        ).toThrow(/impressions/);
+      });
+
+      it('should still validate date params before metric type is checked', () => {
+        // metric type is validated first in the handler, so this throws about metric type
+        expect(() =>
+          handlers.handleGetMetric('bad-metric', { from: '2026-01-01', to: '2026-01-31' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+    });
+
+    describe('validation applies to all endpoints', () => {
+      it('handleGetMetric validates dates', () => {
+        expect(() =>
+          handlers.handleGetMetric('orders', { from: 'bad', to: '2026-01-31' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('handleGetTopProducts validates dates', () => {
+        expect(() =>
+          handlers.handleGetTopProducts({ from: '2026-01-01' }),
+        ).toThrow(AnalyticsValidationError);
+      });
+
+      it('handleGetTopProducts validates granularity', () => {
+        expect(() =>
+          handlers.handleGetTopProducts({
+            from: '2026-01-01',
+            to: '2026-01-31',
+            granularity: 'quarter',
+          }),
+        ).toThrow(AnalyticsValidationError);
+      });
+    });
+  });
+
+  // -------------------------------------------------------------------------
+  // Cross-cutting: data flows correctly through the full pipeline
+  // -------------------------------------------------------------------------
+
+  describe('Pipeline data flow', () => {
+    it('should pass date range from handler params through to response', () => {
+      const from = '2026-04-01';
+      const to = '2026-04-30';
+
+      const dashboard = handlers.handleGetDashboard({ from, to });
+      expect(dashboard.dateRange).toEqual({ from, to });
+
+      const metric = handlers.handleGetMetric('revenue', { from, to });
+      expect(metric.dateRange).toEqual({ from, to });
+    });
+
+    it('should return consistent data between dashboard and metric endpoints', () => {
+      const params = { from: '2026-01-01', to: '2026-01-31' };
+
+      const dashboard = handlers.handleGetDashboard(params);
+      const ordersMetric = handlers.handleGetMetric('orders', params);
+
+      // Both should have the same date range
+      expect(dashboard.dateRange).toEqual(ordersMetric.dateRange);
+
+      // Both use the same granularity resolution logic
+      expect(ordersMetric.granularity).toBe('day'); // 30 days → day
+    });
+
+    it('top products should be the same subset from dashboard', () => {
+      const params = { from: '2026-01-01', to: '2026-01-31' };
+
+      const dashboard = handlers.handleGetDashboard(params);
+      const topProducts = handlers.handleGetTopProducts(params);
+
+      expect(topProducts).toEqual(dashboard.topProducts);
+    });
+
+    it('should handle ISO timestamps with timezone info end-to-end', () => {
+      const result = handlers.handleGetDashboard({
+        from: '2026-01-01T00:00:00.000Z',
+        to: '2026-01-31T23:59:59.999Z',
+      });
+
+      expect(result.dateRange.from).toBe('2026-01-01T00:00:00.000Z');
+      expect(result.dateRange.to).toBe('2026-01-31T23:59:59.999Z');
+    });
+
+    it('should produce valid AnalyticsValidationError instances', () => {
+      try {
+        handlers.handleGetDashboard({ from: 'bad', to: '2026-01-31' });
+        expect.unreachable('should have thrown');
+      } catch (err) {
+        expect(err).toBeInstanceOf(AnalyticsValidationError);
+        expect(err).toBeInstanceOf(Error);
+        expect((err as AnalyticsValidationError).name).toBe('AnalyticsValidationError');
+        expect((err as AnalyticsValidationError).message).toContain('from');
+      }
+    });
+  });
+});
