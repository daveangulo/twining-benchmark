+export interface AnalyticsSummary {
+  totalUsers: number;
+  totalOrders: number;
+  revenue: number;
+  activeUsers: number;
+}
+
+export interface UserAnalytics {
+  userId: string;
+  orderCount: number;
+  totalSpent: number;
+  lastActive: Date;
+}
+
+export interface TrendPoint {
+  timestamp: Date;
+  metric: string;
+  value: number;
+}
