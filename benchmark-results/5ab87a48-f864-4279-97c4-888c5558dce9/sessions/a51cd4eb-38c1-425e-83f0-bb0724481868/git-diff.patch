+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { OrderRepository } from '../../src/repositories/order.repository.js';
+import { AnalyticsService } from '../../src/services/analytics.service.js';
+import type { User } from '../../src/models/user.js';
+import type { Order } from '../../src/models/order.js';
+
+describe('AnalyticsService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let orderRepo: OrderRepository;
+  let service: AnalyticsService;
+
+  const now = new Date('2026-03-15T12:00:00Z');
+
+  function createUser(id: string, name: string): User {
+    const user: User = {
+      id,
+      name,
+      email: `${name.toLowerCase()}@example.com`,
+      role: 'member',
+      createdAt: now,
+      updatedAt: now,
+    };
+    userRepo.save(user);
+    return user;
+  }
+
+  function createOrder(id: string, userId: string, total: number, createdAt: Date = now): Order {
+    const order: Order = {
+      id,
+      userId,
+      items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: total }],
+      total,
+      status: 'pending',
+      createdAt,
+      updatedAt: createdAt,
+    };
+    orderRepo.save(order);
+    return order;
+  }
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    orderRepo = new OrderRepository(db);
+    service = new AnalyticsService(userRepo, orderRepo);
+  });
+
+  describe('getSummary', () => {
+    it('should return zeros when no data exists', () => {
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(0);
+      expect(summary.totalOrders).toBe(0);
+      expect(summary.revenue).toBe(0);
+      expect(summary.activeUsers).toBe(0);
+    });
+
+    it('should aggregate stats from users and orders', () => {
+      createUser('user-1', 'Alice');
+      createUser('user-2', 'Bob');
+      createUser('user-3', 'Charlie');
+
+      createOrder('order-1', 'user-1', 50);
+      createOrder('order-2', 'user-1', 30);
+      createOrder('order-3', 'user-2', 100);
+
+      const summary = service.getSummary();
+
+      expect(summary.totalUsers).toBe(3);
+      expect(summary.totalOrders).toBe(3);
+      expect(summary.revenue).toBe(180);
+      expect(summary.activeUsers).toBe(2);
+    });
+  });
+
+  describe('getUserAnalytics', () => {
+    it('should return analytics for a user with orders', () => {
+      createUser('user-1', 'Alice');
+
+      const earlier = new Date('2026-03-10T12:00:00Z');
+      const later = new Date('2026-03-14T12:00:00Z');
+
+      createOrder('order-1', 'user-1', 50, earlier);
+      createOrder('order-2', 'user-1', 30, later);
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.userId).toBe('user-1');
+      expect(analytics.orderCount).toBe(2);
+      expect(analytics.totalSpent).toBe(80);
+      expect(analytics.lastActive).toEqual(later);
+    });
+
+    it('should return analytics for a user with no orders', () => {
+      createUser('user-1', 'Alice');
+
+      const analytics = service.getUserAnalytics('user-1');
+
+      expect(analytics.userId).toBe('user-1');
+      expect(analytics.orderCount).toBe(0);
+      expect(analytics.totalSpent).toBe(0);
+      expect(analytics.lastActive).toEqual(now);
+    });
+
+    it('should throw for non-existent user', () => {
+      expect(() => service.getUserAnalytics('nonexistent')).toThrow('User not found');
+    });
+  });
+
+  describe('getTrends', () => {
+    it('should return order trend points within date range', () => {
+      createUser('user-1', 'Alice');
+
+      const d1 = new Date('2026-03-10T12:00:00Z');
+      const d2 = new Date('2026-03-12T12:00:00Z');
+      const d3 = new Date('2026-03-20T12:00:00Z');
+
+      createOrder('order-1', 'user-1', 50, d1);
+      createOrder('order-2', 'user-1', 30, d2);
+      createOrder('order-3', 'user-1', 100, d3);
+
+      const start = new Date('2026-03-09T00:00:00Z');
+      const end = new Date('2026-03-15T00:00:00Z');
+
+      const trends = service.getTrends('orders', start, end);
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0]?.metric).toBe('orders');
+      expect(trends[0]?.value).toBe(1);
+    });
+
+    it('should return revenue trend points within date range', () => {
+      createUser('user-1', 'Alice');
+
+      const d1 = new Date('2026-03-10T12:00:00Z');
+      const d2 = new Date('2026-03-12T12:00:00Z');
+
+      createOrder('order-1', 'user-1', 50, d1);
+      createOrder('order-2', 'user-1', 30, d2);
+
+      const start = new Date('2026-03-09T00:00:00Z');
+      const end = new Date('2026-03-13T00:00:00Z');
+
+      const trends = service.getTrends('revenue', start, end);
+
+      expect(trends).toHaveLength(2);
+      expect(trends[0]?.value).toBe(50);
+      expect(trends[1]?.value).toBe(30);
+    });
+
+    it('should return user trend points within date range', () => {
+      const d1 = new Date('2026-03-10T12:00:00Z');
+      const d2 = new Date('2026-03-20T12:00:00Z');
+
+      const user1: User = {
+        id: 'user-1',
+        name: 'Alice',
+        email: 'alice@example.com',
+        role: 'member',
+        createdAt: d1,
+        updatedAt: d1,
+      };
+      const user2: User = {
+        id: 'user-2',
+        name: 'Bob',
+        email: 'bob@example.com',
+        role: 'member',
+        createdAt: d2,
+        updatedAt: d2,
+      };
+      userRepo.save(user1);
+      userRepo.save(user2);
+
+      const start = new Date('2026-03-09T00:00:00Z');
+      const end = new Date('2026-03-15T00:00:00Z');
+
+      const trends = service.getTrends('users', start, end);
+
+      expect(trends).toHaveLength(1);
+      expect(trends[0]?.metric).toBe('users');
+    });
+
+    it('should throw for unknown metric', () => {
+      expect(() =>
+        service.getTrends('unknown', new Date(), new Date()),
+      ).toThrow('Unknown metric');
+    });
+  });
+});
