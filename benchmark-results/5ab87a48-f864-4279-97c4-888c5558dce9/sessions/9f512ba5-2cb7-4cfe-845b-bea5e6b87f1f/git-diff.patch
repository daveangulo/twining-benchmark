+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { EmailNotificationHandler } from '../../src/notifications/email-handler.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+describe('EmailNotificationHandler', () => {
+  let eventBus: EventBus;
+  let handler: EmailNotificationHandler;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    handler = new EmailNotificationHandler(eventBus);
+  });
+
+  describe('order:created email', () => {
+    it('should send email on order created', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+          ],
+          total: 20,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.recipient).toBe('alice@example.com');
+      expect(emails[0]?.subject).toContain('Order Confirmation');
+      expect(emails[0]?.body).toContain('Widget x2');
+      expect(emails[0]?.body).toContain('$20.00');
+      expect(emails[0]?.body).toContain('Alice');
+    });
+
+    it('should include HTML body with item table', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+            { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+          ],
+          total: 45,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.htmlBody).toContain('<h1>Order Confirmation</h1>');
+      expect(emails[0]?.htmlBody).toContain('Widget');
+      expect(emails[0]?.htmlBody).toContain('Gadget');
+      expect(emails[0]?.htmlBody).toContain('<table>');
+      expect(emails[0]?.htmlBody).toContain('$45.00');
+    });
+  });
+
+  describe('order:status-changed email', () => {
+    const makeStatusEvent = (
+      previousStatus: string,
+      newStatus: string,
+    ): OrderStatusChangedEvent => ({
+      type: 'order:status-changed',
+      order: {
+        id: 'order-1',
+        userId: 'user-1',
+        items: [],
+        total: 20,
+        status: newStatus as any,
+        createdAt: new Date(),
+        updatedAt: new Date(),
+      },
+      previousStatus,
+      newStatus,
+      timestamp: new Date(),
+    });
+
+    it('should send email on status change to confirmed', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Order Confirmed');
+      expect(emails[0]?.body).toContain('confirmed and is being prepared');
+      expect(emails[0]?.htmlBody).toContain('<h1>Order Confirmed</h1>');
+    });
+
+    it('should send email on status change to shipped', async () => {
+      await eventBus.emit(makeStatusEvent('confirmed', 'shipped'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Order Shipped');
+      expect(emails[0]?.body).toContain('shipped and is on its way');
+    });
+
+    it('should send email on status change to delivered', async () => {
+      await eventBus.emit(makeStatusEvent('shipped', 'delivered'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Order Delivered');
+      expect(emails[0]?.body).toContain('delivered');
+    });
+
+    it('should send email on status change to cancelled', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'cancelled'));
+
+      const emails = handler.getSentEmails();
+      expect(emails).toHaveLength(1);
+      expect(emails[0]?.subject).toContain('Order Cancelled');
+      expect(emails[0]?.body).toContain('cancelled');
+    });
+
+    it('should include previous and new status in HTML body', async () => {
+      await eventBus.emit(makeStatusEvent('pending', 'confirmed'));
+
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.htmlBody).toContain('pending');
+      expect(emails[0]?.htmlBody).toContain('confirmed');
+    });
+
+    it('should include previous and new status in plain text body', async () => {
+      await eventBus.emit(makeStatusEvent('confirmed', 'shipped'));
+
+      const emails = handler.getSentEmails();
+      expect(emails[0]?.body).toContain('confirmed');
+      expect(emails[0]?.body).toContain('shipped');
+    });
+  });
+
+  describe('email management', () => {
+    it('should count sent emails', async () => {
+      expect(handler.getSentEmailCount()).toBe(0);
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getSentEmailCount()).toBe(1);
+    });
+
+    it('should filter emails by recipient', async () => {
+      const event: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [
+            { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+          ],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      expect(handler.getSentEmailsForRecipient('alice@example.com')).toHaveLength(1);
+      expect(handler.getSentEmailsForRecipient('bob@example.com')).toHaveLength(0);
+    });
+
+    it('should clear sent emails', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      handler.clearSentEmails();
+      expect(handler.getSentEmailCount()).toBe(0);
+    });
+
+    it('should accumulate emails across multiple events', async () => {
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      });
+
+      await eventBus.emit({
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [],
+          total: 20,
+          status: 'shipped',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+        timestamp: new Date(),
+      });
+
+      expect(handler.getSentEmailCount()).toBe(2);
+      expect(handler.getSentEmails()[0]?.subject).toContain('Confirmed');
+      expect(handler.getSentEmails()[1]?.subject).toContain('Shipped');
+    });
+  });
+
+  describe('getStatusMessage', () => {
+    it('should return correct message for each status', () => {
+      expect(EmailNotificationHandler.getStatusMessage('pending').heading).toBe('Order Received');
+      expect(EmailNotificationHandler.getStatusMessage('confirmed').heading).toBe('Order Confirmed');
+      expect(EmailNotificationHandler.getStatusMessage('shipped').heading).toBe('Order Shipped');
+      expect(EmailNotificationHandler.getStatusMessage('delivered').heading).toBe('Order Delivered');
+      expect(EmailNotificationHandler.getStatusMessage('cancelled').heading).toBe('Order Cancelled');
+    });
+  });
+});
