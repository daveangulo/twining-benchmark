diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..f6875a5
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,29 @@
+import type { CreateOrderInput, OrderStatus } from '../models/order.js';
+
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Validate that a create-order input has at least one item.
+ * Throws if validation fails.
+ */
+export function validateCreateOrderInput(input: CreateOrderInput): void {
+  if (input.items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidOrderStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..2c221f8
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,36 @@
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that a user exists. Throws if the user is undefined.
+ */
+export function validateUserExists(user: User | undefined, userId: string): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${userId}`);
+  }
+}
+
+/**
+ * Validate that an email is not already taken by another user.
+ * Throws if the email is in use.
+ */
+export function validateEmailNotTaken(
+  existingUserWithEmail: User | undefined,
+  email: string,
+): void {
+  if (existingUserWithEmail) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not taken by a different user during update.
+ * Throws if the email is in use by someone else.
+ */
+export function validateEmailNotTakenByOther(
+  existingUserWithEmail: User | undefined,
+  email: string,
+): void {
+  if (existingUserWithEmail) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..c50d735
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,58 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateCreateOrderInput,
+  isValidOrderStatusTransition,
+} from '../../src/validators/order.validator.js';
+import type { OrderStatus } from '../../src/models/order.js';
+
+describe('order.validator', () => {
+  describe('validateCreateOrderInput', () => {
+    it('should pass when items are present', () => {
+      expect(() =>
+        validateCreateOrderInput({
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+        }),
+      ).not.toThrow();
+    });
+
+    it('should throw when items array is empty', () => {
+      expect(() =>
+        validateCreateOrderInput({ userId: 'user-1', items: [] }),
+      ).toThrow('Order must have at least one item');
+    });
+  });
+
+  describe('isValidOrderStatusTransition', () => {
+    const validTransitions: [OrderStatus, OrderStatus][] = [
+      ['pending', 'confirmed'],
+      ['pending', 'cancelled'],
+      ['confirmed', 'shipped'],
+      ['confirmed', 'cancelled'],
+      ['shipped', 'delivered'],
+    ];
+
+    for (const [from, to] of validTransitions) {
+      it(`should allow ${from} -> ${to}`, () => {
+        expect(isValidOrderStatusTransition(from, to)).toBe(true);
+      });
+    }
+
+    const invalidTransitions: [OrderStatus, OrderStatus][] = [
+      ['pending', 'shipped'],
+      ['pending', 'delivered'],
+      ['confirmed', 'pending'],
+      ['shipped', 'cancelled'],
+      ['delivered', 'pending'],
+      ['delivered', 'cancelled'],
+      ['cancelled', 'pending'],
+      ['cancelled', 'confirmed'],
+    ];
+
+    for (const [from, to] of invalidTransitions) {
+      it(`should reject ${from} -> ${to}`, () => {
+        expect(isValidOrderStatusTransition(from, to)).toBe(false);
+      });
+    }
+  });
+});
diff --git a/tests/validators/user.validator.test.ts b/tests/validators/user.validator.test.ts
new file mode 100644
index 0000000..3b99701
--- /dev/null
+++ b/tests/validators/user.validator.test.ts
@@ -0,0 +1,59 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateUserExists,
+  validateEmailNotTaken,
+  validateEmailNotTakenByOther,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const makeUser = (overrides: Partial<User> = {}): User => ({
+  id: 'user-1',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+  ...overrides,
+});
+
+describe('user.validator', () => {
+  describe('validateUserExists', () => {
+    it('should pass when user exists', () => {
+      expect(() => validateUserExists(makeUser(), 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists(undefined, 'user-99')).toThrow(
+        'User not found: user-99',
+      );
+    });
+  });
+
+  describe('validateEmailNotTaken', () => {
+    it('should pass when no existing user has the email', () => {
+      expect(() =>
+        validateEmailNotTaken(undefined, 'new@example.com'),
+      ).not.toThrow();
+    });
+
+    it('should throw when email is already taken', () => {
+      expect(() =>
+        validateEmailNotTaken(makeUser(), 'alice@example.com'),
+      ).toThrow('User with email alice@example.com already exists');
+    });
+  });
+
+  describe('validateEmailNotTakenByOther', () => {
+    it('should pass when no other user has the email', () => {
+      expect(() =>
+        validateEmailNotTakenByOther(undefined, 'new@example.com'),
+      ).not.toThrow();
+    });
+
+    it('should throw when email is in use by another user', () => {
+      expect(() =>
+        validateEmailNotTakenByOther(makeUser(), 'alice@example.com'),
+      ).toThrow('Email alice@example.com is already in use');
+    });
+  });
+});
