diff --git a/tests/adapters/sms.adapter.test.ts b/tests/adapters/sms.adapter.test.ts
new file mode 100644
index 0000000..c906cd4
--- /dev/null
+++ b/tests/adapters/sms.adapter.test.ts
@@ -0,0 +1,203 @@
+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import {
+  SmsNotificationAdapter,
+  formatSmsBody,
+} from '../../src/adapters/sms.adapter.js';
+import type { SmsMessage } from '../../src/adapters/sms.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order-confirmation',
+    channels: ['sms'],
+    priority: 'high',
+    recipient: '+15551234567',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    createdAt: new Date('2026-01-01'),
+    ...overrides,
+  };
+}
+
+describe('SmsNotificationAdapter', () => {
+  let adapter: SmsNotificationAdapter;
+
+  beforeEach(() => {
+    adapter = new SmsNotificationAdapter();
+  });
+
+  describe('channel property', () => {
+    it('should be "sms"', () => {
+      expect(adapter.channel).toBe('sms');
+    });
+  });
+
+  describe('send()', () => {
+    it('should deliver SMS for a valid phone number recipient', async () => {
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+      expect(result.error).toBeUndefined();
+
+      const messages = adapter.getSentMessages();
+      expect(messages).toHaveLength(1);
+      expect(messages[0]?.to).toBe('+15551234567');
+    });
+
+    it('should format message body from subject and body', async () => {
+      await adapter.send(makePayload());
+
+      const message = adapter.getSentMessages()[0]!;
+      expect(message.body).toContain('Order Confirmation');
+      expect(message.body).toContain('Widget x2');
+    });
+
+    it('should resolve recipient via resolver when not a phone number', async () => {
+      const resolver = vi.fn().mockResolvedValue('+15559876543');
+      adapter = new SmsNotificationAdapter({ recipientResolver: resolver });
+
+      const result = await adapter.send(makePayload({ recipient: 'user-1' }));
+
+      expect(result.success).toBe(true);
+      expect(resolver).toHaveBeenCalledWith('user-1');
+      expect(adapter.getSentMessages()[0]?.to).toBe('+15559876543');
+    });
+
+    it('should fail when recipient cannot be resolved', async () => {
+      adapter = new SmsNotificationAdapter();
+
+      const result = await adapter.send(makePayload({ recipient: 'user-1' }));
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Could not resolve recipient to phone number');
+    });
+
+    it('should fail when resolver returns null', async () => {
+      const resolver = vi.fn().mockResolvedValue(null);
+      adapter = new SmsNotificationAdapter({ recipientResolver: resolver });
+
+      const result = await adapter.send(makePayload({ recipient: 'user-1' }));
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Could not resolve recipient to phone number');
+    });
+
+    it('should use custom transport when provided', async () => {
+      const customTransport = vi.fn().mockResolvedValue(undefined);
+      adapter = new SmsNotificationAdapter({ transport: customTransport });
+
+      await adapter.send(makePayload());
+
+      expect(customTransport).toHaveBeenCalledTimes(1);
+      expect(customTransport).toHaveBeenCalledWith(
+        expect.objectContaining({
+          to: '+15551234567',
+          body: expect.any(String),
+        }),
+      );
+    });
+
+    it('should catch transport errors and return failure', async () => {
+      const failingTransport = vi.fn().mockRejectedValue(new Error('Network timeout'));
+      adapter = new SmsNotificationAdapter({ transport: failingTransport });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Network timeout');
+    });
+
+    it('should handle non-Error exceptions', async () => {
+      const failingTransport = vi.fn().mockRejectedValue('string error');
+      adapter = new SmsNotificationAdapter({ transport: failingTransport });
+
+      const result = await adapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Unknown error');
+    });
+
+    it('should deliver multiple messages independently', async () => {
+      await adapter.send(makePayload({ id: 'notif-0001', recipient: '+15551111111' }));
+      await adapter.send(makePayload({ id: 'notif-0002', recipient: '+15552222222' }));
+
+      const messages = adapter.getSentMessages();
+      expect(messages).toHaveLength(2);
+      expect(messages[0]?.to).toBe('+15551111111');
+      expect(messages[1]?.to).toBe('+15552222222');
+    });
+
+    it('should accept various phone number formats', async () => {
+      for (const phone of ['+15551234567', '5551234567', '(555) 123-4567']) {
+        adapter.clearSentMessages();
+        const result = await adapter.send(makePayload({ recipient: phone }));
+        expect(result.success).toBe(true);
+      }
+    });
+
+    it('should include all notification types', async () => {
+      for (const type of ['order-confirmation', 'order-status-update', 'welcome', 'account-update'] as const) {
+        adapter.clearSentMessages();
+        await adapter.send(makePayload({ type }));
+        expect(adapter.getSentMessages()).toHaveLength(1);
+      }
+    });
+
+    it('should include all priority levels', async () => {
+      for (const priority of ['low', 'normal', 'high'] as const) {
+        adapter.clearSentMessages();
+        await adapter.send(makePayload({ priority }));
+        expect(adapter.getSentMessages()).toHaveLength(1);
+      }
+    });
+  });
+
+  describe('getSentMessages / clearSentMessages', () => {
+    it('should return a copy of sent messages', async () => {
+      await adapter.send(makePayload());
+
+      const messages1 = adapter.getSentMessages();
+      const messages2 = adapter.getSentMessages();
+      expect(messages1).toEqual(messages2);
+      expect(messages1).not.toBe(messages2);
+    });
+
+    it('should clear sent messages', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentMessages()).toHaveLength(1);
+
+      adapter.clearSentMessages();
+      expect(adapter.getSentMessages()).toHaveLength(0);
+    });
+  });
+});
+
+describe('formatSmsBody', () => {
+  it('should combine subject and body', () => {
+    const payload = makePayload();
+    const result = formatSmsBody(payload);
+    expect(result).toBe('Order Confirmation: order-1: Your order has been placed. Items: Widget x2. Total: $20.00');
+  });
+
+  it('should truncate long messages to 160 chars', () => {
+    const payload = makePayload({
+      subject: 'Long Subject',
+      body: 'A'.repeat(200),
+    });
+    const result = formatSmsBody(payload);
+    expect(result.length).toBe(160);
+    expect(result.endsWith('...')).toBe(true);
+  });
+
+  it('should not truncate messages at or under 160 chars', () => {
+    const payload = makePayload({
+      subject: 'Hi',
+      body: 'Short',
+    });
+    const result = formatSmsBody(payload);
+    expect(result).toBe('Hi: Short');
+    expect(result.endsWith('...')).toBe(false);
+  });
+});
