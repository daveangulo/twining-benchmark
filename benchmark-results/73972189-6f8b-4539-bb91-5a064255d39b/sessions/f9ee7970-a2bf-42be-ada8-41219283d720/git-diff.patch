@@ -0,0 +1,27 @@
+/**
+ * Notification log model — records sent notifications for history tracking.
+ */
+
+export type NotificationChannel = 'email' | 'webhook' | 'in_app';
+export type NotificationType = 'order_confirmation' | 'order_status_update';
+export type DeliveryStatus = 'sent' | 'failed';
+
+export interface NotificationLog {
+  id: string;
+  recipient: string;
+  channel: NotificationChannel;
+  type: NotificationType;
+  subject: string;
+  body: string;
+  status: DeliveryStatus;
+  sentAt: Date;
+  createdAt: Date;
+}
+
+export interface NotificationHistoryQuery {
+  recipient?: string;
+  type?: NotificationType;
+  channel?: NotificationChannel;
+  startDate?: Date;
+  endDate?: Date;
+}
