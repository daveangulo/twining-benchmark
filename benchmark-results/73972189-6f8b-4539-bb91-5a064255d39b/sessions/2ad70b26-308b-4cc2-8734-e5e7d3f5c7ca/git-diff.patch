@@ -0,0 +1,35 @@
+/**
+ * Base interface for all notification delivery adapters.
+ *
+ * ARCHITECTURAL CONSTRAINT: Every notification channel (email, webhook, in-app,
+ * etc.) MUST have an adapter that implements this interface. The NotificationService
+ * dispatches to adapters based on the payload's channel field.
+ *
+ * To add a new notification channel:
+ * 1. Add the channel name to NotificationChannel in src/models/notification.ts
+ * 2. Create an adapter class implementing NotificationAdapter
+ * 3. Register the adapter with NotificationService via registerAdapter()
+ *
+ * Adapters are responsible for:
+ * - Formatting the NotificationPayload for their specific channel
+ * - Handling delivery (or stubbing it for testing)
+ * - Returning a NotificationResult indicating success or failure
+ *
+ * Adapters must NOT:
+ * - Emit events on the EventBus (that is the NotificationService's job)
+ * - Call other adapters directly
+ * - Store notification records (the NotificationService handles persistence)
+ */
+
+import type { NotificationChannel, NotificationPayload, NotificationResult } from '../models/notification.js';
+
+export interface NotificationAdapter {
+  /** The channel this adapter handles. Must match a NotificationChannel value. */
+  readonly channel: NotificationChannel;
+
+  /**
+   * Deliver a notification through this adapter's channel.
+   * Must not throw — return a failed NotificationResult instead.
+   */
+  send(payload: NotificationPayload): Promise<NotificationResult>;
+}
