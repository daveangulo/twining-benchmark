+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,227 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookAdapter,
+  InMemoryWebhookTransport,
+} from '../../src/adapters/webhook.adapter.js';
+import type { WebhookTransport, WebhookRequest } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    channel: 'webhook',
+    notificationType: 'order-confirmation',
+    recipient: 'https://example.com/webhook',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+describe('WebhookAdapter', () => {
+  let adapter: WebhookAdapter;
+
+  beforeEach(() => {
+    adapter = new WebhookAdapter();
+  });
+
+  describe('resolveRecipient', () => {
+    it('should accept a valid https URL', () => {
+      const payload = makePayload({ recipient: 'https://hooks.example.com/notify' });
+      expect(adapter.resolveRecipient(payload)).toBe('https://hooks.example.com/notify');
+    });
+
+    it('should accept a valid http URL', () => {
+      const payload = makePayload({ recipient: 'http://localhost:3000/webhook' });
+      expect(adapter.resolveRecipient(payload)).toBe('http://localhost:3000/webhook');
+    });
+
+    it('should trim whitespace', () => {
+      const payload = makePayload({ recipient: '  https://example.com/hook  ' });
+      expect(adapter.resolveRecipient(payload)).toBe('https://example.com/hook');
+    });
+
+    it('should return null for empty URL', () => {
+      const payload = makePayload({ recipient: '' });
+      expect(adapter.resolveRecipient(payload)).toBeNull();
+    });
+
+    it('should return null for invalid URL', () => {
+      const payload = makePayload({ recipient: 'not-a-url' });
+      expect(adapter.resolveRecipient(payload)).toBeNull();
+    });
+
+    it('should return null for URL without protocol', () => {
+      const payload = makePayload({ recipient: 'example.com/webhook' });
+      expect(adapter.resolveRecipient(payload)).toBeNull();
+    });
+  });
+
+  describe('formatPayload', () => {
+    it('should format notification payload as webhook body', () => {
+      const payload = makePayload();
+      const body = adapter.formatPayload(payload);
+
+      expect(body.notificationType).toBe('order-confirmation');
+      expect(body.subject).toBe('Order Confirmation: order-1');
+      expect(body.body).toBe('Your order has been placed. Items: Widget x2. Total: $20.00');
+      expect(body.metadata).toEqual({ orderId: 'order-1', userId: 'user-1' });
+      expect(body.timestamp).toBeDefined();
+    });
+
+    it('should include ISO timestamp', () => {
+      const payload = makePayload();
+      const body = adapter.formatPayload(payload);
+
+      // Verify it's a valid ISO date string
+      expect(new Date(body.timestamp).toISOString()).toBe(body.timestamp);
+    });
+
+    it('should handle payload without metadata', () => {
+      const payload = makePayload({ metadata: undefined });
+      const body = adapter.formatPayload(payload);
+
+      expect(body.metadata).toBeUndefined();
+    });
+  });
+
+  describe('send', () => {
+    it('should successfully send a valid webhook', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.channel).toBe('webhook');
+      expect(result.message).toContain('https://example.com/webhook');
+    });
+
+    it('should store delivered webhook with request body', async () => {
+      const payload = makePayload();
+      await adapter.send(payload);
+
+      const delivered = adapter.getDeliveredWebhooks();
+      expect(delivered).toHaveLength(1);
+      expect(delivered[0]?.url).toBe('https://example.com/webhook');
+      expect(delivered[0]?.requestBody.notificationType).toBe('order-confirmation');
+      expect(delivered[0]?.requestBody.subject).toBe('Order Confirmation: order-1');
+      expect(delivered[0]?.deliveryId).toMatch(/^whk-/);
+    });
+
+    it('should return failure for invalid URL', async () => {
+      const payload = makePayload({ recipient: 'not-valid' });
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(false);
+      expect(result.channel).toBe('webhook');
+      expect(result.message).toContain('Invalid webhook URL');
+    });
+
+    it('should not store webhook on URL validation failure', async () => {
+      const payload = makePayload({ recipient: 'bad-url' });
+      await adapter.send(payload);
+
+      expect(adapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+
+    it('should return failure when transport throws', async () => {
+      const failingTransport: WebhookTransport = {
+        async post(): Promise<{ deliveryId: string }> {
+          throw new Error('Connection refused');
+        },
+      };
+
+      const failAdapter = new WebhookAdapter(failingTransport);
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.channel).toBe('webhook');
+      expect(result.message).toBe('Connection refused');
+    });
+
+    it('should not store webhook when transport throws', async () => {
+      const failingTransport: WebhookTransport = {
+        async post(): Promise<{ deliveryId: string }> {
+          throw new Error('fail');
+        },
+      };
+
+      const failAdapter = new WebhookAdapter(failingTransport);
+      await failAdapter.send(makePayload());
+
+      expect(failAdapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+
+    it('should handle non-Error thrown by transport', async () => {
+      const failingTransport: WebhookTransport = {
+        async post(): Promise<{ deliveryId: string }> {
+          throw 'string error';
+        },
+      };
+
+      const failAdapter = new WebhookAdapter(failingTransport);
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.message).toBe('Unknown transport error');
+    });
+
+    it('should assign unique delivery IDs to each webhook', async () => {
+      await adapter.send(makePayload());
+      await adapter.send(makePayload({ recipient: 'https://other.com/hook' }));
+
+      const delivered = adapter.getDeliveredWebhooks();
+      expect(delivered).toHaveLength(2);
+      expect(delivered[0]?.deliveryId).not.toBe(delivered[1]?.deliveryId);
+    });
+  });
+
+  describe('custom transport', () => {
+    it('should use injected transport', async () => {
+      const calls: WebhookRequest[] = [];
+      const customTransport: WebhookTransport = {
+        async post(request: WebhookRequest) {
+          calls.push(request);
+          return { deliveryId: 'custom-001' };
+        },
+      };
+
+      const customAdapter = new WebhookAdapter(customTransport);
+      await customAdapter.send(makePayload());
+
+      expect(calls).toHaveLength(1);
+      expect(calls[0]?.url).toBe('https://example.com/webhook');
+
+      const delivered = customAdapter.getDeliveredWebhooks();
+      expect(delivered[0]?.deliveryId).toBe('custom-001');
+    });
+  });
+
+  describe('getDeliveredWebhooks and clearDeliveredWebhooks', () => {
+    it('should return a copy of delivered webhooks', async () => {
+      await adapter.send(makePayload());
+      const webhooks1 = adapter.getDeliveredWebhooks();
+      const webhooks2 = adapter.getDeliveredWebhooks();
+      expect(webhooks1).toEqual(webhooks2);
+      expect(webhooks1).not.toBe(webhooks2);
+    });
+
+    it('should clear delivered webhooks', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getDeliveredWebhooks()).toHaveLength(1);
+
+      adapter.clearDeliveredWebhooks();
+      expect(adapter.getDeliveredWebhooks()).toHaveLength(0);
+    });
+  });
+});
+
+describe('InMemoryWebhookTransport', () => {
+  it('should return sequential delivery IDs', async () => {
+    const transport = new InMemoryWebhookTransport();
+    const r1 = await transport.post({ url: 'https://a.com', body: { notificationType: 'system-alert', subject: 'S', body: 'B', timestamp: new Date().toISOString() } });
+    const r2 = await transport.post({ url: 'https://b.com', body: { notificationType: 'system-alert', subject: 'S', body: 'B', timestamp: new Date().toISOString() } });
+
+    expect(r1.deliveryId).toBe('whk-000001');
+    expect(r2.deliveryId).toBe('whk-000002');
+  });
+});
