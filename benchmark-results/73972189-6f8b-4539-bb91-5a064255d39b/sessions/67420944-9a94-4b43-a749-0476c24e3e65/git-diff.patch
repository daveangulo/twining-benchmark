diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..531a924
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,52 @@
+/**
+ * Pure validation functions for order operations.
+ *
+ * These are stateless, side-effect-free validators extracted from OrderService.
+ * They can be reused anywhere order validation is needed.
+ */
+
+import type { OrderItem, OrderStatus } from '../models/order.js';
+
+/**
+ * Allowed status transitions for order lifecycle.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Validate that an order has at least one item.
+ */
+export function validateOrderItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate a status transition, throwing if invalid.
+ */
+export function validateStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(
+      `Invalid status transition: ${from} -> ${to}`,
+    );
+  }
+}
diff --git a/src/validators/shared.validator.ts b/src/validators/shared.validator.ts
new file mode 100644
index 0000000..1b43346
--- /dev/null
+++ b/src/validators/shared.validator.ts
@@ -0,0 +1,14 @@
+/**
+ * Shared validation functions used across multiple modules.
+ *
+ * Pure functions with no side effects or external dependencies.
+ */
+
+const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
+
+/**
+ * Validate that a string looks like a valid email address.
+ */
+export function isValidEmail(email: string): boolean {
+  return EMAIL_REGEX.test(email);
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..466c61b
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,88 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateOrderItems,
+  isValidStatusTransition,
+  validateStatusTransition,
+} from '../../src/validators/order.validator.js';
+import type { OrderItem, OrderStatus } from '../../src/models/order.js';
+
+describe('order.validator', () => {
+  describe('validateOrderItems', () => {
+    it('should pass for non-empty items array', () => {
+      const items: OrderItem[] = [
+        { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+      ];
+      expect(() => validateOrderItems(items)).not.toThrow();
+    });
+
+    it('should throw for empty items array', () => {
+      expect(() => validateOrderItems([])).toThrow(
+        'Order must have at least one item',
+      );
+    });
+
+    it('should pass for multiple items', () => {
+      const items: OrderItem[] = [
+        { productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 },
+        { productId: 'p2', name: 'Gadget', quantity: 1, unitPrice: 25 },
+      ];
+      expect(() => validateOrderItems(items)).not.toThrow();
+    });
+  });
+
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject pending -> shipped', () => {
+      expect(isValidStatusTransition('pending', 'shipped')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      const statuses: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'];
+      for (const status of statuses) {
+        expect(isValidStatusTransition('delivered', status)).toBe(false);
+      }
+    });
+
+    it('should reject cancelled -> any', () => {
+      const statuses: OrderStatus[] = ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'];
+      for (const status of statuses) {
+        expect(isValidStatusTransition('cancelled', status)).toBe(false);
+      }
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transitions with descriptive message', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+  });
+});
diff --git a/tests/validators/shared.validator.test.ts b/tests/validators/shared.validator.test.ts
new file mode 100644
index 0000000..fddd59b
--- /dev/null
+++ b/tests/validators/shared.validator.test.ts
@@ -0,0 +1,37 @@
+import { describe, it, expect } from 'vitest';
+import { isValidEmail } from '../../src/validators/shared.validator.js';
+
+describe('shared.validator', () => {
+  describe('isValidEmail', () => {
+    it('should accept valid email addresses', () => {
+      expect(isValidEmail('user@example.com')).toBe(true);
+      expect(isValidEmail('alice@test.org')).toBe(true);
+      expect(isValidEmail('name+tag@domain.co')).toBe(true);
+    });
+
+    it('should reject emails without @', () => {
+      expect(isValidEmail('userexample.com')).toBe(false);
+    });
+
+    it('should reject emails without domain', () => {
+      expect(isValidEmail('user@')).toBe(false);
+    });
+
+    it('should reject emails without local part', () => {
+      expect(isValidEmail('@example.com')).toBe(false);
+    });
+
+    it('should reject emails with spaces', () => {
+      expect(isValidEmail('user @example.com')).toBe(false);
+      expect(isValidEmail('user@ example.com')).toBe(false);
+    });
+
+    it('should reject empty string', () => {
+      expect(isValidEmail('')).toBe(false);
+    });
+
+    it('should reject emails without TLD dot', () => {
+      expect(isValidEmail('user@domain')).toBe(false);
+    });
+  });
+});
