@@ -0,0 +1,181 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { WebhookNotificationAdapter } from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides: Partial<NotificationPayload> = {}): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order_confirmation',
+    recipient: 'user-123',
+    subject: 'Order #123',
+    body: 'Widget x2. Total: $20.00',
+    channel: 'webhook',
+    ...overrides,
+  };
+}
+
+describe('WebhookNotificationAdapter', () => {
+  let adapter: WebhookNotificationAdapter;
+
+  beforeEach(() => {
+    adapter = new WebhookNotificationAdapter({
+      url: 'https://hooks.example.com/notify',
+      secret: 'my-secret',
+    });
+  });
+
+  describe('channel', () => {
+    it('should report "webhook" as its channel', () => {
+      expect(adapter.channel).toBe('webhook');
+    });
+  });
+
+  describe('validateUrl', () => {
+    it('should accept valid HTTP URLs', () => {
+      expect(adapter.validateUrl('http://example.com/hook')).toBe(true);
+      expect(adapter.validateUrl('https://hooks.example.com/notify')).toBe(true);
+    });
+
+    it('should reject invalid URLs', () => {
+      expect(adapter.validateUrl('')).toBe(false);
+      expect(adapter.validateUrl('not-a-url')).toBe(false);
+      expect(adapter.validateUrl('ftp://example.com')).toBe(false);
+      expect(adapter.validateUrl('https://')).toBe(false);
+    });
+  });
+
+  describe('formatPayload', () => {
+    it('should format notification payload as webhook JSON', () => {
+      const payload = makePayload();
+      const formatted = adapter.formatPayload(payload);
+
+      expect(formatted.notificationId).toBe('notif-0001');
+      expect(formatted.type).toBe('order_confirmation');
+      expect(formatted.recipient).toBe('user-123');
+      expect(formatted.subject).toBe('Order #123');
+      expect(formatted.body).toBe('Widget x2. Total: $20.00');
+      expect(formatted.channel).toBe('webhook');
+      expect(formatted.timestamp).toBeDefined();
+    });
+
+    it('should include metadata when present', () => {
+      const payload = makePayload({ metadata: { orderId: 'ord-456' } });
+      const formatted = adapter.formatPayload(payload);
+
+      expect(formatted.metadata).toEqual({ orderId: 'ord-456' });
+    });
+
+    it('should leave metadata undefined when not present', () => {
+      const payload = makePayload();
+      delete payload.metadata;
+      const formatted = adapter.formatPayload(payload);
+
+      expect(formatted.metadata).toBeUndefined();
+    });
+  });
+
+  describe('buildHeaders', () => {
+    it('should include Content-Type and secret header', () => {
+      const headers = adapter.buildHeaders();
+
+      expect(headers['Content-Type']).toBe('application/json');
+      expect(headers['x-webhook-secret']).toBe('my-secret');
+    });
+
+    it('should omit secret header when not configured', () => {
+      const noSecretAdapter = new WebhookNotificationAdapter({
+        url: 'https://hooks.example.com/notify',
+      });
+      const headers = noSecretAdapter.buildHeaders();
+
+      expect(headers['Content-Type']).toBe('application/json');
+      expect(headers['x-webhook-secret']).toBeUndefined();
+    });
+
+    it('should include custom headers', () => {
+      const customAdapter = new WebhookNotificationAdapter({
+        url: 'https://hooks.example.com/notify',
+        headers: { 'X-Custom': 'value' },
+      });
+      const headers = customAdapter.buildHeaders();
+
+      expect(headers['Content-Type']).toBe('application/json');
+      expect(headers['X-Custom']).toBe('value');
+    });
+  });
+
+  describe('send', () => {
+    it('should send successfully with valid URL', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notificationId).toBe('notif-0001');
+      expect(result.channel).toBe('webhook');
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+      expect(result.error).toBeUndefined();
+    });
+
+    it('should fail for invalid webhook URL', async () => {
+      const badAdapter = new WebhookNotificationAdapter({ url: 'not-a-url' });
+      const result = await badAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('Invalid webhook URL');
+    });
+
+    it('should record sent webhooks with correct fields', async () => {
+      const payload = makePayload();
+      await adapter.send(payload);
+
+      const webhooks = adapter.getSentWebhooks();
+      expect(webhooks).toHaveLength(1);
+      expect(webhooks[0]?.url).toBe('https://hooks.example.com/notify');
+      expect(webhooks[0]?.payload.notificationId).toBe('notif-0001');
+      expect(webhooks[0]?.payload.channel).toBe('webhook');
+      expect(webhooks[0]?.headers['Content-Type']).toBe('application/json');
+      expect(webhooks[0]?.headers['x-webhook-secret']).toBe('my-secret');
+      expect(webhooks[0]?.sentAt).toBeInstanceOf(Date);
+    });
+
+    it('should not record webhook when URL is invalid', async () => {
+      const badAdapter = new WebhookNotificationAdapter({ url: 'bad' });
+      await badAdapter.send(makePayload());
+      expect(badAdapter.getSentWebhooks()).toHaveLength(0);
+    });
+
+    it('should handle multiple sends independently', async () => {
+      await adapter.send(makePayload({ id: 'n1' }));
+      await adapter.send(makePayload({ id: 'n2' }));
+
+      const webhooks = adapter.getSentWebhooks();
+      expect(webhooks).toHaveLength(2);
+      expect(webhooks[0]?.payload.notificationId).toBe('n1');
+      expect(webhooks[1]?.payload.notificationId).toBe('n2');
+    });
+  });
+
+  describe('clearSentWebhooks', () => {
+    it('should clear the sent webhooks list', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentWebhooks()).toHaveLength(1);
+
+      adapter.clearSentWebhooks();
+      expect(adapter.getSentWebhooks()).toHaveLength(0);
+    });
+  });
+
+  describe('config without secret', () => {
+    it('should work without a secret configured', async () => {
+      const simpleAdapter = new WebhookNotificationAdapter({
+        url: 'https://hooks.example.com/notify',
+      });
+      const result = await simpleAdapter.send(makePayload());
+
+      expect(result.success).toBe(true);
+
+      const webhooks = simpleAdapter.getSentWebhooks();
+      expect(webhooks[0]?.headers['x-webhook-secret']).toBeUndefined();
+    });
+  });
+});
