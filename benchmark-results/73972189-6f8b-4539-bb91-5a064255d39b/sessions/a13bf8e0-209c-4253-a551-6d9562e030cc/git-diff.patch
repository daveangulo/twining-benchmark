diff --git a/tests/adapters/webhook.adapter.test.ts b/tests/adapters/webhook.adapter.test.ts
new file mode 100644
index 0000000..5303876
--- /dev/null
+++ b/tests/adapters/webhook.adapter.test.ts
@@ -0,0 +1,232 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import {
+  WebhookAdapter,
+  InMemoryWebhookTransport,
+  type WebhookTransport,
+  type WebhookRequest,
+} from '../../src/adapters/webhook.adapter.js';
+import type { NotificationPayload } from '../../src/models/notification.js';
+
+function makePayload(overrides?: Partial<NotificationPayload>): NotificationPayload {
+  return {
+    id: 'notif-0001',
+    type: 'order-confirmation',
+    channel: 'webhook',
+    recipient: 'user-1',
+    subject: 'Order Confirmation: order-1',
+    body: 'Your order has been placed. Items: Widget x2. Total: $20.00',
+    priority: 'normal',
+    createdAt: new Date('2026-01-01T00:00:00Z'),
+    metadata: { orderId: 'order-1', userId: 'user-1' },
+    ...overrides,
+  };
+}
+
+const TEST_URL = 'https://hooks.example.com/notify';
+
+describe('WebhookAdapter', () => {
+  let adapter: WebhookAdapter;
+  let transport: InMemoryWebhookTransport;
+
+  beforeEach(() => {
+    transport = new InMemoryWebhookTransport();
+    adapter = new WebhookAdapter({ url: TEST_URL, transport });
+  });
+
+  describe('channel', () => {
+    it('should report webhook as its channel', () => {
+      expect(adapter.channel).toBe('webhook');
+    });
+  });
+
+  describe('constructor', () => {
+    it('should throw for invalid URL', () => {
+      expect(() => new WebhookAdapter({ url: 'not-a-url' })).toThrow('Invalid webhook URL');
+    });
+
+    it('should throw for empty URL', () => {
+      expect(() => new WebhookAdapter({ url: '' })).toThrow('Invalid webhook URL');
+    });
+
+    it('should throw for non-HTTP URL', () => {
+      expect(() => new WebhookAdapter({ url: 'ftp://example.com/hook' })).toThrow('Invalid webhook URL');
+    });
+
+    it('should accept valid HTTP URL', () => {
+      const a = new WebhookAdapter({ url: 'http://localhost:3000/hook', transport });
+      expect(a.channel).toBe('webhook');
+    });
+
+    it('should accept valid HTTPS URL', () => {
+      const a = new WebhookAdapter({ url: 'https://example.com/hook', transport });
+      expect(a.channel).toBe('webhook');
+    });
+  });
+
+  describe('send', () => {
+    it('should send a webhook successfully', async () => {
+      const payload = makePayload();
+      const result = await adapter.send(payload);
+
+      expect(result.success).toBe(true);
+      expect(result.notification).toBe(payload);
+      expect(result.deliveredAt).toBeInstanceOf(Date);
+      expect(result.error).toBeUndefined();
+    });
+
+    it('should POST JSON payload to the configured URL', async () => {
+      await adapter.send(makePayload());
+
+      const requests = transport.getSentRequests();
+      expect(requests).toHaveLength(1);
+      expect(requests[0]!.url).toBe(TEST_URL);
+
+      const body = JSON.parse(requests[0]!.body);
+      expect(body.id).toBe('notif-0001');
+      expect(body.type).toBe('order-confirmation');
+      expect(body.subject).toBe('Order Confirmation: order-1');
+      expect(body.metadata).toEqual({ orderId: 'order-1', userId: 'user-1' });
+    });
+
+    it('should set Content-Type header to application/json', async () => {
+      await adapter.send(makePayload());
+
+      const requests = transport.getSentRequests();
+      expect(requests[0]!.headers['Content-Type']).toBe('application/json');
+    });
+
+    it('should include X-Webhook-Secret header when secret is configured', async () => {
+      const secretAdapter = new WebhookAdapter({
+        url: TEST_URL,
+        secret: 'my-secret-123',
+        transport,
+      });
+      await secretAdapter.send(makePayload());
+
+      const requests = transport.getSentRequests();
+      expect(requests[0]!.headers['X-Webhook-Secret']).toBe('my-secret-123');
+    });
+
+    it('should not include X-Webhook-Secret header when no secret', async () => {
+      await adapter.send(makePayload());
+
+      const requests = transport.getSentRequests();
+      expect(requests[0]!.headers['X-Webhook-Secret']).toBeUndefined();
+    });
+
+    it('should serialize createdAt as ISO string in payload', async () => {
+      await adapter.send(makePayload());
+
+      const body = JSON.parse(transport.getSentRequests()[0]!.body);
+      expect(body.createdAt).toBe('2026-01-01T00:00:00.000Z');
+    });
+
+    it('should default metadata to empty object when undefined', async () => {
+      await adapter.send(makePayload({ metadata: undefined }));
+
+      const body = JSON.parse(transport.getSentRequests()[0]!.body);
+      expect(body.metadata).toEqual({});
+    });
+
+    it('should store sent request on success', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentRequests()).toHaveLength(1);
+    });
+  });
+
+  describe('transport failure', () => {
+    it('should return failure when transport rejects', async () => {
+      const failingTransport: WebhookTransport = {
+        async post(): Promise<{ success: boolean; statusCode?: number; error?: string }> {
+          return { success: false, statusCode: 500, error: 'Internal Server Error' };
+        },
+      };
+      const failAdapter = new WebhookAdapter({ url: TEST_URL, transport: failingTransport });
+
+      const result = await failAdapter.send(makePayload());
+
+      expect(result.success).toBe(false);
+      expect(result.error).toBe('Internal Server Error');
+    });
+
+    it('should not store request on transport failure', async () => {
+      const failingTransport: WebhookTransport = {
+        async post(): Promise<{ success: boolean; statusCode?: number; error?: string }> {
+          return { success: false, error: 'timeout' };
+        },
+      };
+      const failAdapter = new WebhookAdapter({ url: TEST_URL, transport: failingTransport });
+
+      await failAdapter.send(makePayload());
+      expect(failAdapter.getSentRequests()).toHaveLength(0);
+    });
+
+    it('should use default error message when transport gives none', async () => {
+      const failingTransport: WebhookTransport = {
+        async post(): Promise<{ success: boolean; statusCode?: number; error?: string }> {
+          return { success: false };
+        },
+      };
+      const failAdapter = new WebhookAdapter({ url: TEST_URL, transport: failingTransport });
+
+      const result = await failAdapter.send(makePayload());
+      expect(result.error).toBe('Webhook delivery failed');
+    });
+  });
+
+  describe('getSentRequests / clearSentRequests', () => {
+    it('should return empty array initially', () => {
+      expect(adapter.getSentRequests()).toEqual([]);
+    });
+
+    it('should return copies (not mutable references)', async () => {
+      await adapter.send(makePayload());
+      const first = adapter.getSentRequests();
+      const second = adapter.getSentRequests();
+      expect(first).not.toBe(second);
+      expect(first).toEqual(second);
+    });
+
+    it('should clear sent requests', async () => {
+      await adapter.send(makePayload());
+      expect(adapter.getSentRequests()).toHaveLength(1);
+
+      adapter.clearSentRequests();
+      expect(adapter.getSentRequests()).toHaveLength(0);
+    });
+  });
+});
+
+describe('InMemoryWebhookTransport', () => {
+  let transport: InMemoryWebhookTransport;
+
+  beforeEach(() => {
+    transport = new InMemoryWebhookTransport();
+  });
+
+  it('should store sent requests', async () => {
+    const request: WebhookRequest = {
+      url: TEST_URL,
+      body: '{"test": true}',
+      headers: { 'Content-Type': 'application/json' },
+      sentAt: new Date(),
+    };
+    const result = await transport.post(request);
+
+    expect(result.success).toBe(true);
+    expect(result.statusCode).toBe(200);
+    expect(transport.getSentRequests()).toHaveLength(1);
+    expect(transport.getSentRequests()[0]!.url).toBe(TEST_URL);
+  });
+
+  it('should clear requests', async () => {
+    await transport.post({
+      url: TEST_URL,
+      body: '{}',
+      headers: {},
+      sentAt: new Date(),
+    });
+    transport.clear();
+    expect(transport.getSentRequests()).toHaveLength(0);
+  });
+});
