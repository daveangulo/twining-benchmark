diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..88ec96f
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,171 @@
+/**
+ * User notification preferences service.
+ *
+ * Manages user notification preferences — what notifications they receive
+ * and how they are delivered.
+ *
+ * Depends on:
+ * - UserPreferencesRepository for data access
+ * - EventBus for reacting to user creation (auto-create default preferences)
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type { UserCreatedEvent } from '../events/event-types.js';
+import type { UserPreferencesRepository } from '../repositories/user-preferences.repository.js';
+import type {
+  UserPreferences,
+  CreateUserPreferencesInput,
+  UpdateUserPreferencesInput,
+} from '../models/user-preferences.js';
+import type { NotificationType } from '../models/notification.js';
+import {
+  DEFAULT_PREFERENCES,
+  ALL_NOTIFICATION_CATEGORIES,
+} from '../models/user-preferences.js';
+import { Logger } from '../utils/logger.js';
+
+let nextId = 1;
+
+function generatePreferencesId(): string {
+  return `pref-${String(nextId++).padStart(4, '0')}`;
+}
+
+export function resetPreferencesIdCounter(): void {
+  nextId = 1;
+}
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(
+    private repository: UserPreferencesRepository,
+    private eventBus: EventBus,
+  ) {
+    this.registerEventHandlers();
+  }
+
+  /**
+   * Subscribe to user creation events to auto-create default preferences.
+   */
+  private registerEventHandlers(): void {
+    this.eventBus.on<UserCreatedEvent>('user:created', (event) => {
+      this.createDefaultPreferences(event.user.id);
+    });
+  }
+
+  /**
+   * Create default preferences for a new user.
+   */
+  private createDefaultPreferences(userId: string): void {
+    const existing = this.repository.findByUserId(userId);
+    if (existing) {
+      this.logger.info(`Preferences already exist for user ${userId}`);
+      return;
+    }
+
+    this.logger.info(`Creating default preferences for user ${userId}`);
+    const now = new Date();
+    const preferences: UserPreferences = {
+      id: generatePreferencesId(),
+      userId,
+      ...DEFAULT_PREFERENCES,
+      enabledCategories: [...DEFAULT_PREFERENCES.enabledCategories],
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    this.repository.save(preferences);
+  }
+
+  /**
+   * Get preferences for a user. Returns undefined if not found.
+   */
+  getPreferences(userId: string): UserPreferences | undefined {
+    return this.repository.findByUserId(userId);
+  }
+
+  /**
+   * Create preferences for a user with custom settings.
+   * Throws if the user already has preferences.
+   */
+  createPreferences(input: CreateUserPreferencesInput): UserPreferences {
+    const existing = this.repository.findByUserId(input.userId);
+    if (existing) {
+      throw new Error(`Preferences already exist for user ${input.userId}`);
+    }
+
+    const now = new Date();
+    const preferences: UserPreferences = {
+      id: generatePreferencesId(),
+      userId: input.userId,
+      emailEnabled: input.emailEnabled ?? DEFAULT_PREFERENCES.emailEnabled,
+      emailFrequency: input.emailFrequency ?? DEFAULT_PREFERENCES.emailFrequency,
+      enabledCategories: input.enabledCategories
+        ? [...input.enabledCategories]
+        : [...DEFAULT_PREFERENCES.enabledCategories],
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    this.repository.save(preferences);
+    this.logger.info(`Created preferences for user ${input.userId}`);
+    return preferences;
+  }
+
+  /**
+   * Update preferences for a user.
+   * Throws if the user has no preferences.
+   */
+  updatePreferences(userId: string, input: UpdateUserPreferencesInput): UserPreferences {
+    const existing = this.repository.findByUserId(userId);
+    if (!existing) {
+      throw new Error(`No preferences found for user ${userId}`);
+    }
+
+    const updates: Partial<UserPreferences> = { updatedAt: new Date() };
+
+    if (input.emailEnabled !== undefined) {
+      updates.emailEnabled = input.emailEnabled;
+    }
+    if (input.emailFrequency !== undefined) {
+      updates.emailFrequency = input.emailFrequency;
+    }
+    if (input.enabledCategories !== undefined) {
+      updates.enabledCategories = [...input.enabledCategories];
+    }
+
+    const updated = this.repository.update(existing.id, updates);
+    this.logger.info(`Updated preferences for user ${userId}`);
+    return updated;
+  }
+
+  /**
+   * Check whether a notification should be sent to a user based on their preferences.
+   * Returns true if the notification should be sent.
+   *
+   * If no preferences exist for the user, defaults to allowing the notification
+   * (opt-out model: notifications are sent unless explicitly disabled).
+   */
+  shouldSendNotification(userId: string, notificationType: NotificationType): boolean {
+    const preferences = this.repository.findByUserId(userId);
+
+    if (!preferences) {
+      return true;
+    }
+
+    if (!preferences.emailEnabled) {
+      return false;
+    }
+
+    return preferences.enabledCategories.includes(notificationType);
+  }
+
+  /**
+   * Get the email frequency setting for a user.
+   * Returns 'immediate' if no preferences exist.
+   */
+  getEmailFrequency(userId: string): UserPreferences['emailFrequency'] {
+    const preferences = this.repository.findByUserId(userId);
+    return preferences?.emailFrequency ?? 'immediate';
+  }
+}
diff --git a/tests/services/preferences.service.test.ts b/tests/services/preferences.service.test.ts
new file mode 100644
index 0000000..e197187
--- /dev/null
+++ b/tests/services/preferences.service.test.ts
@@ -0,0 +1,232 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { Database } from '../../src/utils/database.js';
+import { UserPreferencesRepository } from '../../src/repositories/user-preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import type { UserCreatedEvent } from '../../src/events/event-types.js';
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let eventBus: EventBus;
+  let repository: UserPreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    eventBus = new EventBus();
+    repository = new UserPreferencesRepository(db);
+    service = new PreferencesService(repository, eventBus);
+    resetPreferencesIdCounter();
+  });
+
+  describe('auto-create on user:created', () => {
+    it('should create default preferences when a user is created', async () => {
+      const event: UserCreatedEvent = {
+        type: 'user:created',
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const prefs = service.getPreferences('user-1');
+      expect(prefs).toBeDefined();
+      expect(prefs!.userId).toBe('user-1');
+      expect(prefs!.emailEnabled).toBe(true);
+      expect(prefs!.emailFrequency).toBe('immediate');
+      expect(prefs!.enabledCategories).toEqual([
+        'order_confirmation',
+        'order_status_update',
+        'welcome',
+        'account_updated',
+      ]);
+    });
+
+    it('should not overwrite existing preferences on duplicate user:created event', async () => {
+      service.createPreferences({
+        userId: 'user-1',
+        emailEnabled: false,
+      });
+
+      const event: UserCreatedEvent = {
+        type: 'user:created',
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      await eventBus.emit(event);
+
+      const prefs = service.getPreferences('user-1');
+      expect(prefs!.emailEnabled).toBe(false);
+    });
+  });
+
+  describe('createPreferences', () => {
+    it('should create preferences with defaults when no options provided', () => {
+      const prefs = service.createPreferences({ userId: 'user-1' });
+
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.emailEnabled).toBe(true);
+      expect(prefs.emailFrequency).toBe('immediate');
+      expect(prefs.enabledCategories).toHaveLength(4);
+    });
+
+    it('should create preferences with custom settings', () => {
+      const prefs = service.createPreferences({
+        userId: 'user-1',
+        emailEnabled: true,
+        emailFrequency: 'daily_digest',
+        enabledCategories: ['order_confirmation'],
+      });
+
+      expect(prefs.emailFrequency).toBe('daily_digest');
+      expect(prefs.enabledCategories).toEqual(['order_confirmation']);
+    });
+
+    it('should throw when preferences already exist for user', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      expect(() => service.createPreferences({ userId: 'user-1' })).toThrow(
+        'Preferences already exist for user user-1',
+      );
+    });
+
+    it('should generate sequential IDs', () => {
+      const p1 = service.createPreferences({ userId: 'user-1' });
+      const p2 = service.createPreferences({ userId: 'user-2' });
+
+      expect(p1.id).toBe('pref-0001');
+      expect(p2.id).toBe('pref-0002');
+    });
+  });
+
+  describe('updatePreferences', () => {
+    it('should update email enabled setting', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.updatePreferences('user-1', { emailEnabled: false });
+
+      expect(updated.emailEnabled).toBe(false);
+      expect(updated.emailFrequency).toBe('immediate');
+    });
+
+    it('should update email frequency', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.updatePreferences('user-1', {
+        emailFrequency: 'weekly_digest',
+      });
+
+      expect(updated.emailFrequency).toBe('weekly_digest');
+    });
+
+    it('should update enabled categories', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const updated = service.updatePreferences('user-1', {
+        enabledCategories: ['order_confirmation', 'welcome'],
+      });
+
+      expect(updated.enabledCategories).toEqual(['order_confirmation', 'welcome']);
+    });
+
+    it('should throw when no preferences exist', () => {
+      expect(() =>
+        service.updatePreferences('user-1', { emailEnabled: false }),
+      ).toThrow('No preferences found for user user-1');
+    });
+
+    it('should update the updatedAt timestamp', () => {
+      const prefs = service.createPreferences({ userId: 'user-1' });
+      const originalUpdatedAt = prefs.updatedAt;
+
+      const updated = service.updatePreferences('user-1', { emailEnabled: false });
+
+      expect(updated.updatedAt.getTime()).toBeGreaterThanOrEqual(originalUpdatedAt.getTime());
+    });
+  });
+
+  describe('shouldSendNotification', () => {
+    it('should return true when no preferences exist (opt-out model)', () => {
+      expect(service.shouldSendNotification('user-1', 'order_confirmation')).toBe(true);
+    });
+
+    it('should return true when email is enabled and category is subscribed', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      expect(service.shouldSendNotification('user-1', 'order_confirmation')).toBe(true);
+    });
+
+    it('should return false when email is globally disabled', () => {
+      service.createPreferences({ userId: 'user-1', emailEnabled: false });
+
+      expect(service.shouldSendNotification('user-1', 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false when category is not in enabled list', () => {
+      service.createPreferences({
+        userId: 'user-1',
+        enabledCategories: ['welcome'],
+      });
+
+      expect(service.shouldSendNotification('user-1', 'order_confirmation')).toBe(false);
+    });
+
+    it('should return true for subscribed category even when others are disabled', () => {
+      service.createPreferences({
+        userId: 'user-1',
+        enabledCategories: ['order_confirmation'],
+      });
+
+      expect(service.shouldSendNotification('user-1', 'order_confirmation')).toBe(true);
+      expect(service.shouldSendNotification('user-1', 'order_status_update')).toBe(false);
+    });
+  });
+
+  describe('getEmailFrequency', () => {
+    it('should return immediate when no preferences exist', () => {
+      expect(service.getEmailFrequency('user-1')).toBe('immediate');
+    });
+
+    it('should return the configured frequency', () => {
+      service.createPreferences({
+        userId: 'user-1',
+        emailFrequency: 'daily_digest',
+      });
+
+      expect(service.getEmailFrequency('user-1')).toBe('daily_digest');
+    });
+  });
+
+  describe('getPreferences', () => {
+    it('should return undefined for unknown user', () => {
+      expect(service.getPreferences('user-999')).toBeUndefined();
+    });
+
+    it('should return preferences for known user', () => {
+      service.createPreferences({ userId: 'user-1' });
+
+      const prefs = service.getPreferences('user-1');
+      expect(prefs).toBeDefined();
+      expect(prefs!.userId).toBe('user-1');
+    });
+  });
+});
