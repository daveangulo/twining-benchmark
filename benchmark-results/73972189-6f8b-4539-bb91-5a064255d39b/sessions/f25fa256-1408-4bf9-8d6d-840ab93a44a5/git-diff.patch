+  describe('notification ordering', () => {
+    it('should deliver notifications to the same recipient in order even with concurrent sends', async () => {
+      const deliveryOrder: string[] = [];
+      let resolveFirst: (() => void) | undefined;
+      const firstBlocked = new Promise<void>((resolve) => {
+        resolveFirst = resolve;
+      });
+
+      // Create a slow adapter that blocks on the first notification
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          if (payload.type === 'order_confirmation') {
+            await firstBlocked;
+          }
+          deliveryOrder.push(payload.type);
+          return {
+            success: true,
+            notificationId: payload.id,
+            channel: 'email',
+            deliveredAt: new Date(),
+          };
+        },
+      };
+
+      service.registerAdapter(slowAdapter);
+
+      // Fire both events concurrently — order_confirmation first, then status_update
+      const orderCreatedEvent: OrderCreatedEvent = {
+        type: 'order:created',
+        order: {
+          id: 'order-1',
+          userId: 'user-1',
+          items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+          total: 10,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        user: {
+          id: 'user-1',
+          name: 'Alice',
+          email: 'alice@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        timestamp: new Date(),
+      };
+
+      const statusChangedEvent: OrderStatusChangedEvent = {
+        type: 'order:status-changed',
+        order: {
+          id: 'order-1',
+          userId: 'alice@example.com',
+          items: [],
+          total: 10,
+          status: 'confirmed',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'pending',
+        newStatus: 'confirmed',
+        timestamp: new Date(),
+      };
+
+      // Emit both concurrently — without the queue, the second would complete first
+      const p1 = eventBus.emit(orderCreatedEvent);
+      const p2 = eventBus.emit(statusChangedEvent);
+
+      // Unblock the first notification after both are queued
+      resolveFirst!();
+
+      await Promise.all([p1, p2]);
+
+      // The queue should ensure order_confirmation is delivered before order_status_update
+      expect(deliveryOrder).toEqual(['order_confirmation', 'order_status_update']);
+    });
+
+    it('should allow concurrent delivery to different recipients', async () => {
+      const deliveryOrder: string[] = [];
+      let resolveFirst: (() => void) | undefined;
+      const firstBlocked = new Promise<void>((resolve) => {
+        resolveFirst = resolve;
+      });
+
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          if (payload.recipient === 'alice@example.com') {
+            await firstBlocked;
+          }
+          deliveryOrder.push(payload.recipient);
+          return {
+            success: true,
+            notificationId: payload.id,
+            channel: 'email',
+            deliveredAt: new Date(),
+          };
+        },
+      };
+
+      service.registerAdapter(slowAdapter);
+
+      // Send to two different recipients concurrently
+      const p1 = service.send({
+        id: 'n1',
+        type: 'welcome',
+        channel: 'email',
+        recipient: 'alice@example.com',
+        subject: 'Hello Alice',
+        body: 'Welcome',
+        priority: 'normal',
+        createdAt: new Date(),
+      });
+      const p2 = service.send({
+        id: 'n2',
+        type: 'welcome',
+        channel: 'email',
+        recipient: 'bob@example.com',
+        subject: 'Hello Bob',
+        body: 'Welcome',
+        priority: 'normal',
+        createdAt: new Date(),
+      });
+
+      // Bob's should complete first since Alice is blocked
