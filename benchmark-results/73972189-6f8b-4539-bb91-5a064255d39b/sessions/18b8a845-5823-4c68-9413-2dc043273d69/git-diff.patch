+/**
+ * User notification preferences model.
+ *
+ * Controls how and when a user receives notifications. Currently
+ * focused on email settings — the only active notification channel.
+ * Designed to be extensible when additional channels are added.
+ */
+
+import type { NotificationType } from './notification.js';
+
+/**
+ * How frequently email notifications are delivered.
+ * - 'instant': sent immediately when the event occurs
+ * - 'daily': batched and sent once per day
+ * - 'weekly': batched and sent once per week
+ */
+export type EmailFrequency = 'instant' | 'daily' | 'weekly';
+
+/**
+ * A user's notification preference settings.
+ */
+export interface UserNotificationPreferences {
+  id: string;
+  userId: string;
+  /** Master switch for all email notifications. */
+  emailEnabled: boolean;
+  /** Delivery frequency for email notifications. */
+  emailFrequency: EmailFrequency;
+  /** Notification categories the user is subscribed to. */
+  subscribedCategories: NotificationType[];
+  updatedAt: Date;
+}
+
+/**
+ * Input for creating notification preferences.
+ */
+export interface CreatePreferencesInput {
+  userId: string;
+  emailEnabled?: boolean;
+  emailFrequency?: EmailFrequency;
+  subscribedCategories?: NotificationType[];
+}
+
+/**
+ * Input for updating notification preferences.
+ */
+export interface UpdatePreferencesInput {
+  emailEnabled?: boolean;
+  emailFrequency?: EmailFrequency;
+  subscribedCategories?: NotificationType[];
+}
+
+/**
+ * All notification categories that exist in the system.
+ */
+export const ALL_NOTIFICATION_CATEGORIES: NotificationType[] = [
+  'order_confirmation',
+  'order_status_update',
+  'user_welcome',
+  'user_updated',
+];
+
+/**
+ * Returns default preferences for a new user — all emails enabled,
+ * instant delivery, subscribed to all categories.
+ */
+export function getDefaultPreferences(userId: string, id: string): UserNotificationPreferences {
+  return {
+    id,
+    userId,
+    emailEnabled: true,
+    emailFrequency: 'instant',
+    subscribedCategories: [...ALL_NOTIFICATION_CATEGORIES],
+    updatedAt: new Date(),
+  };
+}
