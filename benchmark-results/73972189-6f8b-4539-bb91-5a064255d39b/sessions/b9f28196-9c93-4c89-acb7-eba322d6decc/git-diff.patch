diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..1024832
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,72 @@
+/**
+ * Pure validation functions for order operations.
+ *
+ * These validators contain no side effects and no database calls.
+ * Services call these after performing any necessary data lookups.
+ */
+
+import type { OrderItem, OrderStatus } from '../models/order.js';
+import type { User } from '../models/user.js';
+
+/**
+ * Valid status transitions for orders.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate that an order has at least one item.
+ * Throws if items array is empty.
+ */
+export function validateOrderItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Validate that the user exists for order creation.
+ * The service performs the lookup; this function checks the result.
+ */
+export function validateOrderUser(user: User | undefined, userId: string): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${userId}`);
+  }
+}
+
+/**
+ * Validate a status transition and throw if invalid.
+ */
+export function validateStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(`Invalid status transition: ${from} -> ${to}`);
+  }
+}
+
+/**
+ * Validate that an order exists.
+ * The service performs the lookup; this function checks the result.
+ */
+export function validateOrderExists<T>(order: T | undefined, id: string): asserts order is T {
+  if (!order) {
+    throw new Error(`Order not found: ${id}`);
+  }
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..543f39e
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,38 @@
+/**
+ * Pure validation functions for user operations.
+ *
+ * These validators contain no side effects and no database calls.
+ * Services call these after performing any necessary data lookups.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that an email is not already taken.
+ * The service performs the DB lookup; this function checks the result.
+ */
+export function validateEmailNotTaken(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not in use by another user (for updates).
+ * The service performs the DB lookup; this function checks the result.
+ */
+export function validateEmailNotInUse(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
+
+/**
+ * Validate that a user exists.
+ * The service performs the lookup; this function checks the result.
+ */
+export function validateUserExists(user: User | undefined, id: string): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${id}`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..7886035
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,116 @@
+import { describe, it, expect } from 'vitest';
+import {
+  isValidStatusTransition,
+  validateOrderItems,
+  validateOrderUser,
+  validateOrderExists,
+  validateStatusTransition,
+} from '../../src/validators/order.validator.js';
+import type { User } from '../../src/models/user.js';
+
+describe('Order Validators', () => {
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject pending -> shipped', () => {
+      expect(isValidStatusTransition('pending', 'shipped')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(isValidStatusTransition('delivered', 'pending')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'confirmed')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'shipped')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'cancelled')).toBe(false);
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(isValidStatusTransition('cancelled', 'pending')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'confirmed')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'shipped')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'delivered')).toBe(false);
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+  });
+
+  describe('validateOrderItems', () => {
+    it('should not throw for non-empty items', () => {
+      expect(() =>
+        validateOrderItems([
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+        ]),
+      ).not.toThrow();
+    });
+
+    it('should throw for empty items array', () => {
+      expect(() => validateOrderItems([])).toThrow(
+        'Order must have at least one item',
+      );
+    });
+  });
+
+  describe('validateOrderUser', () => {
+    const testUser: User = {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    };
+
+    it('should not throw when user exists', () => {
+      expect(() => validateOrderUser(testUser, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateOrderUser(undefined, 'user-99')).toThrow(
+        'User not found: user-99',
+      );
+    });
+  });
+
+  describe('validateOrderExists', () => {
+    it('should not throw when order exists', () => {
+      expect(() => validateOrderExists({ id: 'order-1' }, 'order-1')).not.toThrow();
+    });
+
+    it('should throw when order is undefined', () => {
+      expect(() => validateOrderExists(undefined, 'order-99')).toThrow(
+        'Order not found: order-99',
+      );
+    });
+  });
+});
diff --git a/tests/validators/user.validator.test.ts b/tests/validators/user.validator.test.ts
new file mode 100644
index 0000000..d58e96c
--- /dev/null
+++ b/tests/validators/user.validator.test.ts
@@ -0,0 +1,58 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateEmailNotTaken,
+  validateEmailNotInUse,
+  validateUserExists,
+} from '../../src/validators/user.validator.js';
+import type { User } from '../../src/models/user.js';
+
+const makeUser = (overrides: Partial<User> = {}): User => ({
+  id: 'user-1',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date(),
+  updatedAt: new Date(),
+  ...overrides,
+});
+
+describe('User Validators', () => {
+  describe('validateEmailNotTaken', () => {
+    it('should not throw when no existing user', () => {
+      expect(() => validateEmailNotTaken('new@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when email is already taken', () => {
+      const existing = makeUser({ email: 'taken@example.com' });
+      expect(() => validateEmailNotTaken('taken@example.com', existing)).toThrow(
+        'User with email taken@example.com already exists',
+      );
+    });
+  });
+
+  describe('validateEmailNotInUse', () => {
+    it('should not throw when no existing user', () => {
+      expect(() => validateEmailNotInUse('free@example.com', undefined)).not.toThrow();
+    });
+
+    it('should throw when email is in use', () => {
+      const existing = makeUser({ email: 'used@example.com' });
+      expect(() => validateEmailNotInUse('used@example.com', existing)).toThrow(
+        'Email used@example.com is already in use',
+      );
+    });
+  });
+
+  describe('validateUserExists', () => {
+    it('should not throw when user exists', () => {
+      const user = makeUser();
+      expect(() => validateUserExists(user, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists(undefined, 'user-99')).toThrow(
+        'User not found: user-99',
+      );
+    });
+  });
+});
