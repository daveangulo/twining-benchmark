diff --git a/src/models/notification-log.ts b/src/models/notification-log.ts
new file mode 100644
index 0000000..7363ce9
--- /dev/null
+++ b/src/models/notification-log.ts
@@ -0,0 +1,32 @@
+/**
+ * Notification log model — tracks the history of all sent notifications.
+ *
+ * Each log entry captures the full context of a notification delivery attempt:
+ * recipient, channel, type, timestamp, and delivery status.
+ */
+
+import type { NotificationType, NotificationChannel, NotificationStatus } from './notification.js';
+
+export interface NotificationLog {
+  id: string;
+  notificationId: string;
+  recipient: string;
+  channel: NotificationChannel;
+  type: NotificationType;
+  status: NotificationStatus;
+  subject: string;
+  body: string;
+  metadata?: Record<string, unknown>;
+  createdAt: Date;
+  deliveredAt?: Date;
+  error?: string;
+}
+
+export interface NotificationHistoryQuery {
+  recipient?: string;
+  type?: NotificationType;
+  channel?: NotificationChannel;
+  status?: NotificationStatus;
+  startDate?: Date;
+  endDate?: Date;
+}
diff --git a/src/repositories/notification-log.repository.ts b/src/repositories/notification-log.repository.ts
new file mode 100644
index 0000000..14e026b
--- /dev/null
+++ b/src/repositories/notification-log.repository.ts
@@ -0,0 +1,96 @@
+/**
+ * Repository for NotificationLog data access.
+ *
+ * Extends BaseRepository with notification-log-specific query methods
+ * for filtering by recipient, type, channel, status, and date range.
+ */
+
+import type { DatabaseRecord } from '../utils/database.js';
+import type { Database } from '../utils/database.js';
+import type { NotificationLog, NotificationHistoryQuery } from '../models/notification-log.js';
+import type { NotificationChannel, NotificationStatus, NotificationType } from '../models/notification.js';
+import { BaseRepository } from './base.repository.js';
+
+export class NotificationLogRepository extends BaseRepository<NotificationLog> {
+  constructor(db: Database) {
+    super(db, 'notification_logs');
+  }
+
+  protected toDomain(record: DatabaseRecord): NotificationLog {
+    const log: NotificationLog = {
+      id: record['id'] as string,
+      notificationId: record['notificationId'] as string,
+      recipient: record['recipient'] as string,
+      channel: record['channel'] as NotificationChannel,
+      type: record['type'] as NotificationType,
+      status: record['status'] as NotificationStatus,
+      subject: record['subject'] as string,
+      body: record['body'] as string,
+      createdAt: new Date(record['createdAt'] as string),
+    };
+    if (record['metadata']) {
+      log.metadata = JSON.parse(record['metadata'] as string) as Record<string, unknown>;
+    }
+    if (record['deliveredAt']) {
+      log.deliveredAt = new Date(record['deliveredAt'] as string);
+    }
+    if (record['error']) {
+      log.error = record['error'] as string;
+    }
+    return log;
+  }
+
+  protected toRecord(entity: NotificationLog): DatabaseRecord {
+    const record: DatabaseRecord = {
+      id: entity.id,
+      notificationId: entity.notificationId,
+      recipient: entity.recipient,
+      channel: entity.channel,
+      type: entity.type,
+      status: entity.status,
+      subject: entity.subject,
+      body: entity.body,
+      createdAt: entity.createdAt.toISOString(),
+    };
+    if (entity.metadata) {
+      record['metadata'] = JSON.stringify(entity.metadata);
+    }
+    if (entity.deliveredAt) {
+      record['deliveredAt'] = entity.deliveredAt.toISOString();
+    }
+    if (entity.error) {
+      record['error'] = entity.error;
+    }
+    return record;
+  }
+
+  findByRecipient(recipient: string): NotificationLog[] {
+    return this.findAll((log) => log.recipient === recipient);
+  }
+
+  findByType(type: NotificationType): NotificationLog[] {
+    return this.findAll((log) => log.type === type);
+  }
+
+  findByChannel(channel: NotificationChannel): NotificationLog[] {
+    return this.findAll((log) => log.channel === channel);
+  }
+
+  findByDateRange(startDate: Date, endDate: Date): NotificationLog[] {
+    return this.findAll(
+      (log) => log.createdAt >= startDate && log.createdAt <= endDate,
+    );
+  }
+
+  query(filter: NotificationHistoryQuery): NotificationLog[] {
+    return this.findAll((log) => {
+      if (filter.recipient && log.recipient !== filter.recipient) return false;
+      if (filter.type && log.type !== filter.type) return false;
+      if (filter.channel && log.channel !== filter.channel) return false;
+      if (filter.status && log.status !== filter.status) return false;
+      if (filter.startDate && log.createdAt < filter.startDate) return false;
+      if (filter.endDate && log.createdAt > filter.endDate) return false;
+      return true;
+    });
+  }
+}
diff --git a/src/services/notification-history.service.ts b/src/services/notification-history.service.ts
new file mode 100644
index 0000000..ed3486e
--- /dev/null
+++ b/src/services/notification-history.service.ts
@@ -0,0 +1,102 @@
+/**
+ * Notification history service — tracks and queries sent notification history.
+ *
+ * Integrates with the notification flow by subscribing to 'notification:sent'
+ * events on the EventBus. Every notification delivery result is logged
+ * to the NotificationLogRepository for later querying.
+ *
+ * Depends on:
+ * - EventBus for receiving notification:sent events
+ * - NotificationLogRepository for persisting log entries
+ * - NotificationService for reading notification details
+ */
+
+import type { EventBus } from '../events/event-bus.js';
+import type { NotificationSentEvent } from '../events/event-types.js';
+import type { NotificationLog, NotificationHistoryQuery } from '../models/notification-log.js';
+import type { NotificationType } from '../models/notification.js';
+import type { NotificationLogRepository } from '../repositories/notification-log.repository.js';
+import type { NotificationService } from './notification.service.js';
+import { Logger } from '../utils/logger.js';
+
+let nextLogId = 1;
+
+function generateLogId(): string {
+  return `nlog-${String(nextLogId++).padStart(4, '0')}`;
+}
+
+export function resetNotificationLogIdCounter(): void {
+  nextLogId = 1;
+}
+
+export class NotificationHistoryService {
+  private logger = new Logger('NotificationHistoryService');
+
+  constructor(
+    private eventBus: EventBus,
+    private repository: NotificationLogRepository,
+    private notificationService: NotificationService,
+  ) {
+    this.registerEventHandlers();
+  }
+
+  private registerEventHandlers(): void {
+    this.eventBus.on<NotificationSentEvent>('notification:sent', (event) => {
+      this.handleNotificationSent(event);
+    });
+  }
+
+  private handleNotificationSent(event: NotificationSentEvent): void {
+    const notification = this.notificationService
+      .getNotifications()
+      .find((n) => n.id === event.notificationId);
+
+    if (!notification) {
+      this.logger.warn(`Notification not found for logging: ${event.notificationId}`);
+      return;
+    }
+
+    const log: NotificationLog = {
+      id: generateLogId(),
+      notificationId: event.notificationId,
+      recipient: notification.recipient,
+      channel: notification.channel,
+      type: notification.type,
+      status: event.success ? 'sent' : 'failed',
+      subject: notification.subject,
+      body: notification.body,
+      metadata: notification.metadata,
+      createdAt: event.timestamp,
+      deliveredAt: event.success ? event.timestamp : undefined,
+      error: event.error,
+    };
+
+    this.repository.save(log);
+    this.logger.info(
+      `Logged notification ${event.notificationId} — ${event.success ? 'sent' : 'failed'}`,
+    );
+  }
+
+  getHistory(query?: NotificationHistoryQuery): NotificationLog[] {
+    if (!query) {
+      return this.repository.findAll();
+    }
+    return this.repository.query(query);
+  }
+
+  getHistoryForRecipient(recipient: string): NotificationLog[] {
+    return this.repository.findByRecipient(recipient);
+  }
+
+  getHistoryByType(type: NotificationType): NotificationLog[] {
+    return this.repository.findByType(type);
+  }
+
+  getHistoryByDateRange(startDate: Date, endDate: Date): NotificationLog[] {
+    return this.repository.findByDateRange(startDate, endDate);
+  }
+
+  getLogCount(): number {
+    return this.repository.count();
+  }
+}
diff --git a/tests/services/notification-history.service.test.ts b/tests/services/notification-history.service.test.ts
new file mode 100644
index 0000000..126c20b
--- /dev/null
+++ b/tests/services/notification-history.service.test.ts
@@ -0,0 +1,265 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../../src/events/event-bus.js';
+import { Database } from '../../src/utils/database.js';
+import {
+  NotificationService,
+  resetNotificationIdCounter,
+} from '../../src/services/notification.service.js';
+import {
+  NotificationHistoryService,
+  resetNotificationLogIdCounter,
+} from '../../src/services/notification-history.service.js';
+import { NotificationLogRepository } from '../../src/repositories/notification-log.repository.js';
+import { EmailAdapter } from '../../src/adapters/email.adapter.js';
+import type { OrderCreatedEvent, OrderStatusChangedEvent } from '../../src/events/event-types.js';
+
+function createOrderCreatedEvent(overrides?: Partial<OrderCreatedEvent>): OrderCreatedEvent {
+  return {
+    type: 'order:created',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [{ productId: 'p1', name: 'Widget', quantity: 2, unitPrice: 10 }],
+      total: 20,
+      status: 'pending',
+      createdAt: new Date('2025-06-01T10:00:00Z'),
+      updatedAt: new Date('2025-06-01T10:00:00Z'),
+    },
+    user: {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    },
+    timestamp: new Date('2025-06-01T10:00:00Z'),
+    ...overrides,
+  };
+}
+
+function createStatusChangedEvent(overrides?: Partial<OrderStatusChangedEvent>): OrderStatusChangedEvent {
+  return {
+    type: 'order:status-changed',
+    order: {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [],
+      total: 20,
+      status: 'confirmed',
+      createdAt: new Date('2025-06-01T10:00:00Z'),
+      updatedAt: new Date('2025-06-01T10:00:00Z'),
+    },
+    previousStatus: 'pending',
+    newStatus: 'confirmed',
+    timestamp: new Date('2025-06-01T10:00:00Z'),
+    ...overrides,
+  };
+}
+
+describe('NotificationHistoryService', () => {
+  let eventBus: EventBus;
+  let db: Database;
+  let notificationService: NotificationService;
+  let historyService: NotificationHistoryService;
+  let repository: NotificationLogRepository;
+  let emailAdapter: EmailAdapter;
+
+  beforeEach(() => {
+    eventBus = new EventBus();
+    db = new Database();
+    repository = new NotificationLogRepository(db);
+    notificationService = new NotificationService(eventBus);
+    emailAdapter = new EmailAdapter();
+    notificationService.registerAdapter(emailAdapter);
+    historyService = new NotificationHistoryService(eventBus, repository, notificationService);
+    resetNotificationIdCounter();
+    resetNotificationLogIdCounter();
+  });
+
+  describe('logging sent notifications', () => {
+    it('should log a notification after it is sent via adapter', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+
+      const logs = historyService.getHistory();
+      expect(logs).toHaveLength(1);
+      expect(logs[0]?.recipient).toBe('alice@example.com');
+      expect(logs[0]?.channel).toBe('email');
+      expect(logs[0]?.type).toBe('order_confirmation');
+      expect(logs[0]?.status).toBe('sent');
+      expect(logs[0]?.deliveredAt).toBeDefined();
+    });
+
+    it('should capture subject and body in log', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+
+      const logs = historyService.getHistory();
+      expect(logs[0]?.subject).toContain('Order Confirmation');
+      expect(logs[0]?.body).toContain('Widget x2');
+    });
+
+    it('should capture metadata in log', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+
+      const logs = historyService.getHistory();
+      expect(logs[0]?.metadata).toEqual({ orderId: 'order-1', userId: 'user-1' });
+    });
+
+    it('should generate sequential log IDs', async () => {
+      await eventBus.emit(createStatusChangedEvent());
+      await eventBus.emit(createStatusChangedEvent({
+        order: {
+          id: 'order-2',
+          userId: 'user-1',
+          items: [],
+          total: 30,
+          status: 'shipped',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        previousStatus: 'confirmed',
+        newStatus: 'shipped',
+      }));
+
+      const logs = historyService.getHistory();
+      expect(logs).toHaveLength(2);
+      expect(logs[0]?.id).toBe('nlog-0001');
+      expect(logs[1]?.id).toBe('nlog-0002');
+    });
+
+    it('should log multiple notifications from different events', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+      await eventBus.emit(createStatusChangedEvent());
+
+      const logs = historyService.getHistory();
+      expect(logs).toHaveLength(2);
+      expect(logs[0]?.type).toBe('order_confirmation');
+      expect(logs[1]?.type).toBe('order_status_update');
+    });
+  });
+
+  describe('querying by recipient', () => {
+    it('should return logs for a specific recipient', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+      await eventBus.emit(createOrderCreatedEvent({
+        user: {
+          id: 'user-2',
+          name: 'Bob',
+          email: 'bob@example.com',
+          role: 'member',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+        order: {
+          id: 'order-2',
+          userId: 'user-2',
+          items: [{ productId: 'p1', name: 'Gadget', quantity: 1, unitPrice: 15 }],
+          total: 15,
+          status: 'pending',
+          createdAt: new Date(),
+          updatedAt: new Date(),
+        },
+      }));
+
+      const aliceLogs = historyService.getHistoryForRecipient('alice@example.com');
+      expect(aliceLogs).toHaveLength(1);
+      expect(aliceLogs[0]?.recipient).toBe('alice@example.com');
+
+      const bobLogs = historyService.getHistoryForRecipient('bob@example.com');
+      expect(bobLogs).toHaveLength(1);
+      expect(bobLogs[0]?.recipient).toBe('bob@example.com');
+    });
+
+    it('should return empty array for unknown recipient', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+
+      const logs = historyService.getHistoryForRecipient('unknown@example.com');
+      expect(logs).toHaveLength(0);
+    });
+  });
+
+  describe('querying by type', () => {
+    it('should return logs filtered by notification type', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+      await eventBus.emit(createStatusChangedEvent());
+
+      const confirmationLogs = historyService.getHistoryByType('order_confirmation');
+      expect(confirmationLogs).toHaveLength(1);
+      expect(confirmationLogs[0]?.type).toBe('order_confirmation');
+
+      const statusLogs = historyService.getHistoryByType('order_status_update');
+      expect(statusLogs).toHaveLength(1);
+      expect(statusLogs[0]?.type).toBe('order_status_update');
+    });
+  });
+
+  describe('querying by date range', () => {
+    it('should return logs within a date range', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+      await eventBus.emit(createStatusChangedEvent());
+
+      const now = new Date();
+      const oneMinuteAgo = new Date(now.getTime() - 60_000);
+      const oneMinuteFromNow = new Date(now.getTime() + 60_000);
+
+      const logs = historyService.getHistoryByDateRange(oneMinuteAgo, oneMinuteFromNow);
+      expect(logs).toHaveLength(2);
+    });
+
+    it('should exclude logs outside the date range', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+
+      const distantPast = new Date('2020-01-01T00:00:00Z');
+      const distantPastEnd = new Date('2020-01-02T00:00:00Z');
+
+      const logs = historyService.getHistoryByDateRange(distantPast, distantPastEnd);
+      expect(logs).toHaveLength(0);
+    });
+  });
+
+  describe('combined query', () => {
+    it('should support filtering by multiple criteria', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+      await eventBus.emit(createStatusChangedEvent());
+
+      const logs = historyService.getHistory({
+        recipient: 'alice@example.com',
+        type: 'order_confirmation',
+      });
+      expect(logs).toHaveLength(1);
+      expect(logs[0]?.type).toBe('order_confirmation');
+    });
+
+    it('should return empty when no logs match query', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+
+      const logs = historyService.getHistory({
+        recipient: 'alice@example.com',
+        type: 'order_status_update',
+      });
+      expect(logs).toHaveLength(0);
+    });
+
+    it('should return all logs when query is empty object', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+      await eventBus.emit(createStatusChangedEvent());
+
+      const logs = historyService.getHistory({});
+      expect(logs).toHaveLength(2);
+    });
+  });
+
+  describe('log count', () => {
+    it('should return zero when no notifications logged', () => {
+      expect(historyService.getLogCount()).toBe(0);
+    });
+
+    it('should track the number of logged notifications', async () => {
+      await eventBus.emit(createOrderCreatedEvent());
+      expect(historyService.getLogCount()).toBe(1);
+
+      await eventBus.emit(createStatusChangedEvent());
+      expect(historyService.getLogCount()).toBe(2);
+    });
+  });
+});
