+++ b/tests/validators/preferences.validator.test.ts
@@ -0,0 +1,46 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validatePreferencesNotExist,
+  validatePreferencesExist,
+} from '../../src/validators/preferences.validator.js';
+import type { UserPreferences } from '../../src/models/user-preferences.js';
+
+const testPrefs: UserPreferences = {
+  id: 'pref-0001',
+  userId: 'user-0001',
+  emailEnabled: true,
+  emailFrequency: 'immediate',
+  enabledCategories: ['order_confirmation'],
+  createdAt: new Date(),
+  updatedAt: new Date(),
+};
+
+describe('preferences.validator', () => {
+  describe('validatePreferencesNotExist', () => {
+    it('should not throw when no existing preferences', () => {
+      expect(() =>
+        validatePreferencesNotExist(undefined, 'user-0001'),
+      ).not.toThrow();
+    });
+
+    it('should throw when preferences already exist', () => {
+      expect(() =>
+        validatePreferencesNotExist(testPrefs, 'user-0001'),
+      ).toThrow('Preferences already exist for user user-0001');
+    });
+  });
+
+  describe('validatePreferencesExist', () => {
+    it('should not throw when preferences exist', () => {
+      expect(() =>
+        validatePreferencesExist(testPrefs, 'user-0001'),
+      ).not.toThrow();
+    });
+
+    it('should throw when no preferences found', () => {
+      expect(() =>
+        validatePreferencesExist(undefined, 'user-9999'),
+      ).toThrow('No preferences found for user user-9999');
+    });
+  });
+});
