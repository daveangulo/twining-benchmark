diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..f760b95
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,40 @@
+import type { OrderItem, OrderStatus } from '../models/order.js';
+
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Check whether a status transition is allowed.
+ */
+export function isValidStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): boolean {
+  return STATUS_TRANSITIONS[from].includes(to);
+}
+
+/**
+ * Validate that a status transition is allowed. Throws if not.
+ */
+export function validateStatusTransition(
+  from: OrderStatus,
+  to: OrderStatus,
+): void {
+  if (!isValidStatusTransition(from, to)) {
+    throw new Error(`Invalid status transition: ${from} -> ${to}`);
+  }
+}
+
+/**
+ * Validate that an order has at least one item.
+ */
+export function validateOrderItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
diff --git a/src/validators/preferences.validator.ts b/src/validators/preferences.validator.ts
new file mode 100644
index 0000000..5d3a371
--- /dev/null
+++ b/src/validators/preferences.validator.ts
@@ -0,0 +1,27 @@
+import type { UserPreferences } from '../models/user-preferences.js';
+
+/**
+ * Validate that preferences do not already exist for a user.
+ * Throws if preferences are found.
+ */
+export function validatePreferencesNotExist(
+  existing: UserPreferences | undefined,
+  userId: string,
+): void {
+  if (existing) {
+    throw new Error(`Preferences already exist for user ${userId}`);
+  }
+}
+
+/**
+ * Validate that preferences exist for a user.
+ * Throws if not found.
+ */
+export function validatePreferencesExist(
+  existing: UserPreferences | undefined,
+  userId: string,
+): asserts existing is UserPreferences {
+  if (!existing) {
+    throw new Error(`No preferences found for user ${userId}`);
+  }
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..dc50934
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,39 @@
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that a user exists. Throws if not found.
+ */
+export function validateUserExists(
+  user: User | undefined,
+  id: string,
+): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${id}`);
+  }
+}
+
+/**
+ * Validate that an email is not already taken.
+ * Takes the result of a lookup by email — throws if a user was found.
+ */
+export function validateEmailNotTaken(
+  existingUser: User | undefined,
+  email: string,
+): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not in use by another user.
+ * Used during updates where the user may keep their own email.
+ */
+export function validateEmailNotInUse(
+  existingUser: User | undefined,
+  email: string,
+): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..6f6e0ec
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,82 @@
+import { describe, it, expect } from 'vitest';
+import {
+  isValidStatusTransition,
+  validateStatusTransition,
+  validateOrderItems,
+} from '../../src/validators/order.validator.js';
+
+describe('order.validator', () => {
+  describe('isValidStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(isValidStatusTransition('pending', 'confirmed')).toBe(true);
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(isValidStatusTransition('pending', 'cancelled')).toBe(true);
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(isValidStatusTransition('confirmed', 'shipped')).toBe(true);
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(isValidStatusTransition('confirmed', 'cancelled')).toBe(true);
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(isValidStatusTransition('shipped', 'delivered')).toBe(true);
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(isValidStatusTransition('pending', 'delivered')).toBe(false);
+    });
+
+    it('should reject pending -> shipped', () => {
+      expect(isValidStatusTransition('pending', 'shipped')).toBe(false);
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(isValidStatusTransition('delivered', 'pending')).toBe(false);
+      expect(isValidStatusTransition('delivered', 'cancelled')).toBe(false);
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(isValidStatusTransition('cancelled', 'pending')).toBe(false);
+      expect(isValidStatusTransition('cancelled', 'confirmed')).toBe(false);
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should not throw for valid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should throw for invalid transitions', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+
+    it('should throw for transitions from terminal states', () => {
+      expect(() => validateStatusTransition('cancelled', 'confirmed')).toThrow(
+        'Invalid status transition',
+      );
+    });
+  });
+
+  describe('validateOrderItems', () => {
+    it('should not throw for non-empty items', () => {
+      expect(() =>
+        validateOrderItems([
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+        ]),
+      ).not.toThrow();
+    });
+
+    it('should throw for empty items', () => {
+      expect(() => validateOrderItems([])).toThrow(
+        'Order must have at least one item',
+      );
+    });
+  });
+});
