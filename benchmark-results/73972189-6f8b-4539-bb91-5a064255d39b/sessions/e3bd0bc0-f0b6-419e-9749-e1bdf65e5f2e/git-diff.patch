+
+  // -------------------------------------------------------
+  // 6. Notification ordering
+  // -------------------------------------------------------
+  describe('notification ordering', () => {
+    it('should preserve notification order for the same user across channels', async () => {
+      const deliveryOrder: string[] = [];
+
+      // Replace adapters with slow variants to test ordering
+      const slowEmailAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          await new Promise((r) => setTimeout(r, 30));
+          deliveryOrder.push(`email:${payload.type}`);
+          return { success: true, notification: payload, deliveredAt: new Date() };
+        },
+      };
+      const slowSmsAdapter: NotificationAdapter = {
+        channel: 'sms' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          await new Promise((r) => setTimeout(r, 10));
+          deliveryOrder.push(`sms:${payload.type}`);
+          return { success: true, notification: payload, deliveredAt: new Date() };
+        },
+      };
+
+      notificationService.registerAdapter(slowEmailAdapter);
+      notificationService.registerAdapter(slowSmsAdapter);
+
+      // Send two notifications for the same user — they should be serialized
+      const p1 = notificationService.send({
+        type: 'order-confirmation',
+        channel: 'email',
+        recipient: 'alice@example.com',
+        subject: 'First',
+        body: 'First notification.',
+        metadata: { userId: 'user-1' },
+      });
+      const p2 = notificationService.send({
+        type: 'order-status-update',
+        channel: 'sms',
+        recipient: '+15551234567',
+        subject: 'Second',
+        body: 'Second notification.',
+        metadata: { userId: 'user-1' },
+      });
+
+      await Promise.all([p1, p2]);
+
+      // Even though SMS is faster, email was queued first for user-1
+      expect(deliveryOrder[0]).toBe('email:order-confirmation');
+      expect(deliveryOrder[1]).toBe('sms:order-status-update');
+    });
+
+    it('should allow concurrent delivery for different users', async () => {
+      const deliveryOrder: string[] = [];
+
+      const slowAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          const delay = payload.recipient === 'alice@example.com' ? 40 : 10;
+          await new Promise((r) => setTimeout(r, delay));
+          deliveryOrder.push(payload.recipient);
+          return { success: true, notification: payload, deliveredAt: new Date() };
+        },
+      };
+
+      notificationService.registerAdapter(slowAdapter);
+
+      await Promise.all([
+        notificationService.send({
+          type: 'welcome',
+          channel: 'email',
+          recipient: 'alice@example.com',
+          subject: 'Hi Alice',
+          body: 'Welcome.',
+          metadata: { userId: 'user-alice' },
+        }),
+        notificationService.send({
+          type: 'welcome',
+          channel: 'email',
+          recipient: 'bob@example.com',
+          subject: 'Hi Bob',
+          body: 'Welcome.',
+          metadata: { userId: 'user-bob' },
+        }),
+      ]);
+
+      // Bob's faster email should complete first (different users = concurrent)
+      expect(deliveryOrder[0]).toBe('bob@example.com');
+      expect(deliveryOrder[1]).toBe('alice@example.com');
+    });
+
+    it('should preserve order of multiple notifications to the same user', async () => {
+      const deliveryOrder: string[] = [];
+
+      const trackingAdapter: NotificationAdapter = {
+        channel: 'email' as const,
+        async send(payload: NotificationPayload): Promise<NotificationResult> {
+          deliveryOrder.push(payload.subject);
+          return { success: true, notification: payload, deliveredAt: new Date() };
+        },
+      };
+
+      notificationService.registerAdapter(trackingAdapter);
+
+      // Fire 5 notifications sequentially for the same user
+      const promises = [];
+      for (let i = 1; i <= 5; i++) {
+        promises.push(
+          notificationService.send({
+            type: 'order-status-update',
+            channel: 'email',
+            recipient: 'alice@example.com',
+            subject: `Notification ${i}`,
+            body: `Body ${i}`,
+            metadata: { userId: 'user-1' },
+          }),
+        );
+      }
+
+      await Promise.all(promises);
+
+      expect(deliveryOrder).toEqual([
+        'Notification 1',
+        'Notification 2',
+        'Notification 3',
+        'Notification 4',
+        'Notification 5',
+      ]);
+    });
+  });
