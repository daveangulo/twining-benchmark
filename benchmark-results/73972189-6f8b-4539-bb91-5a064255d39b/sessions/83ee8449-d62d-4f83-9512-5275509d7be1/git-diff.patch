diff --git a/src/validators/common.validator.ts b/src/validators/common.validator.ts
new file mode 100644
index 0000000..ecbdb1f
--- /dev/null
+++ b/src/validators/common.validator.ts
@@ -0,0 +1,18 @@
+/**
+ * Common validators shared across services.
+ *
+ * All functions are pure — no side effects, no database calls.
+ * They receive data and throw if validation fails.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that a user exists (was found by a prior lookup).
+ * Throws if the user is undefined.
+ */
+export function validateUserExists(user: User | undefined, userId: string): asserts user is User {
+  if (!user) {
+    throw new Error(`User not found: ${userId}`);
+  }
+}
diff --git a/src/validators/order.validator.ts b/src/validators/order.validator.ts
new file mode 100644
index 0000000..42419a8
--- /dev/null
+++ b/src/validators/order.validator.ts
@@ -0,0 +1,46 @@
+/**
+ * Order validators — pure validation functions for order operations.
+ *
+ * No side effects, no database calls. Each function receives
+ * already-fetched data and throws if validation fails.
+ */
+
+import type { Order, OrderItem, OrderStatus } from '../models/order.js';
+
+/**
+ * Valid status transitions for orders.
+ */
+const STATUS_TRANSITIONS: Record<OrderStatus, OrderStatus[]> = {
+  pending: ['confirmed', 'cancelled'],
+  confirmed: ['shipped', 'cancelled'],
+  shipped: ['delivered'],
+  delivered: [],
+  cancelled: [],
+};
+
+/**
+ * Validate that an order has at least one item.
+ */
+export function validateOrderHasItems(items: OrderItem[]): void {
+  if (items.length === 0) {
+    throw new Error('Order must have at least one item');
+  }
+}
+
+/**
+ * Validate that an order exists (was found by a prior lookup).
+ */
+export function validateOrderExists(order: Order | undefined, orderId: string): asserts order is Order {
+  if (!order) {
+    throw new Error(`Order not found: ${orderId}`);
+  }
+}
+
+/**
+ * Validate that a status transition is allowed.
+ */
+export function validateStatusTransition(from: OrderStatus, to: OrderStatus): void {
+  if (!STATUS_TRANSITIONS[from].includes(to)) {
+    throw new Error(`Invalid status transition: ${from} -> ${to}`);
+  }
+}
diff --git a/src/validators/user.validator.ts b/src/validators/user.validator.ts
new file mode 100644
index 0000000..3c1e8f7
--- /dev/null
+++ b/src/validators/user.validator.ts
@@ -0,0 +1,28 @@
+/**
+ * User validators — pure validation functions for user operations.
+ *
+ * No side effects, no database calls. Each function receives
+ * already-fetched data and throws if validation fails.
+ */
+
+import type { User } from '../models/user.js';
+
+/**
+ * Validate that an email is not already taken by another user.
+ * Used during user creation.
+ */
+export function validateEmailNotTaken(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`User with email ${email} already exists`);
+  }
+}
+
+/**
+ * Validate that an email is not already in use by a different user.
+ * Used during user update when the email is being changed.
+ */
+export function validateEmailNotInUse(email: string, existingUser: User | undefined): void {
+  if (existingUser) {
+    throw new Error(`Email ${email} is already in use`);
+  }
+}
diff --git a/tests/validators/common.validator.test.ts b/tests/validators/common.validator.test.ts
new file mode 100644
index 0000000..78e58d7
--- /dev/null
+++ b/tests/validators/common.validator.test.ts
@@ -0,0 +1,26 @@
+import { describe, it, expect } from 'vitest';
+import { validateUserExists } from '../../src/validators/common.validator.js';
+import type { User } from '../../src/models/user.js';
+
+describe('common validators', () => {
+  describe('validateUserExists', () => {
+    const user: User = {
+      id: 'user-1',
+      name: 'Alice',
+      email: 'alice@example.com',
+      role: 'member',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    };
+
+    it('should not throw when user exists', () => {
+      expect(() => validateUserExists(user, 'user-1')).not.toThrow();
+    });
+
+    it('should throw when user is undefined', () => {
+      expect(() => validateUserExists(undefined, 'user-99')).toThrow(
+        'User not found: user-99',
+      );
+    });
+  });
+});
diff --git a/tests/validators/order.validator.test.ts b/tests/validators/order.validator.test.ts
new file mode 100644
index 0000000..0e08bce
--- /dev/null
+++ b/tests/validators/order.validator.test.ts
@@ -0,0 +1,87 @@
+import { describe, it, expect } from 'vitest';
+import {
+  validateOrderHasItems,
+  validateOrderExists,
+  validateStatusTransition,
+} from '../../src/validators/order.validator.js';
+import type { Order } from '../../src/models/order.js';
+
+describe('order validators', () => {
+  describe('validateOrderHasItems', () => {
+    it('should not throw when items are present', () => {
+      expect(() =>
+        validateOrderHasItems([
+          { productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 },
+        ]),
+      ).not.toThrow();
+    });
+
+    it('should throw when items array is empty', () => {
+      expect(() => validateOrderHasItems([])).toThrow(
+        'Order must have at least one item',
+      );
+    });
+  });
+
+  describe('validateOrderExists', () => {
+    const order: Order = {
+      id: 'order-1',
+      userId: 'user-1',
+      items: [{ productId: 'p1', name: 'Widget', quantity: 1, unitPrice: 10 }],
+      total: 10,
+      status: 'pending',
+      createdAt: new Date(),
+      updatedAt: new Date(),
+    };
+
+    it('should not throw when order exists', () => {
+      expect(() => validateOrderExists(order, 'order-1')).not.toThrow();
+    });
+
+    it('should throw when order is undefined', () => {
+      expect(() => validateOrderExists(undefined, 'order-99')).toThrow(
+        'Order not found: order-99',
+      );
+    });
+  });
+
+  describe('validateStatusTransition', () => {
+    it('should allow pending -> confirmed', () => {
+      expect(() => validateStatusTransition('pending', 'confirmed')).not.toThrow();
+    });
+
+    it('should allow pending -> cancelled', () => {
+      expect(() => validateStatusTransition('pending', 'cancelled')).not.toThrow();
+    });
+
+    it('should allow confirmed -> shipped', () => {
+      expect(() => validateStatusTransition('confirmed', 'shipped')).not.toThrow();
+    });
+
+    it('should allow confirmed -> cancelled', () => {
+      expect(() => validateStatusTransition('confirmed', 'cancelled')).not.toThrow();
+    });
+
+    it('should allow shipped -> delivered', () => {
+      expect(() => validateStatusTransition('shipped', 'delivered')).not.toThrow();
+    });
+
+    it('should reject pending -> delivered', () => {
+      expect(() => validateStatusTransition('pending', 'delivered')).toThrow(
+        'Invalid status transition: pending -> delivered',
+      );
+    });
+
+    it('should reject delivered -> any', () => {
+      expect(() => validateStatusTransition('delivered', 'pending')).toThrow(
+        'Invalid status transition',
+      );
+    });
+
+    it('should reject cancelled -> any', () => {
+      expect(() => validateStatusTransition('cancelled', 'confirmed')).toThrow(
+        'Invalid status transition',
+      );
+    });
+  });
+});
