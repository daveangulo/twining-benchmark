diff --git a/src/services/preferences.service.ts b/src/services/preferences.service.ts
new file mode 100644
index 0000000..670f9fa
--- /dev/null
+++ b/src/services/preferences.service.ts
@@ -0,0 +1,123 @@
+/**
+ * Preferences service — manages user notification preferences.
+ *
+ * Provides CRUD for preferences and a query method used by the
+ * notification service to decide whether a notification should be sent.
+ *
+ * Depends on:
+ * - PreferencesRepository (data access)
+ * - UserRepository (validates user exists)
+ */
+
+import type { UserPreferences, UpdateEmailPreferencesInput, NotificationCategory } from '../models/user-preferences.js';
+import { createDefaultEmailPreferences } from '../models/user-preferences.js';
+import type { PreferencesRepository } from '../repositories/preferences.repository.js';
+import type { UserRepository } from '../repositories/user.repository.js';
+import { Logger } from '../utils/logger.js';
+
+let nextId = 1;
+
+function generatePreferencesId(): string {
+  return `pref-${String(nextId++).padStart(4, '0')}`;
+}
+
+export function resetPreferencesIdCounter(): void {
+  nextId = 1;
+}
+
+export class PreferencesService {
+  private logger = new Logger('PreferencesService');
+
+  constructor(
+    private preferencesRepository: PreferencesRepository,
+    private userRepository: UserRepository,
+  ) {}
+
+  /**
+   * Get preferences for a user. Returns undefined if none have been created.
+   */
+  getPreferences(userId: string): UserPreferences | undefined {
+    return this.preferencesRepository.findByUserId(userId);
+  }
+
+  /**
+   * Get or create preferences for a user.
+   * If no preferences exist, creates defaults (all enabled, immediate delivery).
+   */
+  getOrCreatePreferences(userId: string): UserPreferences {
+    const existing = this.preferencesRepository.findByUserId(userId);
+    if (existing) {
+      return existing;
+    }
+
+    const user = this.userRepository.findById(userId);
+    if (!user) {
+      throw new Error(`User not found: ${userId}`);
+    }
+
+    const now = new Date();
+    const preferences: UserPreferences = {
+      id: generatePreferencesId(),
+      userId,
+      email: createDefaultEmailPreferences(),
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    this.preferencesRepository.save(preferences);
+    this.logger.info(`Created default preferences for user ${userId}`);
+    return preferences;
+  }
+
+  /**
+   * Update email preferences for a user.
+   */
+  updateEmailPreferences(userId: string, input: UpdateEmailPreferencesInput): UserPreferences {
+    const preferences = this.getOrCreatePreferences(userId);
+
+    const updatedEmail = { ...preferences.email };
+    if (input.enabled !== undefined) {
+      updatedEmail.enabled = input.enabled;
+    }
+    if (input.frequency !== undefined) {
+      updatedEmail.frequency = input.frequency;
+    }
+    if (input.subscribedCategories !== undefined) {
+      updatedEmail.subscribedCategories = [...input.subscribedCategories];
+    }
+
+    const updated = this.preferencesRepository.update(preferences.id, {
+      email: updatedEmail,
+      updatedAt: new Date(),
+    });
+
+    this.logger.info(`Updated email preferences for user ${userId}`);
+    return updated;
+  }
+
+  /**
+   * Check whether a notification should be sent to a user via email.
+   *
+   * Returns true if:
+   * - The user has no preferences (defaults allow all notifications)
+   * - Email is enabled AND frequency is 'immediate' AND the category is subscribed
+   */
+  shouldSendEmail(userId: string, category: NotificationCategory): boolean {
+    const preferences = this.preferencesRepository.findByUserId(userId);
+
+    // No preferences means defaults apply — send everything
+    if (!preferences) {
+      return true;
+    }
+
+    if (!preferences.email.enabled) {
+      return false;
+    }
+
+    if (preferences.email.frequency !== 'immediate') {
+      return false;
+    }
+
+    return preferences.email.subscribedCategories.includes(category);
+  }
+}
diff --git a/tests/services/preferences.service.test.ts b/tests/services/preferences.service.test.ts
new file mode 100644
index 0000000..0e81c35
--- /dev/null
+++ b/tests/services/preferences.service.test.ts
@@ -0,0 +1,196 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Database } from '../../src/utils/database.js';
+import { UserRepository } from '../../src/repositories/user.repository.js';
+import { PreferencesRepository } from '../../src/repositories/preferences.repository.js';
+import {
+  PreferencesService,
+  resetPreferencesIdCounter,
+} from '../../src/services/preferences.service.js';
+import type { User } from '../../src/models/user.js';
+
+const makeUser = (overrides?: Partial<User>): User => ({
+  id: 'user-1',
+  name: 'Alice',
+  email: 'alice@example.com',
+  role: 'member',
+  createdAt: new Date('2024-01-01'),
+  updatedAt: new Date('2024-01-01'),
+  ...overrides,
+});
+
+describe('PreferencesService', () => {
+  let db: Database;
+  let userRepo: UserRepository;
+  let prefsRepo: PreferencesRepository;
+  let service: PreferencesService;
+
+  beforeEach(() => {
+    db = new Database();
+    userRepo = new UserRepository(db);
+    prefsRepo = new PreferencesRepository(db);
+    service = new PreferencesService(prefsRepo, userRepo);
+    resetPreferencesIdCounter();
+  });
+
+  describe('getOrCreatePreferences', () => {
+    it('should create default preferences for a user', () => {
+      userRepo.save(makeUser());
+
+      const prefs = service.getOrCreatePreferences('user-1');
+
+      expect(prefs.id).toBe('pref-0001');
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.subscribedCategories).toEqual([
+        'order_confirmation',
+        'order_status_update',
+      ]);
+    });
+
+    it('should return existing preferences without creating duplicates', () => {
+      userRepo.save(makeUser());
+
+      const first = service.getOrCreatePreferences('user-1');
+      const second = service.getOrCreatePreferences('user-1');
+
+      expect(first.id).toBe(second.id);
+    });
+
+    it('should throw if user does not exist', () => {
+      expect(() => service.getOrCreatePreferences('no-such-user')).toThrow(
+        'User not found: no-such-user',
+      );
+    });
+  });
+
+  describe('getPreferences', () => {
+    it('should return undefined when no preferences exist', () => {
+      expect(service.getPreferences('user-1')).toBeUndefined();
+    });
+
+    it('should return preferences after creation', () => {
+      userRepo.save(makeUser());
+      service.getOrCreatePreferences('user-1');
+
+      const prefs = service.getPreferences('user-1');
+      expect(prefs).toBeDefined();
+      expect(prefs!.userId).toBe('user-1');
+    });
+  });
+
+  describe('updateEmailPreferences', () => {
+    it('should disable email notifications', () => {
+      userRepo.save(makeUser());
+
+      const prefs = service.updateEmailPreferences('user-1', { enabled: false });
+
+      expect(prefs.email.enabled).toBe(false);
+      // Other fields unchanged
+      expect(prefs.email.frequency).toBe('immediate');
+      expect(prefs.email.subscribedCategories).toEqual([
+        'order_confirmation',
+        'order_status_update',
+      ]);
+    });
+
+    it('should change frequency', () => {
+      userRepo.save(makeUser());
+
+      const prefs = service.updateEmailPreferences('user-1', { frequency: 'daily_digest' });
+
+      expect(prefs.email.frequency).toBe('daily_digest');
+    });
+
+    it('should update subscribed categories', () => {
+      userRepo.save(makeUser());
+
+      const prefs = service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['order_confirmation'],
+      });
+
+      expect(prefs.email.subscribedCategories).toEqual(['order_confirmation']);
+    });
+
+    it('should apply multiple updates at once', () => {
+      userRepo.save(makeUser());
+
+      const prefs = service.updateEmailPreferences('user-1', {
+        enabled: true,
+        frequency: 'never',
+        subscribedCategories: [],
+      });
+
+      expect(prefs.email.enabled).toBe(true);
+      expect(prefs.email.frequency).toBe('never');
+      expect(prefs.email.subscribedCategories).toEqual([]);
+    });
+
+    it('should create preferences if none exist', () => {
+      userRepo.save(makeUser());
+
+      const prefs = service.updateEmailPreferences('user-1', { frequency: 'daily_digest' });
+
+      expect(prefs.userId).toBe('user-1');
+      expect(prefs.email.frequency).toBe('daily_digest');
+    });
+  });
+
+  describe('shouldSendEmail', () => {
+    it('should return true when no preferences exist (defaults)', () => {
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(true);
+    });
+
+    it('should return true with default preferences', () => {
+      userRepo.save(makeUser());
+      service.getOrCreatePreferences('user-1');
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(true);
+      expect(service.shouldSendEmail('user-1', 'order_status_update')).toBe(true);
+    });
+
+    it('should return false when email is disabled', () => {
+      userRepo.save(makeUser());
+      service.updateEmailPreferences('user-1', { enabled: false });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false when frequency is not immediate', () => {
+      userRepo.save(makeUser());
+      service.updateEmailPreferences('user-1', { frequency: 'daily_digest' });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+    });
+
+    it('should return false for unsubscribed category', () => {
+      userRepo.save(makeUser());
+      service.updateEmailPreferences('user-1', {
+        subscribedCategories: ['order_confirmation'],
+      });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(true);
+      expect(service.shouldSendEmail('user-1', 'order_status_update')).toBe(false);
+    });
+
+    it('should return false when frequency is never', () => {
+      userRepo.save(makeUser());
+      service.updateEmailPreferences('user-1', { frequency: 'never' });
+
+      expect(service.shouldSendEmail('user-1', 'order_confirmation')).toBe(false);
+    });
+  });
+
+  describe('ID generation', () => {
+    it('should generate sequential IDs', () => {
+      userRepo.save(makeUser({ id: 'user-1' }));
+      userRepo.save(makeUser({ id: 'user-2', email: 'bob@example.com' }));
+
+      const prefs1 = service.getOrCreatePreferences('user-1');
+      const prefs2 = service.getOrCreatePreferences('user-2');
+
+      expect(prefs1.id).toBe('pref-0001');
+      expect(prefs2.id).toBe('pref-0002');
+    });
+  });
+});
