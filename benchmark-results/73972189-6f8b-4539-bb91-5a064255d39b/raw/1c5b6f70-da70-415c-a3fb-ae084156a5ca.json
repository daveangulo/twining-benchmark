        "new_string": "    it('should maintain order in history logs', async () => {\n      // Use a fully isolated pipeline so prior test handlers don't interfere\n      statusChangeCallbacks.clear();\n      resetNotificationIdCounter();\n      resetLogIdCounter();\n      resetUserIdCounter();\n      resetOrderIdCounter();\n      resetPreferencesIdCounter();\n\n      const freshDb = new Database();\n      const freshEventBus = new EventBus();\n      const freshUserRepo = new UserRepository(freshDb);\n      const freshOrderRepo = new OrderRepository(freshDb);\n      const freshPrefsRepo = new PreferencesRepository(freshDb);\n      const freshNotifLogRepo = new NotificationLogRepository(freshDb);\n\n      const freshUserService = new UserService(freshUserRepo, freshEventBus);\n      const freshOrderService = new OrderService(freshOrderRepo, freshUserRepo, freshEventBus);\n      const freshPrefsService = new PreferencesService(freshPrefsRepo, freshUserRepo);\n      historyService = new NotificationHistoryService(freshNotifLogRepo);\n\n      const soloEmailAdapter = new EmailAdapter();\n      notificationService = new NotificationService(freshEventBus, [soloEmailAdapter]);\n      notificationService.setPreferencesService(freshPrefsService);\n      notificationService.setHistoryService(historyService);\n\n      const user = await freshUserService.createUser({\n        name: 'Quinn',\n        email: 'quinn@example.com',\n        role: 'member',\n      });\n\n      freshPrefsService.getOrCreatePreferences(user.id);\n\n      const order = await freshOrderService.createOrder({\n        userId: user.id,\n        items: [{ productId: 'p1', name: 'Headphones', quantity: 1, unitPrice: 50 }],\n      });",
