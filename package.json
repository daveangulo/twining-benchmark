{
  "name": "twining-bench",
  "version": "0.1.0",
  "description": "Benchmark harness for evaluating multi-agent coordination strategies with Twining",
  "type": "module",
  "bin": {
    "twining-bench": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "phase0:run": "tsx src/phase0/phase0-runner.ts",
    "phase0:analyze": "tsx src/phase0/phase0-analyze.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "@anthropic-ai/sdk": "^0.78.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "simple-git": "^3.32.0",
    "simple-statistics": "^7.8.8",
    "ts-morph": "^27.0.2",
    "uuid": "^13.0.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
